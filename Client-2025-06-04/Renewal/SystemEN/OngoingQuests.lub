		Summary = ""
	},
	[8137] = {
		Title = "ตามหาช่างทำกุญแจ",
		Description = {
			"ดูเหมือนว่า Koshei จะเป็นสิ่งชั่วร้ายอมตะที่ถูกปิดผนึกไว้โดยเด็กสาวชื่อ Maria ส่วน Maria นั้นจำเป็นต้องได้รับการปลดปล่อยจากคุกหินของเธอ โดยการตามหาช่างทำกุญแจเพื่อสร้าง ^0000ffGolden Key^000000"
