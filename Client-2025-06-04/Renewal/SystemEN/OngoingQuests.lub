	[13000] = {
		Title = "RWC 2011 สะสมการ์ด (RWC 2011 Card Gathering)",
		Description = {
			"กำจัด Gold Poring ที่ปรากฏตัวแบบสุ่มรอบๆ Rune-Midgarts และสะสม Blue Card ให้เพียงพอเพื่อสะกดคำว่า \"RWC 2011\""
		},
		Summary = ""
	},
	[13001] = {
		Title = "RWC 2011 สะสมการ์ด",
		Description = {
			"รอหนึ่งวันก่อนที่จะนำ Blue Card มามอบให้ New Agent เพิ่มเติม"
		},
		Summary = "รีเซ็ตตอน 04:00",
		CoolTimeQuest = 1
	},
	[13002] = {
		Title = "สะสม Brigan (Brigan collecting)",
		Description = {
			"สะสมชิ้นส่วน Brigan 50 ชิ้นจาก Turtle Island หรือ Glastheim และนำกลับมาให้ Gelkah ที่ Eden Group"
		},
		Summary = "นำ Brigan 50 ชิ้นกลับมา"
	},
	[13003] = {
		Title = "คำขอ Carat (Carat Request)",
		Description = {
			"คำขอนี้มาจากพ่อค้าใน Morroc พวก Carat ขายไอศกรีมตลอดทั้งปีทำให้เขาไม่สามารถทำกำไรได้เลย ทีม Eden Group รู้ดีว่านั่นไม่ใช่เหตุผลที่แท้จริง แต่คำขอก็คือคำขอ"
		},
		Summary = "ล่า Carat 30 ตัวและกลับไปหา Gelkah"
	},
	[13004] = {
		Title = "คำขอ Carat",
		Description = {
			"รอให้เวลาหมดลงก่อนที่จะรับคำขอนี้ได้อีกครั้ง"
		},
		Summary = "รีเซ็ตตอน 04:00",
		CoolTimeQuest = 1
	},
	[13005] = {
		Title = "คำขอ Arclouse (Arclouse Request)",
		Description = {
			"คุณรู้ไหมว่ามีถั่วที่ใช้เป็นอาหารใน Rune-Midgarts? เวลาที่ Arclouse ม้วนตัว มันจะดูคล้ายกับถั่วเลยล่ะ"
		},
		Summary = "ล่า Arclouse 22 ตัวและกลับไปหา Gelkah"
	},
	[13006] = {
