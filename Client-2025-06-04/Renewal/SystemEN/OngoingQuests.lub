	[8212] = {
		Title = "บทเรียนของ Shurank",
		Description = {
			"ฉันเห็นว่าคุณพอจะเข้าใจเกี่ยวกับทักษะ Bash บ้างแล้ว แต่ถึงอย่างนั้น มันก็ยังไม่พอ"
