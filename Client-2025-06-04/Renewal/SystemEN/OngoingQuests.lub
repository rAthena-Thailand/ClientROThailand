	[8035] = {
		Title = "เรือเหาะทำงานอย่างไร",
		Description = {
			"คุณได้ส่งจดหมายของ Ferlock ให้กับ Tarlock แล้ว ตอนนี้น่าจะเป็นเวลาที่ดีที่จะถามเขาเกี่ยวกับวิธีการทำงานของเรือเหาะ"
