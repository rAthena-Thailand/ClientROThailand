	[1010] = {
		Title = "เปลี่ยนอาชีพเป็น Merchant",
		Description = {
			"ไปรับพัสดุที่จะนำไปส่งจากโกดังสินค้า จากนั้นมุ่งหน้าไปที่ Mage Guild ในเมือง Geffen เมื่อไปถึงที่นั่น ให้ไปหา Mage Guildsman ที่ดูแลอยู่"
