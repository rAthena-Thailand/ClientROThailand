	[8238] = {
		Title = "บทเรียนของ Guarnien",
		Description = {
			"ก่อนอื่น คุณจำเป็นต้องรู้ทักษะ Increase Weight Limit เลเวล 5 เสียก่อน ถึงจะเรียนทักษะ Push Cart ได้ อย่างที่คุณเห็น ทักษะนี้เป็นรูปแบบขั้นสูงของทักษะ Increase Weight Limit คุณสามารถหารถเข็นมาใช้ได้จากพนักงาน Kafra ส่วนใหญ่โดยเสียค่าธรรมเนียมนิดหน่อย สำหรับตอนนี้ ทำไมคุณไม่ลองเรียนทักษะ Push Cart จนถึงเลเวล 4 ดูล่ะ?"
		},
		Summary = "กลับไปหา Guarnien หลังจากฝึกทักษะรถเข็นจนเชี่ยวชาญ"
	},
	[8239] = {
		Title = "บทเรียนของ Guarnien",
		Description = {
			"ฉันเชื่อว่าถึงเวลาสำหรับบทเรียนสุดท้ายของฉันแล้ว ฉันจะพูดถึงทักษะที่เป็นเครื่องหมายการค้าของพ่อค้า: ^871F78Vending^000000 (การตั้งร้านขายของ)"
		},
		Summary = "ฟังบทเรียนของ Guarnien"
	},
	[8240] = {
		Title = "บทเรียนของ Guarnien",
		Description = {
			"สำหรับภารกิจสุดท้ายของคุณ ฉันจะขอให้คุณเรียนทักษะ Vending จนถึงเลเวล 4 แน่นอนว่าเมื่อคุณทำได้ ฉันจะมีรางวัลเล็กๆ น้อยๆ ให้ ฉันจะรอนะ ตั้งใจเข้าล่ะ~"
		},
		Summary = "กลับไปหา Guarnien หลังจากฝึกทักษะ Vending จนเชี่ยวชาญ"
	},
	[8241] = {
		Title = "การเก็บรวบรวม Red Jewel",
		Description = {
			"คุณเก็บ Red Jewel ได้จากหลุมศพซึ่งมีการบันทึกเสียงไว้ในนั้น!"
		},
		Summary = "คุณนำหินนี้ไปให้ Magic scholar ใน Ash-Vacuum บน Rune-Midgarts"
	},
	[8242] = {
		Title = "การเก็บรวบรวม blue Jewel",
		Description = {
			"คุณเก็บ blue jewel ได้จากหลุมศพซึ่งมีการบันทึกเสียงไว้ในนั้น!"
		},
		Summary = "คุณนำหินนี้ไปให้ Magic scholar ใน Ash-Vacuum บน Rune-Midgarts"
	},
	[8243] = {
		Title = "เรียนรู้ภาษาใหม่",
		Description = {
			"ทั้งสามอาณาจักรต่างกำลังทำงานร่วมกันเพื่อสืบสวนภาษาที่พูดโดยผู้คนใน Ash Vacuum จงไปตามหา ^0000ffนักวิชาการด้านภาษาแห่ง Arunafeltz^000000"
		},
		Summary = ""
	},
	[8244] = {
		Title = "แฟรี่และยักษ์พฤกษา",
		Description = {
			"จงหาตัวอย่างภาษาที่พูดโดยพวกแฟรี่และยักษ์พฤกษา จากนั้นให้ Linguist Dictionary ทราบว่าพวกเขาพูดว่าอะไรกันแน่"
		},
		Summary = "รายงานกลับไปยังนักวิชาการด้านภาษาแห่ง Arunafeltz"
	},
	[8245] = {
		Title = "การสืบสวนตัวอย่างภาษา",
		Description = {
			"ค้นหา Rune-Midgarts Magician ที่เร่ร่อนอยู่ภายใน Expedition Camp"
		},
		Summary = ""
	},
	[8246] = {
		Title = "การสืบสวนตัวอย่างภาษา",
		Description = {
			"คุณได้พบกับเผ่าพันธุ์ใหม่ทั้งสองแล้วใช่ไหม? พวกแอสซาสซิน (Assassins) ฝังอัญมณีไว้แถวๆ นั้น แต่ระวังให้ดีเวลาเก็บรวบรวมพวกมัน เพราะพวกมันมีกับดักติดตั้งไว้อยู่"
		},
		Summary = "หาอัญมณีและนำกลับไปให้ Rune-Midgart Magician"
	},
	[8247] = {
		Title = "ความคืบหน้าการวิจัย",
		Description = {
			"ฉันจะส่งต่อเสียงที่สกัดออกมาจากอัญมณีไปยังนักวิชาการด้านภาษาแห่ง Arunafeltz ถ้าคุณไม่ได้ยุ่งขนาดนั้น ช่วยไปเช็คความคืบหน้าการวิจัยของนักวิชาการด้านภาษาทีได้ไหม"
		},
		Summary = ""
	},
	[8248] = {
		Title = "ความคืบหน้าการวิจัย",
		Description = {
			"เราจะรวบรวมข้อมูลมหาศาลเหล่านี้และทำให้เป็นเครื่องแปลภาษาแบบพกพาได้อย่างไรกันนะ... คุณช่วยไปถามความเห็นของ Mechanic Engineer จาก Schwaltzvalt หน่อยได้ไหม?"
		},
		Summary = ""
	},
	[8249] = {
		Title = "การบีบอัดข้อมูล",
		Description = {
			"กลับไปหา Rune-Midgart Magician และดูว่าเขารู้วิธีบีบอัดข้อมูลโดยใช้เวทมนตร์ของเขาหรือไม่"
		},
		Summary = ""
	},
	[8250] = {
		Title = "อัญมณีเก็บข้อมูล",
		Description = {
			"ข้างนอก Ash-Vacuum มี ^0000ffหินลึกลับอย่างมากซึ่งไม่สามารถพบได้ใน Midgarts^000000 คุณช่วยนำมันมาให้ฉันสักอันได้ไหม?"
		},
		Summary = "หา Unidentified Mineral และนำกลับไปให้ Magician Whisper"
	},
	[8251] = {
		Title = "การฉีดเวทมนตร์",
