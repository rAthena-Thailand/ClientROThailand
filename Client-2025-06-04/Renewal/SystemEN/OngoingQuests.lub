		Summary = "ตามหา Johan ที่ Glast Heim"
	},
	[7220] = {
		Title = "ระยะที่ 2 ส่วนที่ 1 - Wraith",
		Description = {
			"Johan มอบภารกิจให้คุณกำจัด Wraith ที่แข็งแกร่งซึ่งปรากฏตัวที่ชั้น 1 ของอาราม"
