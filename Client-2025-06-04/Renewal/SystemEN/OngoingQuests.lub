	[11075] = {
		Title = "ราชาแห่งยาพิษ",
		Description = {
			"ไม่!! ฉันล้มเหลวอีกแล้ว! และฉันก็ใช้เวลานานมากในการเตรียมวัตถุดิบพวกนั้น..."
