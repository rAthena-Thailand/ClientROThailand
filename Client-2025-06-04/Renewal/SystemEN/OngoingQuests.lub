		Summary = "พบ Geschupenschte ช่างตีเหล็กแห่ง Einbech"
	},
	[2001] = {
		Title = "เปลี่ยนอาชีพเป็น Blacksmith",
		IconName = "ico_jq.bmp",
		Description = {
