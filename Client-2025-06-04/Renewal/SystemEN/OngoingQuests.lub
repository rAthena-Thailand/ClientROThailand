		Summary = "ไวโอลินของ Calla ถูกยึดไป"
	},
	[8079] = {
		Title = "Klitzer และ Calla",
		Description = {
			"สิ่งที่คุณต้องทำก็แค่ส่ง ^FF00001 Flower^000000 ให้เธอ ผมไม่มีเงิน Zeny เลย และผมไม่คิดว่าตัวเองจะเป็นที่ต้อนรับที่คฤหาสน์ Kapellthaine หรอก"
