	[11057] = {
		Title = "ยาสมุนไพร - การเป็นผู้ช่วยคุณหมอ",
		Description = {
			"โปรดรวบรวม... ^3355FFLeopard Claw 2 ชิ้น^000000, ^3355FFSolid Peach 10 ชิ้น^000000, ^3355FFPoisonous Toad Skin 5 ชิ้น^000000, ^3355FFBrown Root 20 ชิ้น^000000, ^3355FFSprout 10 ชิ้น^000000 และ ^3355FFHoney Pot 5 ชิ้น^000000"
		},
		Summary = "รับวัตถุดิบที่ Hua Tuo สั่งไว้"
	},
	[11058] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"Mikhail ลูกชายตัวน้อยของฉัน ทำตุ๊กตา Matrosica ที่ฉันเก็บสะสมไว้พังตอนที่ฉันไม่อยู่ และเขาก็ไม่ยอมกลับเข้าบ้านหลังจากที่หนีออกไปเพราะความกลัว"
		},
		Summary = "ตามหา Mikhail เขาบอกว่าจะไม่ยอมออกไปนอกเมือง"
	},
	[11059] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"ฮิฮิ เขาเป็นพวกงี่เง่าและไม่มีเพื่อนเลย แต่ถ้าคุณเป็นคนในหมู่บ้าน ^0000FFเจ้าของโรงเตี๊ยมต้นแอปเปิล^000000 เป็นคนที่ดูดีและใจดีกับ Mikhail มาก"
		},
		Summary = "ไปที่โรงเตี๊ยมต้นแอปเปิล (Apple Tree Inn) ซึ่งเป็นข้อมูลเพียงอย่างเดียว"
	},
	[11060] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"ฉันไม่รู้ว่าเขาเป็นแขกหรือเปล่า เหมือนฉันแค่ให้ทานแก่คนเดินทางที่ผ่านไปมา หากคุณสัญญาว่าจะค้างคืนที่โรงเตี๊ยมของเรา ฉันจะให้ข้อมูลที่คุณต้องการ เป็นยังไงบ้าง?"
		},
		Summary = "ค้างคืนที่โรงเตี๊ยมแล้วถามเจ้าของโรงเตี๊ยมเกี่ยวกับ Mikhail"
	},
	[11061] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"ทำไมเขาถึงพูดว่าเขาทำของล้ำค่าพังหรือหน้าซีดเป็นไก่ต้ม เพราะเขาต้องการกาวที่ติดแน่นเป็นพิเศษงั้นเหรอ? มีพวกผู้ชายหลายคนอยู่ในโรงเหล้า ฉันก็เลยบอกให้เขาไปที่นั่น"
		},
		Summary = "ดูเหมือน Mikhail จะไปที่โรงเหล้า ไปที่โรงเหล้าแล้วหา Mikhail กันเถอะ"
	},
	[11062] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"ฉันไม่รู้เรื่องพวกกาวหรอกนะ แต่ฉันรู้จักคนที่รู้เรื่องนี้ดีมากและได้แนะนำเขาไปแล้ว นั่นคือ Viktor ชายที่อยู่ตรงมุมโรงเหล้านั่นแหละ"
		},
		Summary = "ดูเหมือน Mikhail จะไม่อยู่ในโรงเหล้า ลองถาม Victor เกี่ยวกับ Mikhail ที่เจ้าของโรงเหล้าแนะนำดู"
	},
	[11063] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"โอเค เครื่องดื่มที่คุณสั่งได้แล้ว ขอให้สนุกนะ"
		},
		Summary = "ดื่มสักหน่อยแล้วเข้าไปหา Viktor"
	},
	[11064] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"คุณสามารถหาวัตถุดิบได้จากปลักโคลนในพื้นที่ห่างไกลที่คุณต้องนั่งเรือไปนานๆ เพื่อทำกาวติดแน่นพิเศษ เด็กที่แค่ทำ Matrosika พังก็ตกใจแทบตายอย่างเขาน่ะเหรอ จะมีความกล้าเข้าไปในสถานที่น่ากลัวแบบนั้น?"
		},
		Summary = "Mikhail ไปไหนกันแน่? ไปที่ปลักโคลนเพื่ออะไร?"
	},
	[11065] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"คุณจะเห็นปลักโคลนขนาดใหญ่ที่แค่ดูก็รู้สึกเหนียวตัวไปหมดแล้ว บรรยากาศมันน่ากลัวมาก มีฟองปุดๆ ลอยขึ้นมา"
		},
		Summary = "ไม่มีร่องรอยว่ามีใครมาที่นี่ กลับไปที่บ้านของ Mikhail กันเถอะ"
	},
	[11066] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"พอมองกลับเข้าไปในบ้าน พบว่า Mikhail กำลังแอบอยู่ในเตาผิง ไปเอากาวมาและช่วยซ่อม Matryoshka กันเถอะ"
		},
		Summary = "ไปหา Viktor ที่โรงเหล้าเพื่อถามหาวัตถุดิบที่แน่นอนของกาว"
	},
	[11067] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"มีเกาะใหญ่ใกล้กับ Moscovia จากที่นั่น คุณจะเห็นปลักโคลนเมื่อเดินลึกเข้าไปในป่า ^0000FFพืชที่เติบโตในปลักโคลนนั่น 10 อัน^000000 และ ^0000FFชามปรุงยา^000000 อย่าลืมเอามันมาด้วย"
		},
		Summary = "เก็บมา 10 ชิ้นแล้วกลับไปหา Viktor อย่าลืมเตรียมชามยาไปด้วย!"
	},
	[11068] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"โอเค ได้แล้ว! ฉันมั่นใจว่าฉันให้กาวคุณไปแล้วนะ ทีนี้ฉันจะรบกวนอะไรคุณอีกล่ะ? ไปได้แล้ว!"
		},
		Summary = "ได้รับกาวมาแล้ว กลับไปหา Mikhail และบอกเขา"
	},
	[11069] = {
		Title = "Mikhail เด็กชายขี้ขลาด",
		Description = {
			"ถ้าอย่างนั้น ฉันจะเอา Matrosica ไปคืนแม่ล่ะ"
		},
		Summary = "Mikhail ออกมาจากเตาผิงแล้ว กลับไปหา Gaul กันเถอะ"
	},
	[11070] = {
		Title = "ราชาแห่งยาพิษ",
		Description = {
			"ทำไมคุณถึงอยากเรียนรู้เรื่องนี้? ถึงฉันอยากจะสอน แต่ฉันก็แก่เกินกว่าจะจำทุกอย่างได้แล้ว ไปหาศิษย์คนสุดท้ายของฉัน ^0000FF'Song Zhi Du'^000000 ดูสิ เขาอาจจะบอกอะไรที่เป็นประโยชน์กับคุณได้"
		},
		Summary = "ตามหา Song Zhi Du ที่ทำงานอยู่ที่สำนักงานแพทย์และถามเกี่ยวกับการใช้ยาพิษ"
	},
	[11071] = {
		Title = "ราชาแห่งยาพิษ",
		Description = {
			"ไปทำอะไรที่คุณอยากทำเถอะ ฉันแค่รู้สึกผิดหวัง..."
		},
		Summary = "ดูเหมือน Song Zhi Du กำลังโกรธอยู่ สามารถทำให้เขารู้สึกดีขึ้นได้โดยการนำบางอย่างมาให้เขา"
	},
	[11072] = {
		Title = "ราชาแห่งยาพิษ",
		Description = {
			"ถ้าคุณรู้สึกผิดกับฉันจริงๆ คุณต้องช่วยฉันล้างแค้น! ไปหา ^0000FFBee Sting 4 อัน, Venom Canine 10 อัน, Empty Potion 10 อัน, Green Potion 30 อัน^000000 มาให้ฉัน"
		},
		Summary = "กลับไปหา Song Zhi Du พร้อมวัตถุดิบที่เขาสั่ง"
	},
	[11073] = {
		Title = "ราชาแห่งยาพิษ",
		Description = {
			"สิ่งที่เหลือคือการปรุงยาพิษนี้ แล้วก็นำไปให้เจ้าเมือง Louyang ดื่ม..."
		},
		Summary = "คุยกับเขาอีกครั้งและฟังเรื่องราว จากนั้นช่วยงาน Song Zhi Du"
