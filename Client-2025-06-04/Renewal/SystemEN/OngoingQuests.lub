		Summary = "คุยกับ \"Pyrus\" สมาชิกทีมแรคคูนไชโยที่ลานกว้าง Geffen"
	},
	[1202] = {
		Title = "มองออกไปนอกหน้าต่าง ไชโยให้กับทีมแรคคูน!",
		Description = {
			"กังวลเรื่องคู่รักแรคคูนที่กำลังทะเลาะกัน ไปจับสมาชิกทีมแรคคูนไชโยในฟิลด์เพื่อสะสม Stolen Candy และ Stolen Cookie อย่างละ 5 ชิ้น"
		},
		Summary = "คุยกับ \"Pyrus\" สมาชิกทีมแรคคูนไชโยที่ลานกว้าง Geffen"
	},
	[1203] = {
		Title = "มองออกไปนอกหน้าต่าง ไชโยให้กับทีมแรคคูน!",
		Description = {
			"ไปรับเสื้อผ้าจาก \"Citrus\" ซึ่งอยู่ใกล้กับ \"Sage Welshyun\" ทางตอนเหนือของ Geffen"
