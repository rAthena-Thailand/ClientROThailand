	[8104] = {
		Title = "จดหมายแนะนำจาก High Priest Zhed",
		Description = {
			"อา แต่ก่อนที่คุณจะไป ให้ฉันเตือนคุณว่าอย่า ^FF0000เข้าไปใกล้ Holy Ground^000000 เด็ดขาด ฉันขอย้ำอีกครั้งว่าอยู่ห่างจาก Holy Ground ไว้"
