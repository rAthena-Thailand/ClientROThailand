	[14295] = {
		Title = "มุ่งหน้าสู่ Aldebaran (To Aldebaran)",
		Description = {
			"ฉันพบใบเสร็จที่ออกโดย Aldebaran พร้อมกับรอยเท้าที่น่าสงสัย เป็นไปได้ไหมที่จะไป Aldebaran เพื่อหาเบาะแสของอาชญากร?"
