	[5035] = {
		Title = "ช่วยคุณลุงหน่อย!",
		Description = {
			"คุณลุง Memo ที่เกาะ Dewata กำลังมีปัญหา ไปดูหน่อยซิว่าเกิดอะไรขึ้นกับเผ่า Jaty เพื่อเป็นการช่วยเหลือเขา"
		},
		Summary = "เผ่า Jaty อยู่ที่ทิศ 10 นาฬิกาของเกาะ Dewata"
	},
	[5036] = {
		Title = "ช่วยคุณลุงหน่อย!",
		Description = {
			"ในการทำน้ำมันปาล์ม จำเป็นต้องมี Palm Oil Fruit แต่ Poby ที่ออกไปเก็บผลไม้พวกนั้นยังไม่กลับมาเลย ช่วยไปที่ป่าปาล์มแล้วตามหา Poby ให้หน่อย"
		},
		Summary = "ตามหา Poby ทางตอนใต้ของป่าปาล์ม"
	},
	[5037] = {
		Title = "ช่วยคุณลุงหน่อย!",
		Description = {
			"Poby ปีนขึ้นไปบนต้นไม้โดยไม่มีอุปกรณ์นิรภัย แล้วตกลงมาจนเจ็บหลังและขยับตัวไม่ได้เลย โปรดนำสถานการณ์ของ Poby ไปบอก Lero ในเผ่า Jaty ที"
		},
		Summary = "แจ้งเรื่องของ Poby ให้ Lero ในเผ่า Jaty ทราบ"
	},
	[5038] = {
		Title = "ช่วยคุณลุงหน่อย!",
		Description = {
			"คุณตัดสินใจช่วย Lero เก็บผลไม้แทน Poby ที่บาดเจ็บ จงไปถาม Poby ว่ามีวิธีเก็บผลไม้จากต้นปาล์มอย่างไร"
		},
		Summary = "ถาม Poby เกี่ยวกับวิธีเก็บผลปาล์ม"
	},
	[5039] = {
		Title = "ช่วยคุณลุงหน่อย!",
		Description = {
