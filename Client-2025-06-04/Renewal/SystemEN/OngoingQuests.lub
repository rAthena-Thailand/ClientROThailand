		Summary = "ช่วงเวลาแห่งความพินาศ"
	},
	[12458] = {
		Title = "Of the future story",
		Description = {
			"แม้จะมีการเสียสละของกษัตริย์ Schmidt แต่ผลงานของเขากลับถูกบิดเบือนและส่งต่อมาผิดๆ"
		},
		Summary = "รสชาติของมังกร"
	},
	[12459] = {
		Title = "Repose to the king's thoughts",
		Description = {
			"เพื่อช่วยชีวิตผู้คนนับไม่ถ้วน Schmidt ยอมสละชีวิตของเขาเข้าไปใน Orb แต่ในกระบวนการนั้น พลังของ Orb ได้รวบรวมความคิดของเขาและพยายามทิ้งบันทึกความอัปยศไว้ให้คนรุ่นหลัง การทำให้ความคิดของเขาสงบลงคือภารกิจของคุณ"
		},
		Summary = "การเยียวยาของ Schmidz"
	},
	[12460] = {
		Title = "Aftereffects of the Fall",
		Description = {
			"มันยากที่จะทนดูฉากการล่มสลายไม่ว่าทางใดก็ตาม ไม่สามารถเข้าไปสร้าง ^ff0000 Glasheim Purification ^000000 ได้ในขณะที่ผลข้างเคียงยังคงอยู่"
		},
		Summary = "รีเซ็ตเวลา 04:00",
		CoolTimeQuest = 1
	},
	[12461] = {
		Title = "The aftereffects of powerful death",
		Description = {
			"ผลข้างเคียงนี้มาพร้อมกับผลข้างเคียงของการล่มสลาย ในระหว่างที่พักผ่อน เมนูที่เกี่ยวข้องกับ ^ff0000 Glassheim Purification (ระดับสูง) ^000000 จะไม่ปรากฏและไม่สามารถใช้งานได้"
		},
		Summary = "รีเซ็ตหลังจาก 3 วัน ณ เวลา 4 นาฬิกา",
		CoolTimeQuest = 1
	},
	[12462] = {
		Title = "Repose to the king's thoughts (advanced)",
		Description = {
			"เพื่อช่วยชีวิตผู้คนนับไม่ถ้วน Schmidt ยอมสละชีวิตของเขาเข้าไปใน Orb แต่ในกระบวนการนั้น พลังของ Orb ได้รวบรวมความคิดของเขาและพยายามทิ้งบันทึกความอัปยศไว้ให้คนรุ่นหลัง การทำให้ความคิดของเขาสงบลงคือภารกิจของคุณ"
