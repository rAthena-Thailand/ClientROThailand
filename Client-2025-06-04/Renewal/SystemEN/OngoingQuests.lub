		Summary = "การพบเจอ Etran"
	},
	[12298] = {
		Title = "Two wishes",
		Description = {
			"ส่งมอบสร้อยคอของ Etran ให้กับ Robert หาใบไม้สีทองของ Home Tree มีสองคำขอที่ฝากไว้ ลองถาม Hiel เกี่ยวกับวิธีหาใบไม้ของ Home Tree"
		},
		Summary = "สองปรารถนา"
	},
	[12299] = {
		Title = "Revisiting Robert",
		Description = {
			"การทำลาย Home Tree เพื่อเอาใบไม้นั้นเป็นเรื่องต้องห้าม อย่างไรก็ตาม หากผู้สร้างมอบให้เองก็อาจจะโอเค แต่คราวก่อน Robert ไม่ได้ถูกทิ้งไว้ข้างหน้า Home Tree หรอกเหรอ?"
		},
		Summary = "กลับไปหา Robert อีกครั้ง"
	},
	[12300] = {
		Title = "Revisitng Etran",
		Description = {
			"แสดงใบไม้ของ Home Tree และให้กำลังใจ Etran ถึงแม้ว่าการที่ Robert ปฏิเสธไม่รับสร้อยคอนั้นจะค่อนข้างรุนแรง..."
		},
		Summary = "กลับไปหา Etran อีกครั้ง"
	},
	[12301] = {
		Title = "Two remaining friends",
		Description = {
			"Robert และ Etran จะทำหน้าที่ตามโชคชะตาของพวกเขาจนถึงที่สุด จนกว่าแผ่นดินในอดีต (ซึ่งคือปัจจุบันสำหรับพวกเขา) จะกลายเป็นแผ่นดินที่อุดมสมบูรณ์ในปัจจุบัน ลองคุยกับ Hiel และ Clever ผู้ที่ทำให้การพบกันครั้งนี้เป็นจริงได้"
		},
		Summary = "สองเพื่อนที่เหลืออยู่"
	},
	[12302] = {
		Title = "Salim Hamid",
		Description = {
			"คุยกับ Salim Hamid ครูฝึกสอนอาชีพพ่อค้า"
		},
		Summary = "คุยกับครูฝึกสอนพ่อค้า"
	},
	[12303] = {
		Title = "Applicant for trader",
		Description = {
			"พวกเขาบอกว่าคนที่มีเงิน 100 Zeny เท่านั้นที่มีสิทธิ์เข้าเรียนบทเรียนพ่อค้าที่มีชื่อเสียงของ Salim Hamid มันไม่ใช่เงินจำนวนมากนัก ดังนั้นคุณต้องหาไอเทมบางอย่างมาขาย"
		},
		Summary = "สะสม 100 Zeny"
	},
	[12304] = {
		Title = "Introduction to merchantology",
		Description = {
			"พ่อค้ามีทักษะหลากหลายในการหาเงินอย่างถูกกฎหมาย ฟังคำอธิบายจากผู้ช่วยที่อยู่ข้างๆ Salim Hamid"
		},
		Summary = "ความลับของการเจรจาต่อรอง"
	},
	[12305] = {
		Title = "About the capability figure",
		Description = {
			"พ่อค้าก็มีสถานะองค์ประกอบหลักเช่นกัน เพียงแค่ศึกษาค่าความสามารถของแต่ละสถานะ แน่นอนว่ามันขึ้นอยู่กับคุณ..."
		},
		Summary = "ไม่ได้บังคับให้คุณต้องทำ"
	},
	[12306] = {
		Title = "Experience of disounts",
		Description = {
			"ไปที่ตู้ขายของอัตโนมัติที่ส่งเสียงดังในห้องเรียนพ่อค้า กลับมาหลังจากตรวจสอบราคาส่วนลดของ Garlet และ Zargon ในการตรวจสอบราคาส่วนลด คุณต้องสวมใส่ Merchant Manual ด้วย"
		},
		Summary = "ดูส่วนลดโดยการสวมใส่ Merchant Manual"
	},
	[12307] = {
		Title = "Way to the Merchant",
		Description = {
			"ตามคำบอกกล่าวของ Salim Hamid ในการเปลี่ยนอาชีพเป็น Merchant คุณควรไปที่เมือง Alberta ไปที่อาคารโรงตีเหล็กในทิศทาง 5 นาฬิกา"
		},
		Summary = "เดินทางไป Alberta"
	},
	[12308] = {
		Title = "Removal of Worm Tails",
		Description = {
			"เมื่อเร็วๆ นี้มีพัสดุจำนวนมากถูกส่งไปยัง Prontera เพื่อการขนส่งที่ราบรื่นยิ่งขึ้น คุณต้องลดจำนวน Worm Tail แถวๆ Alberta กลับมาหลังจากล่า Worm Tail 20 ตัว"
		},
		Summary = "ล่า Worm Tail 20 ตัว"
	},
	[12309] = {
		Title = "Removal of Boa",
		Description = {
			"อุบัติเหตุเกิดขึ้นบ่อยครั้งกับพ่อค้าเก็บเห็ดที่เผลอไปสัมผัสโดนงูโดยไม่ได้ตั้งใจ กลับมาหาพ่อค้าที่เก็บของหลังจากล่า Boa 20 ตัว"
		},
		Summary = "ล่า Boa 20 ตัว"
	},
	[12310] = {
		Title = "Removal of Spore",
		Description = {
			"ของชำที่ถูกส่งไปยังเมืองหลวงเริ่มปนเปื้อนด้วยเมล็ดของ Spore กลับมาหาพ่อค้าที่เก็บของหลังจากล่า Spore 20 ตัว"
		},
		Summary = "ล่า Spore 20 ตัว"
	},
	[12311] = {
		Title = "Removal of Pirate Skeletons",
		Description = {
			"Salim Hamid ดูเหมือนจะอยากใช้เรือร้างแถวๆ Alberta หลังจากซ่อมแซมเสร็จ กลับมาหลังจากกำจัด Pirate Skeleton 10 ตัว"
		},
		Summary = "ล่า Pirate Skeleton 10 ตัว"
	},
	[12312] = {
		Title = "supplementary to the theory lesson",
		Description = {
