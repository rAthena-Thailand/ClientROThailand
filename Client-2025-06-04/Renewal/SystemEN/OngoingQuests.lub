	},
	[14297] = {
		Title = "คุณอยู่ในโรงแรม (You are in the inn)",
		Description = {
			"ในยามดึกสงัดแบบนี้ จะมีที่อื่นอีกเหรอสำหรับคนแปลกหน้าที่เพิ่งมาถึงเมือง? ไปที่โรงแรมซะ"
