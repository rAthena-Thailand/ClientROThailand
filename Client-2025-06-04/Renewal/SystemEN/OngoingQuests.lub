		Summary = "Horns of Hillslion 10 อัน, Mystic Horns 10 อัน, Horse Hooves 10 อัน"
	},
	[7429] = {
		Title = "[รอดำเนินการ] เทรนด์ล่าสุดมันช่างดุดัน!",
		IconName = "ico_dq.bmp",
		Description = {
