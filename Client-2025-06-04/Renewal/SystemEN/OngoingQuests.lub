		Summary = ""
	},
	[9256] = {
		Title = "<การตรวจโต๊ะที่ยุ่งเหยิง>",
		Description = {
			"บันทึกการตรวจ ^0000FFโต๊ะที่ยุ่งเหยิง^000000: จากคำให้การของ Rosa กล่องเครื่องประดับดูเหมือนจะมีราคาแพงกว่าสร้อยคอ คนร้ายอาจจะตั้งเป้าไปที่สร้อยคอเพียงอย่างเดียว"
		},
		Summary = ""
	},
	[9257] = {
		Title = "<การตรวจวัตถุแปลกปลอม>",
		Description = {
			"บันทึกการตรวจ ^0000FFวัตถุแปลกปลอมที่พบบนพื้น^000000: พบการค้นพบที่สำคัญจนบรรยายไม่ได้ คงต้องรอดูว่าเรื่องราวจะดำเนินต่อไปอย่างไร การสืบสวนอาจจะพบจุดคลี่คลายในเร็วๆ นี้"
		},
		Summary = ""
	},
	[9258] = {
		Title = "<ผลการตรวจสถานที่เกิดเหตุ>",
		Description = {
			"คนรู้จักหรือครูฝึกสัตว์, แฟนของ Luen ที่แม่ไม่ยอมรับ, สถานที่เกิดเหตุอาจถูกจัดฉาก, คนร้ายอาจชอบแอลกอฮอล์, ผลประโยชน์ทางการเงินอาจไม่ใช่แรงจูงใจหลักของการโจรกรรม จะดำเนินการสืบสวนต่อไปพร้อมกับการค้นพบที่สำคัญในบ้านของ Luen"
		},
		Summary = ""
	},
	[9259] = {
		Title = "<การยืนยันคำให้การของ Cruyan>",
		Description = {
			"ยืนยันคำให้การของ ^0000FFCruyan^000000 ไปยังดินแดนแห่งมวลดอกไม้บานและล่ามอนสเตอร์เพื่อดูว่าจะสามารถรับ Concentration Potion จากพวกมันได้หรือไม่ ล่า Menblatt 5 ตัว, Petal 30 ตัว"
		},
		Summary = "คุยกับ Balumin ใกล้ทางเข้า Eclage เมื่อล่าเสร็จสิ้น"
	},
	[9260] = {
		Title = "<บันทึกการสืบสวนภาคสนาม>",
		Description = {
			"Concentration Potion จาก ^0000FFCruyan^000000 ไม่สามารถหาได้จากมอนสเตอร์ อ้างที่อยู่ (Alibi) ไม่ได้รับการยืนยัน ^0000FFBalumin^000000 ไม่มีพยานแต่ส่วนหนึ่งของอ้างที่อยู่ได้รับการยืนยัน ^0000FFพ่อค้าเร่^000000 อยู่ในอาการมึนเมา และมอบ Concentration Potion เป็นรางวัลหลอกลวงจากการฉ้อโกงการพนันของเขา"
		},
		Summary = ""
	},
