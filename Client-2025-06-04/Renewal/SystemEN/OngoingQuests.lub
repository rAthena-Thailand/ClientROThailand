	[12000] = {
		Title = "เพื่อนเก่า",
		Description = {
			"ตามหาเพื่อนเก่าของ Maku และคุยกับเขา"
		},
		Summary = ""
	},
	[12001] = {
		Title = "Digotz เพื่อนเก่าของ Maku",
		Description = {
			"คุณได้คุยกับ Digotz เพื่อนสมัยเด็กของ Maku แล้ว กลับไปหา Maku และคุยกับเขา"
		},
		Summary = "Maku"
	},
	[12002] = {
		Title = "ผู้นำสารแห่งมิตรภาพ",
		Description = {
			"ทำหน้าที่เป็นผู้นำสารระหว่าง Maku และ Digotz เพื่อมิตรภาพที่ยั่งยืนของพวกเขา"
		},
		Summary = "ไปๆ มาๆ เพื่อส่งข้อความ"
	},
	[12003] = {
		Title = "ข้อความจาก Digotz",
		Description = {
			"ส่งข้อความของ Digotz ถึง Maku \"-ไอ้สารเลวที่สิ้นหวัง! -แกยังเป็นคนงี่เง่าที่ดื้อรั้นเหมือนเดิม! -แกติดค้างมื้อเที่ยงฉันอย่างน้อย 3 มื้อนะ! -ยังไม่รวมคำขอโทษอีก! -แต่ใครจะสนล่ะว่าแกคิดยังไง?! -ฉันมีความสุขฉิบหายเลยตอนไม่มีแก!\""
		},
		Summary = "Maku"
	},
	[12004] = {
		Title = "เพื่อนอีกคนของ Maku",
		Description = {
			"หลังจากใจเย็นลง Maku บอกว่าเพื่อนของเขาที่ชื่อ Benkaistein มักจะคอยดูแลไม่ให้เขามีเรื่องชกต่อย บางที Digotz อาจจะรู้จัก Benkaistein คนนี้ด้วยเช่นกัน..."
		},
		Summary = "Digotz"
	},
	[12005] = {
		Title = "Benkaistein",
		Description = {
			"Digotz บอกคุณว่า Benkaistein มีคำตอบสำหรับสถานการณ์ที่เขาและ Maku กำลังเผชิญอยู่ เขากำลังศึกษาอยู่ในสถานที่ที่มีหนังสือจำนวนมาก..."
		},
		Summary = "ตามหาที่อยู่ของ Benkaistein"
	},
	[12006] = {
		Title = "ของที่หายไปของ Benkaistein",
		Description = {
			"ช่วย Benkaistein ตามหาสิ่งที่เขาทำหายและนำกลับมาให้เขา"
		},
		Summary = ""
	},
	[12007] = {
		Title = "Kazien",
		Description = {
			"ชายชราใน Lighthalzen ขอให้คุณตามหาชายที่ชื่อ Kazien ภายในตึก Corporation เพื่อดูว่าคุณพอจะช่วยอะไรเขาได้บ้าง"
		},
		Summary = "ตามหา Kazien"
	},
	[12008] = {
		Title = "Researcher Garins",
		Description = {
			"ไปพบ Garins ในห้องปฏิบัติการ Einbroch Laboratory และยืนยันว่าเขาได้รับของที่สั่งแล้ว Kazien ขอให้คุณเก็บเรื่องนี้ไว้เป็นความลับจากทุกคน ดังนั้นจงระมัดระวังและรอบคอบในการสอบถามหาตัวเขา"
		},
		Summary = "ตามหา Garins ใน Einbroch"
	},
	[12009] = {
		Title = "FAled mission",
		Description = {
			"คุณทำภารกิจของ Kazien ล้มเหลวเนื่องจากคุณเปิดเผยข้อมูลมากเกินไป Kazien อาจจะให้โอกาสคุณอีกครั้งหากคุณพยายาม..."
		},
		Summary = "Kazien"
	},
	[12010] = {
		Title = "No entrance",
		Description = {
			"คุณกำลังประสบปัญหาในการผ่านยามของห้องปฏิบัติการ Laboratory Guard คุณควรแจ้งให้ Kazien ทราบถึงอุปสรรคของคุณ มิฉะนั้นคุณอาจจะไม่มีวันทำงานนี้สำเร็จ"
		},
		Summary = "Kazien"
	},
	[12011] = {
		Title = "Lyozien",
		Description = {
			"ตามหาชายที่ชื่อ Lyozien บนเรือเหาะเที่ยวบินระหว่างประเทศ (Airship International Flight) เช่นเคย จงเก็บเรื่องนี้ไว้เป็นความลับและอย่าบอกใครเกี่ยวกับงานนี้"
		},
		Summary = "Lyozien"
	},
	[12012] = {
		Title = "Meet Mr. Ahman",
		Description = {
			"ทำภารกิจให้สำเร็จโดยการไปพบคุณ Ahman ที่สนามบิน Izlude Airport แล้วกลับมาหา Lyozien"
		},
		Summary = "พบคุณ Ahman"
	},
	[12013] = {
		Title = "Delivery complete",
		Description = {
			"หลังจากคุยกับคุณ Ahman แล้ว คุณควรแจ้งให้ Lyozien ทราบว่าการส่งของเสร็จสิ้นแล้ว"
		},
		Summary = "Lyozien"
	},
	[12014] = {
		Title = "More missions",
		Description = {
			"Lyozien กล่าวว่า Kazien พี่ชายของเขาอาจจะมีงานอื่นให้คุณทำอีก"
		},
		Summary = "Kazien"
	},
	[12015] = {
		Title = "Ghalstein",
		Description = {
			"คุณแอบไปได้ยิน Ghalstein กำลังสนทนาอย่างมีพิรุธ พยายามหาข้อมูลเพิ่มเติมเกี่ยวกับสิ่งที่คุณอาจจะได้ยินมา"
		},
		Summary = ""
	},
	[12016] = {
		Title = "Sneaking into the Laboratory",
		Description = {
			"คุณต้องลอบเข้าไปในห้องปฏิบัติการลับโดยการสืบสวนเรื่องการหายตัวไปของผู้คนจากย่านสลัมฝั่งตะวันออก และนำหลักฐานกลับมาให้ Ghalstein"
		},
		Summary = ""
	},
	[12017] = {
		Title = "Membership approved",
		Description = {
			"ตามหา Gusharr แถวๆ Yuno แล้วเขาจะบอกคุณเกี่ยวกับภารกิจถัดไป แสดงบัตรสมาชิก (Membership Card) ให้เขาเห็นเพื่อพิสูจน์ว่าคุณทำงานร่วมกับ Ghalstein"
		},
		Summary = ""
	},
	[12018] = {
		Title = "Meeting the President",
		Description = {
			"แสดงบัตรสมาชิกของคุณต่อเลขาของท่านประธาน คุณสามารถเข้าพบประธาน Weierstrass ได้เฉพาะช่วงเวลา 20:00 น. ถึง 23:00 น. และ 11:00 น. ถึง 14:00 น. ตามเวลา PST เท่านั้น"
		},
		Summary = ""
	},
	[12019] = {
		Title = "The President's Mission",
		Description = {
			"นำแฟ้มเอกสารไปให้คุณ Hes O'Neil เลขาของท่านประธานก่อนที่คุณจะจากไป จากนั้นไปพบกับ Benith ที่สำนักงานใหญ่ Kafra ใน Al De Baran เพื่อรับทราบภารกิจถัดไป"
		},
		Summary = ""
	},
	[12020] = {
		Title = "Rescuing a Secret Wing Member",
		Description = {
			"คุณต้องตามหาเจ้าหน้าที่ Jargeah แถวสะพานขาดที่ไหนสักแห่งระหว่าง Einbroch และ Lighthalzen เขาได้รับบาดเจ็บและต้องการความช่วยเหลือ จงไปที่นั่นก่อนที่ศัตรูจะถึงตัวเขา"
		},
		Summary = ""
	},
	[12021] = {
		Title = "The Sealed File Folder",
		Description = {
			"Jargeah มอบแฟ้มเอกสารที่ปิดผนึกไว้ให้คุณ คุณควรกลับไปรายงานต่อ Benith ที่สำนักงานใหญ่ Kafra"
		},
		Summary = ""
	},
	[12022] = {
		Title = "The Sealed File Folder",
		Description = {
			"ส่งแฟ้มเอกสารที่ปิดผนึกไว้ให้ประธาน Weierstrass ใน Lighthalzen"
		},
		Summary = ""
	},
	[12023] = {
		Title = "Shinokas the researcher",
		Description = {
			"ภารกิจถัดไปของคุณคือตามหานักวิจัย Shinokas ผู้กุมความลับเกี่ยวกับ Rekenber Corporation มีรายงานว่าพบเห็นเขาอยู่ที่ไหนสักแห่งใน Einbroch"
		},
		Summary = ""
	},
	[12024] = {
		Title = "Kafra Corporation Agent",
		Description = {
			"ตามหาเจ้าหน้าที่ของ Kafra Corporation ในทุ่งสังหาร Lighthalzen field"
		},
		Summary = ""
	},
	[12025] = {
		Title = "Rekenber's Secret Archive",
		Description = {
			"ใช้บัตรผ่านสำหรับตึก Rekenber และไปพบกับเจ้าหน้าที่ Lestin ซึ่งจะเป็นผู้อธิบายภารกิจของคุณ"
		},
		Summary = ""
	},
	[12026] = {
		Title = "Rekenber's Secret Archive",
		Description = {
			"ลอบเข้าไปในหอจดหมายเหตุลับ (Secret Archive) ด้วยบัตรผ่านของ Lestin (มีบางอย่างเขียนไว้ที่ด้านหลังบัตร) ในช่วงที่ยามเปลี่ยนกะ นำหลักฐานใดๆ ก็ตามที่คุณหาได้กลับมา"
		},
		Summary = ""
	},
	[12027] = {
		Title = "Rekenber's Secret Archive",
		Description = {
			"ตามหา Esuna ที่ด้านนอกเมือง Lighthalzen และส่งต่อข้อมูลที่คุณพบในหอจดหมายเหตุลับ"
		},
		Summary = ""
	},
	[12028] = {
		Title = "Kurelle the traitor",
		Description = {
			"กลับไปหาท่านประธานพร้อมข่าวเรื่อง Kurelle ผู้ทรยศแห่งหน่วย Secret Wing จากนั้นกลับไปหา Ghalstein เพื่อรับยาถอนพิษสำหรับยาพิษสีแดงที่เขาให้คุณไว้"
		},
		Summary = ""
	},
	[12029] = {
		Title = "Lost Engagement Ring",
		Description = {
			"ช่วย Shuda ตามหาแหวนหมั้นที่หายไป ซึ่ง Annon คู่หมั้นของเธอขว้างลงไปในน้ำ คุณควรหาอะไรบางอย่างมาตกมันขึ้นมา"
		},
		Summary = ""
	},
	[12030] = {
		Title = "Engagement Ring Found",
		Description = {
			"คุณพบแหวนหมั้นของ Shuda อยู่ในตัว Phen ที่คุณตกขึ้นมาจากน้ำ นำมันกลับไปให้เธอ"
		},
		Summary = "Shuda"
	},
	[12031] = {
		Title = "Find Annon",
		Description = {
			"ตอนนี้ Shuda ได้แหวนหมั้นคืนแล้ว คุณควรตามหา Annon และแจ้งให้เขาทราบ จะต้องมีใครสักคนที่เคยเห็นเขาแน่ๆ"
		},
		Summary = ""
	},
	[12032] = {
		Title = "Searching for Annon",
		Description = {
			"คุณพบกับชายชราคนหนึ่งที่บอกว่ามีชายหนุ่มวิ่งผ่านเขาเข้าไปในป่า จะใช่ Annon หรือเปล่านะ? ค้นหาร่องรอยที่อยู่ของเขาในป่า"
		},
		Summary = "รอยเท้าของ Annon"
	},
	[12033] = {
		Title = "Traces of blood",
		Description = {
			"คุณพบร่องรอยของเลือด ใครก็ตามที่วิ่งไปทางนี้อาจจะได้รับบาดเจ็บ รอยเหล่านั้นมุ่งหน้าไปทางเหนือ... Annon ต้องอยู่แถวนี้แน่ๆ"
		},
		Summary = ""
	},
	[12034] = {
		Title = "Annon's side of the story",
		Description = {
			"คุณพบสถานที่แปลกประหลาดที่มีรอยเลือดมากขึ้น Annon ต้องอยู่ที่นี่... เมื่อคุณพบเขา คุณควรถามเขาว่าทำไมเขาถึงหนีมาจาก Shuda"
		},
		Summary = ""
	},
	[12035] = {
		Title = "Holy Threads",
		Description = {
			"Boonthom ขอให้คุณนำไอเทมต่อไปนี้กลับมาเพื่อสร้างไอเทมที่มีพลังศักดิ์สิทธิ์: 1 needle Packet, 1 Spool, 1 Solid Husk, และ 1 bottle of Holy Water จากนั้นคุณจะได้รับอนุญาตให้เข้าสู่ดันเจี้ยนชั้นใต้ดินระดับที่ 1"
		},
		Summary = ""
	},
	[12036] = {
		Title = "The Stone Slate Message",
		Description = {
			"ตอนนี้คุณพบส่วนสุดท้ายของแผ่นหินแล้ว คุณควรส่งข้อความที่คุณพบไปให้ Boonthom"
		},
		Summary = "Shaman Boonthom"
	},
	[12037] = {
		Title = "Holier Threads",
		Description = {
