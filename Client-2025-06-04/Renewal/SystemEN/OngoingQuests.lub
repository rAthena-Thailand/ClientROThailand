	},
	[12502] = {
		Title = "Defeat the Visions of Glastheim",
		Description = {
			"สังหารหนึ่งในสองภาพลวงตา (Illusions) ใน Glastheim",
			"^0000ffเควสทั้งหมดเหล่านี้สามารถสำเร็จได้โดยการเคลียร์เพียงอย่างใดอย่างหนึ่งจากสองอย่าง^000000"
		},
		Summary = "ภาพลวงตาของ Himelmez"
	},
	[12505] = {
		Title = "Sealing Incomplete Cracks",
		IconName = "ico_ev.bmp",
		Description = {
			"พลังงานอันไม่พึงประสงค์ไหลซึมออกมาจากรอยแยกที่ดูเหมือนจะไม่สมบูรณ์ หากมีห้วงเวลาและอวกาศที่บิดเบี้ยวซึ่งแม้แต่ Oscar ก็ยังไม่สังเกตเห็น มันอาจก่อให้เกิดปัญหาร้ายแรงได้",
			"คุณจะไม่สามารถรับความช่วยเหลือจาก Oscar ได้ แต่มันอาจเป็นไปได้ที่จะทำลายรอยแยกนั้นก่อนที่มันจะก่อตัวขึ้นโดยสมบูรณ์"
		},
		Summary = "ภัยคุกคามของโลก"
	},
	[12506] = {
		Title = "Crack Seal Retry",
		IconName = "ico_ev.bmp",
		Description = {
			"หากคุณล้มเหลวในการปิดผนึกรอยแยก ให้พักสักครู่แล้วลองใหม่อีกครั้ง"
		},
		Summary = "รีเซ็ตเวลา 04:00",
		CoolTimeQuest = 1
	},
	[12507] = {
		Title = "Sealer of Cracks",
		IconName = "ico_ev.bmp",
		Description = {
			"ปิดผนึกรอยแยกที่ขยายตัวอย่างไม่สมบูรณ์ได้อย่างสมบูรณ์แบบ คุณได้ช่วยชีวิตเพื่อนร่วมงานและมิตรสหายจากภัยคุกคามอันยิ่งใหญ่ที่อาจมาสู่โลกนี้",
			"บางทีบันทึกนี้อาจจะนำโชคมาให้คุณบ้าง"
		},
		Summary = "ร่องรอยของการช่วยโลก"
	},
	[12508] = {
		Title = "Take the Dragon's Trial",
		IconName = "ico_jq.bmp",
		Description = {
			"^FF0000'คุณเป็นผู้เข้ารับการทดสอบมังกรจริงๆ หรือ?'^FF0000",
			"มังกรแห่งกาลอวกาศตรงหน้าคุณดูจะเป็นภาพที่น่าดูหมิ่น แต่ในความเป็นจริง มีคนเพียงไม่กี่คนที่มีเงื่อนไขเหมาะสมกับการเป็น ^ff0000Dragon Knight^000000 มากไปกว่าคุณ ตอนนี้มาเข้ารับการทดสอบและพิสูจน์มันเถอะ"
		},
		Summary = "กลายเป็นสหายของมังกร"
	},
	[12509] = {
		Title = "Cool Down",
		IconName = "ico_jq.bmp",
		Description = {
			"ดูเหมือนคุณจะจดจ่อมากเกินไป ดังนั้นมาพักสักครู่แล้วลองใหม่อีกครั้ง"
		},
		Summary = "พัก 30 นาที"
	},
	[12510] = {
		Title = "About the Hidden Arena",
		Description = {
			"ที่เหนือรอยแยกแห่งมิติ เราค้นพบว่าลานประลองกำลังถูกดำเนินการในทางที่ผิดกฎหมาย",
			"ฉันไม่รู้ว่าพวกเขาทรมานและเคี่ยวเข็ญผู้ที่กลายเป็นอดีตไปแล้วเหล่านั้นอย่างไร แต่มันน่าสนใจมากทีเดียว"
		},
		Summary = "กฎของคนขลาด"
	},
	[12511] = {
		Title = "No Game Today",
		Description = {
			"ลานประลองกล่าวกันว่าจะเปิดทุกๆ 3 วัน เป็นเรื่องดีที่จะได้พักผ่อนเมื่อไม่มีการแข่งขัน"
		},
		Summary = "อีก 3 วัน การแข่งขันจะเริ่มใหม่ตอนตี 4",
		CoolTimeQuest = 1
	},
	[12512] = {
		Title = "Evidence of Surviving",
		Description = {
			"หากคุณยังคงยืนอยู่ในลานประลอง และหากคุณกำลังดูบัตรผ่านนี้อยู่ มันคือข้อพิสูจน์ว่าคุณยังมีชีวิตอยู่"
		},
		Summary = "ฉันยังไม่ตาย"
	},
	[12513] = {
		Title = "The reason the tower was destroyed",
		Description = {
			"ตัวเอกของความวุ่นวายนี้ดูเหมือนจะตั้งหลักปักฐานอยู่ในหอคอยที่ลอยอยู่ครึ่งๆ กลางๆ มาตรวจสอบกันว่ามันคืออะไรกันแน่"
		},
		Summary = "เจ้าของหอคอยคนใหม่"
	},
	[12514] = {
		Title = "Aftermath of entering the tower",
		Description = {
			"ต้องใช้พลังงานทางจิตอย่างมากในการเข้าออกสถานที่แห่งนี้ แม้ว่าจะมีสิ่งที่ต้องทำเหลืออยู่ แต่ควรมาเยี่ยมชมใหม่อีกครั้งหลังจากผ่านไป 3 วัน"
		},
		Summary = "เข้าใหม่ได้ตอนตี 4 หลังผ่านไป 3 วัน",
		CoolTimeQuest = 1
	},
	[12515] = {
		Title = "Confrontation with the owner of the new tower",
		Description = {
			"เจ้าของหอคอยคนใหม่ไม่ได้ฆ่าผู้อยู่อาศัยในหอคอยทั้งหมด เขาใจกว้างจริงๆ แต่ในทางกลับกัน เมื่อมองดูมอนสเตอร์ที่ลงมา คุณก็จินตนาการไม่ได้เลยว่าเขาแข็งแกร่งขนาดไหน"
		},
		Summary = "มาเก็บตัวเงียบๆ กันเถอะ"
	},
	[12516] = {
		Title = "Fountain's Secret 1",
		Description = {
			"ชนะโดยการขยายความแข็งแกร่งของ Betelgeuse ขึ้น 300% หรือมากกว่า ความสามารถในการเพิ่มความยากเฉพาะเจาะจงถึงขีดสุดโดยใช้ <ITEM>[Meteorite Powder]<INFO>1000372</INFO></ITEM> ได้ถูกเพิ่มเข้ามาแล้ว"
		},
		Summary = "การเสริมความแข็งแกร่งของค่าสถานะที่กำหนด"
	},
	[12517] = {
		Title = "Fountain's Secret 1",
		Description = {
			"เอาชนะโดยการขยายความแข็งแกร่งของ Betelgeuse ขึ้น 600% หรือมากกว่า ความสามารถในการผนึกระดับความยากเฉพาะเจาะจงให้เป็น 0 โดยใช้ <ITEM>[Meteorite Powder]<INFO>1000372</INFO></ITEM> ได้ถูกเพิ่มเข้ามาแล้ว"
		},
		Summary = "การผนึกความสามารถที่กำหนด"
	},
	[12518] = {
		Title = "Exiled Being",
		Description = {
			"เป็นที่แน่ชัดว่าเกิดการเปลี่ยนแปลงครั้งใหญ่ในระบบนิเวศของหอคอย ก่อนที่คุณจะระบุได้ว่าใครเป็นเจ้าของบัลลังก์ที่เปลี่ยนไปนี้ คุณจะต้องจัดการทำความสะอาดเสียก่อน"
		},
		Summary = "กรุณาออกไปซะ"
	},
	[12519] = {
		Title = "Original Owner's whereabouts",
		Description = {
			"หากหอคอยกลายเป็นเช่นนี้ สิ่งมีชีวิตที่เคยปกครองสถานที่แห่งนี้แต่เดิมย่อมไม่สามารถเอาชีวิตรอดได้"
		},
		Summary = "ตอนนี้มันอาจจะไม่สำคัญแล้ว"
	},
	[12520] = {
		Title = "Villa of Deception",
		Description = {
			"กล่าวกันว่ารูปลักษณ์ของสิ่งมีชีวิตที่ถูกสังหารไปแล้วยังคงถูกพบเห็นในบ้านพักฤดูร้อนของ High Priest Youth ทาง Ira หวังว่าสิ่งอัปมงคลนี้จะถูกกำจัดด้วยมือของเหล่านักผจญภัยก่อนที่พวกมันจะเรียกความพิโรธของทวยเทพลงมา"
		},
		Summary = "เทพผู้บิดเบี้ยวถูกสังหาร"
	},
	[12521] = {
		Title = "Advanced Villa of Deception",
		Description = {
			"กล่าวกันว่ารูปลักษณ์ของสิ่งมีชีวิตที่ถูกสังหารไปแล้วยังคงถูกพบเห็นในบ้านพักฤดูร้อนของ High Priest Youth ทาง Ira หวังว่าสิ่งอัปมงคลนี้จะถูกกำจัดด้วยมือของเหล่านักผจญภัยก่อนที่มันจะแพร่กระจายออกไปสู่โลกภายนอก"
