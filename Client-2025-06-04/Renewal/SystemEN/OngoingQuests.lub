	[8213] = {
		Title = "บทเรียนของ Shurank",
		Description = {
			"ฉันเห็นว่าคุณได้รับความชำนาญในทักษะ Bash มาบ้างแล้ว แต่ถึงอย่างนั้น มันก็ยังไม่พอ"
