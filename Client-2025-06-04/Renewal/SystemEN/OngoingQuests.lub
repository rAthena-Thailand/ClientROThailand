			"ยามของตู้จำหน่ายสินค้าอัตโนมัติ Guardian Mutual Aid กำลังรีบเร่ง ในสถานะนี้อาจเป็นเรื่องยากที่จะส่งมอบผลิตภัณฑ์อย่างถูกต้อง"
		},
		Summary = ""
	},
	[12277] = {
		Title = "I want to, I'm happy.",
		Description = {
			"ถ้าคุณพบกลุ่มประกาศจับ ลองนำไปให้ Halihi ดูสิ มีความเป็นไปได้สูงที่ ^990099Poring และ Poring^000000 ในฟิลด์ต่างๆ จะมีมันอยู่"
		},
		Summary = ""
	},
	[12278] = {
		Title = "Towards Bakonawa Lake...",
		Description = {
			"เข้าสู่ทะเลสาบเพื่อหยุดยั้ง Bakonawa ไม่คิดว่าฉันจะต้องกลับเข้าไปในทะเลสาบอีกภายในสัปดาห์นี้"
		},
		Summary = "รีเซ็ตหลังจาก 7 วัน ณ เวลา 4 นาฬิกา",
		CoolTimeQuest = 1
	},
	[12279] = {
		Title = "Get Rid of Bakonawa",
		Description = {
			"การต่อสู้ครั้งใหญ่จะปะทุขึ้นหากปล่อย Bakonawa ไว้แบบนี้ เขาจะต้องถูกกำจัด"
		},
		Summary = ""
	},
	[12280] = {
		Title = "A suspicious prisoner",
		Description = {
			"ดูเหมือนว่าจะมีนักโทษที่น่าสงสัยอยู่ในคุก จะดีกว่าไหมถ้าได้ลองฟังเรื่องราวของเขาสักครั้ง?"
		},
		Summary = "นักโทษที่น่าสงสัย"
	},
	[12281] = {
		Title = "An unwanted favor",
		Description = {
			"Clever ร้องขอ ^000099Grape Extract Herb Tea^000000 1 แก้ว มันเป็นคำขอที่ยิ่งใหญ่มาจากนักโทษคนหนึ่ง แต่พยายามหามาให้ได้เมื่อเป็นไปได้"
		},
		Summary = "คำขอที่ไม่ต้องการ"
	},
	[12282] = {
		Title = "Gossip king Clever",
		Description = {
			"Clever รู้เรื่องซุบซิบมากมาย เนื่องจากความรู้ของเขาอาจมีประโยชน์ต่อการผจญภัยในอนาคต มาลองฟังเรื่องเหล่านั้นกันเถอะ อาจจะมีข้อมูลที่มีประโยชน์มากอยู่ก็ได้"
		},
		Summary = "เจ้าแห่งเรื่องซุบซิบ Clever"
	},
	[12283] = {
		Title = "The rift researcher",
		Description = {
			"มี Dona วัยเยาว์ชื่อ ^000099Hielle^000000 ผู้ซึ่งเป็นที่รู้จักในเรื่องการทำวิจัยที่เกี่ยวข้องกับเศษชิ้นส่วนรอยแยก จงตามหาตัวนักวิจัยคนนั้น"
		},
		Summary = "นักวิจัยรอยแยก"
	},
	[12284] = {
		Title = "A cat merchant's source of information",
		Description = {
			"ในหมู่พ่อค้าแมว มีแมวตัวหนึ่งที่ถูกสมมติว่ารู้เรื่องงานวิจัยเกี่ยวกับรอยแยกของ Midgarts มากมาย จงตามหา ^000099Midgarts Post^000000 ผู้โด่งดังในเรื่องกิจกรรมของเขา"
		},
		Summary = "แหล่งข้อมูลของพ่อค้าแมว"
	},
	[12285] = {
		Title = "A way to calm down a cat",
		Description = {
			"หากแมวตัวนั้นหยุดต่อสู้ ก็อาจจะได้รับข้อมูลที่เป็นประโยชน์ จะทำให้เขาสงบลงได้อย่างไรนะ? พวกเขาบอกว่าพวกเขาไม่ได้รับเงินเดือนรายเดือนเป็น ^000099Malangdo Canned Specialties^000000 อย่างนั้นเหรอ?"
		},
		Summary = "วิธีทำให้แมวสงบลง"
	},
	[12286] = {
		Title = "Information traded for some canned foods",
		Description = {
			"ว่ากันว่าต้องใช้ ^000099Dark Debris 1 อัน, อัญมณีสีแดง/เหลือง/น้ำเงิน อย่างละ 2 อัน^000000 เพื่อเปิดใช้งานเศษชิ้นส่วนรอยแยก ดูเหมือนว่า Hiel กำลังลำบากในการหาพวกมันมา"
		},
		Summary = "ข้อมูลที่แลกเปลี่ยนกับอาหารกระป๋อง"
	},
	[12287] = {
		Title = "A weird experience",
		Description = {
			"ทำการทดลองกับ Hiel ว่าปฏิกิริยาที่เพียงพอเกิดขึ้นกับเศษชิ้นส่วนรอยแยกหรือไม่"
		},
		Summary = "ประสบการณ์ที่แปลกประหลาด"
	},
	[12288] = {
		Title = "A successful experience",
		Description = {
			"ด้วยการจัดการปัจจุบันของ Hiel ดูเหมือนว่ามันจะไม่ตอบสนองอย่างถูกต้อง ลองแตะที่ชุดทดลองเพื่อเปิดใช้งานมันดู"
		},
		Summary = "ประสบการณ์ที่ประสบความสำเร็จ"
	},
	[12289] = {
		Title = "Another visitation",
		Description = {
			"ตัวตนที่พบผ่านปฏิกิริยาของรอยแยกต้องเป็นบุคคลที่มีตัวตนจริงในประวัติศาสตร์แน่ๆ ลองถาม Clever ผู้เป็นนักประวัติศาสตร์เกี่ยวกับเรื่องนี้ดู"
		},
		Summary = "การมาเยือนอีกครั้ง"
	},
	[12290] = {
		Title = "Clever's historical documents",
		Description = {
			"มีบุคคลที่ดูเหมือนจะเป็นพวก Lapine ตามเอกสารทางประวัติศาสตร์ของ Clever ลองฟังเรื่องราวของเขาดู"
		},
		Summary = "เอกสารทางประวัติศาสตร์ของ Clever"
	},
	[12291] = {
		Title = "Hidden historical documents (?)",
		Description = {
			"ตามแผนภาพที่ Clever วาดไว้ เอกสารนั้นดูไม่เหมือนจะถูกซ่อนไว้เท่าไหร่ ค่อนข้างจะถูกจัดวางไว้อย่างดีบนชั้นวางมากกว่า ลองค้นหาสถานที่ที่หนังสือถูกจัดระเบียบใน Eclage ดู"
		},
		Summary = "เอกสารทางประวัติศาสตร์ที่ซ่อนอยู่ (?)"
	},
	[12292] = {
		Title = "The unknown ones",
		Description = {
			"บุคคลที่รับผิดชอบในการสร้าง Home Tree และฟื้นฟูแผ่นดิน Bifrost ไม่ใช่สภาผู้เฒ่า (Elder's Assembly) แต่เป็น Dona ที่ไม่รู้จักสองคน ลองถาม Clever เกี่ยวกับ Dona สองคนที่ชื่อ Etran และ Robert"
		},
		Summary = "บุคคลที่ไม่เป็นที่รู้จัก"
	},
	[12293] = {
		Title = "Figures in history",
		Description = {
			"Clever ขอให้ไปพูดคุยโดยตรงกับบุคคลสำคัญในอดีตผ่านอุปกรณ์รอยแยก ไม่แน่ใจว่าเป็นไปได้ไหม แต่ลองไปหา Hiel ดู"
		},
		Summary = "บุคคลสำคัญในประวัติศาสตร์"
	},
	[12294] = {
		Title = "Tour of Eclage",
		Description = {
			"พา Robert ผู้ที่ปรากฏตัวมาจากอดีต ไปรอบๆ สถานที่หลายแห่งใน Eclage เขาจะไม่ประทับใจเหรอถ้าได้เห็นสภาพปัจจุบันของ Home Tree?"
		},
		Summary = "การทัวร์ Eclage"
	},
	[12295] = {
		Title = "Error",
		Description = {
			"Robert หายตัวไปอย่างกะทันหัน กลับไปหา Hiel เพื่อตรวจสอบว่ามีอะไรผิดปกติกับอุปกรณ์รอยแยกหรือไม่"
		},
		Summary = "ข้อผิดพลาด"
	},
	[12296] = {
		Title = "Fun times with the reactor",
		Description = {
			"ใช้เครื่องปฏิกรณ์รอยแยกของ Hiel เพื่อสำรวจพื้นที่ต่างๆ ของ Eclage อาจจะมีสถานที่ที่ Etran ปรากฏตัวอยู่"
		},
		Summary = "ช่วงเวลาสนุกกับเครื่องปฏิกรณ์"
	},
	[12297] = {
		Title = "Encountering Etran",
		Description = {
			"พบตำแหน่งที่สามารถติดต่อ Etran ได้แล้ว มันเป็นโอกาสที่ดีที่จะยืนยันว่าเขาเป็นผู้รับผิดชอบในการฟื้นฟูแผ่นดินจริงหรือไม่"
