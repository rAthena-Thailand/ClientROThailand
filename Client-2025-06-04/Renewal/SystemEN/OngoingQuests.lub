		Summary = "รีเซ็ตตอน 04:00 น.",
		CoolTimeQuest = 1
	},
	[7395] = {
		Title = "ผีบนเรือ Perry",
		Description = {
			"ตัดสินใจไปพิสูจน์ด้วยตัวเองว่าเรื่องเล่าของ Pedro ที่ว่าเรือ Perry มีผีดุนั้นเป็นความจริงหรือไม่ ดูเหมือนพวกผีแถวนี้จะกลัวฉัน ดังนั้นอย่าไปกลัวที่จะขึ้นเรือเลย"
		},
		Summary = "สำรวจเรือ Perry"
	},
	[7396] = {
		Title = "วิญญาณที่โกรธแค้นบนเรือ Perry",
		Description = {
			"เขาถูกปฏิบัติอย่างเลวร้ายบนเรือ Perry โดยวิญญาณเด็กสาวที่โกรธแค้น ลองหาทางแก้ไขกันเถอะ"
		},
		Summary = "คุยกับ Pedro และ Mumbaki"
	},
	[7397] = {
		Title = "คำแนะนำของ Mumbaki Phong",
		Description = {
			"Mumbaki Phong บอกว่าอย่าเลี่ยงวิญญาณ แต่ให้โอบกอดและปลอบประโลมมันแทน ไปหา Elegant Flowers อย่างน้อย 3 ดอก, Mysterious Flowers 3 ดอก และ Beautiful Flowers 3 ดอกเพื่อเป็นของเซ่นไหว้ ลองหาดอกไม้เพื่อมาถวายดู คุณสามารถหาดอกไม้ได้จากสัตว์และมอนสเตอร์แถวๆ นี้"
		},
		Summary = "Elegant Flower 3 ดอก, Mysterious Flower 3 ดอก, Beautiful Flower 3 ดอก"
	},
	[7398] = {
		Title = "ช่อดอกไม้ถวายที่แนะนำโดย Mumbaki",
		Description = {
			"Mumbaki Phong ได้อวยพรดอกไม้และทำช่อดอกไม้ถวาย (Offering Bouquet) จากที่คุณนำมาให้ นำช่อดอกไม้นี้ไปให้ Ghost Diwata บนเรือ Perry กันเถอะ"
		},
		Summary = "ถวายช่อดอกไม้แด่ Diwata"
	},
	[7399] = {
		Title = "เรื่องราวของ Ghost Diwata",
		Description = {
			"Diwata บอกว่าเธอถูกพวกผีเจ้าถิ่นกลั่นแกล้งเพราะเธอมาจากนอกหมู่บ้าน เรือ Perry ต้องติดชะงักเพราะวิญญาณอันทรงพลังของ Diwata"
		},
		Summary = "แจ้งข้อมูลนี้แก่ Pedro"
	},
	[7400] = {
		Title = "Mumbaki แห่ง Port Malaya",
		Description = {
			""
		},
		Summary = ""
	},
	[7401] = {
		Title = "[รอดำเนินการ] ทุกคนขึ้นเรือเพื่อล่องเรือ Perry",
		Description = {
			"ในขณะนี้ เรือ Perry ดูเหมือนจะสามารถกลับมาใช้งานได้ตามปกติแล้ว อย่างไรก็ตาม ไปตรวจสอบกับ <NAVI>[กะลาสี Pedro]<INFO>malaya,326,68,0,101,0</INFO></NAVI> อีกครั้งเถอะ เพราะวิญญาณเจ้าถิ่นและ Diwata อาจจะทะเลาะกันอีกก็ได้..."
