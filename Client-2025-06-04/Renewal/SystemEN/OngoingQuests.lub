	[8211] = {
		Title = "บทเรียนของ Shurank",
		Description = {
			"คุณได้เรียนรู้ศิลปะการใช้ Bash หรือยัง? ฉันเชื่อมั่นอย่างแรงกล้าว่าทักษะ Bash คือแก่นแท้ของวิชาดาบ!"
