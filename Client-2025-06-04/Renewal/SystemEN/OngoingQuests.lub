	[7711] = {
		Title = "การเริ่มต้น",
		Description = {
			"โย่ โฮ! ฉันคือ Doram ที่สุดยอดจากพาสต้า! ฉันปีนภูเขา Laviol มาและถึงท่าเรือ Lasagna แล้ว และฉันกำลังจะยึดครองทวีปใหม่ Midgarts!"
