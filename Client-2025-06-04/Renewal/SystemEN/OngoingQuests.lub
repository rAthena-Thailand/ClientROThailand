	},
	[8191] = {
		Title = "ที่ปรึกษาด้านเสน่ห์ (Charming Advisor)",
		Description = {
			"เมื่อคุณมีทัศนคติที่เหมาะสมต่อความงามแล้ว ถึงเวลาที่คุณจะได้เรียนรู้เทคนิคขั้นสูงในการดึงดูดใจ จงไปหาพี่สาวของฉันในโบสถ์ Prontera เธอจะยินดีสอนคุณเอง"
		},
		Summary = ""
	},
	[8192] = {
		Title = "ที่ปรึกษาผู้เห็นแก่ตัว (Selfish Advisor)",
		Description = {
			"ฉันอยากดื่มของจริงสักหน่อย พวกที่มี ^FF0000Alcohol^000000 อ้อ แล้วฉันก็ต้องการของว่างเพื่อช่วยพยุงพลังงานในการสอนทั้งหมดของฉันด้วย! ^FF00001 Apple, 3 Bananas, 5 Well-Baked Cookies^000000 วางไว้บนจาน ^FF0000China^000000 สวยๆ"
		},
		Summary = "กลับไปหา Aelle พร้อมกับเครื่องดื่มแอลกอฮอล์และกับแกล้ม"
	},
	[8193] = {
		Title = "ที่ปรึกษาผู้เห็นแก่ตัว (Selfish Advisor)",
		Description = {
			"เอาล่ะ ท่าทางที่ง่ายที่สุด แยบยลที่สุด และน่าดึงดูดที่สุดตลอดกาลก็คือการ ^FF0000ขยิบตา^000000 มันเคยช่วยชีวิตฉันไว้ในยามคับขัน และการฝึกฝนจนชำนาญจะช่วยเสริมเสน่ห์ของคุณ"
		},
		Summary = ""
	},
	[8194] = {
		Title = "ที่ปรึกษาจอมขี้เมา (Drunken Advisor)",
		Description = {
			"ปะ-ไปให้พ้น ไปคุยกับ Canell พี่สาวของฉันซะ...!..ครอกฟี้ZZZZzzZZZzzzZZ.."
		},
		Summary = ""
	},
	[8195] = {
		Title = "Canell ผู้ใจดี",
		Description = {
			"เอาล่ะ แดนเซอร์ (Dancer) ที่แท้จริงควรจะค้นหาความลับของการขยิบตาได้ด้วยตัวเอง แต่เนื่องจากฉันเป็นผู้หญิงที่ใจดีมาก ฉันจะยอมอธิบายให้คุณฟังเอง ฮิๆ~"
		},
		Summary = ""
	},
	[8196] = {
		Title = "ความขัดแย้งของสหภาพไตรภาคี",
		Description = {
			"ช่วงนี้พวกนักวิจัยบ่นกันเยอะมาก พวกเขาเครียดมากและฉันคิดว่าใครสักคนควรจะรับฟังปัญหาของพวกเขาจริงๆ โดยเฉพาะพวกที่จัดการเกี่ยวกับเอกสารที่มักจะทะเลาะกันอยู่บ่อยครั้ง คุณอาจจะอยากเริ่มจากการไปคุยกับพวกเขาดูนะ"
		},
		Summary = ""
	},
	[8197] = {
		Title = "การส่งเอกสาร",
		Description = {
			"โอเค ตอนนี้ช่วยนำไฟล์ไปส่งให้ Hue และ Hansenne ที Hue ดูแลเอกสารของ Schwaltzvalt และ Hansenne ดูแลของ Arunafeltz คุณควรไปหา Hue ที่สำนักงานของ Schwaltzvalt ไม่อย่างนั้นเขาจะเอาแต่บ่นเรื่องนี้"
		},
		Summary = "ส่งเอกสารให้ Hue และ Hansenne แล้วกลับมาหา Ryosen"
	},
	[8198] = {
		Title = "รายงานต่อเจ้าหน้าที่วิจัยร่วม",
		Description = {
			"เอาล่ะ น้ำมันหกไปแล้ว (ทำอะไรไม่ได้แล้ว) ฉันต้องไปประชุมนั่นไม่ว่าจะชอบหรือไม่ก็ตาม คุณช่วยส่งสิ่งนี้ให้เจ้าหน้าที่ของศูนย์วิจัยร่วมได้ไหม? ในระหว่างนั้น ฉันต้องเตรียมตัวสำหรับการประชุม"
		},
		Summary = "ส่งเอกสารให้เจ้าหน้าที่วิจัยร่วม"
	},
	[8199] = {
		Title = "คำขอของเจ้าหน้าที่วิจัยร่วม",
		Description = {
			"ได้โปรด คุณควรเข้าร่วมในการประชุมและช่วยไกล่เกลี่ยพวกเขาหากมีอะไรผิดพลาด! ขั้นแรก คุณควรไปพบคนทั้ง 3 คนนั้นและตรวจสอบการเตรียมพร้อมสำหรับการประชุมของพวกเขา หวังว่าพวกเขาจะไม่เตรียมอาวุธอะไรมาหรอกนะ"
		},
		Summary = ""
	},
	[8200] = {
		Title = "คำขอเอกสารของ Ryosen",
		Description = {
			"ฉันได้ขออะไรบางอย่างจากสำนักงาน Arunafeltz ไปแต่ยังไม่ได้อะไรกลับมาเลย คุณช่วยไปเอามันมาจาก Hansenne ได้ไหม? ฉันจำเป็นต้องใช้มันในการประชุมแต่เขาไม่เคยส่งมาให้ฉันเลย เขาต้องลืมมันไปแล้วอีกแน่ๆ!"
		},
		Summary = ""
	},
	[8201] = {
		Title = "เอกสารที่หายไป",
		Description = {
			"ฉันทำมันหาย ฉันคิดว่าฉันอาจจะทำมันตกลงไปในแม่น้ำหรืออะไรสักอย่างตอนที่เล่นล่าสมบัติบนสะพาน! แต่อย่างว่าแหละ พวกแมวน้อยทางตะวันตกเฉียงใต้นั่นสอนเราตกปลาได้นะ รู้ไหม บางทีเราอาจจะตกเอกสารนั่นขึ้นมาจากแม่น้ำได้ก็ได้!"
		},
		Summary = "กลับไปหา Hansenne พร้อมกับเอกสารที่คุณตกขึ้นมาได้"
	},
	[8202] = {
		Title = "การฟื้นฟูเอกสาร",
		Description = {
			"ชาว Schwaltzvalt มีพรสวรรค์บางอย่างในการฟื้นฟูของแบบนี้... ทำไมไม่ลองไปขอให้ Hue ฟื้นฟูสิ่งนี้ดูล่ะ? เขาคงจะกรีดร้องดังลั่นจนหน้าต่างอาจจะแตกได้เลยล่ะ"
		},
		Summary = ""
	},
	[8203] = {
		Title = "การฟื้นฟูเอกสาร",
		Description = {
			"มันเปียกโชกไปหมดเลย.. ฉันควรจะทำให้มันแห้งก่อนแล้วค่อยรีดรอยยับพวกนี้ จากนั้นฉันต้องฟื้นฟูข้อความ ฉันต้องการวัตถุดิบบางอย่าง คุณต้องช่วยฉันเรื่องนี้ ฉันต้องการ ^0000ff1 Folding Fan of Cat Ghost, 1 Old Frying Pan, 1 Flame Stone, 1 Squid Ink^000000"
		},
		Summary = "นำ Folding Fan of Cat Ghost 1 อัน, Old Frying Pan 1 อัน, Flame Stone 1 อัน, Squid Ink 1 อันมาให้"
	},
	[8204] = {
		Title = "Ryosen",
		Description = {
