		Summary = "ส่งข้อความของ Calla ให้ Klitzer"
	},
	[8081] = {
		Title = "Klitzer และ Calla",
		Description = {
			"ตอนนี้ผมรู้สึกดีขึ้นมากเลย โอ้! เมื่อคุณพอมีเวลา ทำไมไม่ลองไปคุยกับแม่ของผมดูล่ะ? ท่านชอบพบปะเพื่อนๆ ของผมเสมอเลย"
		},
		Summary = "พบกับแม่ของ Klitzer"
	},
	[8082] = {
		Title = "Klitzer และ Calla",
		Description = {
			"ฉันทนไม่ได้ที่เห็นความเกลียดชังไร้สาระระหว่างสองเมืองของเรามาขัดขวางไม่ให้ลูกชายได้พบกับผู้หญิงที่เขารัก... จงตามหาใครสักคนที่อาจจะรู้ประวัติศาสตร์ของ Einbroch และ Einbech"
		},
		Summary = ""
	},
	[8083] = {
		Title = "Klitzer และ Calla",
		Description = {
			"ทำไมคุณไม่ลองนำ ^990000Coals^000000 มาให้ฉันล่ะ? มันไม่ใช่เรื่องที่เป็นไปไม่ได้สำหรับคนอย่างคุณหรอก แต่งานประเภทนี้คงต้องใช้ความพยายามในส่วนของคุณอยู่บ้างนะ"
		},
		Summary = "นำ Coals ไปให้ Satra"
	},
	[8084] = {
		Title = "Klitzer และ Calla",
		Description = {
			"เอาล่ะ ฉันจะลองหาทางใช้ประโยชน์จากสิ่งเหล่านี้ดู ฉันเกรงว่าของขวัญที่ฉันขอจากคุณมันจะไม่ค่อยมีประโยชน์เท่าไหร่ ปกติถ่านหินเขาเอาไว้ใช้ทำอะไรกันนะ? อา ฉันมีความคิดใหม่แล้ว! ดูเหมือนว่าการนำถ่านหินมาให้จะทำให้ Satra ยอมเปิดปากพูด"
		},
		Summary = "นำ Coals มาให้ Satra เพิ่มเติม"
	},
	[8085] = {
		Title = "Klitzer และ Calla",
		Description = {
			"อย่างไรก็ตาม เมื่อคุณพบ Klitzer ครั้งต่อไป ช่วยบอกเขาให้มาหาฉันเร็วๆ นี้ด้วยล่ะ อ้อ และเตือนเขาให้แต่งตัวให้เหมาะสมสำหรับโอกาสพิเศษนี้ด้วยนะ โฮ่ โฮ่ โฮ่ โฮ่ โฮ่~!"
		},
		Summary = "ส่งข้อความให้ Klitzer"
	},
	[8086] = {
		Title = "Klitzer และ Calla",
		Description = {
			"เอ๊ะ...? เมื่อกี้คุณว่าไงนะ? คุณเพิ่งบอกว่าแม่ของ Calla อยากให้ผมไปร่วมโต๊ะน้ำชากับท่านงั้นเหรอ? พุทธโธ่ธัมโม...!!"
		},
		Summary = ""
