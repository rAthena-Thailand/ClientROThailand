		Summary = "รีเซ็ตหลังจาก 3 นาที"
	},
	[3042] = {
		Title = "ตุ๊กตา Baphomet ที่ถูกสาป",
		Description = {
			"หลวงพ่อ Patrick แนะนำให้ไปพบ Rust Blackhand ซึ่งอยู่ใกล้กับอาคารหลักของอาราม เขาบอกว่า Rust Blackhand สามารถทำให้ตุ๊กตา Baphomet ที่ถูกสาปมีประโยชน์อย่างมากได้"
		},
		Summary = ""
	},
	[3043] = {
		Title = "Gigantic Majestic Goat",
		Description = {
			"Rust Blackhand บอกว่าเขาสามารถสร้าง Gigantic Majestic Goat ที่มีพลังของ Baphomet ได้ หากคุณนำวัตถุดิบทั้งหมดที่เขาต้องการมาให้"
		},
		Summary = "Cursed Baphomet Doll, Majestic Goat, 30 Crystal of Darkness, 50 Fragment of Darkness และเงิน 990,000 Zeny"
	},
	[3044] = {
		Title = "Gigantic Majestic Goat",
		Description = {
			"Rust Blackhand บอกว่าเขาสามารถสร้าง Gigantic Majestic Goat ที่มีพลังของ Baphomet ได้ หากคุณนำวัตถุดิบทั้งหมดมาให้: Cursed Baphomet Doll, Majestic Goat, 30 Crystal of Darkness, 50 Fragment of Darkness และเงิน 990,000 Zeny"
