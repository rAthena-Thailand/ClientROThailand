	[7421] = {
		Title = "แค่นั้นก็พอแล้ว",
		IconName = "ico_ep.bmp",
		Description = {
			"ในขณะที่ทำงานต่างๆ เด็กรับใช้ของ <NAVI>[Kardui]<INFO>ecl_in03,41,90,0,101,0</INFO></NAVI> ก็มาถึงฉัน ฉันต้องไปพบ Kardui สำนักงานของเขาจะอยู่ที่ชั้นบนสุดเมื่อเดินตามถนนที่คดเคี้ยวขึ้นไป"
		},
		Summary = "คุยกับ Kardui"
	},
	[7422] = {
		Title = "ของขวัญของ Kardui",
		IconName = "ico_ep.bmp",
		Description = {
			"Kardui บอกว่าเขาได้เตรียมของขวัญที่สามารถรับได้จาก <NAVI>[Chief of Staff Shnayim]<INFO>ecl_in03,245,93,0,101,0</INFO></NAVI> มันจะเป็นอะไรกันนะ..."
		},
		Summary = "รับของขวัญผ่าน Shnayim"
	},
	[7423] = {
		Title = "ข่าวลือเกี่ยวกับราชา 1",
		IconName = "ico_ep.bmp",
		Description = {
			"ในระหว่างการสนทนากับ Leo มีการพูดถึงเรื่องที่ไม่น่าไว้วางใจเกี่ยวกับ Kardui เขาดูเหมือนจะไม่ลงรายละเอียดมากนัก แต่มันก็น่ากังวลมาก"
		},
		Summary = ""
	},
	[7424] = {
		Title = "ข่าวลือเกี่ยวกับราชา 2",
		IconName = "ico_ep.bmp",
		Description = {
			"Fome ได้แบ่งปันบางอย่างที่คาดไม่ถึง นั่นคือพวก Lapines เริ่มรู้สึกไม่ชอบ Kardui อย่างลับๆ เรื่องนี้คล้ายกับสิ่งที่ Leo ดูเหมือนจะเก็บงำเอาไว้ก่อนหน้านี้"
		},
		Summary = ""
	},
	[7425] = {
		Title = "ข่าวลือเกี่ยวกับราชา 3",
		IconName = "ico_ep.bmp",
		Description = {
			"ความเชื่อมโยงระหว่างการใช้อำนาจเผด็จการของ Cenes และ Kardui ถูกเปิดเผยผ่านการพูดคุยกับพวก Lapines มันไม่ได้รุนแรงเกินไปนัก แต่มันแน่นอนว่าราชา Kardui องค์ปัจจุบันกำลังถูกพิจารณาในลักษณะที่คล้ายกับว่า Cenes เป็น"
		},
		Summary = ""
	},
	[7426] = {
		Title = "ข่าวลือเกี่ยวกับราชา 4",
		IconName = "ico_ep.bmp",
		Description = {
			"เมื่อไม่นานมานี้ ดูเหมือน Kardui จะกลายเป็น Mayor Jun ท่ามกลางหายนะที่เผชิญหน้ากับเผ่าพันธุ์ Lapine ทั้งหมด พวกเขาดูเหมือนจะไม่คัดค้านนโยบายของเขาอย่างสิ้นเชิง แต่ก็ดูเหมือนจะไม่ได้เห็นด้วยไปเสียหมด"
		},
		Summary = ""
	},
	[7427] = {
		Title = "ในเวลาแบบนี้ เผชิญหน้ากับมันตรงๆ เลย!",
		IconName = "ico_ep.bmp",
		Description = {
			"ความจริงเบื้องหลังความวิตกกังวลและความกลัวของเหล่า Lapine ที่มีต่อ <NAVI>[Kardui]<INFO>ecl_in03,41,90,0,101,0</INFO></NAVI> ไม่สามารถอธิบายได้อีกต่อไป อย่างน้อยเรื่องนี้ควรจะถูกสื่อสารไปยังบุคคลที่เกี่ยวข้องไม่ใช่หรือ? มันอาจจะเป็นไปได้ที่จะได้รับฟังถึงเหตุผลเบื้องหลังทั้งหมดนั้น.."
		},
		Summary = "คุยกับ Kardui"
	},
	[7428] = {
		Title = "Yai แห่งดินแดนรกร้าง",
		IconName = "ico_dq.bmp",
		Description = {
			"จัดหาไอเทมสำหรับ Yai ให้แก่ <NAVI>[Eclage Guard Minuel]<INFO>ecl_in01,82,70,0,101,0</INFO></NAVI> ผู้ที่ยืนประจำการอยู่ทั้งวันทั้งคืน"
