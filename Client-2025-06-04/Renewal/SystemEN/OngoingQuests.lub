	[7437] = {
		Title = "คำร้องขอของ Shnayim",
		IconName = "ico_ep.bmp",
		Description = {
			"อย่าว่าแต่ข้อมูลเกี่ยวกับ Avant เลย ฉันกลับได้รับคำร้องขอที่แปลกประหลาดจาก <NAVI>[Shnayim]<INFO>ecl_in03,245,93,0,101,0</INFO></NAVI> เขาขอให้รวบรวมวัตถุดิบการทดลองสำหรับนักปราชญ์แห่งเวทมนตร์ที่เขาสนับสนุน สิ่งเหล่านั้นคือ Dust Balls 10 อัน และ Leaf Bookmarks 10 อัน"
		},
		Summary = "Dust Balls 10 อัน, Leaf Bookmarks 10 อัน"
	},
	[7438] = {
		Title = "การสนับสนุนที่เป็นความลับ",
		IconName = "ico_ep.bmp",
		Description = {
			"<NAVI>[Shnayim]<INFO>ecl_in03,245,93,0,101,0</INFO></NAVI> ไม่แบ่งปันแม้เพียงนิดเกี่ยวกับนักปราชญ์แห่งเวทมนตร์ที่เขาสนับสนุน และบอกให้ลืมเรื่องที่จะหาคำตอบเกี่ยวกับเรื่องนี้ไปได้เลย ลองถามทหารยาม <NAVI>[Minuel]<INFO>ecl_in01,82,70,0,101,0</INFO></NAVI> และ <NAVI>[Hisie]<INFO>ecl_tdun04,32,35,0,101,0</INFO></NAVI> ดู"
		},
		Summary = "คุยกับ Minuel และ Hisie"
	},
	[7439] = {
		Title = "นักปราชญ์แห่งเวทมนตร์ที่สนับสนุนโดย Shnayim",
		IconName = "ico_ep.bmp",
		Description = {
			"Hisie บอกว่าถ้าคุณตามรอย Shnayim ไป ตำแหน่งของนักปราชญ์คนนั้นก็อาจจะถูกระบุได้เช่นกัน ค้นหาหน้าที่ความรับผิดชอบของ Shnayim ฉันควรจะถามทหารยาม <NAVI>[Minuel]<INFO>ecl_in01,82,70,0,101,0</INFO></NAVI> ดีไหม?"
		},
		Summary = "คุยกับ Minuel"
	},
	[7440] = {
		Title = "พยานหลักฐานของ Minuel",
		IconName = "ico_ep.bmp",
		Description = {
			"ทหารยาม Eclage ชื่อ Minuel บอกว่า Shnayim มักจะเดินทางไปทางทิศตะวันออก ซึ่งเป็นทิศตรงกันข้ามกับ Yai ของเขา ไปหารือกับ <NAVI>[Hisie]<INFO>ecl_tdun04,32,35,0,101,0</INFO></NAVI> กัน"
		},
		Summary = "คุยกับ Hisie"
	},
	[7441] = {
		Title = "ของมาส่งแล้ว!",
		IconName = "ico_ep.bmp",
		Description = {
			"ฉันตัดสินใจไปเยี่ยมเยียน <NAVI>[Yai]<INFO>eclage,304,234,0,101,0</INFO></NAVI> ของจอมเวทเพื่อนำ Dustballs 10 อัน และ Leaf Bookmarks 10 อัน ซึ่งเป็นวัตถุดิบวิจัยไปให้ Hisie จะยืนยันว่าคนๆ นั้นคือ Avant หรือไม่ Hisie จะให้ข้อมูลที่ทางแยกหน้าเมือง Eclage"
		},
		Summary = "Dustballs 10 อัน, Leaf Bookmarks 10 อัน"
	},
	[7442] = {
		Title = "ตัวตนที่แท้จริงของจอมเวท",
		IconName = "ico_ep.bmp",
		Description = {
			"นักปราชญ์แห่งเวทมนตร์ที่พบผ่านแผนการนี้คือ Avant จริงๆ ด้วย ฉันต้องบอกเรื่องนี้กับ <NAVI>[Kardui]<INFO>ecl_in03,41,90,0,101,0</INFO></NAVI>"
		},
		Summary = "คุยกับ Kardui"
	},
	[7443] = {
		Title = "ขัดขวางการวิจัย!",
		IconName = "ico_ep.bmp",
		Description = {
			"Kardui และ Hisie ต้องการรู้ว่า Avant กำลังวิจัยอะไรอยู่ และต้องการจะขัดขวางมัน นี่อาจจะเป็นการแก้แค้นเล็กๆ น้อยๆ ของพี่น้องหรือเปล่า? มาหา <NAVI>[Yai]<INFO>eclage,304,234,0,101,0</INFO></NAVI> ของ Avant และทำลายการวิจัยกันเถอะ!"
		},
		Summary = "ขัดขวางการวิจัยของ Avant"
	},
	[7444] = {
		Title = "สิ่งที่ Avant กำลังวิจัย",
		IconName = "ico_ep.bmp",
		Description = {
			"Avant กำลังวิจัยเกี่ยวกับวิธีการดึงพลังเวทมนตร์ของ Orb ออกมา เนื่องจากนี่เป็นข้อมูลที่อันตราย วัตถุดิบวิจัยควรถูกนำกลับไปให้ <NAVI>[Kardui]<INFO>ecl_in03,41,90,0,101,0</INFO></NAVI> ทันที"
		},
		Summary = "นำวัตถุดิบวิจัยไปส่งให้ Kardui"
	},
	[7445] = {
		Title = "เบื้องหลังของ Avant",
		IconName = "ico_ep.bmp",
		Description = {
			"ฉันตัดสินใจสืบสวนว่าใครอยู่เบื้องหลัง Avant ที่ทำการศึกษาเรื่อง Orb ปัจจุบันผู้ต้องสงสัยอันดับหนึ่งคือเสนาธิการ (Chief of Staff) ผู้ที่สนับสนุน Avant เราจำเป็นต้องเข้าหา <NAVI>[Chief of Staff]<INFO>ecl_in03,245,93,0,101,0</INFO></NAVI> เพื่อเปิดเผยความจริง"
		},
		Summary = "คุยกับเสนาธิการ (Chief of Staff)"
	},
	[7446] = {
		Title = "บทสนทนาที่ไร้ผล",
		IconName = "ico_ep.bmp",
		Description = {
			"ฉันพยายามคุยกับ <NAVI>[Chief of Staff]<INFO>ecl_in03,245,93,0,101,0</INFO></NAVI> แต่ไม่มีผลลัพธ์ที่พิเศษอะไร เขาบอกว่าเขาดูเหมือนจะถูกหลอกโดยคำเยินยอของ Avant ในทางตรงกันข้าม หัวหน้าฝ่ายโลจิสติกส์กลับแสดงความไม่พอใจอย่างรุนแรงที่ <NAVI>[Kardui]<INFO>ecl_in03,41,90,0,101,0</INFO></NAVI> เพิ่มการป้องกันของ Orb ให้แน่นหนาขึ้น"
		},
		Summary = "รายงานต่อ Kardui"
	},
	[7447] = {
		Title = "ความขัดแย้งเรื่อง Orb",
		IconName = "ico_ep.bmp",
		Description = {
			"ฉันทำได้เพียงยืนยันความไม่ไว้วางใจที่มีต่อ <NAVI>[Kardui]<INFO>ecl_in03,41,90,0,101,0</INFO></NAVI> มากกว่าเรื่องการวิจัยของ Avant เสนาธิการหวังว่าการตัดสินใจของ Kardui จะไม่ขุ่นมัว และขอให้เขาแสดงหลักฐานพิสูจน์เรื่องนั้น"
		},
		Summary = "รายงานต่อ Kardui"
	},
	[7448] = {
		Title = "บางอย่างไม่ถูกต้อง",
		IconName = "ico_ep.bmp",
		Description = {
			"หลังจากหารือกับ Kardui และ Hisie ก็ได้ข้อสรุปว่า <NAVI>[Chief of Staff]<INFO>ecl_in03,245,93,0,101,0</INFO></NAVI> คือผู้ที่น่าสงสัยที่สุดจริงๆ อะไรคือเหตุผลเบื้องหลังการต่อต้านของเขาต่อการกระทำของ Kardui ที่มีต่อ Orb กันแน่?"
		},
		Summary = "เฝ้าติดตามเสนาธิการ (Chief of Staff)"
	},
	[7449] = {
		Title = "สิ่งล่อใจที่มีต่อ Orb",
		IconName = "ico_ep.bmp",
		Description = {
			"เสนาธิการแนะนำให้ไปที่นั่นในขณะที่พูดถึงห้องส่องสว่างของ Orb (Orb's lighting room) ก่อนอื่น ฉันตัดสินใจขอเวลา <NAVI>[Kardui]<INFO>ecl_in03,41,90,0,101,0</INFO></NAVI> เพื่อคิดทบทวนดู"
		},
		Summary = "รายงานต่อ Kardui"
	},
	[7450] = {
		Title = "ห้องส่องสว่างของ Orb",
		IconName = "ico_ep.bmp",
		Description = {
