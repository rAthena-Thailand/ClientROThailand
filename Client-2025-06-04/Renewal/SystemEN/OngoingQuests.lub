	[11134] = {
		Title = "ปฏิบัติการกวาดล้างปีศาจเลือด",
		Description = {
			"ไปล่า ^0000FF'button man of devil'^000000 ที่เดินเตร่อยู่รอบๆ หมู่บ้าน"
		},
		Summary = ""
	},
	[11135] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"คุณช่วยไปที่ ^0000FFProntera^000000 และรวบรวม \"^0000FFข้อมูลเกี่ยวกับ Maestro Song^000000\" ได้ไหม? ฉันมีบางอย่างต้องตรวจสอบใน Alberta"
		},
		Summary = ""
	},
	[11136] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"สอบถาม ^f57d7dชายที่สวมแว่นตาใกล้กับประตูทางเข้าปราสาท^000000 เกี่ยวกับบทเพลง"
		},
		Summary = "รับข้อมูลบางอย่างจากบุคคลที่อยู่ใกล้ประตูทางเข้าปราสาท"
	},
	[11137] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"ดูเหมือนว่าควรถาม ^f57d7dผู้หญิงที่ยืนอยู่หน้าร้านขายเครื่องมือ^000000 จะดีกว่า"
		},
		Summary = "การสนทนา"
	},
	[11138] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"ผู้หญิงคนนั้นบอกว่าเธอเชื่อว่า Maestro Song คือลูกชายที่หายสาบสูญไปนานของเธอ กลับไปหา Bard ใน Alberta และบอกเขาเกี่ยวกับสิ่งที่คุณค้นพบใน Prontera"
		},
		Summary = ""
	},
	[11139] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"Karian ได้ยินมาว่า Maestro Song อาจจะขึ้นเรือไปที่ Izlude แต่เรือลำนั้นไปแล้ว ไปพบเขาที่เรือเหาะที่เดินทางไปยัง Hugel"
		},
		Summary = ""
	},
	[11140] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"นี่เป็นครั้งแรกของ Karian บนเรือเหาะและเขากำลังเมาเครื่องบิน คุยกับเขาใน Hugel"
		},
		Summary = ""
	},
	[11141] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"ในขณะที่ Karian กำลังพักผ่อนจากอาการป่วย เขาบอกให้คุณไปที่ผับเพื่อดูว่ามีใครที่นั่นรู้ที่อยู่ของ Maestro Song หรือไม่"
		},
		Summary = ""
	},
	[11142] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"คุณได้ยินเพลงที่ฟังแล้วทรมานหูจากคนหูตึง แต่คุณก็ได้ข้อมูลเพิ่มเติมเกี่ยวกับ Maestro Song กลับไปหา Karian ที่โรงแรม Hugel และรายงานเขา"
		},
		Summary = ""
	},
	[11143] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"ฉันไม่รู้ว่าทำไม ^0000FFMaestro Song'^000000 ถึงไปที่ ^0000FFThanatos Tower^000000"
		},
		Summary = "ไปที่ Thanatos Tower"
	},
	[11144] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"คุณพบใบเสร็จใน Thanatos Tower นำใบเสร็จไปแลกเปลี่ยนกับผู้จัดการร้านใน Yuno : Click"
		},
		Summary = "ตามหาคุณ Click ใน Yuno"
	},
	[11145] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"มีแผนที่ระหว่าง Einbroch และ Lighthalzen ที่มีพวก Teddy Bear อยู่ ล่าพวกมัน 33 ตัวแล้วไปพบ Karian ที่โรงแรม Lighthalzen"
		},
		Summary = ""
	},
	[11146] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"Rion บอกคุณว่าเธอเห็น Maestro Song ไปที่ถ้ำน้ำแข็ง (Ice Cave) ที่ซึ่งแม่ของเธอทำงานอยู่"
		},
		Summary = "ไปที่ถ้ำน้ำแข็งเพื่อตามหาร่องรอยของ Maestro Song"
	},
	[11147] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"คุณพบเนื้อเพลงเขียนอยู่บนกำแพงในขณะที่สำรวจถ้ำน้ำแข็ง"
		},
		Summary = "คุยกับหญิงชรา"
	},
	[11148] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"ตามหาเรือในพื้นที่ทางใต้ของ Veins"
		},
		Summary = ""
	},
	[11149] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"คุณรอดชีวิตจากการเดินทางด้วยเรือมาถึง Comodo สนทนากับ Karian ต่อไป"
		},
		Summary = ""
	},
	[11150] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"ฉันควรจะถามผู้คนแถวหมู่บ้านเกี่ยวกับ Maestro Song ดีไหม?"
		},
		Summary = "สอบถามผู้คนรอบๆ เกี่ยวกับ Maestro Song"
	},
	[11151] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"Kayak Master บอกว่าพนักงานต้อนรับที่ร้านอาหารจดจำใบหน้าคนเก่งมาก..."
		},
		Summary = "ไปที่ร้านอาหาร"
	},
	[11152] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"เขาเคยอยู่ที่นี่ใน Comodo แต่แล้วเขาก็ปลีกตัวไปยังสถานที่เงียบสงบใกล้กับ Morroc ที่ซึ่งสมาคมลับรวมตัวกัน ผู้หญิงคนนั้นบอกว่าชื่อมันฟังดูคล้ายๆ ash หรือ assa..."
		},
		Summary = "ตามหาอาคารทางตะวันออกเฉียงใต้ของ Morroc"
	},
	[11153] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"นี่ดูเหมือนจะเป็นสไตล์การเขียนแบบเดียวกับที่ฉันพบในใบเสร็จ จู่ๆ Karian ก็บอกว่าพวกเราควรไปที่หอนาฬิกา (Clock Tower) ใน Aldebaran"
		},
		Summary = "ไปที่ทางเข้าหอนาฬิกาใน Aldebaran"
	},
	[11154] = {
		Title = "ตามหา Maestro Song",
		Description = {
			"คุณฟัง Karian รำลึกถึงบทเพลงที่เพื่อนของเขาเคยร้องกับเขาที่หน้าหอนาฬิกา"
		},
		Summary = "กลับไปที่ประตูด้านใต้ของ Prontera"
	},
	[11155] = {
		Title = "เปลี่ยนอาชีพเป็น Sura",
		Description = {
			"คุณเพิ่งได้เห็นผู้หญิงคนหนึ่งแสดงพลังที่น่าทึ่ง ไปที่โรงเตี๊ยมและหาข้อมูลเกี่ยวกับเธอเพิ่มเติม"
		},
		Summary = ""
	},
	[11156] = {
		Title = "เปลี่ยนอาชีพเป็น Sura",
		Description = {
			"พิสูจน์ว่าคุณมีสิ่งจำเป็นในการเป็น Sura และล่า Desert Wolf 100 ตัว"
		},
		Summary = ""
	},
	[11157] = {
		Title = "เปลี่ยนอาชีพเป็น Sura",
		Description = {
			"ไปที่ El Mes Gorge ทางตะวันออกเฉียงใต้ของ Yuno และตามหา \"Buddy\" ซึ่งน่าจะอยู่แถวๆ ใจกลาง บอกเขาว่า \"Bruno\" เป็นคนส่งคุณมา"
		},
		Summary = ""
	},
	[11158] = {
		Title = "เปลี่ยนอาชีพเป็น Sura",
		Description = {
			"อาจารย์กำลังนั่งสมาธิอยู่ ดังนั้นคุณต้องรอในห้องรับแขก"
		},
		Summary = "รออาจารย์และเอาชีวิตรอดให้ได้"
	},
	[11159] = {
		Title = "เรื่องราวของ Brian",
		Description = {
			"อา... ผ่านมาได้กี่วันแล้วนะตั้งแต่ฉันมาที่นี่...? คุณพอจะรู้ไหมว่าวันนี้เป็นวันอะไร?"
		},
		Summary = "ฟังเรื่องราวของ Brian"
	},
	[11160] = {
		Title = "เรื่องราวของ John",
		Description = {
			"เอ่อ..... ไม่มีอะไร... ผิดปกติ.... ไม่ต้องห่วง...."
		},
		Summary = "สนทนากับ John ต่อไป"
	},
	[11161] = {
		Title = "เรื่องราวของ Tyler",
		Description = {
			"ถ้าคุณไม่ยุ่ง ช่วยเกาหลังให้ฉันหน่อยได้ไหม? มันคันมากจนฉันรู้สึกเหมือนโดนแมลงกัด ฉันสงสัยว่าจะมีแมลงตัวใหญ่พอที่จะกัดหลังฉันได้ด้วยเหรอ"
		},
		Summary = "สนทนากับ Tyler ต่อไป"
	},
	[11162] = {
		Title = "เรื่องราวของ Rose",
		Description = {
			"บอกเขาว่าไม่มีปัญหาอะไรเลย นอกจากว่าฉันทำงานเก่งเกินไปหน่อย"
		},
		Summary = "สนทนากับ Rose ต่อไป"
	},
	[11163] = {
		Title = "เรื่องราวของ Bain",
		Description = {
			"Frede ขอให้คุณมาเหรอ? แค่บอกเขาว่าฉันสบายดี ง่ายๆ แค่นั้นแหละ จริงไหม?"
		},
		Summary = "สนทนากับ Bain ต่อไป"
	},
	[11164] = {
		Title = "เรื่องราวของ Lash",
		Description = {
			"เอาล่ะ ถ้าคุณอยากรู้สถานการณ์ปัจจุบันของฉัน คุณไม่สังเกตเหรอว่าฉันสุขภาพแข็งแรงดี แขนของฉันดูแข็งแกร่งเหมือนหินเลยนะ? แค่บอกพวกเขาตามที่คุณเห็นนั่นแหละ! ฮ่าๆๆๆๆๆๆๆๆ!"
