	[18121] = {
		Title = "กล่องผู้พิทักษ์และคำเชื้อเชิญ 1",
		IconName = "ico_ep.bmp",
		Description = {
			"Lehar บอกว่าคุณต้องได้รับอนุญาตให้เข้าพบจากเหล่าผู้พิทักษ์แห่ง Issgard ผ่านทางกล่องผู้พิทักษ์ ที่พระราชวัง Prontera ฉันตัดสินใจใช้กล่องผู้พิทักษ์ที่เก็บไว้ในห้องของ <NAVI>[Nyhill]<INFO>prt_cas,331,343,0,101,0</INFO></NAVI> เพื่อรับคำเชื้อเชิญ"
		},
		Summary = "คุยกับ Nyhill ในห้องของเขา"
