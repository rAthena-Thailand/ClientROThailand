		Summary = "คุยกับ Peter"
	},
	[21927] = {
		Title = "เรืออับปางที่น่าสงสัย",
		Description = {
			"Peter บอกว่า 'Bran' เช่าเรือและมุ่งหน้าไปยังซากเรืออับปาง ลองสำรวจพื้นที่ใกล้ซากเรือก่อนจะเข้าไปข้างในเรือ"
