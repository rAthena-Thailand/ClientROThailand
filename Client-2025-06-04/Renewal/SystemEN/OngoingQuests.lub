	[8207] = {
		Title = "Hansenne ไม่ได้มีความผิด",
		Description = {
			"ทั้งหมดที่ฉันต้องการคืออยากให้คนพวกนั้นใกล้ชิดกันมากขึ้น เป็นมิตรกันมากขึ้น.. แต่ปัญหาก็เกิดขึ้นทุกครั้งเลย คุณพอจะมีไอเดียไหมว่าจะทำให้คนพวกนั้นเข้ากันได้อย่างไร?"
		},
		Summary = ""
	},
	[8208] = {
		Title = "ความช่วยเหลือของ Hansenne",
		Description = {
			"เดี๋ยวเขาก็ดีขึ้นเองแหละ เดี๋ยวเขาก็จะเริ่มคิดได้ว่าจริงๆ แล้วมันไม่ใช่เรื่องใหญ่อะไร แต่ประเด็นก็คือ... ความสัมพันธ์ระหว่าง Ryosen และ Hue ดูไม่ค่อยดีเอาเสียเลย ทำไมคุณไม่ลองช่วยพวกเขาให้เข้ากันได้ดูล่ะ?"
