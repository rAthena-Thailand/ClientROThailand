		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"Jekan จะต้องใช้ไอเทมบางอย่างเพื่อทำสำเนาบันทึก: Slick Paper 2 ใบ และ Oil Paper 1 ใบจาก Amatsu, Feather of Birds 3 อันจาก Morroc, และ Blue Gem 20 เม็ดจาก Geffen"
		},
		Summary = "นำไอเทมเหล่านี้มาให้ Jekan เพื่อให้เขาทำสำเนาให้เสร็จเร็วขึ้น"
	},
	[60726] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"สำเนาบันทึกของคุณมีเวทมนตร์การค้นหาที่แปลกประหลาดอยู่ ในการหาข้อมูลเฉพาะเจาะจง คุณต้องเริ่มจากหัวข้อกว้างๆ ก่อนแล้วค่อยเจาะจงลงไป: crusader 3rd_company 3rd_platoon 1st_squad"
		},
		Summary = "ค้นหาชื่อสมาชิกแต่ละคนเพื่อดูว่าปัจจุบันพวกเขาอยู่ที่ไหน"
	},
	[60727] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"ตามหา Zan Huadoku ภายใน Geffen Blacksmith guild รักษาความสุภาพเมื่อถามสารทุกข์สุกดิบเขาก่อนที่จะเริ่มถามเรื่องภารกิจสุดท้ายที่เป็นความลับสุดยอด ใช่แล้ว นั่นแหละวิธีที่ถูกต้อง!"
		},
		Summary = ""
	},
	[60728] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"Zan Huadoku ได้บอกทุกอย่างที่เขาพอจะบอกได้แล้ว คุณควรไปที่ Morroc เพื่อตามหา \"Cuaque Donon\" ซึ่งเห็นครั้งสุดท้ายที่ Inn ฉันรู้สึกว่าคุณอาจจะต้องใช้ความตื้อหน่อยนะใน Morroc"
		},
		Summary = ""
	},
	[60729] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"Cuaque Donon อยู่ในที่ซ่อนของ Rogue Guild น่าจะอยู่ที่ \"Fortress Saint Darmain (South)\" (ใช้แผนที่ ctrl + ~) รหัสผ่านเพื่อเข้าคือ \"Aragham never hoarded upgrade items\""
		},
		Summary = "Cuaque กำลังทุกข์ทรมานจาก PTSD ขั้นรุนแรงและมักจะ \"สติแตก\" ดังนั้นการแกล้งทำเหมือนเขาเป็นเด็กน้อยน่าจะช่วยได้ อาจจะรวมถึงตุ๊กตาด้วย ฮ่าๆๆ"
	},
	[60730] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"Cuaque บอกว่าหน่วยได้พบ \"Megingjard\" และเกิดการโต้เถียงกันขึ้น... คุณจำเป็นต้องรู้เรื่องการโต้เถียงนั้นให้มากกว่านี้ บางที Jack.O ใน Alberta ตรงท่าเรืออาจช่วยได้"
		},
		Summary = "เขายังคงเป็น Crusader ที่ปฏิบัติงานอยู่ ดังนั้นฉันคิดว่าการคุยกับเขาน่าจะตรงไปตรงมามากกว่า"
	},
	[60731] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"Jack.O รู้สึกผ่อนคลายขึ้นได้ด้วย \"Green Herb\" บางทีฉันควรส่งต่อคำแนะนำนี้ให้กับ Crusader คนอื่นๆ ที่ฉันพบ Emma Searth อยู่ใน Aldebaran นั่งเรือเร็วไป Izlude และใช้ Kafra วาร์ปไป Aldebaran แป๊บเดียวก็ถึง!"
		},
		Summary = "บางทีฉันควรพิจารณาหาของช่วยจำให้เหล่า Crusader เหล่านี้ด้วยนะ สิ่งที่จะช่วยให้พวกเขาจำหน้าที่ของตนเองได้เหมือนกับ \"Bookclip\" จาก \"Rideword\""
	},
	[60732] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"ฉันคิดว่าฉันต้องรีบไปหา \"The Nineball\" เขาทำงานเป็นคนคุมประตู (bouncer) ใน Jawaii inn ฉันได้ยินมาว่ามีอดีตบาร์เทนเดอร์ของ Jawaii ทำงานอยู่ในผับใจกลาง Prontera บางทีเขาอาจจะรู้วิธีไป Jawaii โดยไม่ต้องแต่งงาน!"
		},
		Summary = "คนชื่อ Nineball แถมเป็นคนคุมประตูน่าจะเป็นพวกปากหนัก ฉันควรชวนคุยไปเรื่อยๆ จนกว่าเขาจะมีปฏิกิริยาต่อคำถามของฉันบ้าง.."
	},
	[60733] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"ออกจาก Jawaii ด้วย Butterflywing หรือดื่มจนเมามายกลับมาที่ Rune-Midgarts ไปที่ Comodo เพื่อพบกับ \"Royal Myst\" ที่คาสิโนทางใต้ เส้นทาง Morroc ไป Comodo มักจะเป็นวิธีวาร์ปไป Comodo ที่ง่ายที่สุด"
		},
		Summary = "เหล้า \"Alcohol\" สัก \"สองสาม\" แก้ว น่าจะช่วยง้างปากของ Royal Myst ได้.."
	},
	[60734] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"คุณได้คุยกับ Crusader ทุกคนที่ยังมีชีวิตอยู่แล้ว ดูเหมือนว่าจะมีบางอย่างเกิดขึ้น มีการโยนความผิดกัน และ Crusader Egnigem ก็เสียชีวิตในกระบวนการนั้น คุณควรกลับไปที่ปราสาท Prontera และแจ้งข้อมูลที่คุณพบ"
		},
		Summary = "การใช้บริการ Kafra จาก Comodo ไป Morroc แล้วไป Prontera นั้นรวดเร็ว เว้นแต่คุณจะเซฟจุดเกิดไว้ที่ Prontera อยู่แล้ว"
	},
	[60735] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"คุณควรคุยกับสมาชิกคนสุดท้ายของหน่วยที่ 1 นั่นคือ Egnigem ผู้ล่วงลับ การเดินทางด้วย Kafra จาก Prontera ไป Morroc ไป Comodo แล้วไป Umbala จากนั้นเดินทางขึ้นเหนือไปยัง Tree of Life เพื่อไป Niflheim จะนำคุณไปพบเขาได้"
		},
		Summary = "รับฟัง Egnigem และดูว่าคุณพอจะทำอะไรได้บ้างเพื่อแก้ไขเรื่องนี้"
	},
	[60736] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"ด้วยความเมตตาของโอดิน นี่มันช่างเลวร้ายจริงๆ คุณไม่เคยเชื่อเลยว่า Crusader ผู้ศักดิ์สิทธิ์จะทำเรื่องชั่วร้ายเช่นนี้เพื่อแย่งชิงพลังของ Megingjard จงกล้าหาญและกลับไปที่สำนักงานใหญ่ Crusader แล้วบอกสิ่งที่เขารู้แก่ Max Von Shedough"
		},
		Summary = ""
	},
	[60737] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"Max Von Shedough ยอมรับรายงานของฉันแล้ว และเขารู้สึกกังวลใจอย่างมากกับเนื้อหาในนั้น แต่ลึกๆ ในใจฉันเชื่อว่าแม้จะมีเจตนาดีเพียงใด แต่ความจริงทางการเมืองอาจเข้ามาแทรกแซงจนทำให้ความยุติธรรมไม่เกิดขึ้น"
		},
		Summary = "อย่างน้อยฉันต้องบอกผลลัพธ์ให้ Egnigem ทราบ เขาควรได้รับรู้ว่าเขาตายเพื่ออะไร"
	},
	[60738] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"Egnigem ได้อวยพรคุณด้วยพละกำลังทั้งหมดที่เหลืออยู่ของเขา คุณรู้สึกว่ามีคนพิเศษคนหนึ่งที่เขาอยากให้รู้ถึงชะตากรรมของเขา คุณต้องบอก Emma Searth เกี่ยวกับสิ่งที่เกิดขึ้นกับเขา"
		},
		Summary = ""
	},
	[60739] = {
		Title = "ตราประทับแห่ง Megingjard",
		Description = {
			"Emma จำไม่ได้ แต่เธอสัมผัสได้ถึงความสูญเสีย ความศรัทธาในความยุติธรรมของคุณเริ่มสั่นคลอนแล้ว... คุณต้องไปบอก Max Von Shedough เขาคือผู้ตัดสิน และเขาควรได้รับส่วนแบ่งในภาระความรู้สึกผิดนี้"
		},
		Summary = "กลับไปหา Max Von Shedough ที่ปราสาท Prontera"
	},
	[60801] = {
		Title = "คนเลี้ยงสัตว์ WoE",
		Description = {
			"คุณต้องรอให้ตัวจับเวลาหมดลงก่อนที่จะเช่าสัตว์ขี่ตัวอื่นจาก Pet Breeder ที่อยู่ด้านนอกอาณาจักร WoE"
		},
		Summary = ""
	},
	[60810] = {
		Title = "สิทธิ์การเข้าถึง VIP แบบจำกัด",
		Description = {
			"เป็นเวลา 3 วัน สิทธิ์นี้ช่วยให้คุณใช้บริการ Kafra ในราคาส่วนลด, รับบัพจาก Primo d'Buffer, วาร์ปบริการ VIP, รับภารกิจล่าจาก Gramps ได้ 2 ภารกิจพร้อมวาร์ป เมื่อตัวจับเวลาหมดลง คุณจะไม่สามารถเข้าถึงบริการเหล่านี้ได้"
		},
		Summary = "*หมายเหตุ: โบนัส VIP EXP, ช่องตัวละครเพิ่มเติม และคลังเก็บของ 600 ช่อง ไม่รวมอยู่ในสิทธิ์การเข้าถึงนี้"
	},
