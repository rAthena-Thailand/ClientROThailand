		Summary = "สนทนากับ Tarlock ต่อไป"
	},
	[8036] = {
		Title = "ความช่วยเหลือของ Hallen",
		Description = {
			"Hallen ขอให้คุณส่งจดหมายไปให้ <NAVI>Kaci<INFO>man_fild01,0,101,0</INFO></NAVI> จากชายที่ชื่อคุณ Mawong ซึ่งเป็นเหมือนอาจารย์ของเธอ"
		},
		Summary = "ส่งจดหมายให้ Kaci"
	},
	[8037] = {
		Title = "นักทอยลูกเต๋า",
		Description = {
			"คุณได้ส่งจดหมายของ Hallen ให้กับ Kaci แล้ว คุณควรจะลองหาดูว่าเธอรู้อะไรบ้าง..."
		},
		Summary = ""
	},
	[8038] = {
		Title = "นักทอยลูกเต๋า",
		Description = {
			"ปรากฏว่า Kaci คือลูกพี่ลูกน้องของ Hallen หลังจากตอบคำถามของคุณแล้วเธอก็กลับไปดำเนินเกมของเธอต่อ ใครกันนะที่จะรู้เรื่องในอดีตของพวกเขาอีก?"
		},
		Summary = ""
	},
	[8039] = {
		Title = "ความลับของเรือเหาะ",
		Description = {
			"Hallen บอกคุณว่าโครงการของเขาคือการเรียนรู้เพิ่มเติมเกี่ยวกับวิธีการทำงานของเรือเหาะ มันอาจจะเป็นประโยชน์ต่อตัวคุณเองหากลองไปถามใครสักคนที่รอบรู้เรื่องเรือเหาะ แล้วนำสิ่งที่คุณพบมารายงานให้ Hallen ทราบ"
		},
		Summary = ""
	},
	[8040] = {
		Title = "ความลับของเรือเหาะ",
		Description = {
			"\"จริงเหรอ...? คุณจริงจังหรือเปล่า? ของเลียนแบบชิ้นส่วน Ymir's Heart งั้นเหรอ ฉันเคยได้ยินเรื่องนั้นที่ไหนมาก่อนนะ? อืม ขอฉันคิดดูก่อน...\""
		},
		Summary = "สนทนากับ Hallen ต่อไป"
	},
	[8041] = {
		Title = "ความลับของเรือเหาะ",
		Description = {
			"Kaci บอกฉันเกี่ยวกับคนขี้เมาที่ชอบพูดถึง Ymir's Heart อยู่เสมอเวลาที่เขาเล่นเกมลูกเต๋าเพื่อแลกแอปเปิล!"
		},
		Summary = ""
	},
	[8042] = {
		Title = "ความลับของเรือเหาะ",
		Description = {
			"คุณพบว่าผู้อำนวยการที่ห้องแล็บใน Einbroch มีชิ้นส่วนของ Ymir's Heart อยู่ มันคุ้มค่าที่จะลองไปสืบดูนะ..."
		},
		Summary = ""
	},
	[8043] = {
		Title = "ความลับของเรือเหาะ",
		Description = {
			"คุณควรจะออกไปจากที่นี่เสียดีกว่า พวกยามเดินตรวจตราที่นี่เป็นประจำ ดังนั้นคุณถูกจับได้แน่ๆ อืม แล้วมาหาฉันที่เรือเหาะภายหลังนะ ตกลงไหม? ตอนนี้รีบไปเร็ว!"
		},
		Summary = "คุณต้องไปพบ Ferlock"
	},
	[8044] = {
		Title = "คู่หมั้นของ Euslan",
		Description = {
			"\"...คุณเต็มใจที่จะออกไปตามหา Thierry ให้ฉันจริงๆ เหรอ? โอ้ ขอบคุณมากเลย!",
			"คุณไม่รู้หรอกว่าข้อเสนอที่แสนดีของคุณมีความหมายต่อฉันมากแค่ไหน",
			"Thierry ออกเดินทางไปกับเรือเหาะลำหนึ่ง เพื่อไปหายามารักษาอาการป่วยของฉันตามที่หมอบอกว่าฉันจำเป็นต้องใช้มัน\""
		},
		Summary = ""
	},
	[8045] = {
		Title = "คำแนะนำจาก Kaci",
		Description = {
			"\"อา ฉันรู้แล้ว! ฉันจะขอให้กัปตันเรือเหาะช่วยคุณ เขามีรายชื่อผู้โดยสารและจุดหมายปลายทางของพวกเขาอยู่\""
		},
		Summary = "ตรวจสอบรายชื่อผู้โดยสารจากกัปตัน"
	},
	[8046] = {
		Title = "รายชื่อผู้โดยสารของ Ferlock",
		Description = {
			"ตามข้อมูลนี้ ครั้งล่าสุดเขานั่งเรือเหาะไปยัง Hugel นั่นคือทั้งหมดที่ระบุไว้ที่นี่"
		},
		Summary = ""
	},
	[8047] = {
		Title = "ความช่วยเหลือของ Euslan",
		Description = {
			"\"ถ้าคุณมีโอกาส โปรดไปเยี่ยม Eukran พี่ชายของฉันใน Hugel และถามเขาว่า Thierry ของฉันอาจจะอยู่ที่ไหน\""
		},
		Summary = ""
	},
	[8048] = {
		Title = "คำให้การของ Eukran",
		Description = {
			"\"คืออย่างนี้ Thierry ผ่านมาที่นี่เมื่อประมาณเดือนก่อน และบอกฉันว่าเขาต้องไปที่วิหาร Odin ตอนนั้นฉันไม่แน่ใจ แต่ตอนนี้ฉันคิดว่าเขากำลังพยายามช่วยน้องสาวของฉันอยู่\""
		},
		Summary = ""
	},
	[8049] = {
		Title = "ความช่วยเหลือของ Thierry",
		Description = {
			"\"ฉันยังบอกรายละเอียดไม่ได้มากนัก แต่ฉันกำลังทำงานนี้เพื่อหาวิธีรักษาโรคของ Euslan มันเป็นโรคที่การแพทย์สมัยใหม่ไม่สามารถรักษาได้...\""
		},
		Summary = ""
	},
	[8050] = {
		Title = "อันตรายที่กำลังคืบคลานสู่ Thierry",
		Description = {
			"\"ดูเหมือน Thierry จะเริ่มรู้ตัวแล้วว่าจริงๆ แล้วพวกเรากำลังทำอะไรกันอยู่ ฉันคิดว่านั่นคือสาเหตุที่เขาวิจัยช้าลง เราควรจะกำจัดเขาเสียก่อนที่มันจะสายเกินไป\""
		},
		Summary = ""
	},
	[8051] = {
		Title = "ยาของ Euslan",
		Description = {
			"\"มันไม่สำคัญว่าจะเกิดอะไรขึ้นกับฉัน แต่ฉันต้องช่วย Euslan ให้ได้ ฉันต้องการ 5 Runes of the Darkness เพื่อปรุงยานั่นให้เสร็จ ได้โปรดช่วยฉันหาพวกมันทีเถอะ นักผจญภัย...\""
		},
		Summary = "รวบรวม 5 Runes of the Darkness"
	},
	[8052] = {
		Title = "ความช่วยเหลือของ Thierry",
		Description = {
			"\"โปรดเข้าใจด้วยว่าฉันอยากไปพบเธอใจจะขาด แต่ฉันต้องรอจนกว่าพวกสายลับ Rekenber จะเลิกตามล่าฉันก่อน ได้โปรดนำยานี้ไปให้ Euslan โดยเร็วที่สุดเท่าที่คุณจะทำได้ ชีวิตของเธอขึ้นอยู่กับมันแล้ว\""
		},
		Summary = "ส่งมอบยาให้ Euslan"
	},
	[8053] = {
		Title = "ตามหา Postell",
		Description = {
			"\"จงตามหา Postell ลูกชายของ Allen และบอกเขาให้นำยามาด้วย! มุ่งหน้าไปทางตะวันออก ออกไปนอกเมือง แล้วคุณก็น่าจะหา Postell พบ\""
		},
		Summary = ""
	},
	[8054] = {
		Title = "ข้อความจาก Postell",
		Description = {
			"Postell ขอให้คุณช่วยเขาหน่อย โดยให้ช่วยดูแลไม่ให้พ่อของเขาไปก่อเรื่องวุ่นวายที่ไหนอีก"
		},
		Summary = "กลับไปหา Allen"
	},
	[8055] = {
		Title = "การดูแล Allen",
		Description = {
			"\"ถะ-ถ้าเกิดฉันเป็นโรคกระเพาะกำเริบขึ้นมาอีกก่อนที่ Postell จะเอายามาให้ล่ะ?! ฉันอาจจะไม่รอดก็ได้! นะ-นักผจญภัย ได้โปรดอยู่เคียงข้างฉันจนกว่าลูกชายจะมาถึงได้ไหม?\""
		},
		Summary = "ดูแล Allen"
	},
	[8056] = {
		Title = "ของตอบแทนเล็กน้อย",
		Description = {
			"\"ลองดูข้างในลิ้นชักยาดูสิ แล้วหยิบอะไรที่คุณชอบไปได้เลย\" ~Allen"
		},
		Summary = "ดูในลิ้นชักยา"
	},
	[8057] = {
		Title = "Manainne ผู้ขี้บ่น",
		Description = {
			"คุยกับ Manainne เกี่ยวกับต้นไม้ที่แสนอบอุ่น"
		},
		Summary = ""
	},
	[8058] = {
		Title = "คุยกับ El Schatt",
		Description = {
			"\"ต้นไม้ต้นนี้มีความหมายมากสำหรับทุกคนในเมืองนี้ และพวกเราทุกคนต่างก็มีความทรงจำพิเศษที่นี่ แต่เจ้าหมอ El Schatt นั่นกลับวางแผนจะตัดมันทิ้งเพื่อทำร้านของเขา...\" -Manainne"
		},
		Summary = ""
	},
	[8059] = {
		Title = "คุยกับ Perfitz",
		Description = {
			"El Schatt บอกว่าพ่อของเขาอยากจะสร้างร้านที่นี่มานานแล้ว ลองคุยกับ Perfitz พ่อของเขาและลองฟังเรื่องราวในมุมของเขาดู"
		},
		Summary = ""
	},
	[8060] = {
		Title = "El Schatt ผู้ดื้อรั้น",
		Description = {
			"\"ถึงแม้ฉันจะยินดี แต่ฉันกลับรู้สึกสังหรณ์ใจว่ามีบางอย่างไม่ถูกต้อง เหมือนเขากระตือรือร้นเกินไปที่จะตัดต้นไม้นั่นทิ้ง บางทีคนแก่อย่างฉันอาจจะระแวงเกินไปเอง~\" -Perfitz"
		},
		Summary = ""
	},
	[8061] = {
		Title = "เรื่องราวในอดีต",
		Description = {
			"El Schatt บอกว่ามีอยู่ช่วงหนึ่งที่เขาเคยยอมปกป้องต้นไม้ต้นนี้ด้วยชีวิต แต่มันควรจะถูกฝังไว้ในอดีตได้แล้ว คุณควรหาใครสักคนที่อาจจะรู้เรื่องราวในอดีตของเขา"
		},
		Summary = ""
	},
	[8062] = {
		Title = "Kanainne",
		Description = {
			"\"ตอนนี้ El Schatt เป็นแค่คนไร้หัวใจ หน้าเงิน...! เขาเปลี่ยนไปโดยสิ้นเชิง พี่สาวของฉันคงจะนอนตายตาไม่หลับแน่ถ้าเห็นเขาในตอนนี้...\" -Manainne"
		},
		Summary = ""
	},
	[8063] = {
		Title = "วิญญาณของ Kanainne",
		Description = {
			"\"ฉัน... ฉันขอยืมร่างพี่สาวได้ไหม? ใช่ ถ้าเธอยอมร่วมมือด้วย บางที... บางทีมันอาจจะสำเร็จ ฉันต้อง... ต้องทำอะไรสักอย่างก่อนที่เขา... เขา... เขาจะทำร้ายตัวเองไปมากกว่านี้...\""
		},
		Summary = ""
	},
	[8064] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"ช่วยนำซุปลูกชิ้นปลาที่สั่งนี้ไปส่งให้ Neha เพื่อนของฉันที ฉันรู้สึกขอบคุณที่เธอเป็นลูกค้าประจำนะ.."
		},
		Summary = "นำออเดอร์ไปส่งให้ Neha"
	},
	[8065] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"นำซุปลูกชิ้นปลาออเดอร์ต่อไปนี้ไปส่งให้ Maewan ลูกค้าประจำอีกคนของฉัน"
		},
		Summary = "นำออเดอร์ไปส่งให้ Maewan"
	},
	[8066] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"ช่วยนำไปส่งให้ Layoma รูมเมทของฉันที แต่... ระวังหน่อยนะ เธอเป็นคนซีเรียสเรื่องความตรงต่อเวลามาก พยายามอย่าไปสายล่ะ..."
		},
		Summary = "นำออเดอร์ไปส่งให้ Layoma"
	},
	[8067] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"เร็วเข้า นำซุปปลาบดนี้ไปส่งให้ Erjan อ้อ แต่ระวังด้วยนะ เขาเป็นคนจู้จี้จุกจิกมาก..."
		},
		Summary = "นำออเดอร์ไปส่งให้ Erjan"
	},
	[8068] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"คุณมาช้า! ไม่รู้เหรอว่าซุปนี่จะไม่อร่อยถ้ามันไม่ร้อนจนควันขึ้นน่ะ? แต่... ฉันจะยกโทษให้ก็ได้... โดยมีเงื่อนไขเดียว จงไปนำ ^FF00001 Whip^000000 มาให้ฉันใช้ฟาดคุณซะดีๆ รีบเข้าล่ะ ไม่งั้นฉันไม่ปล่อยคุณไปง่ายๆ แน่"
		},
		Summary = "นำ 1 Whip มาให้ Neha"
	},
	[8069] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"\"อ๊ากก แต่คุณมาช้า! นี่เป็นความผิดของคุณ รู้ตัวใช่ไหม? ฉันจะยกโทษให้ก็ได้ถ้าคุณช่วยหาของสะสมให้ฉัน จงไปนำ 1 Bookclip in Memory มาให้ฉัน ตกลงไหม?\""
		},
		Summary = "นำ 1 Bookclip in Memory มาให้ Maewan"
	},
	[8070] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"\"ฉันยอมให้คุณส่งของให้ Cellette ต่อไปไม่ได้หรอก นอกจากคุณจะพิสูจน์ให้ฉันเห็นว่าคุณพึ่งพาได้ อืมม ไปนำ ^ff00001 Mushroom Spore^000000 มาให้ฉัน แล้วฉันจะลืมเรื่องทั้งหมดนี้ไปซะ\""
		},
		Summary = "นำ 1 Mushroom Spore มาให้ Layoma"
	},
	[8071] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"\"หึ ในฐานะบุตรชายคนโตของตระกูล Franchesfeschu ฉันไม่สามารถกินซุปนี่ได้นอกจากมันจะถูกจัดเตรียมอย่างเหมาะสม ไปซะ! ฉันขอสั่งให้เจ้าไปนำ ^ff0000China^000000 ของสามัญชนมาให้ข้า!\""
		},
		Summary = "นำ 1 China มาให้ Erjan"
	},
	[8072] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"\"โอ๊ะ นี่ฉันเผลอหวดคุณไปสองทีเหรอเนี่ย? เหะ เหะ... เอาล่ะ ฉันพอใจแล้ว ฉันจะไปบอก Cellette ให้ว่าคุณทำงานได้ดี... หวังว่าคุณจะมาส่งซุปให้ฉันอีกนะ~\""
		},
		Summary = "กลับไปหา Cellette"
	},
	[8073] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"\"เยี่ยมเลย คุณเอา Bookclip in Memory มาให้ฉันจริงๆ ด้วย! ใช่เลย นี่จะเป็นของสะสมที่ยอดเยี่ยมของฉันเลยล่ะ~ อ้อ แล้วก็เอาซุปมาให้ฉันด้วย ขอบคุณอีกครั้งที่มาส่งนะ~\""
		},
		Summary = "กลับไปหา Cellette"
	},
	[8074] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"\"ก็ได้ บางทีฉันอาจจะไว้ใจให้คุณทำงานให้ Cellette รูมเมทของฉันต่อไปอีกสักหน่อย อ้อ แล้วก็ฝากบอกเธอด้วยนะว่าอย่ากลับบ้านดึกนักบ่อยๆ เข้าใจไหม?\""
		},
		Summary = "กลับไปหา Cellette"
	},
	[8075] = {
		Title = "ซุปลูกชิ้นปลาของ Cellette",
		Description = {
			"\"ไปได้แล้ว คุณได้รับอนุญาตให้ไปได้ จงกลับไปหา Cellette พร้อมกับคำขอบคุณอันสูงส่งจากฉัน\""
		},
		Summary = "กลับไปหา Cellette"
	},
	[8076] = {
		Title = "Klitzer และ Calla",
		Description = {
			"ผมรู้ว่าผมกำลังทำตัวเหมือนคนโง่เง่า แต่ผมยอมแลกทุกอย่างเพื่อให้ได้พบ Calla... แค่อย่าไปฟังสิ่งที่ผมพูดเลย ผมมันก็แค่คนโง่ที่น่าสงสารซึ่งไปตกหลุมรักคนที่ไม่ควรเท่านั้นเอง มันต้องเป็นอย่างนั้นแน่ๆ...."
		},
		Summary = ""
	},
	[8077] = {
		Title = "Klitzer และ Calla",
		Description = {
			"เอาล่ะ บางทีฉันอาจจะไม่ได้พบเขา แต่คุณช่วยนำไวโอลินของฉันไปให้ Klitzer แทนฉันได้ไหม? ฉันเคยเล่นมันให้เขาฟังอยู่บ่อยๆ..."
		},
		Summary = "นำไวโอลินของ Calla ไปให้ Klitzer"
	},
	[8078] = {
		Title = "Klitzer และ Calla",
		Description = {
			"นั่นมันไวโอลินของลูกสาวฉันนี่ ฉันให้เธอเป็นของขวัญตอนอายุสิบหก... แกข้ามเส้นแล้วนะเจ้าหนู! ยาม! มานี่เร็ว!"
