		Summary = "เรียนซ้ำบทเรียนทักษะของพ่อค้า"
	},
	[12315] = {
		Title = "Fake punishment",
		Description = {
			"คุณต้องสังหาร Fake Reveal ผู้ที่พยายามแทรกซึมผ่านประตูด้านหน้าของ Prontera และ Geffen เก็บสะสมบัตรธุรกิจปลอมของเธอทั้ง 5 ใบ แล้วมอบให้ Wishmaiden เพื่อเป็นเครื่องพิสูจน์"
		},
