	},
	[12470] = {
		Title = "Andrea's Revenge I",
		Description = {
			"Andrea ได้รับบาดเจ็บสาหัสจากเคียวที่ถือโดยสิ่งมีชีวิตขนาดเล็กที่มีความสูงเพียงเข่าของเธอ เขาต้องการให้สิ่งมีชีวิตตัวน้อยนั้นได้รับการพักผ่อนด้วยความตายแบบเดียวกัน ^Ff0000 \" รูปลักษณ์ที่น่ารักของเจ้านั่น อย่าได้ถูกหลอกเชียวล่ะ มันยิ่งกว่าปีศาจเสียอีก \"^000000 ฉันคิดว่าเราควรไปตรวจสอบดูว่ามันน่ารักจริงๆ หรือเปล่า"
		},
		Summary = "ปราบ Chaos Baphomet Junior",
		RewardEXP = "1750000",
		RewardJEXP = "1137500",
		RewardItemList = {
			{ItemID = 25271, ItemNum = 1}
		}
	},
	[12471] = {
		Title = "Andrea's Revenge II",
		Description = {
			"Andrea พยายามรักษาด้วยพลังวิญญาณของเธอเองหลังจากได้รับบาดเจ็บสาหัสทางร่างกาย แต่ต้องล้มเลิกการคืนชีพเพราะถูกครอบงำด้วยวิญญาณของสิ่งมีชีวิตที่วุ่นวายนี้ มันเป็นความปรารถนาของเขาที่จะชำระล้างสิ่งชั่วร้ายเหล่านี้ ^Ff0000 \" บางที มันคงเป็นวิญญาณของนักผจญภัยที่ตายไปนานกว่าฉัน มีอะไรอีกหรือเป็นอย่างไรล่ะ? "
		},
		Summary = "ทำลาย Chaos Ghosting",
		RewardEXP = "1750000",
		RewardJEXP = "1137500",
		RewardItemList = {
			{ItemID = 25271, ItemNum = 1}
		}
	},
	[12472] = {
		Title = "Anes' Revenge I",
		Description = {
			"แมลงที่รวดเร็วและชั่วร้ายนี้ได้โจมตี Anes อย่างรุนแรงจนใกล้ตาย เธอเชื่อว่าแมลงมีปีกทั้งหมดในโลกต้องถูกกำจัด ^Ff0099 \" อย่าได้ประมาทเพียงเพราะพวกมันดูเหมือนแมลงวัน เหยื่อของพวกมันรวมถึงคนที่ยังมี 'ชีวิต' อยู่ด้วย \" ^000000ดูเหมือนจะมีความทรงจำที่เลวร้ายมากระหว่างเธอและแมลงชนิดนี้"
		},
		Summary = "ฆ่า Chaos Hunterfly",
		RewardEXP = "1750000",
		RewardJEXP = "1137500",
		RewardItemList = {
			{ItemID = 25271, ItemNum = 1}
		}
	},
	[12473] = {
		Title = "Anes' Revenge II",
		Description = {
			"ไม่ว่าจะด้วยวิธีใด เธอถูกโจมตีโดยนักล่าที่โหดเหี้ยมตัวนี้ซึ่งวิ่งออกมาจากพุ่มไม้และได้รับบาดเจ็บสาหัส น่าเสียดายที่มันเป็นช่วงเวลาที่เธอกำลังกัดแซนด์วิชที่เธอทำตั้งแต่เช้ามืดเพื่อการสำรวจ ^Ff0099 \" ถ้าคุณเจอไอ้ตัวแสบนั่น ให้ดึงขามันออกให้หมดแล้วโยนมันลงกองโคลนซะ \"^000000 มันจะเป็นเรื่องใหญ่หากใครมาขัดจังหวะเวลากินอาหาร"
		},
		Summary = "ฆ่า Killer Mantis ในความโกลาหล",
		RewardEXP = "1750000",
		RewardJEXP = "1137500",
		RewardItemList = {
			{ItemID = 25271, ItemNum = 1}
		}
	},
	[12474] = {
		Title = "Silano's Revenge I",
		Description = {
			"Silbano จำได้อย่างชัดเจนว่าใครคือคู่ต่อสู้ที่โจมตีและขับไล่เขาไปสู่ความตาย ศัตรูในความทรงจำของเขานั้นคล้ายกับมอนสเตอร์ที่โจมตี Anes แต่มีลักษณะอื่นๆ ^Ff0077 \" พี่สาว Anes ต้องการอะไรนะ? อ้อ ท่านก็ต้องการกำจัดพวกมันให้หมดสิ้นเหมือนกัน ถ้าอย่างนั้นฉันก็ต้องการแบบเดียวกัน \"^000000"
		},
		Summary = "ฆ่า Mantis ในความโกลาหล",
		RewardEXP = "1750000",
		RewardJEXP = "1137500",
		RewardItemList = {
			{ItemID = 25781, ItemNum = 1}
		}
	},
	[12475] = {
		Title = "Silano's Revenge II",
		Description = {
			"เนื่องจาก Sylvano ที่อยู่ในสภาพย่ำแย่พยายามจะใช้โพชั่น เพราะเขาไม่มีเวลาแม้แต่จะร่ายเวทรักษา โพชั่นทั้งหมดในกระเป๋าของเขาจึงถูกกลืนกินโดยมอนสเตอร์ที่น่ารำคาญตัวนี้ ^Ff0077 \" มันจะใช้ได้ผลไหม? มันคงจะยังไม่อยู่ที่นั่น ฉันแค่ไม่อยากให้นักผจญภัยคนอื่นได้รับความเสียหายแบบเดียวกัน \"^000000มันขึ้นอยู่กับนักผจญภัยคนต่อไปที่จะรับฟังความหวังเล็กๆ ของเขา"
		},
		Summary = "สมาคมแห่งความโกลาหล (Corporation of Chaos)",
		RewardEXP = "1750000",
		RewardJEXP = "1137500",
		RewardItemList = {
			{ItemID = 25782, ItemNum = 1}
		}
	},
	[12476] = {
		Title = "Cecilia's Revenge I",
		Description = {
			"^0000ff \" ระวังงูตัวนั้นไว้ให้ดี เพราะมันดุร้ายกว่าที่เห็นมาก ทันทีที่คุณละสายตา มันจะโจมตีทันที \"^000000 Cecilia เหนื่อยล้าเพียงครู่เดียวและถูกมอนสเตอร์ตัวนี้กัดที่ที่นั่งของเธอ เธอไม่สามารถขยับตัวได้เนื่องจากพิษอัมพาตที่แพร่กระจายไปทั่วร่างกายในพริบตา ^0000ff \" เขาวงกต ถ้าคุณอยากจะพักสักหน่อย ฉันจะไม่ห้ามหรอก แต่ถ้าฉันยังมีชีวิตอยู่ ฉันอยากจะเลี่ยงที่นั่น... \"^000000"
		},
		Summary = "ฆ่า Sidewinder ในความโกลาหล",
		RewardEXP = "1750000",
		RewardJEXP = "1137500",
		RewardItemList = {
			{ItemID = 25783, ItemNum = 1}
		}
	},
	[12477] = {
		Title = "Cecilia's Revenge II",
		Description = {
			"เธอตกอยู่ในสถานการณ์ที่ไม่สามารถขยับตัวได้ด้วยพิษอัมพาต และเธอกำลังถูกมอนสเตอร์ที่แหลมคมตัวนี้แทงเหมือนหุ่น ^0000ff \" คุณรู้ไหมว่าการที่ใช้มือหรือเท้าไม่ได้ตอนที่แผลถูกเสียบมันเป็นยังไง? ถ้าฉันแค่เป็นอัมพาต ฉันอาจจะมีชีวิตอยู่ได้ แต่นี่เป็นเพราะไอ้มอนสเตอร์เหล็กแหลมนั่นแท้ๆ! \"^000000มันคุ้มค่าที่จะเข้าใจความโกรธของเธอ"
		},
		Summary = "จัดการกับ Chaos Stemworm",
		RewardEXP = "1750000",
