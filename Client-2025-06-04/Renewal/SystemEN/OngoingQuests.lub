		NpcNavi = "prt_elib",
		NpcPosX = "59",
		NpcPosY = "60",
		CoolTimeQuest = 1
	},
	[18162] = {
		Title = "อ่านบันทึกการหลบหนีของนักวิทยาศาสตร์",
		IconName = "ico_vr.bmp",
		Description = {
			"คุณได้อ่าน Fantasy Series 'A Scientist's Escape Record' อย่างน้อยหนึ่งครั้ง!"
