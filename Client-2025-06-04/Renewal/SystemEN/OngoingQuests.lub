	[12593] = {
		Title = "ช่วยเหลือเลทิเซีย (Helping Leticia)",
		IconName = "ico_nq.bmp",
		Description = {
			"เลทิเซียประกาศว่าเธอจะกำจัดพื้นที่ใดๆ ในสวนแห่งกาลเวลา (Garden of Time) ที่อาจเป็นภัยคุกคามต่อเธอ และออสการ์ได้ขอให้คุณช่วยเธอเพราะเธอต้องทำงานเพียงลำพัง ไปหา <NAVI>[เลทิเซีย]<INFO>t_garden,118,92,0,101,0</INFO></NAVI> และดูว่ามีอะไรที่เราสามารถช่วยเธอได้บ้าง.."
