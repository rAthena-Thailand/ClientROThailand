	[5856] = {
		Title = "ฉันชื่อ Morning",
		IconName = "ico_nq.bmp",
		Description = {
			"หวัดดี! เพื่อนที่กำลังอ่านโน้ตฉบับนี้",
			"ฉันต้องย้ายไปอย่างรีบเร่ง เลยทิ้งลูกไว้ข้างหลัง เด็กคนนั้นคือตัวทดลองที่ถูกทิ้งไว้ใน Rudus",
			"คุณสามารถเรียกเด็กคนนั้นว่า <NAVI>[Morning]<INFO>sp_rudus,130,200,0,101,0</INFO></NAVI>",
			"ไม่ใช่ว่าฉันจะปัดภาระนะ ฉันจะมาหาเมื่อมีเวลา แค่ฝากดูแลเรื่องมื้อเช้าให้หน่อย ฉันจะให้สิ่งที่ต้องการตอบแทน ตอนนี้ฉันยังพาลูกไปไม่ได้ ได้โปรดเถอะ",
			"-Olg"
		},
		Summary = "",
		NpcSpr = "4_EP17_MORNING",
		NpcNavi = "sp_rudus",
		NpcPosX = 130,
		NpcPosY = 200
	},
	[5857] = {
		Title = "มาเป็นเพื่อนกับ Morning กันเถอะ",
		IconName = "ico_nq.bmp",
		Description = {
			"หวัดดี! เพื่อนที่อ่านโน้ตฉบับนี้",
			"ขอบคุณที่ทำมื้ออาหารนี้ให้ในตอนเช้า อาจเป็นเพราะเขาเคยเล่าเรื่อง Poring ให้ฉันฟังเมื่อนานมาแล้ว เขาเลยชอบ Poring มากๆ ถ้ามีสัตว์เลี้ยง Poring สักตัว เขาคงเหงาเดินน้อยลง",
			"งั้นขอยืมแรงหน่อย ช่วยหา <ITEM>[Poring's Egg]<INFO>9001</INFO></ITEM> มาให้ Morning ได้ไหม? ได้โปรดนะเพื่อน",
			"-Olg"
		},
		Summary = "Poring's Egg",
		NpcSpr = "4_EP17_MORNING",
		NpcNavi = "sp_rudus",
