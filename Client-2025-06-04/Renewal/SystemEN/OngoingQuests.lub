		Summary = "ถ่วงเวลา"
	},
	[12501] = {
		Title = "Defeat the Visions of Glastheim",
		Description = {
			"สังหารหนึ่งในสองภาพลวงตา (Illusions) ใน Glastheim",
			"^0000ffเควสทั้งหมดเหล่านี้สามารถสำเร็จได้โดยการเคลียร์เพียงอย่างใดอย่างหนึ่งจากสองอย่าง^000000"
		},
