			"Lalaha บอกว่ามีพวก Kokopo เข้าไปใน Sticky Sea เธอขอให้เราไปกำจัดมอนสเตอร์ใน Sticky Sea คุยกับ <NAVI>[Koko]<INFO>jor_back4,101,265,0,101,0</INFO></NAVI> ที่ทางเข้าของ Sticky Sea แล้วเข้าไปข้างในกัน"
		},
		Summary = "คุยกับ Koko"
	},
	[11949] = {
		Title = "Escargo!",
		IconName = "ico_dq.bmp",
		Description = {
			"ใน Sticky Sea กำจัดหอยทากเทวดาที่เน่าเฟะซึ่งกำลังรบกวนเหล่า Kokopo และช่วยเหลือพวกเขา"
		},
		Summary = "กำจัด Corrupted Angel Snail"
	},
	[11950] = {
		Title = "[Standby] Escargo!",
		IconName = "ico_dq.bmp",
		Description = {
			"Sticky Sea ได้รับการทำความสะอาดแล้ว พักผ่อนสักหน่อยในวันนี้"
