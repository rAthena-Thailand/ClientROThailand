	[21246] = {
		Title = "คุณแข็งแกร่งไหม? 1",
		Description = {
			"ที่ประตูหน้าของ Prontera เด็กชายชื่อ Paul ถามว่าฉันแข็งแกร่งไหม และถ้าแข็งแกร่ง เขาจะจัดการ Hornet ได้ไหม ผึ้งที่ออกมาจากรังที่เผลอทำหกโดยบังเอิญกำลังตกอยู่ในอันตรายที่จะกลายเป็นผึ้งป่า ดังนั้นพวกเขาจึงดูเหมือนจะถูกเตือนไม่ให้ออกไปเล่นข้างนอก กำจัด Hornet เพื่อปกป้องสนามเด็กเล่น"
		},
		Summary = "กวาดล้าง Hornet"
	},
	[21247] = {
		Title = "คุณแข็งแกร่งไหม? 2",
		Description = {
			"คำร้องขอของ Paul ที่ประตูหน้าเมือง Prontera ทางตอนใต้เกี่ยวกับตั๊กแตนที่อาศัยอยู่ตามท้องถิ่น และเราไม่รู้ว่าเมื่อไหร่พวกมันจะบุกรุกทุ่งตะวันตก และขอให้ปกป้องทุ่งตะวันตกจากภัยคุกคามที่มองไม่เห็น มาต่อสู้กลับและทำให้มั่นใจเถอะ"
