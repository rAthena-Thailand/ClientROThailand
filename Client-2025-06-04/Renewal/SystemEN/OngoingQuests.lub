	},
	[1011] = {
		Title = "เปลี่ยนอาชีพเป็น Merchant",
		Description = {
			"ไปรับพัสดุที่จะนำไปส่งจากโกดังสินค้า จากนั้นมุ่งหน้าไปที่เมือง Morroc คุณต้องตามหา Java Dullihan ช่างทำสีย้อม เขาเป็นคนขี้ลืมสักหน่อย ดังนั้นคุณอาจจะต้องมอบพัสดุให้ลูกศิษย์ของเขาแทน"
		},
		Summary = "ส่งพัสดุไปให้ช่างทำสีย้อมใน Morroc"
	},
	[1012] = {
		Title = "เปลี่ยนอาชีพเป็น Merchant",
