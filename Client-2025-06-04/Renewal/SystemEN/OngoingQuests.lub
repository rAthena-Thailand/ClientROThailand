	[14450] = {
		Title = "มาช่วยหลวงพ่อที่กำลังลำบากกันเถอะ (Let's help the difficult priest)",
		Description = {
			"ตอนนี้มีดวงวิญญาณอันตรายร่อนเร่อยู่ในดินแดนแห่งความมีชีวิตนี้ โปรดจับวิญญาณเร่ร่อน (Wandering Soul) และวิญญาณทมิฬ (Black Soul) หากคุณจับพวกมันได้ คุณจะสามารถแยกดวงวิญญาณที่ถูกจองจำและวิญญาณทมิฬออกมาได้ แค่สุนัขตัวหนึ่งกับเขาทมิฬก็เพียงพอแล้ว"
		},
		Summary = "งานพาร์ทไทม์ออกล่า"
	},
