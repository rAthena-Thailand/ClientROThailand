		Title = "Kahris อยู่ที่ไหน",
		Description = {
			"ไม่ว่าฉันจะพยายามยอมรับเรื่องของ Briashen มากแค่ไหน มันก็เป็นไปไม่ได้ที่จะคุยกันแบบปกติ เธอขอให้คุณตามหา Kahris เธอดูเหมือนตัวเธอเอง... บางอย่าง"
		},
		Summary = "คุยกับนักผจญภัยที่ดูเหมือน Briashen"
	},
	[8725] = {
		Title = "หน้าตาเหมือนกัน...? (1)",
		Description = {
			"ว่ากันว่า Ranger ชื่อ Lewella กำลังตามหา Briashen แต่ชื่อที่เธอกำลังตามหาไม่ใช่ Briashen งั้นเหรอ...? เมื่อพูดจบ Lewella ก็หายตัวไป"
		},
		Summary = ""
	},
	[8726] = {
		Title = "หน้าตาเหมือนกัน...? (2)",
		Description = {
			"Ranger ชื่อ Kahris ว่ากันว่าเธอกำลังตามหาแฟนเก่าของเธอ แต่หลังจากฟังเรื่องราวแล้ว กลายเป็น Briashen ที่หลงทางอยู่ในดันเจี้ยนนี้งั้นเหรอ...? เมื่อฉันบอกว่าเรื่องของ Briashen ต่างออกไป Kahris ก็หายตัวไป"
		},
		Summary = ""
	},
	[8727] = {
		Title = "หน้าตาเหมือนกัน...? (3)",
		Description = {
			"Gunslinger ชื่อ Kahris ว่ากันว่าเธอกำลังตามหาแฟนเก่าของเธอ แต่ Kahris ที่ Briashen กำลังตามหาคือ Ranger ไม่ใช่เหรอ...? เมื่อพูดจบ Kahris ก็หายตัวไป"
		},
		Summary = ""
	},
	[8728] = {
		Title = "ใครคือ Kahris?",
		Description = {
			"ผู้คนที่ฉันพบใน Garden of Recognition ที่ดูเหมือน Briashen อย่างน้อยดูเหมือนจะไม่ใช่มนุษย์ ไปรายงานต่อ <NAVI>[Mirko]<INFO>anthell02,177,190,0,101,0</INFO></NAVI> ก่อนดีกว่า"
		},
		Summary = "คุยกับ Mirko"
	},
	[8729] = {
		Title = "Briashen อยู่ที่ไหน (2)",
		Description = {
			"Kahris อาจจะเป็น Vitata เจตนาล่ะ...? จุดประสงค์ของการเข้าหา Briashen คืออะไร? ในสถานการณ์ที่ยังไม่รู้อะไรเลย Mirko จึงขอร้องให้เขาเข้าไปใน Garden of Perception อีกครั้งและช่วยเหลือ Briashen"
		},
		Summary = "ยินดีต้อนรับกลับมา"
	},
	[8730] = {
		Title = "เขาวงกตแห่งการตระหนักรู้",
		Description = {
			"Mirko เริ่มวิตกกังวลเมื่อเธอบอกว่าเธอเห็น Kahris เข้าจริงๆ และมันดูเหมือนกับมด ไม่ว่าในกรณีใด การพา Briashen ออกจาก Garden of Perception ดูเหมือนจะเป็นสิ่งสำคัญที่สุด"
