	[13007] = {
		Title = "คำขอ Anolian (Anolian Request)",
		Description = {
			"Glastheim ดูเหมือนจะเป็นสถานที่ศักดิ์สิทธิ์ที่ยอดเยี่ยมไม่เพียงแต่สำหรับเหล่านักผจญภัยเท่านั้น แต่ยังรวมถึงเหล่านักบวชด้วย ฉันไม่รู้จริงๆ ว่าอะไรที่ดึงดูดพวกเขาไปที่นั่น"
