	[1013] = {
		Title = "เปลี่ยนอาชีพเป็น Thief",
		Description = {
			"ไปขโมยเห็ดจากฟาร์มของ Shibu โดยเก็บเห็ด 2 ชนิด: ^0000FFOrange Net Mushroom^000000 (3 คะแนน) และ ^0000FFOrange Gooey Mushroom^000000 (1 คะแนน) คุณต้องทำให้ได้รวม 25 คะแนนเพื่อผ่านการทดสอบ มุ่งหน้าไปยังแผนที่ทางตะวันออกของ Pyramids"
		},
		Summary = "เก็บรวบรวมเห็ด"
	},
	[1014] = {
		Title = "เปลี่ยนอาชีพเป็น Swordman",
		Description = {
			"จุดประสงค์ของการทดสอบนี้คือเพื่อยืนยันว่าคุณมีคุณสมบัติเพียงพอจะเป็น Swordman หรือไม่ เงื่อนไขในการผ่านนั้นง่ายมาก คุณต้องผ่านเส้นทางทั้ง 3 คอร์สและไปถึงจุดเช็คพอยต์สุดท้ายภายในเวลา ^FF000010 นาที^000000"
