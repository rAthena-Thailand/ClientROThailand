		Summary = "ไปที่เกาะซากเรืออับปาง"
	},
	[21928] = {
		Title = "หมู่บ้าน Poring",
		Description = {
			"เราต้องตรวจสอบข้อเท็จจริงเกี่ยวกับข่าวลือเรื่อง 'หมู่บ้าน Poring' (Poring Village) ที่แพร่กระจายอยู่รอบๆ Prontera ตามคำขอของกลุ่ม Paradise รวบรวมข้อมูลจาก 'ทางตะวันตกของ Prontera' กันเถอะ"
		},
		Summary = ""
	},
	[21929] = {
		Title = "มุ่งสู่เกาะซากเรืออับปาง",
		Description = {
			"ดูเหมือนว่า 'Bran' จะซ่อนตัวอยู่บนเกาะที่มีซากเรืออับปาง ลองไปตรวจสอบโดยเดินทางไปยังซากเรือผ่านกะลาสีเรือแถวท่าเรือ Alberta"
		},
		Summary = "สำรวจซากเรืออับปางที่น่าสงสัย"
	},
	[21930] = {
		Title = "แหวนดอกไม้ที่จะเบ่งบานอีกครั้ง",
		Description = {
			" 'แหวนดอกไม้แห่งการเสริมพลัง' (Flower Ring of Fortification) ที่ท่าน Merrick มอบให้สามารถนำไปรับพรได้ ไปที่วิหาร Prontera และพบกับ <NAVI>บาทหลวง Loam<INFO>prt_church,107,99,0,101,0</INFO></NAVI> เพื่อส่งมอบมัน"
		},
		Summary = "คุยกับบาทหลวง Loam"
