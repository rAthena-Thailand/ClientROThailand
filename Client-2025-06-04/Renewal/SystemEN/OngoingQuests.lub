	[11172] = {
		Title = "คำขอจาก Frede",
		Description = {
			"เพื่อนๆ ทุกคนคงจะอยู่ในถ้ำกันหมด เพราะฉันเห็นพวกเขามาเติม Bradium หวังว่าพวกเขาจะแข็งแรงดี คุณช่วยไปเยี่ยมพวกเขาเพื่อเช็คดูหน่อยได้ไหมว่าพวกเขาสบายดีหรือเปล่า?"
		},
		Summary = "พบเพื่อนของ Frede: Brian, John, Tyler, Rose, Bain และ Lash"
	},
	[11173] = {
		Title = "คำขอจาก Frede",
		Description = {
			"ฉันขอโทษจริงๆ ที่ต้องรบกวนคุณอย่างต่อเนื่อง แต่คุณช่วยส่ง Bradium ไปให้เพื่อนๆ ของฉันได้ไหม? ถ้าคุณไปถาม Bouy ที่อาคารทางตะวันตกเฉียงเหนือของหมู่บ้าน เขาจะมอบ Bradium ที่กลั่นแล้วให้คุณ โปรดไปรับมันมาด้วย"
		},
		Summary = "ไปหา Bouy และรับ Bradium ที่กลั่นแล้ว"
	},
	[11174] = {
		Title = "การขาดแคลนเสบียง",
		Description = {
			"มันใช้เวลานานมากในการกลั่นแร่ Bradium ขนาดใหญ่ แต่ชิ้นเล็กๆ จะทำได้รวดเร็ว คุณสามารถรวบรวมชิ้นส่วน Bradium ได้ง่ายๆ จากมอนสเตอร์แถวนี้ ชิ้นส่วน Bradium ประมาณ 30 ชิ้นก็น่าจะพอแบ่งให้ 6 คนแล้ว"
		},
		Summary = "Bradium ไม่เพียงพอ รวบรวมชิ้นส่วน Bradium ขนาดเล็ก 30 ชิ้น"
	},
	[11175] = {
