	[11951] = {
		Title = "มันอันตรายนะ!",
		IconName = "ico_dq.bmp",
		Description = {
			"Lalaha ยังคิดว่ามีพวก Kokopo เข้าไปใน Sticky Sea เธอขอให้เราไปดุพวก Kokopo ที่หลงทางใน Sticky Sea แล้วส่งพวกเขากลับมา คุยกับ <NAVI>[Koko]<INFO>jor_back4,101,265,0,101,0</INFO></NAVI> ที่ทางเข้าและเข้าไปข้างใน เมื่อเสร็จภารกิจแล้วให้กลับไปหา <NAVI>[Lalaha]<INFO>icecastle,67,218,0,101,0</INFO></NAVI>"
		},
		Summary = "ส่งตัว Kokopo กลับไป"
