	[14551] = {
		Title = "หัวหน้า Basilisk (Chief Basilisk)",
		Description = {
			"โปรดไปพบกับ Imoogi หัวหน้าของเหล่า Basilisk และขอให้เขาช่วยทำให้พวกมันสงบลง มีอุปกรณ์สำหรับให้คุณใช้สนทนาติดตั้งอยู่ข้างบนนั้น"
		},
		Summary = "คุยกับ Imoogi"
	},
	[14552] = {
		Title = "ข้อความจากท่าน Imuk (Lord Imuk's message)",
		Description = {
			"เหล่า Basilisk จะทำหน้าที่ของพวกมันต่อไป จนกว่าเจ้าเด็กน้อยนั่นจะยอมส่งมอบ Yeouiju ออกมา"
		},
		Summary = "ไปหา Tartufi"
	},
	[14553] = {
		Title = "ล่า Basilisk (Basilisk Hunt)",
		Description = {
			"โปรดช่วยจัดการพวกมันในระหว่างที่ฉันตามหา Yeouiju การกำจัดพวกมันสัก 20 ตัวก็น่าจะเพียงพอ"
		},
		Summary = "ล่า Basilisk"
	},
	[14554] = {
		Title = "เราสามารถเริ่มออกเรือได้แล้ว (We can start sail now)",
		Description = {
			"จัดการเหล่า Basilisk เรียบร้อยแล้ว ตอนนี้ Tartufi สงบลงแล้ว กลับไปรายงานต่อต้นเรือ Stello"
		},
		Summary = "รายงานต่อต้นเรือ Stello"
	},
	[14555] = {
		Title = "โลกใหม่แห่งรสชาติ (Whole new world of taste)",
		Description = {
			"ฉันกำลังพยายามวิจัยวัตถุดิบอาหารของทวีปใหม่ คุณช่วยหา Fruit of Mastera มาให้ฉันสัก 4 ลูกได้ไหม? และฉันยังต้องการ Cat shape hard biscuit อีก 1 ชิ้นด้วย"
		},
		Summary = "Mastera's Fruit 4 ลูก และ Cat shape Hard Biscuit 1 ชิ้น"
	},
	[14556] = {
		Title = "มีสิ่งที่น่ากลัวสำหรับฉันเช่นกัน (There also is a scary thing for me)",
		Description = {
			"พวกมันมักจะปรากฏตัวในตอนกลางคืนและทำให้ฉันขนลุกมาก พวกเขาบอกว่าฮีโร่คนใหม่จะช่วยฉันได้ โปรดไปพบกับ Shamanyang และฟังวิธีแก้ปัญหาของฉัน Shamanyang อาศัยอยู่แถวทางเข้าหมู่บ้าน"
		},
		Summary = "ไปหา Shamanyang"
	},
	[14557] = {
		Title = "ความจริงนั้นโหดร้ายเสมอ (Truth is alway harsh)",
		Description = {
			"ไปเล่าเรื่องที่ฉันเพิ่งบอกคุณให้พลาธิการ (Boatswain) ฟังที"
		},
		Summary = "ไปหาพลาธิการ"
	},
	[14558] = {
		Title = "สิ่งมีชีวิตที่สกปรก (Dirty Creatures)",
		Description = {
			"ฉันจะไม่มีวันไปคลุกคลีกับพวก Basilisk เด็ดขาด เพราะงั้นไปหา Basil 20 อัน และ Basilrock 5 อันมาให้ฉัน แน่นอนว่ามีรางวัลตอบแทนให้"
		},
		Summary = "Basil และ Basilrock"
	},
	[14559] = {
		Title = "ระยะเวลาของผลเครื่องราง (Charm Effect Duration)",
		Description = {
			"ผลของเครื่องรางจะหายไปตอน 4 นาฬิกา"
		},
		Summary = "รีเซ็ตตอน 04:00",
		CoolTimeQuest = 1
	},
	[14560] = {
		Title = "วัตถุดิบใหม่ (New Ingredient)",
		Description = {
			"เมื่อมีการติดต่อกับผู้คนในทวีปใหม่มากขึ้น เราพบว่าเครื่องรางของพวกเขาก็มีประสิทธิภาพเช่นกัน วันนี้เราต้องการ Basilrock 5 อัน และ Holy water 1 ขวด หามาแล้วรายงานต่อพลาธิการ"
		},
		Summary = "Basilrock และ Holy Water"
	},
	[14561] = {
		Title = "ทั้งสกปรกและโสโครก (Dirty and Filty)",
		Description = {
			"Basilrock นั้นทั้งสกปรกและโสโครก วันนี้ขอสัก 20 อันก็แล้วกัน หามาแล้วรายงานต่อพลาธิการทันที"
		},
		Summary = "Basilrock"
	},
	[14562] = {
		Title = "พื้นฐานดีที่สุด (The basic are the best)",
		Description = {
			"การยึดตามพื้นฐานเป็นวิธีที่มีประสิทธิภาพที่สุด รวบรวม Basil 20 อัน และ Basilrock 5 อัน เมื่อคุณได้ครบแล้ว ให้ไปหาพลาธิการทันที"
		},
		Summary = "Basil และ Basilrock"
	},
	[14563] = {
		Title = "เวลาว่าง (Free time)",
		Description = {
			"งานของวันนี้ยังไม่เสร็จสิ้น เราไม่สามารถวิจัยได้หากงานของเรายังไม่เรียบร้อย กลับมาอีกครั้งหลังรุ่งสาง"
		},
		Summary = "รีเซ็ตตอน 04:00",
		CoolTimeQuest = 1
	},
	[14564] = {
		Title = "ฉันก็ชอบขนมปังเหมือนกัน (I love buns, too)",
		Description = {
			"ว่ากันว่ามีขนมปังในทวีปใหม่ด้วย ที่ Lasagna ก็มีอาหารที่คล้ายกัน ฉันเลยอยากจะลองเปรียบเทียบพวกมันดู คุณช่วยนำมาให้ฉันสัก 20 ชิ้นได้ไหม?"
		},
		Summary = "ขนมปัง 20 ชิ้น"
	},
	[14565] = {
		Title = "เสบียงอาหารฉุกเฉิน (Emergency food supplies)",
		Description = {
			"ฉันสงสัยว่าพวก Nyas เคยใช้เลี้ยงกะลาสีพวกนั้นจาก Navi หรือเปล่า ช่วยหามาให้ฉันอย่างละ 5 ชิ้นที"
		},
		Summary = "Cat Hardtack, Malangdo Canned Food"
	},
	[14566] = {
		Title = "ไอเดียบรรเจิด (Brilliant idea)",
		Description = {
			"น้ำแข็งไม่มีวันละลาย!! ถ้ามันมีอยู่จริง นั่นจะเป็นการปฏิวัติการเก็บรักษาวัตถุดิบเลยล่ะ! มันกระตุ้นความอยากรู้อยากเห็นของฉันมาก! โปรดรวบรวมมาให้ได้ 20 ชิ้น!"
		},
		Summary = "ก้อนน้ำแข็ง (Ice Chunk)"
	},
	[14567] = {
		Title = "นม Kaluna กำลังตกอยู่ในอันตราย! (Kaluna milk is in Danger!)",
		Description = {
			"ยังไม่ได้ข่าวจากคุณ Legalas ที่ควรจะนำ Kahlugna มาให้ฉันเลย โปรดไปพบคุณ Legalas เพื่อดูว่าเกิดอะไรขึ้น เขาอาศัยอยู่ทางใต้"
		},
		Summary = "ไปหาคุณ Legalas"
	},
	[14568] = {
		Title = "เวลาแห่งการหว่านล้อม (Time to persuade)",
		Description = {
			"พวกเราจะหิวตายกันหมดแล้ว! ทำอะไรสักอย่างสิ! ไปคุยกับพวกนั้น หยุดพวกมันไม่ให้กิน Kahlugnag ไปมากกว่านี้!!"
		},
		Summary = "คุณนากทะเล (Mr.Sea Otter) และคุณ Galapago"
	},
	[14569] = {
		Title = "พี่เลี้ยงเด็ก (Babysitter)",
		Description = {
