		},
		Summary = "คุยกับบาทหลวง Bamph"
	},
	[17001] = {
		Title = "พบกับ Larjes",
		IconName = "ico_ep.bmp",
		Description = {
			"บาทหลวง Bamph บอกคุณว่า ชายผู้มีบรรดาศักดิ์สูงคนหนึ่งหายตัวไปอย่างกะทันหันเมื่อไม่นานมานี้ และมีคนเห็นเขาครั้งสุดท้ายที่ Comodo จงตามหา Larjes เพื่อให้เขาช่วยคุณในการตามหาเจ้าหน้าที่ที่หายตัวไป"
		},
		Summary = "คุยกับ Larjes"
	},
	[17002] = {
		Title = "รายงานตัวกับบาทหลวง Bamph",
		IconName = "ico_ep.bmp",
		Description = {
			"Larjes บอกคุณว่าเจ้าหน้าที่คนนั้นถูกลักพาตัวไปโดยองค์กรจาก Arunafeltz คุณควรรายงานเรื่องนี้ให้บาทหลวง Bamph ทราบ"
		},
		Summary = "คุยกับบาทหลวง Bamph",
