		Summary = "ติดใบปลิว"
	},
	[21912] = {
		Title = "เนื้อหาในใบปลิว",
		Description = {
			"หลังจากติดใบปลิวในจุดที่กำหนดแล้ว 'Lumin' ก็หายตัวไปหลังจากพูดบางอย่างที่กวนใจเขา ลองไปหาจุดติดใบปลิวจุดที่สองกันเถอะ"
		},
		Summary = "ติดใบปลิว"
	},
	[21913] = {
		Title = "สู่ Prontera อีกครั้ง!",
		Description = {
			"เพื่อจัดการเรื่องการเลื่อนติดใบปลิวของ 'วิหาร Prontera' เราตัดสินใจไปพบกับ <NAVI>บาทหลวง Loam<INFO>prt_church,107,99,0,101,0</INFO></NAVI> แห่งวิหาร Prontera"
