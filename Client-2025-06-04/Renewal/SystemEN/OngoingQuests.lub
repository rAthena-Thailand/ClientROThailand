	[14004] = {
		Title = "แหวน Valkyrie (Valkyrie Ring)",
		Description = {
			"รับกล่องแหวน Valkyrie Ring Box"
		},
		Summary = ""
	},
	[14118] = {
		Title = "ความกังวลของ Wuhari (Wuhari's concern)",
		Description = {
			"Wuhari กำลังเป็นห่วงน้องชายของเขาที่อยู่ในคุก หาทางเข้าไปในคุกและส่งจดหมายจากใจของ Wuhari ให้กับน้องชายของเขาในคุก"
		},
		Summary = ""
	},
	[14119] = {
		Title = "บททดสอบความอดทน (Test of patience)",
		Description = {
			"นักโทษไม่ตอบสนองเมื่อถูกชวนคุย ดูเหมือนเขาจะทดสอบความอดทนของฉัน"
		},
		Summary = "กำลังคุยกับนักโทษ"
	},
	[14120] = {
		Title = "บททดสอบความอดทน 2 (Test of patience 2)",
		Description = {
			"นักโทษยังคงไม่ตอบสนองแม้จะพยายามคุยด้วยหลายครั้งแล้วก็ตาม ลองพยายามอีกครั้ง"
		},
		Summary = "กำลังคุยกับนักโทษ"
	},
	[14121] = {
		Title = "บททดสอบความอดทน 3 (Test of patience 3)",
		Description = {
			"หมอนี่ดูเหมือนจะปิดปากเงียบไม่ว่าจะยังไงก็ตาม ฉันสงสัยว่าจะมีวิธีอื่นอีกไหม"
		},
		Summary = "กำลังคุยกับนักโทษ"
	},
	[14122] = {
		Title = "เวลาสำหรับเราสอง (Time for two)",
		Description = {
			"จดหมายของ Wuhari ถูกส่งถึง Wuhuru แล้ว เขาขอเวลาสักพักเพื่ออ่านจดหมาย อย่าเพิ่งไปกวนเขาตอนที่เขากำลังอ่านจดหมายอยู่ล่ะ"
		},
		Summary = "ให้เวลาเขาอ่านจดหมาย"
	},
	[14123] = {
		Title = "ความกรุณาของ Wuhuru (Wuhuru's favor)",
		Description = {
			"หลังจากอ่านจดหมายของพี่ชายแล้ว Wuhuru เริ่มเล่าเรื่องราวของเขาอย่างละเอียดและขอให้ฝากความระลึกถึงไปยังพี่ชายของเขาด้วย กลับไปหา Wuhari แล้วบอกความระลึกถึงจากน้องชายของเขา"
		},
		Summary = "ส่งความระลึกถึงให้ Wuhari"
	},
	[14124] = {
		Title = "คำขอแรก (First Request)",
		Description = {
			"สัตว์ของ Jade ถูกขโมยไปเมื่อคืนนี้ ไปสืบสวนดูแล้วรายงานว่าเกิดอะไรขึ้น"
		},
		Summary = "บ้านของ Jade"
	},
	[14125] = {
		Title = "การสำรวจพื้นที่ (Investigating the area)",
		Description = {
			"Wuhari กำลังหาวิธีฟื้นฟูร่างกายของ Wuhuru อย่างไรก็ตาม เขาไม่รู้ว่าต้องทำยังไง ผู้คนในพื้นที่ใกล้เคียงน่าจะรู้อะไรบ้างไหมนะ? ลองไปสำรวจพื้นที่แถวๆ นี้ดู"
		},
		Summary = "คุยกับผู้คนในเมือง"
	},
	[14126] = {
		Title = "ตามหาคุณ Goatie (Searching for Ms. Goatie)",
		Description = {
			"คุณ Masione บอกว่าเขาไม่รู้อะไรมากนัก แต่แนะนำให้ไปหาคุณ Goatie ที่ดูจะหูไวตาไวกว่าในเรื่องพวกนี้"
		},
		Summary = "ตามหาคุณ Goatie"
	},
	[14127] = {
		Title = "ตามหาสามีของคุณ Goatie (Searching for Ms. Goatie's husband)",
		Description = {
			"คุณ Goatie เล่าว่า Wuhuru ดูมีความสุขมากในขณะที่แกว่งกระดาษแผ่นหนึ่งในอากาศ เมื่อถามถึงกระดาษแผ่นนั้น เธอจึงบอกว่าสามีของเธอน่าจะรู้อะไรมากกว่านี้"
		},
		Summary = "ตามหาสามีของคุณ Goatie"
	},
	[14128] = {
		Title = "การได้รับรายงานการวิจัย (Obtaining the research report)",
		Description = {
			"คุณ Svery ผู้ซึ่งสนิทสนมกับ Wuhuru รู้อะไรบางอย่างเพิ่มเติม ภายในจดหมายที่ Wuhuru ทิ้งไว้ก่อนถูกจับเข้าคุกคือรายงานการวิจัย จงนำมันไปให้ Wuhari"
		},
		Summary = "ส่งรายงาน"
	},
	[14131] = {
		Title = "เวลาแห่งการวิเคราะห์ (Analysis time)",
		Description = {
			"Wuhari ได้รับรายงานแล้ว แต่บอกว่ามันต้องใช้เวลาสักพักในการวิเคราะห์รายงาน ลองคุยกับเขาในภายหลัง อย่าไปกวนคนที่กำลังใช้สมาธิศึกษาอยู่เลย"
		},
		Summary = "เวลาสำหรับการวิเคราะห์"
	},
	[14132] = {
		Title = "งานวิจัยของเรา (Our Research)",
		Description = {
			"หลังจากพบสัตว์ตัวนั้นแล้ว ขั้นแรกเราต้องตรวจสอบก่อนว่าเกิดอะไรขึ้น"
		},
		Summary = "งานวิจัยของเรา"
	},
	[14133] = {
		Title = "คำขออีกอย่าง (Another favor)",
		Description = {
			"Wuhari วิเคราะห์รายงานการวิจัยแล้ว แต่เขาก็ยังไม่แน่ใจว่าจะฟื้นฟูร่างกายของน้องชายได้อย่างไร ลองไปหาและถาม Lapine คนเดิมที่เป็นคนขอให้ Wuhuru เข้าร่วมการวิจัยดู"
		},
		Summary = "การรวบรวมหลักฐาน"
	},
	[14134] = {
		Title = "คุณ Goatie ผู้แสนฉลาด (Sharp Ms. Goatie)",
		Description = {
			"แม้ว่าจะไปหาคุณ Svery เพื่อขอข้อมูลเพิ่มเติมแล้ว แต่เขาก็บอกว่าเขาไม่มีเบาะแสเกี่ยวกับ Lapine ระดับสูงคนนั้นเลย อย่างไรก็ตาม เขาแนะนำให้ไปหาภรรยาของเขาที่ฉลาดหลักแหลมในเรื่องพวกนี้"
		},
		Summary = "ไปหาคุณ Goatie"
	},
	[14135] = {
		Title = "ตามหาคุณ Pompe (Searching for Mr. Pompe)",
		Description = {
			"เมื่อถามถึงที่อยู่ของ Lapine ระดับสูง คุณ Goatie ก็ไม่รู้อะไรมากนัก อย่างไรก็ตาม เพื่อนบ้านในเมืองชื่อคุณ Pompe บอกว่าเขาเห็น Lapine คนหนึ่งในทุ่งกว้างซึ่งต่อมาก็ได้หายตัวไป ลองไปถามรายละเอียดจากคุณ Pompe ดู"
		},
		Summary = "ฟังเรื่องราวจากคุณ Pompe"
	},
	[14136] = {
		Title = "ฉากอันน่าสยดสยองในทุ่งกว้าง (A terrible scene in the field)",
		Description = {
			"คุณ Pompe กลัวที่จะออกไปที่ทุ่งกว้าง เขาเล่าถึงศพขนาดใหญ่ที่นอนอยู่ตรงนั้นตั้งแต่ Lapine ระดับสูงคนหนึ่งต้องเผชิญกับความตายอันน่าสยดสยอง ไปสำรวจที่ทุ่งนั่นดู"
		},
		Summary = "การสืบสวนภาคสนาม"
	},
	[14137] = {
		Title = "ข้อเสนอที่น่าสนใจ (An interesting proposition)",
		Description = {
			"เด็กสาว Lapine คนหนึ่งยื่นข้อเสนอที่น่าสนใจ ดูเหมือนว่า Lapine ที่มอบรายงานการวิจัยให้ Wuhuru จะเป็นคนคนเดียวกับพ่อที่หายตัวไปของเธอ มาตามหาเขาด้วยกันเถอะ"
		},
		Summary = "การสืบสวนภาคสนาม"
	},
	[14138] = {
		Title = "ศพขนาดใหญ่ (The big corpse)",
		Description = {
			"มีศพขนาดใหญ่ที่ดูเหมือนว่าจะอยู่ตรงนั้นมาสักพักแล้ว เขาคือ Lapine ที่ทุกคนตามหาอยู่ เราต้องบอกข่าวร้ายนี้ให้เด็กสาวคนนั้นรู้"
		},
		Summary = "รายงานต่อ Giranni"
	},
	[14139] = {
		Title = "ไปหา Wuhuru (To Wuhuru)",
		Description = {
			"เด็กสาวยืนยันว่าศพนั้นคือพ่อของเธอ ฉันต้องกลับไปหา Wuhari มือเปล่าเนื่องจาก Lapine ที่เราสนใจได้เสียชีวิตลงแล้ว ก่อนหน้านั้น ไปหา Wuhuru เพื่อบอกเขาเกี่ยวกับ Lapine ที่เขาเคยทำงานด้วย"
		},
		Summary = "ไปหา Wuhuru"
	},
	[14140] = {
		Title = "ไปหา Wuhari (To Wuhari)",
		Description = {
			"Wuhuru เล่าเรื่องราวของเขาทั้งหมด แต่เรื่องนั้นไม่สามารถบอกกับ Wuhari ได้ทั้งหมด ไปหา Wuhari เพื่ออย่างน้อยก็บอกเขาว่า Lapine คนนั้นตายแล้ว"
		},
		Summary = "รายงานต่อ Wuhari"
	},
	[14141] = {
		Title = "วัตถุดิบเพื่องานวิจัย (Ingredients for research)",
		Description = {
			"Wuhari ขอวัตถุดิบที่เขาจะนำไปใช้วิจัยด้วยตัวเอง จัดหาวัตถุดิบที่จำเป็นให้ Wuhari (Wing piece 1 อัน, sturdy hair 1 อัน, Bradium 1 อัน, rune of darkness 1 อัน, rune of blood 1 อัน)"
		},
		Summary = "รวบรวมไอเทม!"
	},
	[14142] = {
		Title = "ไปยังเมืองแห่งนักธนู! (To the Archer's town!)",
		Description = {
			"จบการเรียนด้วยการไปที่กิลด์นักธนู (Archer's Guild) โดยการไปที่ Payon และเดินทางไปทางเหนือ"
		},
		Summary = "เดินทางไปยังเมืองนักธนู"
	},
	[14143] = {
		Title = "ใบสมัครเปลี่ยนอาชีพนักธนู (Application for the Archer's job change)",
		Description = {
			"ในที่สุด ก็ได้สมัครเปลี่ยนอาชีพเป็นนักธนูแล้ว! ไปทำการเปลี่ยนอาชีพนักธนูที่กิลด์นักธนู"
		},
		Summary = "ใบสมัครเปลี่ยนอาชีพ"
	},
	[14144] = {
