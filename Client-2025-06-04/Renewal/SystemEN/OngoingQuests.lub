	[11038] = {
		Title = "พบผู้ล่วงลับ",
		Description = {
			"โปรดบอกให้ Elly รู้ด้วยว่าสิ่งที่เกิดขึ้นเมื่อเดือนก่อนเป็นความผิดของฉันทั้งหมด ไปยังเมืองแห่งความตายและส่งข้อความของ Erious ให้ Elly"
		},
		Summary = "ส่งข้อความของ Erious ให้ Elly"
	},
	[11039] = {
		Title = "พบผู้ล่วงลับ",
		Description = {
			"ใครบางคนที่คุณต้องไปพบที่นั่น... ฉันเดาว่าคุณต้องการติดต่อกับผู้ล่วงลับ... เมืองแห่งความตายตั้งอยู่ทางเหนือของที่นี่",
			"คุณต้องตามหาชายที่ชื่อ \"Feylin\" สำคัญมากที่จะต้องบอกเขาว่า Billik เป็นคนแนะนำคุณให้เขารู้จัก นำดอกกุหลาบไปมอบให้เขาด้วย"
		},
		Summary = "นำดอกกุหลาบไปให้ Feylin"
	},
	[11040] = {
		Title = "พบผู้ล่วงลับ",
		Description = {
			"หากคุณมาที่นี่เพื่อพบกับเพื่อนที่ล่วงลับของคุณ คุณมาหาผิดคนแล้ว กลับไปซะ"
		},
		Summary = "ยอมแพ้ตอนนี้ไม่ได้ คุยกับ Feylin ต่อไปเรื่อยๆ"
	},
	[11041] = {
		Title = "พบผู้ล่วงลับ",
		Description = {
			"ฉันไม่แน่ใจว่าใครบอกคุณว่าการติดต่อผู้ล่วงลับนั้นเป็นไปได้.... แต่ฉันไม่เคยบอกคุณแน่ อีกอย่าง การพูดเรื่องแบบนี้เป็นสิ่งต้องห้าม"
		},
		Summary = "ยอมแพ้ตอนนี้ไม่ได้ คุยกับ Feylin ต่อไปเรื่อยๆ"
	},
	[11042] = {
