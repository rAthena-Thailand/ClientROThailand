		Summary = "ตรวจสอบกับกลุ่มศาลเตี้ย"
	},
	[14540] = {
		Title = "งานด่วนจากไหนไม่รู้ (An errand out of nowhere)",
		Description = {
			"คุณทำมันจริงๆ เหรอ? ฉันโดนรองเชฟดุด่าก็เพราะคุณ เพราะฉะนั้นคราวนี้คุณติดหนี้ฉัน ไปหา Basilac Clam มาให้ฉัน 3 อัน คุณสามารถเก็บพวกมันได้จากการล่า Basilisk นี่เพื่อตัวคุณเองนะ รู้ใช่ไหม"
		},
		Summary = "Basilac Clam 3 อัน"
	},
	[14541] = {
		Title = "การไม่มีข่าวไม่ใช่ข่าวดี (No news is not a good news)",
