    [20001] = {
        Title = "สำรวจสถานที่ที่ไม่รู้จัก",
        IconName = "ico_ev.bmp",
        Description = {
            "นักผจญภัยผู้ตกลงให้ความร่วมมือในการสำรวจหลังจากมีรายงานว่าพบมิติใหม่ที่ซ่อนอยู่! เหมือนเช่นเคย เราเดินผ่านประตูเข้าไป… แต่นี่มันโลกใบอื่นงั้นเหรอ?!",
