	[7451] = {
		Title = "การทรยศ",
		IconName = "ico_ep.bmp",
		Description = {
			"ทุกอย่างมันช่างสับสนไปหมด มอนสเตอร์ที่ต่อสู้ในห้องส่องสว่างไม่ใช่ลูกน้องของราชาปีศาจ พวกมันควบคุมฉันโดยที่ฉันไม่รู้ตัว Shnayim เสนาธิการทรยศทุกคน! ฉันต้องแจ้งเรื่องนี้ให้ <NAVI>[Kardui]<INFO>ecl_in03,41,90,0,101,0</INFO></NAVI> ทราบ"
