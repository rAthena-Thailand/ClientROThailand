	[8033] = {
		Title = "ความช่วยเหลือของ Ferlock",
		Description = {
			"Ferlock ขอให้คุณไปชิงของที่ถูกขโมยไปคืนมาจากมอนสเตอร์ที่โจมตีเรือเหาะของ Tarlock จงนำ 2 Will of the Darkness และ 2 Prickly Fruit กลับมาให้ Ferlock"
		},
		Summary = "นำไอเทมที่ถูกขโมยกลับมา"
	},
	[8034] = {
		Title = "ความช่วยเหลือของ Ferlock",
		Description = {
			"Ferlock ขอให้คุณนำจดหมายตอบกลับไปให้ Tarlock น้องชายของเขาแทนเขา"
