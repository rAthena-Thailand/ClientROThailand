	},
	[8172] = {
		Title = "ธุระของ Baba Yaga",
		Description = {
			"ในอนาคต ฉันจะไม่ทำอันตรายผู้คนอีก และฉันจะเป็นเด็กดี! ฉันจะเป็นเทพารักษ์ที่ปกป้องบ้านหลังนี้! หัวใจที่แสนใจดีของคุณที่มาอยู่เป็นเพื่อนกับผีเฝ้าบ้านคนหนึ่ง ฉันจะไม่มีวันลืมเลย ขอบคุณอีกครั้งนะ"
		},
		Summary = "กลับไปหา Baba Yaga"
	},
	[8173] = {
		Title = "ธุระของ Baba Yaga",
		Description = {
			"ฉันซื้อไม้กวาดให้คุณยายที่ Payon ฉันไม่มีเวลาทำความสะอาดมันเลย แต่ฉันก็ครอบครองมันไม่ได้เพราะฉันไม่มีเวลาพอ เอ้า ขยับสิ! ถ้าชักช้า เดี๋ยวจะโดนกินวิญญาณนะ! ฮิฮิฮิฮิฮิฮิฮิ"
		},
		Summary = "ฉันกำลังซื้อไม้กวาดจาก Payon"
	},
	[8174] = {
		Title = "ธุระของ Baba Yaga",
		Description = {
			"เมื่อนานมาแล้ว ฉันเพิ่งขโมยไม้กวาดที่เพิ่งทำเสร็จใหม่ๆ มาจาก Goblin ตัวหนึ่ง ฉันดีใจที่พวก Goblin ทำมันออกมาได้ดีและดีใจที่ได้ขโมยมันมา แต่มันกลับถูกขโมยไปอีกที... ลูกชายของฉันออกไปตามหาไม้กวาดครั้งแล้วครั้งเล่า ฉันเพลียใจจริงๆ เพราะฉันเอาแต่แอบอยู่ในต้นไม้และเล่นสนุกกับตัวเอง"
		},
		Summary = ""
	},
	[8175] = {
		Title = "ธุระของ Baba Yaga",
		Description = {
			"อา ฉันแพ้แล้ว สนุกจังเลย ในเมื่อฉันสนุกแล้ว งั้นจะมอบไม้กวาดให้ตามที่สัญญาไว้ คุณเป็นคนที่ตลกดีนะ ไว้มีโอกาสคราวหน้ามาเล่นกันใหม่ล่ะ งั้นก็รับนี่ไป"
		},
		Summary = "กลับไปหา Baba Yaga"
	},
	[8176] = {
		Title = "กุญแจทองคำ",
		Description = {
			"ดีที่มาเสียที ฉันสร้าง 'กุญแจทองคำ' เสร็จพอดี! ตอนนี้ ไปช่วย Maria Morevna ด้วยสิ่งนี้กันเถอะ ระวังตัวจาก Koshey ด้วยล่ะ ฮี่ๆๆๆๆ"
		},
		Summary = "ปลดปล่อย Maria Morevna"
	},
	[8177] = {
		Title = "Koshey อมตะ",
		Description = {
			"ตกลง ... ถ้าใช้มือของคุณตอนนี้ จะสามารถช่วย Maria Morevna ได้ ฉันจะพา Maria Morevna หลบไปเอง ฝากจัดการ Koshey ด้วย!!"
		},
		Summary = "กำจัด Koshey"
	},
	[8178] = {
		Title = "น้ำแห่งความเป็นและน้ำแห่งความตาย",
		Description = {
			"Maria ยังไม่ตาย แต่เธอก็ไม่มีชีวิต ในการจะช่วยเธอ คุณต้องใช้ 'น้ำแห่งความเป็น' และ 'น้ำแห่งความตาย' ถ้าคุณไปหา Babaya (Yaga) คุณจะสามารถช่วยเธอได้ ฉันจะปกป้องเธอจากความตายเอง Babaya ฉันหวังว่าคุณจะได้รับ 'น้ำแห่งความเป็น' และ 'น้ำแห่งความตาย' มาจากท่าน ได้โปรด"
		},
		Summary = "นำน้ำแห่งความเป็นและน้ำแห่งความตายมา"
	},
	[8179] = {
		Title = "น้ำแห่งความเป็นและน้ำแห่งความตาย",
		Description = {
			"'น้ำแห่งความเป็น' ... ฉันจำได้ว่าเคยได้ยินเรื่องนี้มาสักวันหนึ่ง ^0000ff น้ำศักดิ์สิทธิ์หนึ่งขวด ^000000 และ ^0000ff สามารถสร้างได้จากใบไม้สองใบจากต้นไม้ที่ประกอบขึ้นเป็นโลก ^000000 และ 'น้ำแห่งความตาย '... สิ่งนี้สร้างได้ด้วยน้ำคำสาป 1 ชิ้น ^0000ff ^000000 และดอกไม้ของ ^0000ff hyrena (Hinalle) ^000000 10 ชิ้น"
		},
		Summary = "นำวัตถุดิบไปให้ Babayaga"
	},
	[8180] = {
		Title = "น้ำแห่งความเป็นและน้ำแห่งความตาย",
		Description = {
			"มาสิ รับพวกนี้ไปช่วย Maria Morevna นะเจ้าหนู ฮี่ๆ ขั้นแรก ริน 'น้ำแห่งความตาย' ใส่ Maria Morevna เพื่อกำจัดบาดแผลและคำสาป และ 'น้ำแห่งความเป็น' จะทำให้ Maria รอดชีวิต เมื่อได้ไปแล้ว ก็ไปลุยเลย!"
		},
		Summary = "ไปหา Maria Morevna"
	},
	[8181] = {
		Title = "Sight Blaster",
		Description = {
			"ทักษะนี้ฟังดูเหมือนง่ายแต่มันค่อนข้างยากที่จะเรียนรู้ อัศวิน (Knights) คือผู้เชี่ยวชาญทักษะที่ใช้ผลักศัตรูให้ถอยหลัง ดังนั้นจงไปหาใครสักคนที่สามารถอธิบายทฤษฎีการผลักถอยหลัง (Push Back theory) ให้คุณฟังได้ใน Prontera ตรวจสอบทิศทาง 11 นาฬิกาในมินิแมพของคุณ"
		},
		Summary = ""
	},
	[8182] = {
		Title = "ทฤษฎีการผลักถอยหลัง (Push Back Theory)",
		Description = {
			"เอาล่ะ ฉันได้อธิบายเรื่องการผลักให้ดีที่สุดเท่าที่จะทำได้แล้ว จงตั้งสมาธิและฝึกฝนทฤษฎีนี้ด้วยตัวเอง แล้วคุณก็น่าจะทำมันได้"
		},
		Summary = "กลับไปหา Meow"
	},
	[8183] = {
		Title = "Sight Blaster",
		Description = {
			"ฉันไม่ใช่คนใจบุญสุนทานนะ ดังนั้นฉันคาดหวังค่าเล่าเรียนสำหรับคำแนะนำและความพยายามทั้งหมดของฉัน! จงไปนำ ^ff000010 Crystal Blues, 10 Green Lives, 10 Red Bloods, 10 Winds of Verdure^000000 มาให้ฉัน!"
