	[18147] = {
		Title = "บันทึกการหลบหนีของนักวิทยาศาสตร์ - 2",
		IconName = "ico_vr.bmp",
		Description = {
			"Hugel Field <NAVI>[Chapter 1-1]<INFO>hu_fild02,270,273,0,101,0</INFO></NAVI>: \"ควรเคลื่อนที่เมื่อปลอดภัยเท่านั้น\" Eisen Werner สั่งการเจ้าผีเสื้ออย่างไม่แยแส Eisen Werner จะซ่อนตัวอย่างปลอดภัยใกล้กับต้นไม้ในขณะที่ผีเสื้อคอยจัดการกับพวก Norbus ในบริเวณใกล้เคียง"
		},
		Summary = "มาทำให้แน่ใจว่าปลอดภัย"
