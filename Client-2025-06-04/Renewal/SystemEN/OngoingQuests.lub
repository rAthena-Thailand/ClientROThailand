		NpcPosY = 200,
		RewardEXP = "Lv110 5%",
		RewardJEXP = "800000",
		RewardItemList = {
			{ItemID = 25723, ItemNum = 3}
		}
	},
	[5858] = {
		Title = "มาเป็นเพื่อนกับ Morning กันเถอะ",
