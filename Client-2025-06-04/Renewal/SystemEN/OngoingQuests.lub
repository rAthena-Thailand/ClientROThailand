	[7214] = {
		Title = "การฝึกขั้นสูง ระยะที่ 1 การปราบปราม Comodo",
		Description = {
			"บริเวณหน้าถ้ำทางทิศเหนือของ Comodo มี \"Romeo\" สมาชิกกลุ่ม Eden รอนักเรียนฝึกหัดคนต่อไปอยู่"
		},
		Summary = "ตามหา Romeo ใน Comodo"
	},
	[7215] = {
		Title = "ระยะที่ 1 ส่วนที่ 1 - การปราบปราม",
		Description = {
			"Romeo ขอให้คุณกำจัด Stalactic Golem เพื่อทำความเข้าใจบรรยากาศภายในถ้ำและคู่ต่อสู้ จงระวังมอนสเตอร์ตัวอื่นๆ รอบข้างและจัดการ Stalactic Golem"
		},
		Summary = "ล่า Stalactic Golem 3 ตัว"
	},
	[7216] = {
		Title = "ระยะที่ 1 ส่วนที่ 2 - ฝ่าถ้ำทางเหนือ",
		Description = {
			"เมื่อคุณรู้แล้วว่าถ้ำและศัตรูเป็นอย่างไร ภารกิจนี้คือการฝ่าศัตรูออกไปให้พ้นถ้ำ Romeo จะรอคุณอยู่อีกด้านหนึ่งของถ้ำ"
		},
		Summary = "กำจัด Golem และฝ่าถ้ำออกไป Stalactic Golem 10 ตัว"
	},
	[7217] = {
		Title = "ระยะที่ 1 ส่วนที่ 3 - การเคลียร์พื้นที่",
		Description = {
			"Romeo ชมเชยความสามารถในการฝ่าถ้ำของฉันและมอบภารกิจถัดไป เป้าหมายคือการนำความสงบสุขกลับคืนสู่ผืนป่าโดยการกำจัด Wootan Fighter และ Dryad พร้อมรวบรวมไอเทม"
		},
		Summary = "Shoulder Protector 5 อัน, Sharp Leaf 7 อัน"
	},
	[7218] = {
		Title = "รายงานต่อ Instructor Ur",
		Description = {
			"คุณเสร็จสิ้นภารกิจปราบปราม Comodo ทั้งหมดในระยะแรกของหลักสูตรการฝึกขั้นสูงของ Eden Group แล้ว ที่เหลือคือกลับไปยังสำนักงานกลุ่ม Eden และรายงานต่อ Instructor Ur"
		},
		Summary = "รายงานต่อ Instructor Ur"
	},
	[7219] = {
		Title = "การฝึกขั้นสูง ระยะที่ 2 Glast Heim",
		Description = {
			"การฝึกระยะที่สองเริ่มต้นขึ้นที่ Glast Heim จงไปพบ \"Johan\" ที่หน้าอาราม Glast Heim (Monastery) เพื่อรับมอบหมายการฝึก"
