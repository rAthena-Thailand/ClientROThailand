		Summary = "คุยกับ Kiren"
	},
	[7224] = {
		Title = "ระยะที่ 3 ส่วนที่ 1 - Porcellio",
		Description = {
			"Kiren มีบุคลิกที่ค่อนข้างสบายๆ เขาให้ภารกิจเดินเล่นรอบๆ ฟิลด์ใกล้ๆ และกำจัด Porcellio ดูเหมือนจะเป็นคำขอจากชาวบ้านแถวนั้น"
		},
		Summary = "ล่า Porcellio 30 ตัว"
	},
	[7225] = {
		Title = "ระยะที่ 3 ส่วนที่ 2 - นี่คือฝันร้าย (1)",
		Description = {
			"เดิมทีเป็นคำขอให้กำจัด Noxious ตามเรื่องร้องเรียนของชาวเมือง Einbroch แต่ Kiren ยกเลิกคำขอนี้ไปฝ่ายเดียว"
		},
		Summary = "คุณไม่ต้องจับ Noxious แล้ว"
	},
	[7226] = {
		Title = "ระยะที่ 3 ส่วนที่ 2 - นี่คือฝันร้าย (1)",
		Description = {
			"ภารกิจการฝึกที่รวบรวมเรื่องร้องเรียนของชาวเมือง Einbroch มาแบบเต็มๆ สิ่งที่คุณต้องทำคือจัดการกับต้นเหตุของเขม่าควันทางตอนเหนือของเมือง"
		},
		Summary = "ล่า Venomous 30 ตัว"
	},
	[7227] = {
		Title = "ระยะที่ 3 ส่วนที่ 2 - นี่คือฝันร้าย (2)",
		Description = {
			"หนึ่งในปัญหาที่ใหญ่ที่สุดจากเรื่องร้องเรียนของชาวเมือง Einbroch คือพวก Teddy Bear ที่ถูกทิ้งซึ่งเดิมผลิตมาเป็นอาวุธ Kiren บอกว่าต้องระวังเพราะพวกมันเป็นศัตรูที่แข็งแกร่งมาก"
		},
		Summary = "ล่า Teddy Bear 5 ตัว"
	},
	[7228] = {
		Title = "รายงานต่อ Instructor Ur",
		Description = {
			"ในฐานะนักเรียนฝึกหัด ฉันได้ทำตามคำขอของชาวเมือง Einbroch ทั้งหมดเสร็จสิ้นแล้ว กลับไปยังสำนักงานกลุ่ม Eden และรายงานต่อ Instructor Ur"
		},
		Summary = "รายงานต่อ Instructor Ur"
	},
	[7229] = {
		Title = "การฝึกขั้นสูง ระยะที่ 4 Ice Cave",
		Description = {
			"ระยะสุดท้ายของการฝึกคือถ้ำน้ำแข็ง (Ice Cave) ทางทิศตะวันออกเฉียงเหนือของ Rachel สุดปลายทุ่งราบ Ida สมาชิกชื่อ Naomi จะรอคุณอยู่ที่ทางเข้าถ้ำ"
		},
		Summary = "คุยกับ Naomi"
	},
	[7230] = {
		Title = "ระยะที่ 4 ส่วนที่ 1 - Siroma",
		Description = {
			"ภารกิจการฝึกนี้สะท้อนถึงคำขอของชาวบ้านในละแวกนั้นแบบ 100% นั่นคือการกำจัด Siroma ที่คอยขัดขวางการเก็บเกี่ยวน้ำแข็ง"
		},
		Summary = "ล่า Siroma 30 ตัว"
	},
	[7231] = {
		Title = "ระยะที่ 4 ส่วนที่ 2 - น้ำแข็ง!",
		Description = {
			"พวกเขาตัดสินใจที่จะกำจัด Siroma เพิ่มเติม เนื่องจากมันมีอัตราการแพร่พันธุ์ที่ค่อนข้างเร็ว นอกจากนี้ฉันยังได้รับคำขอส่วนตัวจาก Naomi อีกด้วย Naomi บอกว่าไม่ใช่นะ แต่นี่มันคือวัตถุดิบสำหรับทำน้ำแข็งไสชัดๆ Ice Cubic 30 อัน, Sweet Sauce 1 อัน และ Milk 1 อัน"
		},
		Summary = "ล่า Siroma 30 ตัว และนำวัตถุดิบน้ำแข็งไสมาให้"
	},
	[7232] = {
		Title = "รายงานต่อ Instructor Ur",
		Description = {
			"ไม่ว่าเรื่องน้ำแข็งไสนั่นจะเป็นอย่างไร แต่เจ้า Siroma ที่เป็นอุปสรรคต่อการเก็บน้ำแข็งก็ถูกจัดการไปพอสมควรแล้ว ฉันทำเควสต์และการฝึกทั้งหมดเสร็จสิ้นแล้ว กลับไปยังสำนักงานกลุ่ม Eden และรายงานต่อ Instructor Ur"
		},
		Summary = "รายงานต่อ Instructor Ur"
	},
	[7233] = {
		Title = "การฝึกขั้นสูง ระยะที่ 4 Ash Vacuum",
		Description = {
			"Instructor Ur ได้พบกับ Margaret สมาชิกกลุ่ม Eden ที่ออกเดินทางไปกับคณะสำรวจ Ash Vacuum ในฐานะภารกิจการฝึกสุดท้าย และขอให้ฉันช่วยงานเธอ"
		},
		Summary = "คุยกับ Margaret"
	},
	[7234] = {
		Title = "ความช่วยเหลือของ Margaret",
		Description = {
			"Margaret ที่ฉันพบในค่ายสำรวจของเธอกำลังกังวลมาก เนื่องจากเพื่อนร่วมงานของเธอ Miru และ Mine ยังไม่กลับมา ฉันควรไปหา Miru และ Mine เพื่อดูว่าเกิดอะไรขึ้นกับพวกเขา Miru อยู่ทางทิศตะวันออก และ Mine อยู่ทางทิศตะวันตก หลังจากพบ Miru แล้ว ฉันควรไปพบ Mine ต่อ"
		},
		Summary = "ตามหา Meeru และ Mine"
	},
	[7235] = {
		Title = "ระยะที่ 4 สถานการณ์ของ Meeru",
		Description = {
			"สองพี่น้องฝาแฝด Miru และ Mine ออกไปลาดตระเวนในทิศทางตรงกันข้ามเพราะการทะเลาะเบาะแว้งเรื่องเล็กน้อย Miru ขอให้เธอช่วยจับ Nepenthes ตามที่เธอได้สัญญาไว้"
		},
		Summary = "ล่า Nepenthes 1 ตัว"
	},
	[7236] = {
		Title = "ระยะที่ 4 สถานการณ์ของ Mine",
		Description = {
			"เนื่องจากความขัดแย้งกับ Miru ทำให้ Mine ถูกบังคับให้ต้องกำจัด Pinguicula เพียงลำพัง มาช่วย Mine หาวิธีเอาชนะ Pinguicula กันเถอะ"
		},
		Summary = "ล่า Pinguicula 5 ตัว"
	},
	[7237] = {
		Title = "รายงานต่อ Instructor Ur",
		Description = {
			"Margaret บอกให้ฉันกลับไปที่สำนักงานกลุ่ม Eden และรายงานต่อ Instructor Ur โดยบอกว่าเธอคลายความกังวลได้แล้วและการฝึกนั้นเพียงพอแล้ว"
		},
		Summary = "รายงานต่อ Instructor Ur"
	},
	[7238] = {
		Title = "งานวานของ Thorn (ระดับง่าย)",
		Description = {
			"นี่คือคำขอจาก Thorn ช่างตีเหล็กของกลุ่ม Eden หัวใจสำคัญของงานนี้คือการหา \"Iron Ore 20 อัน และ Iron 10 อัน\" ที่ Thorn ต้องการ"
		},
		Summary = "Iron Ore 20 อัน, Iron 10 อัน"
	},
	[7239] = {
		Title = "งานวานของ Thorn (ระดับปกติ)",
		Description = {
