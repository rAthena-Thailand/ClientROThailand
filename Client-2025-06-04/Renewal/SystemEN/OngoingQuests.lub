		},
		Summary = "แค่คุยกับเขาอีกครั้ง"
	},
	[10083] = {
		Title = "หนีจากความจริง สู่โลกที่กว้างใหญ่",
		Description = {
			"ในที่สุดคุณก็ได้รู้รสชาติที่ Iromo ชอบ"
		},
		Summary = "ไปหาเขาพร้อมกับ Monster's Feed และ Red Potion"
	},
	[10084] = {
		Title = "หนีจากความจริง สู่โลกที่กว้างใหญ่",
		Description = {
			"เราพบเหตุผลแล้วว่าทำไมเขาถึงเอาแต่อยู่ในบ้าน"
		},
		Summary = "ถ้าไม่มี Wild Rose อยู่รอบๆ ตัวเขา เขาคงยอมออกไปข้างนอก"
	},
	[10085] = {
		Title = "หนีจากความจริง สู่โลกที่กว้างใหญ่",
		Description = {
			"ถึงแม้เราจะกำจัด Wild Rose ไปหมดแล้ว แต่เราก็ยังดำเนินการต่อไม่ได้มากนัก"
		},
		Summary = "มาทำตามคำแนะนำของแม่เขากันเถอะ"
	},
	[10086] = {
		Title = "หนีจากความจริง สู่โลกที่กว้างใหญ่",
		Description = {
			"เราได้ข้อมูลที่เป็นประโยชน์แล้ว! เขาหวังว่าจะมีพี่ชายหรือน้องชายเป็นของตัวเอง!"
		},
		Summary = "แค่เล่าเรื่องความสัมพันธ์แบบพี่น้องให้เขาฟัง ถ้าคุณไม่รู้เรื่อง ให้ลองไปหาพี่น้องและใช้เวลากับพวกเขา จากนั้นคุณจะเล่าเรื่องให้เขาฟังได้"
	},
	[10087] = {
		Title = "หนีจากความจริง สู่โลกที่กว้างใหญ่",
		Description = {
			"คุณเล่าเรื่องให้เขาฟังแล้ว แต่เขากลับงอนอีกครั้ง ไม่มีความคืบหน้าแล้ว!"
		},
		Summary = "เวลาจะเยียวยาทุกสิ่ง มาทำตามคำแนะนำของแม่เขากันเถอะ"
	},
	[10088] = {
		Title = "หนีจากความจริง สู่โลกที่กว้างใหญ่",
		Description = {
			"เขาค่อนข้างมองมิตรภาพในแง่ร้าย"
		},
		Summary = "เล่าเรื่องเพื่อนของคุณให้เขาฟัง ถ้าคุณไม่รู้เรื่องราวเกี่ยวกับเพื่อนเลย ก็แค่ลองไปสัมผัสมันดู"
	},
	[10089] = {
		Title = "หนีจากความจริง สู่โลกที่กว้างใหญ่",
		Description = {
			"เรื่องราวของคุณดูเหมือนจะมีอิทธิพลต่อเขามาก"
		},
		Summary = "คุณได้ผ่านประสบการณ์ต่างๆ มาเพื่อบอกเขาแล้ว จงเล่าทุกสิ่งที่คุณรู้สึกจากประสบการณ์นั้นให้เขาฟัง"
	},
	[10090] = {
