	},
	[70011] = {
		Title = "ป้ายบอกทางที่เน่าเปื่อย",
		Description = {
			"เมื่อคุณพบป้าย Pirate Skeleton หลายตัวก็ปรากฏกายขึ้น อ่านป้ายบอกทางอีกครั้งเพื่อรับข้อมูลเพิ่มเติม"
		},
		Summary = ""
	},
	[70012] = {
		Title = "สมบัติของ Izlude Irene",
		Description = {
			"\"สำหรับเบาะแสถัดไป เจ้าต้องลงไปข้างล่างอีกหนึ่งชั้น เมื่อพบมันแล้ว เจ้าอาจอ้างสิทธิ์ในสมบัติของ Irene... แต่การจะนำความมั่งคั่งกลับบ้าน เจ้าต้องผ่านการทดสอบความรู้เรื่องโจรสลัดของนางก่อน\""
		},
		Summary = "ตามหา Mouth และพูดคุยกับเขา"
	},
	[70013] = {
		Title = "กำลังหา Data",
		Description = {
			"Mouth บอกว่าเพื่อนของพวกเขาที่ชื่อ Data กำลังวิ่งไปยังเกาะทางเหนือของ Byalan Island ชั้นที่ 3 ที่มีหินรูปเห็ด"
		},
		Summary = ""
	},
	[70014] = {
		Title = "นายทหารของ Izlude",
