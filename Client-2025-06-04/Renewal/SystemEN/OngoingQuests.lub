	[12500] = {
		Title = "Red Pepper-Lambda Suppression",
		Description = {
			"คุณต้องปราบ Red Pepper Lambda หนึ่งในสามผู้ดูแลพื้นที่ปลอดภัย และยึดอำนาจของผู้ดูแลมา แน่นอนว่ามันจะฟื้นคืนในภายหลัง แต่ว่า..."
