	[7587] = {
		Title = "Elizabeth และผ้าไหม",
		Description = {
			"เมื่อมี ^0000FF Elizabeth^000000 ติดตามไปด้วย จงไปยังที่ซ่อนของงูหลามที่ Durian พบและเก็บรักษาผ้าไหมไว้ สามารถเข้าสู่ที่ซ่อนได้ผ่านสระน้ำในหมู่บ้าน Archer (Archer Village's Pond)"
		},
		Summary = "Crystal Silk 10"
	},
	[7588] = {
		Title = "ผ้าไหมของวันนี้!",
		Description = {
			"วันนี้ ฉันได้รับคำขอให้รวบรวมผ้าไหมที่กรอบจากที่ซ่อนของ Silk กล่าวกันว่าทางเข้ารังของ Silk อยู่ที่สระน้ำของหมู่บ้าน Archer และบริเวณริมน้ำทางตะวันตกของ Prontera"
		},
		Summary = "Crystal Silk 10"
	},
