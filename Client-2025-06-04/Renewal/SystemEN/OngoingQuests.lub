	[9240] = {
		Title = "<บันทึกคำให้การของ Luen>",
		Description = {
			"บันทึกคำให้การของ ^0000FFLuen^000000: ไปเดินเล่นในดินแดนแห่งมวลดอกไม้บาน เห็นคนที่มีผมสีแดงสั้นท่าทางรีบร้อน ไม่สามารถระบุเพศได้ ไม่คุ้นหน้าเนื่องจากสีผมที่หาได้ยาก เคยคิดว่า Luen เป็นคนแรกที่มาเจอฉัน แต่จริงๆ แล้วแม่ของ Luen เป็นคนแรกที่พบ"
		},
		Summary = ""
	},
