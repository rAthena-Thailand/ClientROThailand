	[14520] = {
		Title = "ฉันไม่ใช่แค่เด็กคนหนึ่งนะ (I'm not even a kid or two)",
		Description = {
			"โปรดพา Neti มาปลอบโยนที ถ้าฉันไป เขาจะหนีไป ฉันจะอยู่ที่แมพตอน 9 นาฬิกา ฉันจะฝึกซ้อมธนูอยู่บนเกาะเล็กๆ ริมแม่น้ำ"
		},
		Summary = "พา Netty มา"
	},
	[14521] = {
		Title = "โปรดช่วยฉันเรื่องลูกธนูที (Please help me with the arrows)",
		Description = {
			"เจ้าพวกกระต่ายตัวเป็นๆ เก็บลูกธนูไปหมดเลย พวกมันพยายามจะสร้างบ้านหรือไงกัน? อย่างไรก็ตาม ฉันมีลูกธนูแค่ชุดนั้นชุดเดียว คุณช่วยไปจับกระต่ายแล้วนำลูกธนูมาให้ฉันหน่อยได้ไหม? ขอสัก 5 ดอก..."
		},
		Summary = "Old Arrow 5 ดอก"
	},
	[14522] = {
		Title = "ฉันช่วยไม่ได้จริงๆ (I can't help it)",
