	[13009] = {
		Title = "คำขอ Sting (Sting Request)",
		Description = {
			"คุณเคยได้ยินเรื่องการจาริกแสวงบุญของนักบวชไหม? มี Sting จำนวนมากในทางระบายน้ำใต้ดินและในถ้ำ พวกมันคอยรบกวนความสงบของเหล่านักบวช"
