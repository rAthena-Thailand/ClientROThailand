	[8190] = {
		Title = "ขยิบตาเสน่ห์ (Charming Wink)",
		Description = {
			"คุณต้องนำ ^FF00001 Crystal Mirror^0000000 มาให้ฉัน! เครื่องมือนี้จำเป็นอย่างยิ่งต่อบทเรียน ดังนั้นจงไปนำมันมาให้ฉันโดยเร็ว!"
