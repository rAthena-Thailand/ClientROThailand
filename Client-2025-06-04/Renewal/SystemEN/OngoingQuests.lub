	[7189] = {
		Title = "การรวบรวมข้อมูล - ในโรงงาน",
		IconName = "ico_ep.bmp",
		Description = {
			"ชายหูแมวเหรอ? ไม่เคยได้ยินเลย อย่ามัวแต่ตามหาเรื่องเหลวไหลแบบนั้นเลย ไปพบ Ahat ดีกว่า เขาเป็นคนดีมาก! เขาคือต้นแบบของชาว Sapha เลยล่ะ!"
		},
		Summary = "รวบรวมข้อมูลสำเร็จ 2"
	},
	[7190] = {
		Title = "การรวบรวมข้อมูล - ที่กลุ่มองครักษ์",
		IconName = "ico_ep.bmp",
		Description = {
			"หูแมว? แน่ใจนะ? พวกมนุษย์เป็นแบบนี้กันหมดเลยหรือเปล่า? ทำไมไม่ไปพบ Ahat ล่ะ เขาเป็นชาว Sapha ที่แข็งแกร่งมาก ถึงเขาจะเป็น Jarute ที่ต้องทำงานกับกองเอกสาร แต่เขาต้องซ่อนพลังที่แท้จริงเอาไว้แน่ๆ!!"
		},
		Summary = "รวบรวมข้อมูลสำเร็จ 3"
	},
	[7191] = {
		Title = "การมอบหมายจาก Shay - BK",
