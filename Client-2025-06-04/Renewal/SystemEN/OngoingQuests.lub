	[1009] = {
		Title = "เปลี่ยนอาชีพเป็น Merchant",
		Description = {
			"ไปรับพัสดุที่จะนำไปส่งจากโกดังสินค้า จากนั้นมุ่งหน้าไปที่อดีตสมาคม Swordman ใน Prontera เมื่อไปถึงที่นั่น ให้ไปหาพนักงาน Kafra ที่ประจำการอยู่ เธอมีชื่อว่า Blossom"
