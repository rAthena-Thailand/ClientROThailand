	},
	[8009] = {
		Title = "สมัครเปลี่ยนอาชีพเป็น Priest",
		Description = {
			"ยอมรับการทดสอบทั้งสามแห่งความเป็น Priest เพื่อเปลี่ยนอาชีพ"
		},
		Summary = "กำลังสมัครเปลี่ยนอาชีพเป็น Priest"
	},
	[8010] = {
		Title = "เปลี่ยนอาชีพเป็น Priest",
		Description = {
			"คุณต้องไปจาริกแสวงบุญ อันดับแรก ไปพบ Rubalkabara ที่ซากปรักหักพังทางตะวันออกเฉียงเหนือของ Prontera อันดับที่สอง ไปพบ Sister Mathilda ที่อยู่ใกล้ Morroc ทางตะวันตกเฉียงใต้ของ Prontera และสุดท้าย ไปพบ Father Yosuke ในฟิลด์ทางตะวันตกเฉียงเหนือของ Prontera"
		},
		Summary = "การทดสอบที่ 1: การจาริกแสวงบุญ"
	},
	[8011] = {
		Title = "เปลี่ยนอาชีพเป็น Priest",
		Description = {
			"เคลื่อนย้ายไปยังสถานที่ฝึกฝนทางจิตวิญญาณ คุยกับ Peter S. Alberto"
		},
		Summary = "การทดสอบที่ 2: การฝึกฝนทางจิตวิญญาณ"
	},
	[8012] = {
		Title = "เปลี่ยนอาชีพเป็น Priest",
		Description = {
			"เริ่มการฝึกฝน กำจัดมอนสเตอร์ทั้งหมด! อย่าแสดงความเมตตาต่อสิ่งมีชีวิตแห่งความมืด!"
		},
		Summary = "การทดสอบที่ 2: การฝึกฝนทางจิตวิญญาณ"
	},
	[8013] = {
		Title = "เปลี่ยนอาชีพเป็น Priest",
		Description = {
			"คุณเสร็จสิ้นการฝึกฝนทางจิตวิญญาณแล้ว! ไปพบ Sister Cecilia"
		},
		Summary = "การทดสอบเปลี่ยนอาชีพ Priest"
	},
	[8014] = {
		Title = "เปลี่ยนอาชีพเป็น Priest",
		Description = {
			"จงให้คำมั่นสัญญาว่าจะอุทิศตนเพื่อพระเจ้า"
		},
		Summary = "การทดสอบที่ 3: การอุทิศตนต่อพระเจ้า"
	},
	[8015] = {
		Title = "เปลี่ยนอาชีพเป็น Priest",
		Description = {
			"คุณทำภารกิจทั้ง 3 สำเร็จแล้วตามคำสาบานแห่งความเป็น Priest กลับไปพบ Bishop Paul"
		},
		Summary = "กำลังสมัครเปลี่ยนอาชีพเป็น Priest"
	},
	[8016] = {
		Title = "เปลี่ยนอาชีพเป็น Priest",
		Description = {
			"ตอนนี้คุณได้กลายเป็น Priest แล้ว!!"
		},
		Summary = ""
	},
	[8017] = {
		Title = "การตรวจสอบโรงงาน",
		Description = {
			"Zelmeto ขอให้คุณช่วยเขาตรวจสอบเครื่องจักรในโรงงานทีละเครื่องเพื่อดูว่าเครื่องไหนต้องได้รับการซ่อมแซม ตามหาแผงควบคุมที่ 2 และรายงานกลับไปยัง Zelmeto"
		},
		Summary = ""
	},
	[8018] = {
		Title = "การตรวจสอบโรงงาน",
		Description = {
			"คุณพบแผงควบคุมที่ 2 แล้ว และมันพังเสียหายโดยสิ้นเชิง รายงานเรื่องนี้กลับไปยัง Zelmeto"
		},
		Summary = ""
	},
	[8019] = {
		Title = "การตรวจสอบโรงงาน",
		Description = {
			"Zelmeto ขอให้คุณตรวจสอบเครื่องควบคุมแรงดันอัตโนมัติ และรายงานปัญหาที่พบไม่ว่ามันจะดูเล็กน้อยแค่ไหนก็ตาม"
		},
		Summary = ""
	},
	[8020] = {
		Title = "การตรวจสอบโรงงาน",
		Description = {
			"คุณพบเครื่องควบคุมแรงดันอัตโนมัติแล้ว และหลังจากตรวจสอบอย่างละเอียดมากขึ้น คุณพบว่ามันส่งเสียงครูดที่ผิดปกติออกมา และสกรูที่พื้นผิวบางตัวก็หลวม จงรายงานสิ่งที่คุณพบให้ Zelmeto ทราบ"
		},
		Summary = ""
	},
	[8021] = {
		Title = "การตรวจสอบโรงงาน",
		Description = {
			"ตอนนี้ Zelmeto ขอให้คุณไปตรวจสอบแผงควบคุมอีกอันหนึ่ง มันคล้ายกับอันแรกแต่มีขนาดใหญ่กว่า ตั้งอยู่บริเวณใจกลางโรงงาน จงตามหามันและรายงานกลับไปยัง Zelmeto"
		},
		Summary = ""
	},
	[8022] = {
		Title = "การตรวจสอบโรงงาน",
		Description = {
			"แผงควบคุมหลักดูเหมือนจะไม่มีปัญหาอะไร แต่หลังจากลองเคาะที่พื้นผิวของมัน คุณกลับได้ยินเสียงกังวานแบบกลวงๆ ที่น่าใจหาย ดูเหมือนว่าจะมีชิ้นส่วนบางอย่างขาดหายไป... จงรายงานสิ่งที่คุณพบให้ Zelmeto ทราบ"
		},
		Summary = ""
	},
	[8023] = {
