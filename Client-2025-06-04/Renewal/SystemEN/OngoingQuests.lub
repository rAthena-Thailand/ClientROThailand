	[8140] = {
		Title = "แหวนสีแดง (The Red Ring)",
		Description = {
			"คุณปู่ Vassili บอกว่าเขาเคยมีแหวนสีแดงอยู่หนึ่งวงแต่เขาให้ลูกสาวชื่อ Mashenka ไป ซึ่งเธอก็เสียชีวิตไปอย่างน่าเศร้า แต่เขายังมีลูกสาวอีกคนชื่อ Ryubaba ซึ่งอาจจะรู้เรื่องแหวนสีแดงวงนั้น"
