	[8087] = {
		Title = "Klitzer และ Calla",
		Description = {
			"ขอบคุณที่ช่วย Klitzer ลูกชายของฉันนะ น่าเศร้าที่เจ้าลูกโง่นั่นไม่มีหัวคิดเลยในเรื่องบางอย่างเช่นการเลือกเสื้อผ้า ผู้ชายควรจะสวมเสื้อผ้าที่ดูดี อย่าง Formal Suit หรือ Tuxedo สำหรับการประชุมที่สำคัญและโอกาสพิเศษต่างๆ"
		},
		Summary = "หาชุดที่ดูดีให้ Klitzer"
	},
	[8088] = {
		Title = "Klitzer และ Calla",
		Description = {
			"คุณช่วยเปิดหูเปิดตาให้ผมจริงๆ ครับ จากนี้ไปผมจะพยายามอย่างเต็มที่เพื่อให้ได้รับการยอมรับจากพ่อแม่ของ Calla และเป็นคนที่คู่ควรกับความรักของเธอ"
		},
		Summary = ""
	},
	[8089] = {
		Title = "อัญมณีที่ถูกขโมย",
		Description = {
			"\"ฉันไม่มีหลักฐานหรอกนะ แต่ฉันสงสัยว่ามันถูกขโมยโดย Phobe คนรับใช้ที่หายตัวไปในช่วงเวลาเดียวกับที่อัญมณีหายไป คุณอาจจะอยากลองถามคนรับใช้คนอื่นๆ เกี่ยวกับที่อยู่ของเขาดู\" - <NAVI>Vincent<INFO>ra_in01,384,246,0,101,0</INFO></NAVI>"
		},
		Summary = "หาข้อมูลเกี่ยวกับที่อยู่ของ Phobe"
	},
	[8090] = {
		Title = "คุณ Manson",
		Description = {
			"\"ความจริงแล้ว ผมไม่รู้อะไรมากนักหรอกเพราะผมเพิ่งเริ่มทำงานที่นี่ ทำไมคุณไม่ลองถามพนักงานอาวุโสดูล่ะ? คุณไปถามคุณ Manson ที่อยู่ข้างในคฤหาสน์ก็ได้\" - <NAVI>Logan<INFO>rachel,114,232,0,101,0</INFO></NAVI>"
		},
		Summary = "ตามหาคุณ Manson"
	},
	[8091] = {
		Title = "Jenny คนสวน",
		Description = {
			"\"อา Jenny คนสวนของเราเป็นคนแนะนำเขาให้ฉันรู้จักน่ะ เธอทำงานให้ท่าน Zhed มานานแล้ว และเธอรักเด็กมากนะ คุณรู้ไหม ถ้าคุณอยากรู้เรื่องของเด็กคนนั้นมากขึ้น คุณควรไปคุยกับ Jenny\" - <NAVI>Manson<INFO>ra_in01,372,200,0,101,0</INFO></NAVI>"
		},
		Summary = "ตามหา Jenny"
	},
	[8092] = {
		Title = "การค้นหาในตลาด",
		Description = {
			"เอาล่ะ ฉันเดาว่าฉันคงต้องไปที่ตลาดแล้วลองถามไปทั่วดู"
		},
		Summary = "ไปที่ตลาด"
	},
	[8093] = {
		Title = "ข้อความปริศนา",
		Description = {
			"คือว่างี้นะ เมื่อคืนนี้มีชายคนหนึ่งฝากบอกใครก็ตามที่กำลังตามหาคนชื่อ Phobe ให้รับข้อความไว้ โดยพื้นฐานแล้ว เขาอยากให้คุณไปที่ \"ถ้ำน้ำแข็ง\" ไหนดูซิ เขาชื่อ... Nogan? Rogan? อะไรประมาณนั้นแหละ"
		},
		Summary = "ไปที่ถ้ำน้ำแข็ง"
	},
	[8094] = {
		Title = "ถูกหักหลังงั้นเหรอ?",
		Description = {
			"คำสั่งของ Vincent คือให้กำจัดใครก็ตามที่ถามถึง Rogan ซึ่งเป็นชื่อที่เขาสร้างขึ้นมาเอง ดูเหมือนว่าเขาจะวางแผนเล่นงานเรานะเพื่อน เสียใจด้วยจริงๆ ถ้าฉันรู้มาก่อน ฉันคงไม่ทำแบบนั้นหรอก"
		},
		Summary = "กลับไปหา Vincent"
	},
	[8095] = {
		Title = "ตามหา Phobe",
		Description = {
			"คุณจะไม่เดือดร้อนแน่ถ้าฉันสามารถหาอัญมณีและ Phobe พบก่อนที่ท่าน Zhed จะกลับมา ดังนั้นฉันจะพยายามหาพวกเขาให้พบโดยเร็วที่สุด Phobe ยังเป็นแค่เด็ก ดังนั้นเขาอาจจะซ่อนตัวอยู่ที่ไหนสักแห่งในเมือง..."
		},
		Summary = "ลองตามหา Phobe"
	},
	[8096] = {
		Title = "พบอัญมณีที่ถูกขโมยแล้ว",
		Description = {
			"บอกให้รู้ไว้นะ ฉันไม่คิดจะกลับบ้านหรอก! อย่างน้อยก็ไม่ใช่ตอนนี้ แต่ช่วยบอกแม่ให้ทีว่าฉันสบายดี ไม่ต้องเป็นห่วง"
		},
		Summary = "กลับไปหา Vincent"
	},
	[8097] = {
		Title = "แจ้งข่าวแก่ Jenny",
		Description = {
			"ในระหว่างที่ฉันนำอัญมณีนี้ไปคืน คุณช่วยไปบอก Jenny ภรรยาของฉันทีได้ไหมว่าลูกชายของเราปลอดภัยดี? เธอเป็นห่วงเขามากเลย..."
		},
		Summary = "Jenny"
	},
	[8098] = {
