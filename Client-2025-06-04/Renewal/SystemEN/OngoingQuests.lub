		},
		Summary = "ดูแลเด็ก"
	},
	[14570] = {
		Title = "การแปรรูปปลากะตัก (Processing Anchovy)",
		Description = {
			"พวกเขาต้องการทำบางอย่างที่เกี่ยวข้องกับปลากะตัก ไปที่โรงงานปลากะตักกันเถอะ"
		},
		Summary = "โรงงานปลากะตัก"
	},
	[14571] = {
		Title = "เรือประมงปลากะตัก (Anchovy fishing ship)",
		Description = {
			"พวกเขาต้องการขึ้นเรือเพื่อที่จะได้คุ้นเคยกับการขนส่งปลากะตัก ไปเยี่ยมชมเรือประมงปลากะตักกันเถอะ"
		},
		Summary = "เรือประมงปลากะตัก"
	},
	[14572] = {
		Title = "หมดหนทาง... (Helpless...)",
		Description = {
			"ฉันเบื่อและเหนื่อยกับการต้องคลุกคลีกับเจ้าสองคนนั้นที่ทำอะไรไม่ได้เลยและไม่มีความกระตือรือร้นจะทำอะไรทั้งสิ้น ฉันควรกลับไปหาคุณ Legalas โดยที่ไม่มีทางเลือกอื่น"
		},
		Summary = "ไปหาคุณ Legalas"
	},
	[14573] = {
		Title = "ฉันต้องการเวลาส่วนตัว (I need the time on my own)",
		Description = {
			"ฉันน่าจะทำงานบางอย่างได้ในขณะที่พวกเขาไม่อยู่ที่นี่ ฉันต้องเก็บงานให้เสร็จ เพราะงั้นช่วยไปคลุกคลีกับพวกเขาสักพักที และโปรดบอกคุณ Kalu ด้วยว่าฉันจะส่งสินค้าไปให้ในเร็วๆ นี้"
		},
		Summary = "รายงานต่อคุณ Kalu"
	},
	[14574] = {
		Title = "ส่งกล่องข้าว (Meal Box Delivery)",
		Description = {
			"ฉันสามารถทำให้พวกเขาอยู่ห่างจากคุณ Legalas เพื่อให้เขาทำงานได้ คุณช่วยนำข้าวกล่องนี้ไปส่งให้ Panna สมาชิกกลุ่มศาลเตี้ยในถ้ำหน่อยได้ไหม? แน่นอนว่าคุณต้องพาพวกเขาไปด้วยนะ"
