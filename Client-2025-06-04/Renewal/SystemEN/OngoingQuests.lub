	 [19116] = {
        Title = "Pisrik's Research (1) (งานวิจัยของ Pisrik 1)",
        IconName = "ico_jq.bmp",
        Description = {
            "ถ้าคุณส่งมอบวัตถุดิบที่ฉันต้องการในตอนนี้ให้ ฉันจะสอนคุณเองว่าในทางกลับกันฉันสามารถสร้างอะไรได้บ้าง วัตถุดิบที่ฉันต้องการในตอนนี้คือ...",
            "ขบ<ITEM>[Yellow Gemstone]<INFO>715</INFO></ITEM> x 5,",
            "ขบ<ITEM>[Empty Potion Bottle]<INFO>1093</INFO></ITEM> x 4,",
            "ขบ<ITEM>[Heart of Mermaid]<INFO>950</INFO></ITEM> x 10,",
            "ขบ<ITEM>[Powder of Butterfly Wing]<INFO>1057</INFO></ITEM> x 10",
            " ",
            "เมื่อคุณรวบรวมวัตถุดิบทั้งหมดได้แล้ว ให้นำไปให้ <NAVI>[Pisrik]<INFO>yuno_in04,33,108,0,101,0</INFO></NAVI>"
        },
        Summary = "",
        NpcSpr = "4_M_ALCHE_D",
        NpcNavi = "yuno_in04",
        NpcPosX = "33",
        NpcPosY = "108"
    },
    [19117] = {
        Title = "Pisrik's Research (2-1) (งานวิจัยของ Pisrik 2-1)",
        IconName = "ico_jq.bmp",
        Description = {
            "ฉันต้องการ <ITEM>[Carnivorous Plant's Seed]<INFO>1032</INFO></ITEM> ประมาณ 20 อันเพื่อทดลองตามทฤษฎีของฉัน คุณพอจะช่วยฉันเรื่องนี้ด้วยได้ไหม?",
            " ",
            "เมื่อคุณรวบรวมวัตถุดิบทั้งหมดได้แล้ว ให้นำไปให้ <NAVI>[Pisrik]<INFO>yuno_in04,33,108,0,101,0</INFO></NAVI>"
        },
        Summary = "Carnivorous Plant's Seeds 20 อัน",
        NpcSpr = "4_M_ALCHE_D",
        NpcNavi = "yuno_in04",
        NpcPosX = "33",
        NpcPosY = "108"
    },
    [19118] = {
        Title = "Pisrik's Research (2-2) (งานวิจัยของ Pisrik 2-2)",
        IconName = "ico_jq.bmp",
        Description = {
            "การทดลองของฉันดูเหมือนจะไม่เป็นไปด้วยดีอย่างที่คาดไว้ คุณช่วยหา <ITEM>[Carnivorous Plant's Seed]<INFO>1032</INFO></ITEM> ให้ฉันเพิ่มอีกแค่อันเดียวได้ไหม? ฉันจะขอบคุณมากเลย",
            " ",
            "เมื่อคุณรวบรวมวัตถุดิบทั้งหมดได้แล้ว ให้นำไปให้ <NAVI>[Pisrik]<INFO>yuno_in04,33,108,0,101,0</INFO></NAVI>"
        },
        Summary = "Carnivorous Plant's Seed 1 อัน",
        NpcSpr = "4_M_ALCHE_D",
        NpcNavi = "yuno_in04",
        NpcPosX = "33",
        NpcPosY = "108"
    },
    [19119] = {
        Title = "Pisrik's Research (3) (งานวิจัยของ Pisrik 3)",
        IconName = "ico_jq.bmp",
        Description = {
            "เอ่อ... ขอโทษนะ แต่คุณช่วยหาแว่นตาที่ดูเหมือนกับอันที่ฉันใส่อยู่ให้หน่อยได้ไหม? ฉันมองไม่เห็นอะไรข้างหน้าเลย ก็เลยขยับไปไหนไม่ได้ ฉันจะซาบซึ้งมากถ้าคุณช่วยฉันเรื่องนี้",
            " ",
            "หา <ITEM>[Sphinx Glasses]<INFO>2243</INFO></ITEM> และนำไปให้ <NAVI>[Pisrik]<INFO>yuno_in04,33,108,0,101,0</INFO></NAVI>",
            "^FF0000กุ โปรดระวังอย่ามี Sphinx Glasses อันอื่นอยู่ในช่องสัมภาระที่กำลังใช้งานอยู่^000000"
        },
        Summary = "Sphinx Glasses 1 อัน",
        NpcSpr = "4_M_ALCHE_D",
        NpcNavi = "yuno_in04",
        NpcPosX = "33",
        NpcPosY = "108"
    },
    [19120] = {
        Title = "Bard's Song (1) (เพลงของนักกวี 1)",
        IconName = "ico_jq.bmp",
        Description = {
            "ฉันกังวลเกี่ยวกับคำพูดของชายหนุ่มขี้อายที่ชอบ <ITEM>[Tropical Sograt]<INFO>12112</INFO></ITEM> ที่เขาพบใน Prontera คำสาปของนักกวี... ฉันควรจะเริ่มจาก <NAVI>[Morroc Tavern]<INFO>morocc_in,179,65,0,101,0</INFO></NAVI> ดีไหม?"
        },
        Summary = "การรวบรวมข้อมูล"
    },
    [19121] = {
        Title = "Bard's Song (1) (เพลงของนักกวี 1)",
        IconName = "ico_jq.bmp",
        Description = {
            "นักกวี <NAVI>[Raiot]<INFO>morocc_in,169,72,0,101,0</INFO></NAVI> ที่พบในโรงเตี๊ยม Morroc อ้างว่าไม่ใช่เพื่อนของนักกวีคนนั้นและไม่อยากคุยกับฉัน นักกวีหนุ่มที่กำลังร้องไห้ใน Geffen งั้นเหรอ? เขาหมายถึงอะไรกันนะ?",
            " ",
            "กุ คุณต้องผ่าน <NAVI>[Bard's Song Quest]<INFO>geffen,132,38,0,101,0</INFO></NAVI> ใน Geffen ก่อน"
        },
        Summary = "",
        NpcSpr = "2_M_BARD_ORIENT",
        NpcNavi = "morocc_in",
        NpcPosX = "169",
        NpcPosY = "72"
    },
    [19122] = {
        Title = "Bard's Song (2) (เพลงของนักกวี 2)",
        IconName = "ico_jq.bmp",
        Description = {
            "Raiot... เขาคงจะไม่บอกฉันง่ายๆ สินะ?",
            "มีสถานที่ที่ฉันสามารถลอดผ่านกิ่งไม้ไปได้ไหม? Niflheim?",
            "ฉันควรจะไปหาไข่ 5 ฟองจาก Ihire ใน Niflheim ดีไหม?",
            " ",
            "ตามหา Ihire ใน Niflheim และรวบรวม <ITEM>[Eggs]<INFO>574</INFO></ITEM> 5 ฟองมาให้ <NAVI>[Raiot]<INFO>morocc_in,169,72,0,101,0</INFO></NAVI>",
            " ",
            "ขบสถานที่วางไข่ของ Ihire",
            "<NAVI>[พิกัด]<INFO>niflheim,239,70,0,101,0</INFO></NAVI>/<NAVI>[พิกัด]<INFO>niflheim,185,205,0,101,0</INFO></NAVI>/<NAVI>[พิกัด]<INFO>niflheim,85,203,0,101,0</INFO></NAVI>/<NAVI>[พิกัด]<INFO>niflheim,149,81,0,101,0</INFO></NAVI>/<NAVI>[พิกัด]<INFO>niflheim,209,144,0,101,0</INFO></NAVI>",
            "^FF0000กุ ในเมืองแห่งความตาย ไม่มีทางออกหรอก^000000"
        },
        Summary = "ไข่ของ Ihire 5 ฟอง",
        NpcSpr = "2_M_BARD_ORIENT",
        NpcNavi = "morocc_in",
        NpcPosX = "169",
        NpcPosY = "72"
    },
    [19123] = {
        Title = "Bard's Song (2) (เพลงของนักกวี 2)",
        IconName = "ico_jq.bmp",
        Description = {
            "แปลกจัง?! ฉันนึกว่าฉันได้ไข่ 5 ฟองจาก Ihire มาแล้วนะ? ถ้าคุณอยากเรียนรู้ทักษะนี้ ให้หา <ITEM>[Ihire Doll]<INFO>7277</INFO></ITEM> มาให้ฉัน 1 อันงั้นเหรอ?",
            " ",
            "หา <ITEM>[Ihire Doll]<INFO>7277</INFO></ITEM> 1 อันมาให้ <NAVI>[Raiot]<INFO>morocc_in,169,72,0,101,0</INFO></NAVI>"
        },
        Summary = "ตุ๊กตา Ihire Doll 1 ตัว",
