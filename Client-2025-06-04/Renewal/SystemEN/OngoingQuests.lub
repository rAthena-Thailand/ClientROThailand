	[11000] = {
		Title = "การตรวจสอบวิหาร Odin",
		Description = {
			"อย่างไรก็ตาม หากคุณต้องการช่วยเรา โปรดลองสำรวจรอบๆ วิหารและดูว่าคุณต้องการจะทำงานร่วมกับเราหรือไม่ โปรดคุยกับคนแจวเรือ (Boatman) เพื่อเดินทางไปยังวิหาร ตกลงไหม?"
		},
		Summary = "คุยกับ Alex อีกครั้งหลังจากสำรวจวิหารเสร็จแล้ว"
	},
	[11001] = {
		Title = "การตรวจสอบวิหาร Odin",
		Description = {
			"ภารกิจแรกของคุณคือ นำ ^3355FF5 Runes of the Darkness^000000 จากวิหารมาให้ฉัน ไม่ต้องกังวล ฉันจะมั่นใจว่าคุณจะได้รับรางวัลตอบแทนสำหรับความพยายามของคุณ"
		},
		Summary = "นำ 5 Runes of Darkness มาให้ Alex"
	},
	[11002] = {
		Title = "การตรวจสอบวิหาร Odin",
		Description = {
			"Alex กำลังพึมพำเกี่ยวกับหญิงสาวผมสีเทาในขณะที่เขารับ Runes of Darkness ไป"
		},
		Summary = "ฉันควรไปคุยกับเธอไหม?"
	},
	[11003] = {
		Title = "การตรวจสอบวิหาร Odin",
		Description = {
			"ตอนนี้ อย่างแรกคุณต้องไปที่วิหารและสำรวจพื้นที่เพื่อประโยชน์ของคุณเอง คุยกับคนแจวเรือ (Boatman) แล้วเขาจะพาคุณไปที่นั่น ตกลงไหม?"
		},
		Summary = "คุยกับ Laura หลังจากสำรวจเสร็จแล้ว"
	},
	[11004] = {
		Title = "การตรวจสอบวิหาร Odin",
		Description = {
