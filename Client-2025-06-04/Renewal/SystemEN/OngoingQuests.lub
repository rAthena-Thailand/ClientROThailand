	[14479] = {
		Title = "ทำความสะอาดเพื่อขอโทษ (Clean-up out of Apology)",
		Description = {
			"มีใครอีกไหมที่อยู่ที่นั่น? ฉันไม่รู้สิ... ฉันอาจจะจำได้ถ้าที่นี่สะอาดขึ้นอีกครั้ง คุณจะช่วยทำความสะอาดให้ฉันหน่อยได้ไหม? โอ้ ขอบคุณนะ ขั้นแรกคุณต้องเช็ดเชื้อราบนผนัง กำจัดคราบไขมัน และทำความสะอาดพื้น"
		},
		Summary = "เริ่มทำความสะอาดกันเถอะ"
	},
	[14480] = {
		Title = "พิชิตคราบไขมัน (Conquer the Grease)",
