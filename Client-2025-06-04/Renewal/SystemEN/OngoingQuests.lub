		Summary = "รีเซ็ตตอน 04:00",
		CoolTimeQuest = 1
	},
	[14677] = {
		Title = "การอ่านหนังสือในที่แสงสลัว (Studying in Dim Light)",
		Description = {
			"ฉันได้ยินมาว่า Cluster of Nightmares จาก Sweet Nightmare เมื่อนำมาผสมกับสปอร์เรืองแสงจาก Neon Mushroom แล้วทาลงบนพื้นผิว จะทำให้เกิดแสงสำหรับอ่านหนังสือที่พอใช้ได้ คุณช่วยนำคลัสเตอร์ 10 อันและสปอร์ 10 อันมาให้ฉันได้ไหม?"
		},
		Summary = "Shining Spore และ Cluster of Nightmare"
