		Summary = ""
	},
	[3050] = {
		Title = "การฟื้นคืนชีพของ Satan Morroc - ข่าวจาก Morroc",
		Description = {
			"Satan Morroc ที่ถูกผนึกไว้ในเมืองทะเลทราย Morroc ได้ฟื้นคืนชีพขึ้นมา ทำลายพื้นที่บริเวณใกล้เคียงและมุ่งหน้าสู่ทะเลทราย Sograt เหล่านักผจญภัยผู้กล้าหาญ โปรดไปพบ Chief Balrog แห่งกองกำลังพิทักษ์ทวีปในหมู่บ้าน Morroc"
		},
		Summary = "Chief Balrog"
	},
	[3051] = {
		Title = "การฟื้นคืนชีพของ Satan Morroc - บททดสอบคุณสมบัติ",
		Description = {
			"ไม่ใช่ทุกคนที่จะเป็นนักผจญภัยในกองกำลังพิทักษ์ทวีปได้ หากคุณมั่นใจนัก จงพิสูจน์ฝีมือให้ฉันเห็น ไปนำ Live Coal 30 อันมาให้ฉัน"
		},
		Summary = "Live Coal 30 อัน"
	},
	[3052] = {
		Title = "การฟื้นคืนชีพของ Satan Morroc - บททดสอบคุณสมบัติ 2",
		Description = {
			"คุณคิดว่าการเข้าเป็นส่วนหนึ่งของกองกำลังพิทักษ์ทวีปมันง่ายขนาดนั้นเลยเหรอ? การทดสอบยังไม่จบ ไปหา Glacial Heart 50 อันจาก Ice Cave มาให้ฉัน"
		},
		Summary = "Glacial Heart 50 อัน"
	},
	[3053] = {
		Title = "การฟื้นคืนชีพของ Satan Morroc - สมาชิกทีมปราบปราม",
		Description = {
			"ด้วยฝีมือและความพยายามของคุณ ฉันจะรับรองให้คุณเป็นนักผจญภัยในกองกำลังพิทักษ์ทวีป ภารกิจของคุณคือกำจัด Satan Morroc พร้อมกับสมุนของมัน และป้องกันการฟื้นคืนชีพที่สมบูรณ์ จงเตรียมพร้อมที่จะสละชีวิต"
		},
		Summary = ""
	},
	[3054] = {
		Title = "การฟื้นคืนชีพของ Satan Morroc - กำจัดราชาปีศาจ!",
		Description = {
