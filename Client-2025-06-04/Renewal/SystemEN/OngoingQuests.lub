	[11023] = {
		Title = "ช่วยเหลือคุณ Zabaroo - 1",
		Description = {
			"Asbar น่ะเหรอ? เขาอยู่ในร้านขายเครื่องมือ (Tool Shop) คุณหาเขาเจอแน่... แค่มองหาชายที่มีดวงตาดูบ้าคลั่ง!"
		},
		Summary = "ตามหา Asbar"
	},
	[11024] = {
		Title = "ช่วยเหลือคุณ Zabaroo - 2",
		Description = {
			"นำ Maneater Root 5 ชิ้น, Glacial Heart 2 ชิ้น และ Steel 5 ชิ้นมาให้ ถ้าคุณไม่รีบกลับมา ฉันจะไม่ช่วยคุณนะ"
		},
		Summary = "นำวัสดุที่ Asbar ต้องการมาให้"
	},
	[11025] = {
		Title = "ช่วยเหลือคุณ Zabaroo - 3",
		Description = {
			"Asbar ได้มอบ 'อุปกรณ์กลไกตัวหนีบยืดหดได้สัมผัสพิเศษอะไรสักอย่าง' ให้กับคุณ นำมันไปมอบให้ชายแก่ Zabaroo"
		},
		Summary = "กลับไปหา Zabaroo"
	},
	[11026] = {
		Title = "ช่วยเหลือคุณ Zabaroo - 4",
		Description = {
			"ช่วยนำก้อนหินที่ฉันรวบรวมไว้ไปส่งที่โรงงานในเมืองได้ไหม? มันอยู่ใกล้ๆ กับสนามบินหรือเรือเหาะหรืออะไรสักอย่างนี่แหละ ใช้เวลาไม่นานหรอก"
		},
		Summary = "นำก้อนหินไปส่งที่โรงงานในเมือง"
	},
	[11027] = {
		Title = "ช่วยเหลือคุณ Zabaroo - 5",
		Description = {
			"นำหินพวกนั้นไปส่งให้ Bahed ตรงนั้น เขาจะจัดการพวกมันเอง"
		},
		Summary = "นำก้อนหินไปให้ Bahed"
	},
	[11028] = {
		Title = "ช่วยเหลือคุณ Zabaroo - 6",
		Description = {
			"หินพวกนั้นถูกเรียกว่า \"Hetarium\" ซึ่งขายให้กับ Rekenber โอ้ แล้วก็ฝากส่งความระลึกถึงและขอบคุณ Zabaroo สำหรับความทำงานหนักของเขาด้วย"
		},
		Summary = "กลับไปหา Zabaroo"
	},
	[11029] = {
		Title = "มุ่งหน้าสู่เกาะเต่า (Turtle Island)..",
		Description = {
			"โอ้ สถานที่แห่งนั้นมันยากที่จะค้นหาและยิ่งยากขึ้นไปอีกที่จะเดินทางไป คุณแน่ใจเหรอว่าต้องการไป?"
		},
		Summary = "ตามหาคนแจวเรือข้ามฟากเก่าแก่ที่อยู่ทางฝั่งตะวันออกของท่าเรือ Alberta เพื่อรู้วิธีการไปยังเกาะเต่า"
