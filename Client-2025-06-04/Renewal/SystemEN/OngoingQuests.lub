	[8214] = {
		Title = "บทเรียนของ Shurank",
		Description = {
			"รอยหนังด้านพวกนั้น...! มีเพียงผู้เชี่ยวชาญทักษะ Bash เท่านั้นที่จะมีมือแบบนั้น ทำงานได้ดีมาก นักดาบ (Swordman) ฉันประทับใจมากจริงๆ"
		},
		Summary = "ฟังบทเรียนของ Shurank"
	},
	[8215] = {
		Title = "บทเรียนของ Shurank",
		Description = {
			"ถึงตอนนี้ ฉันเชื่อว่าคุณมีความรู้เพียงพอเกี่ยวกับทักษะ Increase HP Recovery แล้ว คราวหน้า ฉันจะสอนสิ่งที่คุณควรรู้เกี่ยวกับทักษะ Provoke ให้"
		},
		Summary = "ฟังบทเรียนของ Shurank"
	},
	[8216] = {
		Title = "คำสั่งของ Shurank",
		Description = {
			"ฉันต้องการให้คุณไปตามหาอัศวินชื่อ ^5D478BDequ'ee^000000 ในเมือง ^5D478BGeffen^000000 ฟังให้ดี นี่คือข้อความ: ^0000FFเกิดอะไรขึ้นกับฆาตกร? ^0000FFคุณสืบรู้หรือยังว่าเขาเป็นใคร? ถ้าคุณรู้แล้ว พวกเราควรจะทำอย่างไรต่อไป?^000000"
		},
		Summary = "นำข้อความของ Shurank ไปส่งให้ Dequ'ee ใน Geffen"
	},
	[8217] = {
		Title = "ข้อความของ Dequ'ee",
		Description = {
			"งั้น Shurank ก็ถามมาว่า \"เกิดอะไรขึ้นกับฆาตกร? คุณสืบรู้หรือยังว่าเขาเป็นใคร? ถ้าคุณรู้แล้ว พวกเราควรจะทำอย่างไรต่อไป?\" พวกเรายังไม่รู้แน่ชัดว่าฆาตกรเป็นใคร แต่อย่างไรก็ตาม เรามีรายชื่อผู้ต้องสงสัยอยู่และเราจะรู้ตัวในเร็วๆ นี้?"
		},
		Summary = "นำข้อความของ Dequ'ee ไปส่งให้ Shurank ใน Izlude"
	},
	[8218] = {
		Title = "บทเรียนของ Shurank",
		Description = {
			"คุณยังไม่ได้เรียนรู้ Provoke อีกเหรอ? ตอนนี้ฉันขอให้คุณไปฝึกฝนตัวเองในการใช้ทักษะ Provoke มาซะ"
		},
		Summary = "ฝึกฝนทักษะ Provoke ให้เชี่ยวชาญ แล้วกลับมาหา Shurank"
	},
	[8219] = {
		Title = "บทเรียนของ Shurank",
		Description = {
			"อืม ดูเหมือนคุณจะมีความเข้าใจพื้นฐานเกี่ยวกับ Provoke แล้ว แต่ขอฉันให้รายละเอียดเพิ่มอีกนิดเพื่อให้คุณเข้าใจการใช้งานทักษะนั้นได้ดียิ่งขึ้น"
		},
		Summary = "ฝึกฝนทักษะ Provoke ให้เชี่ยวชาญ แล้วกลับมาหา Shurank"
	},
	[8220] = {
		Title = "บทเรียนของ Shurank",
		Description = {
			"อา ฉันเห็นว่าคุณมีความเข้าใจในทักษะ Provoke ค่อนข้างดีเลยทีเดียว ครั้งต่อไปที่เราคุยกัน ฉันจะบอกสิ่งที่คุณควรรู้เกี่ยวกับทักษะ ^5D478BEndure^000000 เมื่อคุณพร้อมที่จะเรียนรู้แล้ว ก็กลับมาหาฉันได้เลย"
		},
		Summary = "ฟังบทเรียนของ Shurank"
	},
	[8221] = {
		Title = "บทเรียนของ Shurank",
		Description = {
			"การใช้งาน Endure จะช่วยให้คุณทนทานต่อการโจมตีได้ คุณจะยังได้รับความเสียหายอยู่ แต่การโจมตีของศัตรูจะไม่ทำให้คุณชะงักมากนัก นั่นหมายความว่าคุณจะสามารถสวนกลับการโจมตีของศัตรูหรือหลบหนีได้หากจำเป็น เอาล่ะ ตอนนี้ฉันอยากให้คุณไปฝึกฝนการใช้ทักษะ Endure มา คุณสามารถเป็นนักดาบที่ยอดเยี่ยมได้"
		},
		Summary = "ฝึกฝนทักษะ Endure ให้เชี่ยวชาญ แล้วกลับมาหา Shurank"
	},
	[8222] = {
		Title = "คำสั่งของ Shurank",
		Description = {
			"อา อีกครั้งหนึ่งแล้วนะ ฉันมีงานอื่นให้คุณทำอีกแล้ว โปรดไปหา Dequ'ee ใน Geffen เพราะดูเหมือนว่าเขามีบางอย่างจะขอให้คุณช่วย รีบไปพบกับ Dequ'ee และกลับมาหาฉันเมื่อคุณทำสิ่งที่เขาต้องการเสร็จเรียบร้อยแล้ว"
		},
		Summary = "ไปหา Dequ'ee"
	},
	[8223] = {
		Title = "คำสั่งของ Dequ'ee",
		Description = {
			"ตอนนี้ ฉันต้องการให้คุณไปที่ Morroc และสอบปากคำผู้ต้องสงสัยสี่คน พวกเขาชื่อว่า ^5D478BMuetro^000000, ^5D478BGeil^000000, ^5D478BHans^000000 และ ^5D478BBankley^000000 มันไม่น่าจะยากเกินไป หลังจากที่คุณคุยกับพวกเขาครบทุกคนแล้ว ให้กลับมารายงานฉัน"
		},
		Summary = "กลับไปหา Dequ'ee หลังจากพบหลักฐานใน Morroc"
	},
	[8224] = {
		Title = "เงื่อนงำ",
		Description = {
			"นี่คือบางส่วนของ..., เอาล่ะ เยี่ยมมาก ตอนนี้สิ่งที่เราต้องทำคือหาคำตอบว่าทั้งหมดนี้หมายความว่าอย่างไร เรื่องนี้มันจะยากจริงๆ นะ เราต้องไขความลับนี้ให้ได้ มันเป็นเงื่อนงำเดียวที่เรามีอยู่...."
		},
		Summary = ""
	},
	[8225] = {
		Title = "การใช้เหตุผลของ Dequ'ee",
		Description = {
			"ตกลง! ดูเหมือนว่า Bankley จะเป็นฆาตกร! ถึงแม้เราจะยังเชื่อถือไม่ได้ 100% แต่หลักฐานนี้ค่อนข้างชัดเจน รีบไปที่ Morroc และเฝ้าจับตาดู Bankley ไว้เผื่อว่าเขาจะทำอะไรที่บ้าบิ่น ถ้ามีอะไรเกิดขึ้น ให้รายงานฉันทันที!"
		},
		Summary = "เฝ้าดู Bankley อย่างใกล้ชิดใน Morroc"
	},
	[8226] = {
		Title = "ความตายของ Bankley",
		Description = {
			"-เขาตายแล้ว! Bankley มีสีหน้าเศร้าสร้อยและน่าเวทนา เนื่องจากสีบนแก้มของเขายังคงสดอยู่ เขาเพิ่งตายเมื่อไม่นานมานี้เอง มีบาดแผลยาวและลึกที่หน้าอกของเขา และมีมีดโชกเลือดถูกกำไว้แน่นในมือขวาของเขา-"
		},
		Summary = "รายงานความตายของ Bankley ต่อ Dequ'ee"
	},
	[8227] = {
		Title = "กลับไปหา Shurank",
		Description = {
			"ฆ่าตัวตายเหรอ...? มีบางอย่างไม่ชอบมาพากลเกิดขึ้นที่นี่แล้ว! ส่วนผู้ต้องสงสัยอีกสามคนที่เหลือ ฉันจะให้สมาชิกสมาคมนักดาบช่วยเฝ้าจับตาดูไว้ ดูเหมือนว่าคดีนี้จะปิดตัวลงในตอนนี้ อีกครั้งนะ ขอบคุณสำหรับความช่วยเหลือของคุณ ทำไมไม่กลับไปรายงานตัวกับ Shurank ล่ะ? ฉันเดาว่าเขายังคงอยากจะสอนพื้นฐานวิชานักดาบให้คุณต่อ"
		},
		Summary = "กลับไปหา Shurank"
	},
	[8228] = {
		Title = "บทเรียนของ Shurank",
		Description = {
			"นี่จะเป็นบทเรียนสุดท้ายที่ฉันจะสอนคุณ โปรดตั้งใจฟังให้ดีขณะที่ฉันจะบอกคุณเกี่ยวกับ Magnum Break"
