	[60923] = {
		Title = "ปริศนาฆาตกรรมในพิพิธภัณฑ์",
		Description = {
			"Mrs. Moneybags ไม่ยอมออกจากห้องเลยตั้งแต่เกิดเหตุฆาตกรรมขึ้น ไปพบเธอที่โรงแรม Brasilis"
