			"ทหารทุกคนถูกโจมตีขณะที่พวกเขากำลังส่งความช่วยเหลือไปยังโบสถ์ ตามหาเสบียงในสิ่งก่อสร้างที่ถูกทิ้งร้างใน Prontera: clean bandage 5 อัน, rubbing alcohol 5 อัน, Sour grass 5 อัน, First aid kit 5 อัน, relief food 5 อัน"
		},
		Summary = ""
	},
	[14241] = {
		Title = "กลับไปยังปราสาท (Back to the castle)",
		Description = {
			"คุณพ่อ Thyme ส่งทหารที่ฟื้นตัวแล้วบางส่วนไปกำจัดพวก Orc ใกล้ๆ ปราสาท กลับไปที่ทางเข้าปราสาทกันเถอะ"
		},
		Summary = ""
	},
	[14242] = {
		Title = "กำจัดผู้เฝ้าประตู! (Defeat the Gatekeeper!)",
		Description = {
			"ผู้เฝ้าประตูพบว่าเรากำลังพยายามจะเข้าไปในปราสาท กำจัดผู้เฝ้าประตูซะ!"
		},
		Summary = ""
	},
	[14243] = {
		Title = "เข้าสู่ปราสาท! (Enter the castle!)",
		Description = {
			"ผู้เฝ้าประตูหายไปแล้ว เข้าไปในปราสาทและสืบหาแผนการของพวก Orc"
		},
		Summary = "เข้าสู่ปราสาท!"
	},
	[14244] = {
		Title = "เหนือพอร์ทัล (Beyond the Portal)",
		Description = {
			"Goblin Shaman กำลังพยายามเปิดพอร์ทัล หยุดแผนการของพวกมันด้วยการเข้าไปในพอร์ทัลนั้น"
		},
		Summary = ""
	},
	[14245] = {
		Title = "สู่ถ้ำ Payon (To Payon Cave)",
		Description = {
			"Annie ได้รับแจ้งว่ามีเบาะแสในการหยุดพวก Orc ไปที่ถ้ำ Payon เพื่อตามหาเบาะแสนั้น"
		},
		Summary = ""
	},
	[14246] = {
		Title = "ตามหาเบาะแส 1 (Find a clue 1)",
		Description = {
			"เจ้าของร้านนมกล่าวว่าเขาซ่อนบันทึกที่บอกวิธีการหยุดภัยคุกคามนี้ไว้ที่ไหนสักแห่ง มาหาเบาะแสกันเถอะ"
