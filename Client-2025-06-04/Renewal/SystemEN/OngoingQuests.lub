	},
	[21910] = {
		Title = "สู่ Prontera!",
		Description = {
			"ฉันตัดสินใจเป็นสมาชิกของกลุ่ม Paradise ที่น่าเกรงขาม และแก้ปัญหาภารกิจที่ยากลำบากของ 'วิหารแห่ง Prontera' (Prontera Cathedral) ไปพบและเข้าร่วมกับ <NAVI>เพื่อนร่วมงาน<INFO>prt_fild08,182,359,0,101,0</INFO></NAVI>"
