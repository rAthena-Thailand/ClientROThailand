	[149] = {
		Title = "ตั้งค่าเอฟเฟกต์: หน้าจอสั่น#quake, แผ่นดินไหว, เอฟเฟกต์, ตั้งค่าเกม",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00149",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"แสดงหรือยกเลิกเอฟเฟกต์หน้าจอสั่นเมื่อมีการใช้สกิลที่รุนแรง หรือเมื่อถูกโจมตีด้วยสกิลของมอนสเตอร์ระดับสูง\n\nค คำสั่ง\n/quake: แสดง/ซ่อน หน้าจอสั่น\n\nป <TIPBOX>การตั้งค่าเอฟเฟกต์<INFO>143</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[150] = {
		Title = "ตั้งค่าเอฟเฟกต์: ซ่อนสัตว์อัญเชิญ#ตั้งค่าเกม, ซ่อน, สัตว์อัญเชิญ, โปร่งแสง",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00150",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"แสดงสัตว์อัญเชิญของตัวละครผู้เล่นอื่นที่ไม่ใช่ของคุณเองให้เป็นแบบกึ่งโปร่งใส\n\nสัตว์เลี้ยง (Pets), รถเข็น (Carts), ทหารรับจ้าง (Mercenaries), หมาป่า (Wolves - อัญเชิญ), โฮมุนครูส (Homunculi - อัญเชิญ), จิตวิญญาณ (Spirits - อัญเชิญ), ABR (อัญเชิญ), สัตว์อัญเชิญประเภทพืช (Wooden Warrior และอื่นๆ) จะถูกแสดงผลแบบกึ่งโปร่งใส\n\nค คำสั่งลัด: Ctrl+Home (คำสั่งลัดยังไม่มีการตัดสินใจที่แน่นอน)\n\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: ซ่อนผู้เล่น<INFO>115</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่าเอฟเฟกต์<INFO>143</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[152] = {
		Title = "การตั้งค่าการควบคุม#ตั้งค่าเกม",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถตั้งค่าต่างๆ เพื่อความสะดวกในการใช้งานของคุณได้\n\nป <TIPBOX>การตั้งค่าการควบคุม: Mouse Snap<INFO>153</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่าการควบคุม: No Shift<INFO>154</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่าการควบคุม: Lock On Mode No Ctrl<INFO>15</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่าการควบคุม: Zoom Out<INFO>85</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่าการควบคุม: Mouse Lock<INFO>155</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่าการควบคุม: Quick Skill<INFO>156</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่าการควบคุม: Mini Slot<INFO>157</INFO></TIPBOX>\nป <TIPBOX>ไอเทม: เปรียบเทียบไอเทม<INFO>66</INFO></TIPBOX>\n\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[153] = {
		Title = "การตั้งค่าการควบคุม: Mouse Snap#เป้าหมาย, เก็บไอเทม, มอนสเตอร์, สกิล, ไอเทม, Snap, ตั้งค่าเกม",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Mouse Snap คือฟีเจอร์ที่ช่วยเลื่อนเคอร์เซอร์เมาส์ไปหาเป้าหมายที่เลือกโดยอัตโนมัติเมื่อเมาส์เคลื่อนที่ไปอยู่ใกล้เป้าหมายนั้น\n\n1. เป้าหมายมอนสเตอร์: หากคุณเลื่อนเคอร์เซอร์เมาส์ไปใกล้กับมอนสเตอร์ตัวใดก็ตาม เมาส์จะดูดติดเข้าหาเป้าหมายนั้น\n2. เป้าหมายสกิล: หากคุณเลื่อนเคอร์เซอร์เมาส์ไปยังศัตรูในขณะที่กำลังใช้งานสกิลเป้าหมาย เมาส์จะดูดติดเข้าหาศัตรู\n3. การเก็บไอเทม: หากคุณเลื่อนเคอร์เซอร์เมาส์ไปใกล้กับไอเทมที่ตกอยู่บนพื้น เมาส์จะดูดติดเข้าหาไอเทมนั้น\n\nค คำสั่ง\n/snap: เปิด/ปิด การล็อคเป้าหมายมอนสเตอร์\n/skillsnap: เปิด/ปิด การล็อคเป้าหมายสกิล\n/itemsnap: เปิด/ปิด การล็อคเป้าหมายเก็บไอเทม\n\nป <TIPBOX>การตั้งค่าการควบคุม<INFO>152</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[154] = {
		Title = "การตั้งค่าการควบคุม: No Shift#Heal, Undead, มอนสเตอร์, ฟื้นฟู, เป้าหมาย, ตั้งค่าเกม",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00154",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"สกิลพิเศษ เช่น สกิล Heal ของกลุ่มอาชีพ Acolyte จะเป็นการฟื้นฟูเลือดเมื่อใช้กับผู้คน แต่จะสร้างความเสียหายเมื่อใช้กับศัตรูประเภท Undead\n\nเนื่องจากตัวสกิลถูกใช้งานด้วยฟังก์ชันที่ขัดแย้งกัน เพื่อป้องกันความผิดพลาด เมื่อใช้กับมอนสเตอร์ปกติจะต้องคลิกพร้อมกับกด Shift เพื่อยืนยันการใช้สกิลใส่พวกมัน\n\nหากคุณเลือกฟังก์ชันนี้ ตัวเกมจะรับรู้เสมือนว่าคุณกด Shift ค้างไว้ตลอดเวลาเมื่อใช้สกิลกับมอนสเตอร์ ทำให้คุณสามารถใช้สกิลกับมอนสเตอร์ได้ง่ายขึ้น\n\nค คำสั่ง\n/noshift หรือ /ns: เปิด/ปิด No Shift\n\nป <TIPBOX>การตั้งค่าการควบคุม<INFO>152</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[155] = {
		Title = "การตั้งค่าการควบคุม: Mouse Lock#หน้าจอ, ออกข้างนอก, เคอร์เซอร์, ตั้งค่าเกม, ขอบเขต",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เมื่อตั้งค่าตัวเกมเป็นโหมดหน้าต่าง (Window Mode) แทนที่จะเป็นแบบเต็มหน้าจอ ฟีเจอร์นี้จะช่วยป้องกันไม่ให้เคอร์เซอร์เมาส์หลุดออกนอกขอบเขตหน้าจอเกม\n\nป <TIPBOX>การตั้งค่ากราฟิก: โหมดหน้าจอ<INFO>164</INFO></TIPBOX>\n\nป <TIPBOX>การตั้งค่าการควบคุม<INFO>152</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[156] = {
		Title = "การตั้งค่าการควบคุม: Quick Skill#ตั้งค่าเกม, quick, spell, เมาส์, Quick Skill",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ใช้เมาส์เพื่อดำเนินการสั่งการที่ช่วยให้คุณใช้สกิลได้อย่างรวดเร็ว\n\nค คำสั่ง\n/q1: ใช้สกิลที่บันทึกไว้ในช่อง F9 ด้วยการคลิกเมาส์ขวา\n/q2: ใช้สกิลที่บันทึกไว้ในช่อง F7 และ F8 ด้วยการหมุนวงล้อเมาส์ ขึ้น/ลง\n/q3: เปิดใช้งาน /q1 และ /q2 พร้อมกัน\n\nป <TIPBOX>การตั้งค่าการควบคุม<INFO>152</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[157] = {
		Title = "การตั้งค่าการควบคุม: Mini Slot#ตั้งค่าเกม, สกิล, คีย์ลัด, Mini Slots",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"แสดงช่องสกิลขนาดเล็ก (Mini Skill Slot) จำนวน 2 ช่องที่ด้านบนของหน้าจอ\nการปิดฟีเจอร์นี้จะเป็นการปิดการใช้งานช่องสกิลขนาดเล็ก\n\nป <TIPBOX>การตั้งค่าการควบคุม<INFO>152</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[158] = {
		Title = "การตั้งค่ากราฟิก#ตั้งค่าเกม, API, DirectX",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถกำหนดค่าต่างๆ ที่เกี่ยวข้องกับกราฟิกได้ เช่น ความละเอียดและอุปกรณ์ประมวลผลกราฟิก\n\nป <TIPBOX>การตั้งค่ากราฟิก: Graphics API<INFO>159</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่ากราฟิก: Graphics Device<INFO>160</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่ากราฟิก: ความละเอียดกราฟิก<INFO>161</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่ากราฟิก: ความละเอียดสไปรท์<INFO>162</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่ากราฟิก: ความละเอียดเท็กซ์เจอร์<INFO>163</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่ากราฟิก: โหมดหน้าจอ<INFO>164</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่ากราฟิก: Trinarian Filtering<INFO>165</INFO></TIPBOX>\n\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[159] = {
		Title = "การตั้งค่ากราฟิก: Graphics API#ตั้งค่าเกม, API, DirectX",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00159",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เลือก graphics API เพื่อรันเกม Ragnarok\nคุณสามารถเลือกได้ระหว่าง DirectX 9 หรือ DirectX 7\n\nป <TIPBOX>การตั้งค่ากราฟิก<INFO>158</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
