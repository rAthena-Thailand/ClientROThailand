		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"^i[23817] <ITEM>Mysterious Combination Scroll Bundle<INFO>23817></INFO></ITEM>\n\nนี่คือชุดรวมสูตรผสมที่ช่วยให้คุณสร้างอุปกรณ์ที่มีเอกลักษณ์เฉพาะตัวได้ และคุณสามารถรับสูตรผสมแบบสุ่มหนึ่งอย่างได้จากชุดนี้\n(ตัวอย่าง: Boitata Hat Combination Book, Beelzebub's Crown Combination Book, เป็นต้น...)\nคุณสามารถรับได้จากการกำจัดมอนสเตอร์ระดับบอสต่างๆ ที่อยู่ในทวีป หรือซื้อได้ที่ Paramarket\n\nป แหล่งที่รับได้\nป Paramarket <NAVI>[Huaran]<INFO>paramk,116,100,0,101,0</INFO></NAVI>\nป บัสมอนสเตอร์\nOrc Lord / Amon Ra / Amon Ra (Nightmare) / Vesper / Atroce / Bacsojin / Baphomet / Beelzebub (หลังแปลงร่าง) / Boitata / General Daehyon / Dark Lord / Evil Snake Lord / Detardeurus / Doppelganger / Dracula / Drake / Edgar / Venomous Chimera / Fallen Bishop / Hatii / Gioia / Gloom Under Night / Golden Thief Bug / Queen Scaraba / Queen Scaraba (Nightmare) / Ifrit / Incantation Samurai / Guardian Kades / Kiel-D-01 / Stormy Knight / Kraken / Lady Tanee / Time Holder / Ktullanux / Leak / Lord of the Dead / Maya / Spider Chariot / Mistress / Moonlight / Wounded Morroc / Orc Hero / Osiris / Pharaoh / Phreeoni / Fallen Pyuriel / Valkyrie Randgris / RSX-0806 / Tao Gunka / Thanatos Phantom / Turtle General / Gopinich\n\nป <TIPBOX>ไอเทม<INFO>17</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[137] = {
		Title = "Hugel Monster Racing",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00137",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"การแข่งขันมอนสเตอร์ในเมืองรีสอร์ต Hugel\nคุณสามารถเสี่ยงโชคด้วยการแข่งขันมอนสเตอร์ได้\n\nค ข้อมูลการเข้าใช้งาน:\nป <NAVI>[Eckar Ellebird]<INFO>hugel,58,72,0,101,0</INFO></NAVI>\nป <NAVI>[Eckar Erenes]<INFO>hugel,62,69,0,101,0</INFO></NAVI>\n\nค ข้อมูลของรางวัล:\nป <NAVI>[Mysterious Medal Crane]<INFO>hugel,64,79,0,101,0</INFO></NAVI>\nป <NAVI>[Mysterious Medal Crane]<INFO>hugel,96,168,0,101,0</INFO></NAVI>\n* ที่ตู้ Mysterious Medal Crane คุณสามารถได้รับรางวัลหายาก เช่น ใบตีบวกอาวุธและชุดเกราะระดับ 7-13, Sillit Pong และ Neuralizer\n\nป <NAVI>[Wayne]<INFO>hugel,68,79,0,101,0</INFO></NAVI>\n* คุณสามารถรับหมวกซีรีส์ Racing Cap เป็นของที่ระลึกจาก Wayne พนักงานของสมาคมแข่งมอนสเตอร์\n\nป <NAVI>[Hot Machine]<INFO>hugel,66,67,0,101,0</INFO></NAVI>\n* คุณสามารถเสริมพลัง (Enchant) หมวกซีรีส์ Racing Cap ได้ที่เครื่อง Hot Machine\n\nป <NAVI>[Ei'felle]<INFO>ein_in01,85,208,0,101,0</INFO></NAVI>\n* ว่ากันว่า Ei'felle แห่งเมือง Einbroch กำลังรวบรวมโลหะบางอย่างอยู่...\n\nป <TIPBOX>เมืองรีสอร์ต Hugel<INFO>4042</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[138] = {
		Title = "ตั้งค่าเริ่มต้น: Skin#Skin, ค่าเริ่มต้น, ป่า, ตั้งค่าเกม",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00138",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถเปลี่ยนสกิน (Skin) ของ Ragnarok Online ได้\n\nเกมจะเปลี่ยนเป็นสกินที่เลือก\nคุณยังสามารถใช้สกินที่คุณสร้างขึ้นเองได้ ไม่เพียงแต่สกินที่มีให้เท่านั้น\nคุณสามารถโหลดสกินที่ตั้งค่าไว้ในเกมด้วยชื่อโฟลเดอร์ที่สร้างขึ้นในโฟลเดอร์ Skin\nนอกจากนี้คุณยังสามารถแบ่งปันสกินที่ผู้อื่นทำขึ้นและนำมาใช้ได้โดยการแตกไฟล์ลงในโฟลเดอร์ Skin ในโฟลเดอร์เกมของคุณ\n\nค วิธีใช้งาน\nESC > ตั้งค่าเกม (Game Settings) > ตั้งค่าพื้นฐาน (Basic Settings) > Skin > เลือกสกินที่ต้องการ\n\nป <TIPBOX>ตั้งค่าพื้นฐาน<INFO>33</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[139] = {
		Title = "ตั้งค่าพื้นฐาน: เสียง#ตั้งค่าเกม, เอฟเฟกต์เสียง, เสียงประกอบ, ปิดเสียง, sound, bgm",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00139",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"กำหนดระดับเสียง\nคุณสามารถตั้งค่าเสียงพื้นหลัง (BGM) และเอฟเฟกต์เสียง (Sound Effects) แยกกันได้ และหากคุณไม่ต้องการเสียงเกมเลย คุณสามารถทำเครื่องหมายที่ช่องเพื่อปิดเสียงได้\n\nค คำสั่ง\n/sound: เปิด/ปิด เอฟเฟกต์เสียง\n/bgm: เปิด/ปิด เสียงเพลงพื้นหลัง\n\nป <TIPBOX>ตั้งค่าพื้นฐาน<INFO>33</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[140] = {
		Title = "การตั้งค่า: จดหมาย#ตั้งค่าเกม, Rodex, รับ, ปฏิเสธ, สมาชิกกิลด์",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00140",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"โดยพื้นฐานแล้ว คุณสามารถรับจดหมายจากผู้ใช้ทุกคนได้\nหากคุณไม่ต้องการรับจดหมายจากคนที่คุณไม่รู้จัก คุณสามารถบล็อกได้โดยการบล็อกผู้ใช้ทั่วไป\n\nค รับจากผู้ใช้ทุกคน: รับจดหมายจากผู้ใช้ทั้งหมด\nค บล็อกผู้ใช้ทั่วไป: รับจดหมายจากสมาชิกกิลด์เท่านั้น\n\nป <TIPBOX>ตั้งค่าพื้นฐาน<INFO>33</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[141] = {
		Title = "การตั้งค่า: ลำดับความสำคัญ#ตั้งค่าเกม, สูง, กลาง, ต่ำ, กระบวนการ, ประสิทธิภาพ",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00141",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถเพิ่มประสิทธิภาพของเกมได้โดยการเพิ่มลำดับความสำคัญของโปรแกรม (Program Priority) ที่ Windows มีให้\nค่าเริ่มต้นคือ ปกติ (Normal)\n\nค High: คุณสามารถปรับปรุงอาการหน่วงของเกมได้โดยการใช้ทรัพยากรของคอมพิวเตอร์มากขึ้น\nค Low: มีประโยชน์สำหรับการรัน Ragnarok ในโหมดหน้าต่าง (Window Screen) และใช้งานโปรแกรมอื่นไปพร้อมกัน\n\nป <TIPBOX>ตั้งค่าพื้นฐาน<INFO>33</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[142] = {
		Title = "การตั้งค่า: การแจ้งเตือนเข้าสู่ระบบ#ตั้งค่าเกม, ล็อกอิน, สมาชิกกิลด์",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"แสดงข้อความการเข้าสู่ระบบของสมาชิกกิลด์และเพื่อนในหน้าต่างแชท\n\nค กด ESC หรือปุ่มตัวเลือกเพื่อเปิดการตั้งค่าเกม\nทำเครื่องหมายที่ช่อง 'เปิดการแจ้งเตือนการเข้าสู่ระบบ' ในแท็บตั้งค่าพื้นฐาน\n\nค คำสั่ง\n/loginout, /li\n\nป <TIPBOX>ตั้งค่าพื้นฐาน<INFO>33</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[143] = {
		Title = "การตั้งค่าเอฟเฟกต์#esc, ตั้งค่าเกม",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถตั้งค่าเอฟเฟกต์กราฟิกต่างๆ ในเกมได้\n\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: แสดงออร่า<INFO>144</INFO></TIPBOX>\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: แสดงเอฟเฟกต์<INFO>145</INFO></TIPBOX>\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: แสดงเงา<INFO>146</INFO></TIPBOX>\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: ขยายการแสดงผลดาเมจ<INFO>88</INFO></TIPBOX>\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: ชื่อแผนที่<INFO>69</INFO></TIPBOX>\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: หมอก<INFO>147</INFO></TIPBOX>\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: รอยเท้า<INFO>148</INFO></TIPBOX>\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: หน้าจอสั่น<INFO>149</INFO></TIPBOX>\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: ซ่อนผู้เล่น<INFO>115</INFO></TIPBOX>\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: ซ่อนสัตว์อัญเชิญ<INFO>150</INFO></TIPBOX>\n\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[144] = {
		Title = "ตั้งค่าเอฟเฟกต์: แสดงออร่า#เอฟเฟกต์หน้าจอ, เลเวลสูงสุด, ออร่า, ทำให้เรียบง่าย, ซ่อน, จำกัด, ตั้งค่าเกม",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00144",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เมื่อคุณถึงระดับเลเวลที่กำหนด คุณจะมีออร่าพิเศษแสดงขึ้น\n(การถึงเลเวลจำกัดของแต่ละกลุ่มอาชีพ ตัวอย่าง: Base Level 99, 200, …)\n\nนี่คือออร่าที่แสดงถึงการถึงระดับสูงสุดของกลุ่มอาชีพ แต่คุณสามารถซ่อนมันได้หากไม่ต้องการ\nหากคุณเลือกซ่อนการแสดงผลออร่า (Hide) การแสดงออร่าทั้งหมดรวมถึงออร่าของตัวคุณเองจะถูกซ่อนไว้\n\nนอกจากนี้ หากคุณต้องการแสดงออร่าแต่คิดว่ามันใหญ่เกินไป คุณสามารถเลือก 'ออร่าขนาดเล็ก' (Mini Aura) เพื่อทำให้ขนาดของเอฟเฟกต์ดูเรียบง่ายขึ้นได้\n\nค คำสั่ง\n/aura: เปิด/ปิด การแสดงออร่าแบบเรียบง่าย\n/aura2: เปิด/ปิด การแสดงออร่า\n\nป <TIPBOX>การตั้งค่าเอฟเฟกต์<INFO>143</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[145] = {
		Title = "ตั้งค่าเอฟเฟกต์: แสดงเอฟเฟกต์#เอฟเฟกต์หน้าจอ, เอฟเฟกต์, แสงสว่าง, ตั้งค่าเกม",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00145",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"กำหนดว่าจะให้แสดงผลเอฟเฟกต์หรือไม่\n\nเอฟเฟกต์รวมถึงไม่เพียงแต่สภาพแวดล้อม เช่น แผนที่ แต่ยังรวมถึงเอฟเฟกต์สกิลและเอฟเฟกต์ของไอเทมด้วย\nในกรณีของไอเทมหรือแผนที่ที่ใช้เอฟเฟกต์จำนวนมาก การซ่อนเอฟเฟกต์อาจทำให้หลายส่วนหายไป ดังนั้นโปรดใช้งานด้วยความระมัดระวัง\n\nค คำสั่ง\n/effect: เปิด/ปิด เอฟเฟกต์\n/mineffect: ลดเอฟเฟกต์ลง/กลับสู่สถานะเดิม\n\nป <TIPBOX>การตั้งค่าเอฟเฟกต์<INFO>143</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[146] = {
		Title = "ตั้งค่าเอฟเฟกต์: แสดงเงา#เอฟเฟกต์หน้าจอ, แสงสว่าง, บรรยากาศ, ตั้งค่าเกม",
