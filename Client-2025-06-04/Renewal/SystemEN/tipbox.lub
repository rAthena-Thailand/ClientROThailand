tbl = {
	[1] = {
		Title = "กล่องคำแนะนำ (Tip Box)",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00001",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถเปิดกล่องคำแนะนำได้โดยการพิมพ์ /tip, กดปุ่ม Alt+D หรือคลิกที่ไอคอน Tipbox\nกล่องคำแนะนำจะให้ข้อมูลที่เป็นประโยชน์สำหรับการเล่นเกม\nหากคุณต้องการข้อมูลเพิ่มเติม กรุณาใส่คำค้นหาใน ^3b488cช่องค้นหา^000000\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[2] = {
		Title = "ช่วยเหลือ: รายการคำสั่ง#/h",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00002",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถดูคำสั่งที่มีประโยชน์ใน Ragnarok ได้โดยการพิมพ์ /h\nคำสั่งที่เครื่องหมาย / นำหน้า สามารถใช้งานได้โดยการพิมพ์ลงใน^3b488cหน้าต่างแชท^000000\n\nป <TIPBOX>รายการคำสั่ง<INFO>83</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่าอื่นๆ และคำสั่งในการเล่นเกม<INFO>166</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[3] = {
		Title = "ตัวละคร: HP",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00003",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"บ่งบอกถึงพลังชีวิตของตัวละคร\n^ff0000เมื่อ HP เหลือ 0 ตัวละครของคุณจะไม่สามารถทำการต่อสู้ได้ ^000000โปรดระมัดระวังเนื่องจากอาจเกิด ^ff0000บทลงโทษการเสียค่าประสบการณ์^000000 ในบางแผนที่\nกด Alt + END เพื่อเปิด/ปิด แถบแสดง HP/SP\nป <TIPBOX>ตัวละคร: SP<INFO>4</INFO></TIPBOX>\nป <TIPBOX>การฟื้นฟูอัตโนมัติ<INFO>12</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}, 
		PageEX = {
