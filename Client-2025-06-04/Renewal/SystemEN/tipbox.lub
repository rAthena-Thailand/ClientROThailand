	[13] = {
		Title = "ตัวละคร: น้ำหนักบรรทุก",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00012",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"แสดงน้ำหนักที่ตัวละครสามารถบรรทุกได้และน้ำหนักของไอเทมที่ถืออยู่ในปัจจุบัน\nคุณสามารถพกไอเทมได้ตามขีดจำกัดน้ำหนัก และหากน้ำหนัก ^ff0000เกินขีดจำกัด คุณจะไม่สามารถเก็บไอเทมได้อีก\nหากน้ำหนักอยู่ที่ 70% หรือสูงกว่า HP และ SP จะไม่ฟื้นฟูโดยอัตโนมัติ และหากเกิน 90% จะไม่สามารถโจมตีหรือใช้ทักษะได้^000000\n\nป <TIPBOX>การขยายขีดจำกัดน้ำหนัก<INFO>2002</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
