	[9135] = {
		Title = "อาชีพคลาส 4#4th Job",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เมื่อนักผจญภัยมาถึงขีดจำกัดของอาชีพคลาส 3 แล้ว เขาหรือเธอจะสามารถเปลี่ยนเป็นอาชีพคลาส 4 ได้\nทักษะที่มากขึ้นและการผจญภัยที่ยิ่งใหญ่รอคุณอยู่\n\nป <TIPBOX>คู่มือการเปลี่ยนอาชีพคลาส 4<INFO>9136</INFO></TIPBOX>\n\nค ข้อควรระวัง\nในกรณีของนักผจญภัยที่เปลี่ยนเป็นคลาส 3 ในสถานะที่ไม่ใช่แบบดั้งเดิม (non-traditional) หาก Base Level ถึง 200 <NAVI>[Disclose]<INFO>prt_in,285,161,0,101,0,</INFO></NAVI> จะสนับสนุนการเลื่อนขั้น\n\nป <TIPBOX>ไปที่หน้าอาชีพ<INFO>9031</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9136] = {
		Title = "เควสเปลี่ยนอาชีพคลาส 4#4th Job Change",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
