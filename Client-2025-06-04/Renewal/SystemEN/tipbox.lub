			{ EffectNum = 3, Twinkle = 1, StartX = 120, StartY = 265, DistX = 0, DistY = 0, MoveTime = 0 }
		}
	},
	[4] = {
		Title = "ตัวละคร: SP",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00003",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"บ่งบอกถึงพลังจิตของตัวละคร\nทักษะ (Skill) บางอย่างจะ ^3b488cใช้ค่า SP^000000 ^000000โปรดระมัดระวังเพราะ^ff0000เมื่อ SP เหลือ 0 ตัวละครของคุณจะไม่สามารถใช้ทักษะได้^000000\nกด Alt+END เพื่อเปิด/ปิด แถบแสดง HP/SP\nป <TIPBOX>ตัวละคร: HP<INFO>3</INFO></TIPBOX>\nป <TIPBOX>การฟื้นฟูอัตโนมัติ<INFO>12</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
