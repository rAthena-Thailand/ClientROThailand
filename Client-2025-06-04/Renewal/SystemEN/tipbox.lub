	[9146] = {
		Title = "JQ Abyss Chaser",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"อาชีพคลาส 4 Abyss Chaser ผู้ที่เปลี่ยนอาชีพมาจาก Shadow Chasers ใช้พลังแห่งความมืดมิด (Abyss) เพื่อทำการโจมตีต่างๆ\nพลัง Abyss สามารถใช้ในรูปแบบเวทมนตร์หรือรวมไว้ที่ปลายมีดสั้นเพื่อสร้างความเสียหายสูงสุด คุณยังสามารถใช้พลังที่ปลายลูกธนูเพื่อปลดปล่อยการโจมตีแบบต่อเนื่องได้ด้วย\nค ^663399Base Level 200 หรือสูงกว่า^000000\nค ^663399Job Level 70 หรือสูงกว่า^000000\nค ^663399อาชีพที่ต้องการ: Shadow Chaser^000000\nป <NAVI>[Vicente]<INFO>s_atelier,122,59,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>เควสเปลี่ยนอาชีพคลาส 4<INFO>9136</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
