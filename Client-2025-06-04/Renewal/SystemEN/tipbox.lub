	[7142] = {
		Title = "MD Bangungot Hospital 2nd Floor (100)",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"โรงพยาบาลเป็นสถานที่ที่น่ากลัว โรงพยาบาลแห่งนี้เป็นสถานที่ที่มีมอนสเตอร์ที่อาจเป็นคำสาป โรคภัย หรือภูตผีอาศัยอยู่??? แม้แต่เรื่องราวสยองขวัญที่ว่าถึงแม้คุณจะตาย คุณก็ยังไม่ตาย?\n\nค เงื่อนไขเบื้องต้น: ทำเควส Nurse's Quest ใน Port Malaya ให้สำเร็จ\nค ข้อมูลดันเจี้ยน\nป ทำซ้ำได้ทุกๆ 7 วัน\nป จำกัดเวลา: 60 นาที\nป เลเวล 100 ขึ้นไป\nป <NAVI>[Nurse]<INFO>ma_dun01,147,10,0,101,0</INFO></NAVI>\nป <ITEM>[Bangungot Boots of Nightmare]<INFO>2491</INFO></ITEM> หรือ <ITEM>[Kalasag]<INFO>2169</INFO></ITEM> สามารถรับได้ระหว่างการบุกดันเจี้ยน และสามารถนำไปเสริมพลังได้ที่ <NAVI>[Tribe Blacksmith]<INFO>ma_fild01,158,243,0,101,0</INFO></NAVI>\n\nป <TIPBOX>กลับไปหน้าก่อนหน้า<INFO>7141</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[7143] = {
		Title = "MD Buwaya Cave (130)",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"มอนสเตอร์ในถ้ำที่เกี่ยวข้องกับการหายตัวไปของชาวบ้าน Boo กล่าวกันว่ามีผู้คนมากมายถูกระดมกำลังมาเพื่อสังหาร Buwaya แต่พวกเขาก็ไม่เคยเอาชนะมันได้อย่างเด็ดขาด\nมาทำให้เต็มที่กันเถอะ เพื่อไม่ให้มันปรากฏตัวออกมาอีกเลย\n\nค เงื่อนไขเบื้องต้น: ทำเควส Secret in the Woods ให้สำเร็จ\nค ข้อมูลดันเจี้ยน\nป เข้าได้ทุกวัน (รีเซ็ตเวลา 04:00 น. ของวันถัดไป)\nป จำกัดเวลา: 60 นาที\nป เลเวล 130 ขึ้นไป\nป <NAVI>[Guard]<INFO>ma_fild02,312,317,0,101,0</INFO></NAVI>\nป <ITEM>[Buwaya Sack Cloth]<INFO>2590</INFO></ITEM> หรือ <ITEM>[Kalasag]<INFO>2169</INFO></ITEM> สามารถรับได้ระหว่างการบุกดันเจี้ยน และสามารถนำไปเสริมพลังได้ที่ <NAVI>[Tribe Blacksmith]<INFO>ma_fild01,158,243,0,101,0</INFO></NAVI>\n\nป <TIPBOX>กลับไปหน้าก่อนหน้า<INFO>7141</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
