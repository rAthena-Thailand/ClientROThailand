	[4225] = {
		Title = "Q Contest of the Gray Wolf Forest (170)#Quest Episode 18", -- เควสการประลองแห่งป่าหมาป่าสีเทา (170)#เควสตอนที่ 18
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"นักผจญภัยผู้ซึ่งสร้างความสัมพันธ์กับผู้คนในป่าหมาป่าสีเทาและได้รับการยอมรับให้เป็นสมาชิกของหมู่บ้าน จะได้รับการเห็นคุณค่าในความพยายาม และจะได้เข้าร่วมในการประชุมเพื่อกำหนดอนาคตของป่าหมาป่าสีเทาด้วย\nการแข่งขันที่เริ่มต้นขึ้นในที่สุด ผลของการประชุมจะเป็นอย่างไร?\nดำเนินการแข่งขันเพื่อชิงสิทธิ์\nค ^663399เลเวล 170 ขึ้นไป^000000\nป <NAVI>[Village Boy]<INFO>wolfvill,180,179,0,101,0</INFO></NAVI>\n\nป <TIPBOX>Episode 18 Direction of Prayer<INFO>4217</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำเพิ่มเติม<INFO>1000</INFO></TIPBOX>"
		}
	},
	[4226] = {
