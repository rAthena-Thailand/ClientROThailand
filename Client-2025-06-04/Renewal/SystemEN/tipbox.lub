	[9162] = {
		Title = "แนะนำโครงการปรับปรุงอุปกรณ์ของสถาบัน Regenschirm#Item Reform",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ทีมวิจัยทั้งสี่ทีมของสถาบันวิจัย Regenschirm ในเครือ Rekenber กำลังปรับปรุงความสมบูรณ์แบบเพื่อการพาณิชย์โดยการทำการทดลองในแบบของตนเอง\nพวกเขารับคำร้องจากนักผจญภัยเฉพาะอุปกรณ์ที่ผ่านการวิจัยสำเร็จแล้วเท่านั้น เพื่อนำมาดัดแปลงและอัปเกรดเป็นอุปกรณ์ใหม่ เนื่องจากเป้าหมายของกระบวนการทั้งหมดคือการสะสมข้อมูล ผลลัพธ์จึงถูกส่งคืนให้กับเจ้าของ ช่างโชคดีจริงๆ\nโปรดทราบว่าการอัปเกรดมักต้องการระดับการขัดเกลา (Refine rate) ที่กำหนดไว้\n\nโปรดดูรายการอุปกรณ์ที่แต่ละทีมดูแลได้ด้านล่าง:\nป <TIPBOX>[Team Atnard]<INFO>9163</INFO></TIPBOX>\nทีมวิจัยเฉพาะทางด้านอาวุธ\nป <TIPBOX>[Team Fresa]<INFO>9164</INFO></TIPBOX>\nทีมวิจัยเฉพาะทางด้านชุดเกราะ\nป <TIPBOX>[Team Gerter]<INFO>9165</INFO></TIPBOX>\nทีมวิจัยเฉพาะทางด้านเครื่องประดับ\nป <TIPBOX>[Team Richiet]<INFO>9166</INFO></TIPBOX>\nทีมวิจัยอุปกรณ์ที่ไม่ได้มาตรฐาน\n\nวิธีเดินทางไปยังสถาบัน Regenschirm:\nป <NAVI>[Equipment Modification PR Agent]<INFO>lighthalzen,99,156,0,101,0</INFO></NAVI>\n(Lighthalzen)\nป <NAVI>[Equipment Modification PR Agent]<INFO>itemmall,14,50,0,101,0</INFO></NAVI>\n(Item Mall)\n\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9163] = {
		Title = "รายการอุปกรณ์ดัดแปลงของ Team Atnard#Regenschirm Equipment Modification Item Reform",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"นี่คือรายการอุปกรณ์ที่ดัดแปลงโดย Atnard ทีมในเครือสถาบันวิจัย Regenschirm ภายใต้ Rekenber\nอุปกรณ์ที่จะนำมาดัดแปลงต้องการระดับการขัดเกลา +9 หรือสูงกว่าสำหรับอาวุธ Thanos และ +7 หรือสูงกว่าสำหรับอาวุธ OS\n\nป อาวุธ Thanos\nป <ITEM>[Thanos Sword-AD]<INFO>500024</INFO></ITEM>\nป +9 <ITEM>[Thanos Sword]<INFO>13441</INFO></ITEM>\nป <ITEM>[Thanos Greatsword-AD]<INFO>600016</INFO></ITEM>\nป +9 <ITEM>[Thanos Greatsword]<INFO>21009</INFO></ITEM>\nป <ITEM>[Thanos Katar-AD]<INFO>610019</INFO></ITEM>\nป +9 <ITEM>[Thanos Katar]<INFO>28000</INFO></ITEM>\nป <ITEM>[Thanos Axe-AD]<INFO>620009</INFO></ITEM>\nป +9 <ITEM>[Thanos Axe]<INFO>28100</INFO></ITEM>\nป <ITEM>[Thanos Bow-AD]<INFO>700029</INFO></ITEM>\nป +9 <ITEM>[Thanos Bow]<INFO>18119</INFO></ITEM>\nป <ITEM>[Thanos Hammer-AD]<INFO>590020</INFO></ITEM>\nป +9 <ITEM>[Thanos Hammer]<INFO>16028</INFO></ITEM>\nป <ITEM>[Thanos Dagger-AD]<INFO>510030</INFO></ITEM>\nป +9 <ITEM>[Thanos Dagger]<INFO>13093</INFO></ITEM>\nป <ITEM>[Thanos Two-Handed Staff-AD]<INFO>640017</INFO></ITEM>\nป +9 <ITEM>[Thanos Two-Handed Staff]<INFO>2023</INFO></ITEM>\nป <ITEM>[Thanos Whip-AD]<INFO>580016</INFO></ITEM>\nป +9 <ITEM>[Thanos Whip]<INFO>1988</INFO></ITEM>\nป <ITEM>[Thanos Violin-AD]<INFO>570016</INFO></ITEM>\nป +9 <ITEM>[Thanos Violin]<INFO>1933</INFO></ITEM>\nป <ITEM>[Thanos Knuckle-AD]<INFO>560017</INFO></ITEM>\nป +9 <ITEM>[Thanos Knuckle]<INFO>1836</INFO></ITEM>\nป <ITEM>[Thanos Staff-AD]<INFO>550023</INFO></ITEM>\nป +9 <ITEM>[Thanos Staff]<INFO>1669</INFO></ITEM>\nป <ITEM>[Thanos Spear-AD]<INFO>530012</INFO></ITEM>\nป +9 <ITEM>[Thanos Spear]<INFO>1438</INFO></ITEM>\n\nป อาวุธ OS\nป <ITEM>[Beam Claymore-OSAD]<INFO>600028</INFO></ITEM>\nป +7 <ITEM>[Beam Claymore-OS]<INFO>21047</INFO></ITEM>\nป <ITEM>[Meuchler-OSAD]<INFO>610039</INFO></ITEM>\nป +7 <ITEM>[Meuchler-OS]<INFO>28038</INFO></ITEM>\nป <ITEM>[Blasti-OSAD]<INFO>620018</INFO></ITEM>\nป +7 <ITEM>[Blasti-OS]<INFO>28136</INFO></ITEM>\nป <ITEM>[Virtual Bow-OSAD]<INFO>700054</INFO></ITEM>\nป +7 <ITEM>[Virtual Bow-OS]<INFO>18178</INFO></ITEM>\nป <ITEM>[MH-P89-OSAD]<INFO>700055</INFO></ITEM>\nป +7 <ITEM>[MH-P89-OS]<INFO>18179</INFO></ITEM>\nป <ITEM>[AC-B44-OSAD]<INFO>700056</INFO></ITEM>\nป +7 <ITEM>[AC-B44-OS]<INFO>18180</INFO></ITEM>\nป <ITEM>[HR-S55-OSAD]<INFO>810013</INFO></ITEM>\nป +7 <ITEM>[HR-S55-OS]<INFO>28253</INFO></ITEM>\nป <ITEM>[Burning Knuckle-OSAD]<INFO>560034</INFO></ITEM>\nป +7 <ITEM>[Burning Knuckle-OS]<INFO>1862</INFO></ITEM>\nป <ITEM>[Cannon Rapier-OSAD]<INFO>500051</INFO></ITEM>\nป +7 <ITEM>[Cannon Rapier-OS]<INFO>13493</INFO></ITEM>\nป <ITEM>[Saphir Mace-OSAD]<INFO>590043</INFO></ITEM>\nป +7 <ITEM>[Saphir Mace-OS]<INFO>16088</INFO></ITEM>\nป <ITEM>[Ultio-OSAD]<INFO>590044</INFO></ITEM>\nป +7 <ITEM>[Ultio-OS]<INFO>16089</INFO></ITEM>\nป <ITEM>[Rutilus Stick-OSAD]<INFO>550075</INFO></ITEM>\nป +7 <ITEM>[Rutilus Stick-OS]<INFO>26151</INFO></ITEM>\nป <ITEM>[Electric Fox-OSAD]<INFO>550076</INFO></ITEM>\nป +7 <ITEM>[Electric Fox-OS]<INFO>26164</INFO></ITEM>\nป <ITEM>[Circuit Board-OSAD]<INFO>540051</INFO></ITEM>\nป +7 <ITEM>[Circuit Board-OS]<INFO>28629</INFO></ITEM>\nป <ITEM>[Kuroiro-OSAD]<INFO>510066</INFO></ITEM>\nป +7 <ITEM>[Kuroiro-OS]<INFO>28755</INFO></ITEM>\nป <ITEM>[Boost Lance-OSAD]<INFO>530031</INFO></ITEM>\nป +7 <ITEM>[Boost Lance-OS]<INFO>32019</INFO></ITEM>\n\nผู้จัดการ Team Atnard:\nป <NAVI>[Phase]<INFO>rgsr_in,115,169,0,101,0</INFO></NAVI>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9162</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
		}
	},
