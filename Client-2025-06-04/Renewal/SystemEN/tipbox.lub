	[48] = {
		Title = "สัตว์เลี้ยง: การจับมอนสเตอร์#Petal",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00048",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ในการจับมอนสเตอร์ ต้องเตรียมไอเทมสำหรับจับ (Taming item) ที่เหมาะสมกับมอนสเตอร์ชนิดนั้นๆ\nหลังจากเตรียมข้อมูลและไอเทมเรียบร้อยแล้ว ให้ดับเบิลคลิกไอเทมจับแล้วเลือกเป้าหมายที่มอนสเตอร์ตัวนั้น\nเมื่อเลือกเป้าหมายแล้ว จะมีเครื่องสล็อตแมชชีนปรากฏขึ้นตรงกลางหน้าจอ คุณสามารถคลิกที่สล็อตแมชชีนเพื่อลุ้นผลสำเร็จหรือล้มเหลว\n\nเมื่อจับสำเร็จ ข้อความแจ้งการได้รับไข่มอนสเตอร์จะแสดงขึ้นพร้อมคำว่า Success และคุณสามารถตรวจสอบไข่มอนสเตอร์ได้ในหน้าต่างสัมภาระ\n\nป <TIPBOX>ระบบสัตว์เลี้ยง<INFO>47</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[49] = {
		Title = "สัตว์เลี้ยง: NPC ที่เกี่ยวข้อง#Taming Merchant, Pet Food, Egg Incubator, Egg Incubator, Pet Food, Pet Accessories",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00049",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ค พ่อค้าแลกเปลี่ยนสัตว์เลี้ยง\nหากคุณมีคูปองที่สามารถแลกเปลี่ยนเป็นสัตว์เลี้ยงได้ คุณสามารถนำไปแลกเป็นสัตว์เลี้ยงที่กำหนดได้ผ่าน ^3b488cพ่อค้าสัตว์เลี้ยงใน Alberta และ Prontera^000000\nป <NAVI>[Alberta Pet Trader]<INFO>alberta,179,141,0,101,0</INFO></NAVI>\nป <NAVI>[Prontera Pet Trader]<INFO>prontera,210,209,0,101,0</INFO></NAVI>\n\nค พ่อค้าอุปกรณ์สัตว์เลี้ยง\nประจำอยู่ตามเมืองต่างๆ ขายไอเทมจำพวก ^3b488cที่ฟักไข่พกพา, อาหารสัตว์, เครื่องประดับ^000000 ฯลฯ\nป <NAVI>[Prontera Pet Groomer]<INFO>prontera,218,211,0,101,0</INFO></NAVI>\nป <NAVI>[Geffen Pet Groomer]<INFO>geffen,193,152,0,101,0</INFO></NAVI>\nป <NAVI>[Izlude Pet Groomer]<INFO>izlude_in,72,98,0,101,0</INFO></NAVI>\nป <NAVI>[Morroc Pet Groomer]<INFO>morocc,203,87,0,101,0</INFO></NAVI>\nป <NAVI>[Morroc (Pyramid) Pet Groomer]<INFO>moc_ruins,118,170,0,101,0</INFO></NAVI>\nป <NAVI>[Payon Pet Groomer]<INFO>payon,177,131,0,101,0</INFO></NAVI>\nป <NAVI>[Yuno Pet Groomer]<INFO>yuno,197,114,0,101,0</INFO></NAVI>\nป <NAVI>[Lighthalzen Pet Groomer]<INFO>lighthalzen,222,191,0,101,0</INFO></NAVI>\nป <NAVI>[Brasilis Pet Groomer]<INFO>brasilis,201,309,0,101,0</INFO></NAVI>\nป <NAVI>[Lasagna Pet Groomer]<INFO>lasagna,179,176,0,101,0</INFO></NAVI>\n\nป <TIPBOX>ระบบสัตว์เลี้ยง<INFO>47</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
