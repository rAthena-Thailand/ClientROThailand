	[4000] = {
		Title = "โลกแห่ง Ragnarok",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เวทีแห่งการผจญภัยในโลกของ Ragnarok ส่วนใหญ่คือทวีป Midgard ดินแดนที่มีมนุษย์เป็นศูนย์กลาง\nดินแดนที่อยู่เหนือมิติซึ่งมีเหล่าแฟรี่และยักษ์อาศัยอยู่ และพื้นที่ท้องถิ่นในเขตนิรนามที่ถูกค้นพบโดยเหล่าผู้สำรวจ\n\nป <TIPBOX>ทวีป Midgard<INFO>4001</INFO></TIPBOX>\nป <TIPBOX>ดินแดนเหนือมิติ<INFO>4002</INFO></TIPBOX>\nป <TIPBOX>ภูมิภาคท้องถิ่น (Localizing Region)<INFO>4003</INFO></TIPBOX>\n\nป <TIPBOX>แผนที่โลก<INFO>900</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[4001] = {
		Title = "ทวีป Midgard",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Midgard คือศูนย์กลางแห่งชีวิตและเป็นทวีปหลักของเหล่ามนุษย์ผู้มีชีวิตรอด\nหลังจากสงครามศักดิ์สิทธิ์ที่เหล่าเทพ เจ้าหญิง และมนุษย์ต่างต่อสู้เพื่อความเชื่อของตนเอง\nมีสามประเทศที่เป็นแกนหลักตั้งอยู่ตามแนวชายฝั่งตะวันออกเฉียงใต้ของทวีป Midgard\n\nป <TIPBOX>อาณาจักร Rune-Midgards<INFO>4004</INFO></TIPBOX>\nป <TIPBOX>สาธารณรัฐ Schwartzvald<INFO>4040</INFO></TIPBOX>\nป <TIPBOX>อาณาจักร Arunafeltz<INFO>4050</INFO></TIPBOX>\n\nป <TIPBOX>Malangdo<INFO>4031</INFO></TIPBOX>\nป <TIPBOX>Lutie<INFO>4014</INFO></TIPBOX>\n\nค ^663399ดันเจี้ยนในภูมิภาค Midgard^000000\nป <TIPBOX>ทางลัด<INFO>6151</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[4002] = {
		Title = "ดินแดนเหนือมิติ",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"จอมมาร Morroc ที่อ่อนกำลังลงได้สร้างรอยแยกขนาดใหญ่ในมิติเพื่อซ่อนตัว เหล่านักผจญภัยที่กระโจนเข้าสู่รอยแยกมิติเพื่อตามล่า Morroc ได้พบกับโลกใหม่ที่นั่น คณะสำรวจซึ่งตั้งชื่อโลกนิรนามแห่งนี้ว่า \'Ash-Vacuum\' จะต้องแกะรอยตามร่องรอยของราชาปีศาจพร้อมกับคลี่คลายเรื่องราวของดินแดนที่ไม่คุ้นเคยนี้\nป <NAVI>[Cat Paw Agent]<INFO>moc_para01,44,19,0,101,0</INFO></NAVI> สามารถนำทางคุณไปที่นั่นได้\n\nป <TIPBOX>รอยแยกมิติ (Dimensional Rift)<INFO>4021</INFO></TIPBOX>\nป <TIPBOX>ค่ายสำรวจร่วมสามอาณาจักร<INFO>4015</INFO></TIPBOX>\nป <TIPBOX>ด่านหน้า Laphine, Splendide<INFO>4016</INFO></TIPBOX>\nป <TIPBOX>เมืองเหมือง Sapha, Manuk<INFO>4017</INFO></TIPBOX>\nป <TIPBOX>เมืองหลวงของ Sapha, El Dicastes<INFO>4018</INFO></TIPBOX>\nป <TIPBOX>เมืองหลวงของ Laphine, Eclage<INFO>4019</INFO></TIPBOX>\nป <TIPBOX>จุดพักนักเดินทาง, หมู่บ้าน Mora<INFO>4020</INFO></TIPBOX>\n\nป <TIPBOX>โลกแห่ง Ragnarok<INFO>4000</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
