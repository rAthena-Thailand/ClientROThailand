	[93] = {
		Title = "การถอดการ์ด#ถอดการ์ด, Socket, สารหล่อลื่น, Richard, Malangdo",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00093",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณต้องการย้ายการ์ดที่ติดตั้งอยู่ในอุปกรณ์หนึ่งไปยังอีกอุปกรณ์หนึ่งใช่ไหม? ในกรณีนั้น โปรดอย่าลังเลที่จะมาหาข้า~!\n\nค่าธรรมเนียมการถอดการ์ดปกติ\nป <ITEM>[New Type Advanced Lubricant]<INFO>25239</INFO></ITEM>\nป <ITEM>[New Type Normal Lubricant]<INFO>25238</INFO></ITEM>\nการ์ดสามารถแยกออกมาได้โดยการเลือกสารหล่อลื่นชนิดใดชนิดหนึ่งพร้อมจ่าย ^009999[100,000 Zeny]^000000 แน่นอนว่าโอกาสสำเร็จจะดีที่สุดเมื่อใช้สารหล่อลื่นคุณภาพสูงรุ่นใหม่\n\nค่าธรรมเนียมการถอดการ์ดบอส\nป <ITEM>[Cillit Pong]<INFO>6443</INFO></ITEM>\n\nสำหรับรายละเอียดเพิ่มเติม โปรดปรึกษา ป <NAVI>[Richard]<INFO>malangdo,220,160,0,101,0</INFO></NAVI> ในเมือง Malangdo"
		}
	},
	[94] = {
		Title = "ไอเทมคอสตูม#Fashion Stone, Costume Headgear, Enchantment, Effect",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00094",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ไอเทมคอสตูมคือไอเทมที่สวมใส่ทับอุปกรณ์ที่มีอยู่เดิม และเป็นไอเทมที่เน้นด้านแฟชั่นมากกว่าประสิทธิภาพ\nมีทั้งส่วนหัวบน/กลาง/ล่าง และชุดเกราะ โดยจะสวมใส่ในแถบ Special Equipment ในหน้าต่าง UI อุปกรณ์ (ALT+Q)\n\n\nป <TIPBOX>Fashion Stone: การเสริมพลังคอสตูม<INFO>95</INFO></TIPBOX>\nป <TIPBOX>Fashion Stone: คูปองแลกคอสตูม<INFO>53</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[95] = {
		Title = "Fashion Stone: การเสริมพลังคอสตูม#Fashion Stone, Costume Headgear, Enchantment, Effect, Aver De Dosh, Heidam Fellow, Eve Pater, Lace La Zard, Libri, Gregio Grumani",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00095",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ยินดีต้อนรับ! นี่คือ Fashion Stone!!\nพวกเรา <NAVI>[Fashion Stone]<INFO>malangdo,116,151,0,101,0</INFO></NAVI> จัดการไอเทมคอสตูมหลากหลายรูปแบบ\nหากคุณต้องการแต่งสไตล์ไอเทมหมวกคอสตูมให้ดูดีขึ้น พบกับผู้จัดการร้าน ^e5004f\'Aver De Dosh\'^000000 หากคุณต้องการตกแต่งไอเทม ให้ไปหา ^e5004f\'Lace La Zard\'^000000 หากคุณต้องการแลกเปลี่ยนไอเทมคอสตูมหรือแลกเปลี่ยน Costume Stone Box ให้ไปหา ^e5004f\'Heidam Fellow\'^000000 หากคุณต้องการเพิ่มเอฟเฟกต์ให้กับไอเทมคอสตูม ให้ไปหา ^e5004f\'Gregio Gurmani\'^000000 หากคุณต้องการเปลี่ยนไอเทมธรรมดาให้เป็นไอเทมคอสตูม ให้ไปหา ^e5004f\'Eve Pater\'^000000 และปรึกษา \'Libri\' สำหรับการเปลี่ยนออปชั่นของหินบางชนิด รวมถึง 'Convex Lens' เพื่อซื้อแว่นขยาย!\n^e5004fไอเทมลิมิเต็ดบางชิ้นจะไม่สามารถใช้บริการของ Fashion Stone ได้^000000\n\n\nป <TIPBOX>ไอเทมคอสตูม<INFO>94</INFO></TIPBOX>\nป <TIPBOX>Fashion Stone: คูปองแลกคอสตูม<INFO>53</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
