	[4399] = {
		Title = "Q Fresh taste! (230)#230 Episode 21 Daily Quest", -- Q รสชาติที่สดใหม่! (230)#เควสรายวัน Episode 21 เลเวล 230
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"กลุ่มทหารรับจ้าง Richard ผู้ปฏิบัติหน้าที่หลากหลายใน Lunaforma ต้องการวัตถุดิบที่แตกต่างกันไปตามสถานการณ์ มาช่วยหาวัตถุดิบสดใหม่ที่พวกเขาต้องการในบริเวณใกล้เคียงกันเถอะ\n\nป เงื่อนไข: ต้องสำเร็จภารกิจ <TIPBOX>Q It's called a mercenary group... (230)<INFO>4387</INFO></TIPBOX>\nค ^663399เลเวล 230 ขึ้นไป^000000\n\nป <NAVI>[Baldaris]<INFO>mbase_in,302,123,0,101,0</INFO></NAVI>\n\nป <TIPBOX>EP 21 Age of Heroes<INFO>4367</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
