	[4299] = {
		Title = "ซีรีส์แฟนตาซี VR-Books#ซีรีส์แฟนตาซี",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip04299",
		Imgcoord= { Position = 5, Size = 100 },
		Page= {
			"ซีรีส์แฟนตาซีเป็นหนังสือนิทานแนวคิดใหม่ที่ให้คุณดำเนินเรื่องราวในพื้นที่เสมือนจริงไปกับเหล่าตัวละครในหนังสือ คุณสามารถสัมผัสประสบการณ์นี้ได้ที่ห้องสมุดทิศตะวันออกของ Prontera! อ่านซีรีส์แฟนตาซีและสะสมของใช้ส่วนตัวของตัวละครเพื่อเป็นรางวัล! คุณจะได้รับ Minimi พิเศษด้วย\n\nค ^663399รายชื่อหนังสือซีรีส์แฟนตาซี^000000\nป <TIPBOX>คุณหนูช้อนทองผู้รักความสงบ<INFO>4300</INFO></TIPBOX>\nป <TIPBOX>บันทึกการหลบหนีของนักวิทยาศาสตร์<INFO>4301</INFO></TIPBOX>\nป <TIPBOX>Elena Bolkova, เปลวเพลิงอันยิ่งใหญ่<INFO>4302</INFO></TIPBOX>\nป <TIPBOX>ไม้ประดับที่ใครก็ปลูกได้ง่ายๆ (ฉบับปฏิบัติจริง)<INFO>4303</INFO></TIPBOX>\n\nป <TIPBOX>ข้าวสารสด~สมุดทำอาหารเพื่อการพักผ่อนที่ Hugel ของ Seyren Windsor<INFO>4308</INFO></TIPBOX>\nป <TIPBOX>การเลี้ยง Angelling~Poring ในความฝัน~<INFO>4309</INFO></TIPBOX>\nป <TIPBOX>ฉันเป็นสายเลือดบริสุทธิ์เพียงคนเดียวในสถาบัน<INFO>4310</INFO></TIPBOX>\nป <TIPBOX>คู่มือธุรกิจ Criatura<INFO>4311</INFO></TIPBOX>\nป <TIPBOX>การผจญภัยครั้งใหญ่เหนือสุดปลายสายรุ้ง<INFO>4312</INFO></TIPBOX>\n\nค ^663399ไอเทมพิเศษ^000000\nป <TIPBOX>รายการแลกเปลี่ยนทั่วไป<INFO>4304</INFO></TIPBOX>\nป <TIPBOX>Minimi จากซีรีส์แฟนตาซี<INFO>4305</INFO></TIPBOX>\nป <TIPBOX>ไอเทมบัฟของตัวเอกในซีรีส์แฟนตาซี<INFO>4306</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[4300] = {
		Title = "VR001 คุณหนูช้อนทองผู้รักความสงบ#หนังสือแฟนตาซี",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\illust\\vrbook001_k",
		Imgcoord= { Position = 5, Size = 70 },
		Page= {
			"ซีรีส์แฟนตาซีจากผลงานยอดนิยมในหมวดโรแมนติกแฟนตาซีเปิดตัวแล้ว!\nความร่วมมือระหว่างเจ้าหญิงที่อยากใช้ชีวิตอย่างสงบกับสภาพแวดล้อมที่ไม่ยอมให้เป็นเช่นนั้น\nค ^4d4dff#นิยายวังหลวง #เน้นกิจกรรม #ปริศนา^000000\n\nค ^663399สถานที่ตั้งหนังสือ^000000\nค ห้องสมุดทิศตะวันออกของ Prontera\nค <NAVI>[Fantasy Seriesญ-001]<INFO>prt_elib,54,60,0,101,0</INFO></NAVI>\n\nค ^663399เลเวลพื้นฐาน: 100 Lv^000000\nค ^663399ประเภทการดำเนินเรื่อง: Field^000000\n\nค ประพันธ์โดย Spica Nerius\nค ผู้ผลิตและจัดพิมพ์: VR-Books\n\nป <TIPBOX>ซีรีส์แฟนตาซี VR-Books<INFO>4299</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[4301] = {
		Title = "VR002 บันทึกการหลบหนีของนักวิทยาศาสตร์#หนังสือแฟนตาซี",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\illust\\vrbook002_k",
		Imgcoord= { Position = 5, Size = 70 },
		Page= {
			"ผลงานนี้ถูกสร้างขึ้นใหม่โดยหน่วย Rebellion หลังจากตรวจสอบบันทึกของนักวิทยาศาสตร์ที่หลบหนีจากห้องทดลองวิจัยที่ผิดกฎหมาย โอกาสที่จะได้เห็นมุมมองทางจิตวิทยาของอาชญากรพิเศษระดับแนวหน้า\nค ^4d4dff#ไดอารี่ #การเอาชีวิตรอด^000000\n\nค ^663399สถานที่ตั้งหนังสือ^000000\nค ห้องสมุดทิศตะวันออกของ Prontera\nค <NAVI>[Fantasy Seriesญ-002]<INFO>prt_elib,59,60,0,101,0</INFO></NAVI>\n\nค ^663399เลเวลพื้นฐาน: 100 Lv^000000\nค ^663399ประเภทการดำเนินเรื่อง: Field^000000\n\nค บันทึกของ Eisen Werner, เรียบเรียงโดย Rebellion\nค ผู้ผลิตและจัดพิมพ์: VR-Books\n\nป <TIPBOX>ซีรีส์แฟนตาซี VR-Books<INFO>4299</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
