	[5001] = {
		Title = "MD Geffen Night Arena (210)#Geffen Night Arena Tournament Hero's Trace Magic",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip05001",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"มีข้อมูลข่าวกรองว่ามีสถานที่ที่เหล่านักสู้ที่เคยโลดแล่นในการประลองเวทมนตร์พากันถอดหน้ากากและต่อสู้กัน บางทีถ้าคุณลองถามชายจอมซนคนนั้นดู คุณอาจจะได้รับข้อมูลที่ถูกต้อง?\n\nค โครงสร้างดันเจี้ยน\nป ทำซ้ำได้ทุกๆ 3 วัน\nป จำกัดเวลา: 60 นาที\n(อย่างไรก็ตาม จำกัดเวลาต่อรอบคือ 1 นาที)\nป เลเวล 210 หรือสูงกว่า\n\nจุดเริ่มต้น\nป <NAVI>[Naughty Man]<INFO>geffen_in,78,62,0,101,0</INFO></NAVI>\n\nตำแหน่งทางเข้าดันเจี้ยน\nป <NAVI>[Abandoned Portal]<INFO>dali02,80,61,0,101,0</INFO></NAVI>\n\nค ตำแหน่งแลกเปลี่ยนอุปกรณ์\nป <NAVI>[Abandoned Vending Machine]<INFO>dali02,83,67,0,101,0</INFO></NAVI>\n\n\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>7129</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
