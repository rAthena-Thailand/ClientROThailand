	[7092] = {
		Title = "MD Horror Toy Factory Beginner (70)",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"นักวิจัยที่แนะนำตัวเองว่าเป็นผู้ศึกษาเรื่องเวลาและมิติในชุดแต่งกายที่แปลกประหลาด เขากล่าวว่าการก้าวข้ามรอยแยกมิติที่เสถียร อาจส่งผลต่อเหตุและผลภายในดันเจี้ยน มันฟังดูน่าสงสัย แต่สำหรับโรงงานของเล่นที่อ่อนแอพอที่แม้แต่มือใหม่ก็เข้าถึงได้ การเข้าไปสำรวจก็ไม่ใช่ความคิดที่แย่นัก\n\nค ข้อมูลดันเจี้ยน\nป ทำซ้ำได้สัปดาห์ละครั้ง (รีเซ็ตทุกวันพฤหัสบดี เวลา 04:00 น.)\nป จำกัดเวลา: 60 นาที\nป เลเวล 70 หรือสูงกว่า\nป <NAVI>[Unusual Clown]<INFO>xmas,232,290,0,101,0</INFO></NAVI>\n\nค ไอเทมดรอปจากการตะลุยดันเจี้ยน\nป <ITEM>[Bloody Coin]<INFO>7642</INFO></ITEM>\nป <ITEM>[Old Parasol]<INFO>13442</INFO></ITEM>\nป <ITEM>[Shadow Walk]<INFO>2486</INFO></ITEM>\nป <ITEM>[Red Lantern]<INFO>2976</INFO></ITEM>\nป <ITEM>[Wounded Heart]<INFO>2977</INFO></ITEM>\nป <ITEM>[Gentle Heart]<INFO>2978</INFO></ITEM>\nป <ITEM>[Lush Rose]<INFO>18848</INFO></ITEM>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>7091</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
