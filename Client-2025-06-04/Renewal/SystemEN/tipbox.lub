	[8048] = {
		Title = "บันทึกประจำวัน",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\item\\ฑืณเภวธถภฝ",
		Imgcoord = { Position = 5, Size = 200 },
		Page = {
			"^339999เดือน X วันที่ X^000000\n\ฉันพอใจกับชีวิตคู่กับ Cain แต่เส้นทางของแม่บ้านยังยากเกินไปสำหรับฉัน เธอทำได้ พยายามต่อไปนะ!",
			"^666666..........ฉันพลิกไปสองสามหน้า^000000",
			"^339999เดือน X วันที่ X^000000\n\nฉันเผลอหลับไปตอนกำลังทำอาหารเย็นและทำอาหารไหม้ อา ทำไมฉันถึงทำแบบนี้! ถ้าเป็นแบบนี้ต่อไปฉันคงจะกลายเป็นเจ้าสาวที่ถูกเกลียดชัง!",
			"^666666..........ฉันพลิกไปสองสามหน้า^000000",
			"^339999เดือน X วันที่ X^000000\n\nฉันมีลูกแล้ว ลูกของฉันกับ Cain หัวใจของฉันสับสนระหว่างความกังวลเล็กน้อยและความปีติยินดีอย่างมาก ด้วยใบหน้าที่อวบอิ่มของเธอ Cain บอกว่าเธอจะได้เป็นเหมือนพ่อของเธอแล้วเขาก็ยิ้ม เมื่อคิดถึงอนาคตฉันก็กลัวนิดหน่อย แต่พอเห็น Cain ฉันก็มีความสุขด้วย",
			"^666666..........ฉันพลิกไปสองสามหน้า^000000",
			"^339999เดือน X วันที่ X^000000\n\nประสาทของ Cain เริ่มตึงเครียดขึ้นทีละนิด หลังจากมีการสร้างโรงงานในหมู่บ้านข้างๆ ชายหนุ่มในหมู่บ้านก็พากันเลิกอาชีพขุดเหมือง เขาภูมิใจในงานของเขามากและดูเหมือนจะได้รับบาดเจ็บทางใจอย่างลึกซึ้ง\n\nป ฉันอยากจะปลอบโยนเขาเวลาที่เขาหดหู่ แต่ฉันไม่รู้ว่าจะปลอบเขาอย่างไร มันเจ็บปวดมากที่ไม่สามารถเป็นกำลังใจให้เขาได้ในเวลาแบบนี้",
			"^666666..........ฉันพลิกไปสองสามหน้า^000000",
			"^339999เดือน X วันที่ X^000000\n\nลูกเกิดมาแล้ว เป็นลูกสาวที่น่ารักจริงๆ เธอชื่อ ^339999Tarsha^000000 ดวงตาของเธอเหมือน Cain และเธอก็น่ารักมาก ลูกของฉัน ^339999Tarsha^000000! ฉันอยากเป็นแม่ที่ดีจริงๆ สำหรับเด็กคนนี้",
			"^666666..........ฉันพลิกไปสองสามหน้า^000000",
			"^339999เดือน X วันที่ X^000000\n\nTarsha เรียกฉันว่า \'แม่\'! นี่เป็นความสุขที่มหัศจรรย์จริงๆ ถ้าเด็กคนนี้โตมาอย่างดีและแข็งแรง ฉันไม่คิดว่าฉันจะขออะไรไปมากกว่านี้อีกแล้ว",
			"^666666..........ฉันพลิกไปสองสามหน้า^000000",
			"^339999เดือน X วันที่ X^000000\n\nCain ประสบอุบัติเหตุ ดูเหมือนว่าจะมีก๊าซพิษออกมาขณะขุดหาแร่ธาตุ ไม่มีความเสียหายใหญ่หลวงนัก แต่ก๊าซทำให้แขนขวาของเขาเป็นอัมพาต และ Cain ไม่สามารถไปที่เหมืองได้อีกต่อไป\n\nเขาจมอยู่ในความเศร้าโศกอย่างหนัก เมื่อฉันเตรียมซุปร้อนๆ ให้เขา Cain ยิ้มขอบคุณและกินซุปจนหมด แต่เงาของความเศร้าบนใบหน้าของเขาก็ไม่หายไป\n\nในเมื่อเขารักงานของเขามาก เขาจึงดูสิ้นหวังมาก พรุ่งนี้ฉันต้องแสดงฝีมือการทำอาหารให้ Cain ดู ฉันหวังว่าเขาจะแข็งแกร่งขึ้น",
			"^666666..........ฉันพลิกไปสองสามหน้า^000000",
			"^339999เดือน X วันที่ X^000000\n\nวันที่ Cain กลับบ้านมาพร้อมความมึนเมานั้นเพิ่มมากขึ้น อารมณ์ฉุนเฉียวก็แย่ลง หัวใจของเขาเต็มไปด้วยพลังอันมืดมนจนฉันไม่สามารถเข้าถึงเขาได้อีกแล้ว\n\nเหมือนหมาป่าที่หิวกระหาย เขาดูดุร้ายและเกรี้ยวกราด ฉันกลัวเขา",
			"^666666..........ฉันพลิกไปสองสามหน้า^000000",
			"^339999เดือน X วันที่ X^000000\n\nTarsha กำลังเล่นสนุกในห้องครัวและโดนน้ำร้อนลวกมือ การรักษาเสร็จสิ้นไปด้วยดี แต่มือของ Tarsha บางส่วนก็ยังคงทิ้ง ^ 339999 รอยแผลเป็นจากน้ำร้อนลวก ^ 000000 ไว้\nTarsha เล่นกับตุ๊กตาของเธอเหมือนที่เคยทำและหัวเราะคิกคัก แต่ทำไมไม่รู้ฉันกลับร้องไห้",
			"^666666..........ฉันพลิกไปสองสามหน้า^000000",
			"^339999เดือน X วันที่ X^000000\n\nCain ไม่เข้าบ้านอีกต่อไปแล้ว เงินที่เขาเคยหาได้ก็ร่อยหรอลง และเขาเริ่มทำงานในร้านค้าในหมู่บ้าน\nมันยากและลำบากจริงๆ ที่ต้องทำงานบ้านและงานที่ร้านไปพร้อมๆ กัน แต่เมื่อมองไปที่รอยยิ้มที่ไร้เดียงสาของ Tarsha ฉันก็แข็งแกร่งขึ้น ฉันกังวลว่า Cain อาจจะไปที่ไหนสักแห่งและก่ออุบัติเหตุขึ้นอีก",
			"^666666..........ฉันพลิกไปสองสามหน้า^000000",
			"^339999เดือน X วันที่ X^000000\n\nเห็นได้ชัดว่าร่างกายของฉันเริ่มอ่อนแอลง ฉันอยากจะคุยกับ Cain แต่ความรู้สึกของเขานั้นช่างน่าอึดอัดจนฉันพูดไม่ออก\nTarsha เองก็ร้องไห้บ่อยขึ้นด้วย โอ้ ลูกน้อยที่น่าสงสารของฉัน เขาดีใจที่ได้เห็นพ่อที่ไม่ได้เจอกันบ่อยๆ แต่ปฏิกิริยาของเขากลับเย็นชามาก อย่างไรก็ตาม บางครั้งเขาก็ทำให้ Tarsha ยิ้มได้\nในตอนกลางคืนที่พวกเขาดื่มสุรา พวกเขามักจะดูดุร้ายและมองพวกเราเหมือนเป็นการคุกคาม ร่างกายของฉันจะทนรับมันได้ไหวก่อนที่ความเศร้าโศกของเขาจะจบลงไหม...",
			"^666666..........หลังจากนี้ มีเพียงหน้ากระดาษที่ว่างเปล่า^000000"
		}
	},
