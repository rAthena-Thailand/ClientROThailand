		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"สถานที่ซึ่งตำนานยังคงเป็นส่วนหนึ่งของประวัติศาสตร์ ทวีป Midgard เรื่องราวเก่าแก่และการผจญภัยของเหล่าฮีโร่กำลังรอคุณอยู่\n\nป <TIPBOX>MD Suspicious Shipwreck (10)<INFO>7085</INFO></TIPBOX>\nป <TIPBOX>MD Poring Village (30)<INFO>7086</INFO></TIPBOX>\nป <TIPBOX>MD Borsev Lab (60)<INFO>7088</INFO></TIPBOX>\nป <TIPBOX>MD Weekend Dungeon (60)<INFO>7089</INFO></TIPBOX>\nป <TIPBOX>MD Orc Memory (40)<INFO>7090</INFO></TIPBOX>\nป <TIPBOX>MD Horror Toy Factory<INFO>7091</INFO></TIPBOX>\nป <TIPBOX>MD Remnants' Hideout<INFO>7094</INFO></TIPBOX>\nป <TIPBOX>MD Sealed Shrine (75)<INFO>7095</INFO></TIPBOX>\nป <TIPBOX>MD Underground Drainage (90)<INFO>7096</INFO></TIPBOX>\nป <TIPBOX>MD Octopus Cave<INFO>7097</INFO></TIPBOX>\nป <TIPBOX>MD Friday Dungeon (99)<INFO>7098</INFO></TIPBOX>\nป <TIPBOX>MD Infinite Space (100)<INFO>7099</INFO></TIPBOX>\nป <TIPBOX>MD Dreams and Shadows (120)<INFO>7100</INFO></TIPBOX>\nป <TIPBOX>MD King's Heels (130)<INFO>7101</INFO></TIPBOX>\nป <TIPBOX>MD Tower of the Constellation (240)<INFO>5002</INFO></TIPBOX>\nป <TIPBOX>MD Sunken Tower (40~249)<INFO>5003</INFO></TIPBOX>\nป <TIPBOX>MD Lake of Fire(250)<INFO>5006</INFO></TIPBOX>\nป <TIPBOX>MD Hall of Life(250)<INFO>5007</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>7083</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
