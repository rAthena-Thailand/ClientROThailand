	[191] = {
		Title = "รายการคำสั่งที่มีประโยชน์#ตั้งค่าเกม, การตั้งค่าอื่นๆ",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"นี่คือรายการคำสั่งที่มีประโยชน์เมื่อได้ใช้งานในบางโอกาส\n\n/v: ตรวจสอบระดับเสียงเอฟเฟกต์\n/v <ตัวเลข>: ปรับระดับเสียงเอฟเฟกต์ตามค่าตัวเลขที่ระบุ\n/bv: ตรวจสอบระดับเสียงเพลงประกอบ (BGM)\n/bv <ตัวเลข>: ปรับระดับเสียงเพลงประกอบตามค่าตัวเลขที่ระบุ\n/trade <ชื่อตัวละคร>: ขอแลกเปลี่ยนกับตัวละครที่ระบุ\n/guildinvite <ชื่อตัวละคร>: เชิญตัวละครที่ระบุเข้ากิลด์\n/clanchat <ข้อความ>: ส่งข้อความถึงสมาชิกในแคลน\n/web <ที่อยู่เว็บไซต์>: เปิดเบราว์เซอร์โดยพิมพ์ที่อยู่หน้าเว็บ\n/naviopen: เปิดหน้าต่างระบบนำทาง (Navigation)\n/navigation /navi <ชื่อแผนที่> <x/y> (ตัวอย่าง: /navi yuno 100/100): นำทางคุณไปยังตำแหน่งที่ระบุ\n/navigation2 /navi2 <ชื่อแผนที่> <ตำแหน่ง> <ตัวเลือก> (ตัวอย่าง: /navi2 yuno 100/100 1/1/1 (วาร์ป/เงิน zeny/เครื่องบิน: 1: ใช้, 0: ไม่ใช้)): ตรวจสอบตัวเลือกการใช้งานสำหรับการนำทางและระบุตำแหน่งย่อย\n\nป <TIPBOX>การตั้งค่าอื่นๆ และคำสั่งในการเล่นเกม<INFO>166</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[192] = {
		Title = "เปลี่ยนฟอนต์แสดงค่าความเสียหาย#ภาษาเกาหลี, ตัวเลข, ตั้งค่า, แสดงผล, Damage, ความโปร่งใส, โจมตี, ตั้งค่าเกม",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00192",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถเปลี่ยนรูปแบบการแสดงตัวเลขความเสียหาย (Damage) เมื่อโจมตีมอนสเตอร์ได้ตามความต้องการ\nผลนี้จะมีผลเฉพาะบนหน้าจอของคุณเท่านั้น และคุณสามารถลบการแสดงความเสียหายออกไปได้ทั้งหมดขึ้นอยู่กับการเลือกของคุณ\n\n1. พื้นฐาน (Default): ตัวเลขความเสียหายพื้นฐานที่ใช้งานอยู่ในปัจจุบัน\n2. ตัวเลข (Number): เพิ่มการไล่เฉดสีที่ด้านนอกของตัวเลข\n3. ภาษาเกาหลี (Korean): แสดงความเสียหายเป็นตัวอักษรเกาหลี\n4. โปร่งใส (Transparent): ไม่แสดงตัวเลขความเสียหาย\n\nลูกศรที่อยู่ถัดจาก Default ด้านบน ใช้กำหนดทิศทางที่ตัวเลขความเสียหายจะเคลื่อนที่เมื่อปรากฏขึ้นและหายไปว่าจะให้คงที่หรือไม่\n\n1. พื้นฐาน (Default): ทิศทางพื้นฐานที่ใช้งานอยู่ในปัจจุบัน ทิศทางจะเปลี่ยนไปตามการหมุนของหน้าจอ\n2.: กำหนดให้ไหลเฉียงไปทางขวา\n3.: กำหนดให้ไหลขึ้นไปตรงกลางด้านบนเท่านั้น\n4.: กำหนดให้ไหลเฉียงไปทางซ้าย\n\nที่อยู่: Alt+Q -> แท็บแสดงความเสียหาย (Damage Display)\n\nคุณสามารถเปลี่ยนขอบเขตการแสดงความเสียหายได้ที่\nป <TIPBOX>ตั้งค่าเอฟเฟกต์: ขยายการแสดงความเสียหาย<INFO>88</INFO></TIPBOX>\n\nป <TIPBOX>การตั้งค่าอื่นๆ และคำสั่งในการเล่นเกม<INFO>166</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[193] = {
		Title = "อันดับ: Taekwon",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"[Taekwon Boy/Girl]\nTaekwon Ranker:\nผู้ที่ติดอันดับ (อันดับที่ 1 ถึง 10) จะสามารถใช้งานสกิลต่อเนื่องจาก Whirlwind Kick, Roundhouse Kick, Heel Drop และ Counter Kick ได้\nTaekwon Ranker ที่มีเลเวล 90~99 จะได้รับ MaxHP และ MaxSP เพิ่มขึ้นเป็น 3 เท่า และสามารถใช้สกิล Taekwon ได้ทุกสกิล\n\n^3b488วิธีสะสมแต้มอันดับ (Ranking Points)^000000\n1 แต้ม: ได้รับทุกครั้งที่กำจัดมอนสเตอร์เป้าหมายของสกิล Taekwon Mission ครบ 100 ตัว\nคุณสามารถตรวจสอบมอนสเตอร์เป้าหมายได้โดยการใช้สกิล Taekwon Mission\n\nเมื่อคุณเปลี่ยนอาชีพเป็นคลาสที่สูงขึ้น รางวัลของ Taekwon Ranker จะหายไป\n\nตรวจสอบอันดับ Taekwondo: /taekwon\n\nป <TIPBOX>ระบบการจัดอันดับ<INFO>9082</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[194] = {
		Title = "ตำราเวทมนตร์ (สายอาชีพ Warlock)#Reading Spell Book",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"หลังจากเปลี่ยนอาชีพเป็น Warlock ซึ่งเป็นอาชีพคลาส 3 ของ Wizard และเรียนรู้สกิล Reading Spellbook รวมถึงสกิลสำหรับบันทึกเวทมนตร์แล้ว คุณจะสามารถเช่าตำราเวทมนตร์ได้\nอย่างไรก็ตาม ตำราเวทมนตร์บางเล่มไม่สามารถบันทึกเป็นเวทมนตร์สะสมได้ และตำราเวทมนตร์บางเล่มสามารถเช่าได้หลังจากทำเควสต์เสร็จสิ้นแล้วเท่านั้น\n\nผู้จัดการตำราเวทมนตร์แห่ง Geffen:\nป <NAVI>[Velofos]<INFO>geffen_in,176,105,0,101,0</INFO></NAVI>\nป <NAVI>[Lea]<INFO>geffen_in,175,112,0,101,0</INFO></NAVI>\n\nค ตำราเวทมนตร์ระดับกลาง: Storm Gust, Lord of Vermillion, Meteor Storm\nค ตำราเวทมนตร์ระดับสูง: Drain Life, Jack Frost, Earth Strain, Crimson Rock, Chain Lightning\nค ตำราเวทมนตร์ระดับสูงสุด: Comet, Tetra Vortex (สอบถาม Lea, Velofos. ต้องมีเลเวล 140 ขึ้นไป)\n\nป อาจมีการเรียกเก็บเงินมัดจำการเช่าสำหรับตำราเวทมนตร์ทั้งหมด และหากตำราเวทมนตร์สูญหาย คุณสามารถเช่าใหม่ได้โดยการจ่ายเงินมัดจำเพิ่มเติม\n\nป <TIPBOX>JQ Warlock<INFO>9058</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[195] = {
