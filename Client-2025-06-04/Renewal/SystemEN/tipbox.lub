	[71] = {
		Title = "Homunculus#Embryo,Bioethics,Creation,Lif,Amistr,Filir,Vanilmirth",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00071",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"อาชีพสาย Alchemist สามารถสร้างและอัญเชิญ Homunculus มาช่วยในการต่อสู้ได้ผ่านสกิล \'Bioethics\'\nเงื่อนไข: เลเวล 60 ขึ้นไป, สำเร็จเควส Bioethics\nสิ่งที่ต้องเตรียม: Geek Glasses, Grampa Beard, 20x Jellopy\nสถานที่เริ่มเควส: ป <NAVI>[Kellasus]<INFO>lhz_in01,224,140,0,101,0</INFO></NAVI>\n\nหากคุณเรียนรู้สกิล \'Bioethics\' แล้ว คุณสามารถสร้าง \'Embryo\' ได้ผ่านคู่มือการปรุงยา (Potion Creation Guide) และสกิล Pharmacy\nวัตถุดิบ: 1 Glass Tube, 1 Morning Dew of Yggdrasil, 1 Seed of Life, 1 Medicine Bowl\nยิ่งระดับสกิล Pharmacy สูง รวมถึงเลเวลและค่าสถานะของผู้สร้างสูงเท่าไหร่ โอกาสสำเร็จก็จะมากขึ้นเท่านั้น\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[72] = {
		Title = "ค้นหาร้านค้า#Catalog,item,Shop",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00072",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถใช้ไอเทมประเภทแคตตาล็อกเพื่อค้นหาหรือซื้อไอเทมจากร้านค้าที่ตั้งอยู่ได้\nจำนวนครั้งในการค้นหาและซื้อจะแตกต่างกันไปตามแคตตาล็อกแต่ละชนิด และจะค้นหาเฉพาะร้านค้าในแผนที่ปัจจุบันเท่านั้น\nป ^i[12580] Window Shopper Catalog: ค้นหาได้ 10 ครั้ง\nป ^i[23368] Special Catalog Silver: ค้นหาและซื้อได้ 3 ครั้ง\n\nป วิธีการใช้งาน\n* เลือกประเภทของร้านค้าที่ต้องการค้นหา (ขาย/รับซื้อ)\n* ใส่ชื่อไอเทม (ค้นหาไอเทมที่มีคำดังกล่าวประกอบอยู่)\n* สำหรับไอเทมที่ใส่การ์ด สามารถระบุชื่อนำหน้าหรือนามสกุลได้\n* หากต้องการค้นหาในช่วงราคาที่ต้องการ สามารถระบุได้\n\nป สถานที่ซื้อแคตตาล็อก\n* Paradise <NAVI>[Catalog Vending Machine]<INFO>moc_para01,22,16,0,101,0</INFO></NAVI>\n* สมาคมพ่อค้า Alberta <NAVI>[Catalog Mage]<INFO>alberta_in,74,38,0,101,0</INFO></NAVI>\nสามารถซื้อ Special Catalog Silver ได้ที่นี่\n\nป <TIPBOX>ร้านค้า<INFO>67</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
