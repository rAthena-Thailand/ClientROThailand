	[4028] = {
		Title = "ภูมิภาค: Amatsu",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip04028",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"หมู่บ้านดอกซากุระอันเงียบสงบของ Amatsu ผู้ซึ่งค้นพบตัวตนของกันและกันกับ Rune Midgard โดยบังเอิญ ในที่สุดก็ได้เปิดเส้นทางเดินน้ำหลังจากเตรียมการอย่างละเอียดถี่ถ้วนเป็นเวลาห้าปี\nหลังคาสีฟ้าสวยงามของหอคอยปราสาท Himezi สามารถมองเห็นได้จากทางด้านตะวันออกของทะเลสาบทางทิศตะวันออก จากทุกที่ในเมืองที่เต็มไปด้วยศิลปะ วัฒนธรรม และกลิ่นอายของดอกซากุระ\nการมาเยือน Amatsu เมืองลึกลับที่ทวยเทพและผู้คนอยู่ร่วมกัน เนินต้นซากุระขนาดใหญ่ที่มีตำนานมากมาย และศาลเจ้านอกเมืองที่อุทิศแด่เทพเจ้าต่างๆ อาจนำไปสู่ความเชื่อมโยงอันลึกลับที่ไม่มีใครล่วงรู้\n\nคุณสามารถเดินทางไปที่นั่นได้จาก Alberta\nป <NAVI>[ไป Amatsu]<INFO>alberta,246,74,0,101,0</INFO></NAVI>\nป <NAVI>[ปราสาท Himezi Castle]<INFO>amatsu,85,235,0,101,0</INFO></NAVI>\nป <NAVI>[เนินซากุระ Cherry Hill]<INFO>amatsu,264,197,0,101,0</INFO></NAVI>\nป <NAVI>[ศาลเจ้า Temple]<INFO>ama_fild01,174,330,0,101,0</INFO></NAVI>\n\nป <TIPBOX>ภูมิภาคท้องถิ่น<INFO>4003</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[4029] = {
		Title = "ภูมิภาค: Kunlun",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip04029",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Kunlun เกาะแห่งทวยเทพ มาถึงตามเส้นทางทะเลที่ค้นพบโดยเหล่าพ่อค้าชาว Alberta หลังจากใช้ความพยายามอย่างหนัก\nเจ้าสำนักแห่ง Kunlun ผู้ใช้ชีวิตร่วมกันอย่างเงียบสงบและฝึกฝนพลังเวทมนตร์นิรนาม ไม่ค่อยชอบใจนักที่มีชาวต่างชาติมารวมตัวกันที่เกาะ แต่พวกเขาก็ไม่สามารถหยุดยั้งเหล่านักผจญภัยและพ่อค้าจากการออกเรือมุ่งหน้าสู่ Kunlun เพื่อค้นหาการผจญภัยครั้งใหม่และเงินทองได้\n\nคุณสามารถเดินทางไปที่นั่นได้จาก Alberta\nป <NAVI>[ไป Kunlun]<INFO>alberta,246,62,0,101,0</INFO></NAVI>\nป <NAVI>[แบบจำลอง Prontera Model]<INFO>gon_fild01,240,228,0,101,0</INFO></NAVI>\nป <NAVI>[แบบจำลอง Comodo Model]<INFO>gon_fild01,119,246,0,101,0</INFO></NAVI>\nป <NAVI>[แบบจำลอง Glastheim Model]<INFO>gon_fild01,175,339,0,101,0</INFO></NAVI>\nป <NAVI>[Temple of the Western Queen]<INFO>gon_dun01,153,48,0,101,0</INFO></NAVI>\n\nป <TIPBOX>ภูมิภาคท้องถิ่น<INFO>4003</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
