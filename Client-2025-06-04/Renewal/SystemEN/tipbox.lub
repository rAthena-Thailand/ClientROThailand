	[8370] = {
		Title = "Traveler's Tombstone#Warp Increase",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip08370",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Cardinal และ Inquisitor ที่เรียนรู้ทักษะ Warp Portal จนถึงเลเวล 4 สามารถรับตำแหน่งบันทึก Warp Portal เพิ่มเติมได้ผ่านเควส\n\nค คำแนะนำการเริ่มเควส:\nป <NAVI>[Missionary Rosetta]<INFO>prontera,226,329,0,101,0</INFO></NAVI>\n\nCardinal และ Inquisitor ที่ได้รับตำแหน่งบันทึก Warp Portal เพิ่มเติมแล้ว จะสามารถใช้ Traveler's Tombstone ได้\nโดยปกติแล้ว สถานที่เหล่านี้จะเป็นดันเจี้ยนและพื้นที่ส่วนลึกของแผนที่ที่คุณไม่สามารถจดจำตำแหน่งได้ แต่คุณสามารถใช้ Blue Gemstone หรือ Holy Water ในการชำระศักดิ์สิทธิ์ Traveler's Tombstone เพื่อจดจำตำแหน่งเหล่านั้นได้\n\nค ตำแหน่งที่ค้นพบศิลา\n-Abyss Lake Underground Cave ชั้น 3 ใน Hugel\n- Odin's Temple พื้นที่ทางเหนือ ใน Hugel\n- Glastheim Underground Waterway ชั้น 4\n- Clock Tower ชั้น 4\n- Clock Tower ชั้นใต้ดิน 4\n\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[8371] = {
		Title = "Gender Change Card Sale #Gender Change Card",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip08371",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ขายไอเทมเวทมนตร์ที่สามารถเปลี่ยนเพศของคุณได้\nสามารถใช้ได้ในหมู่บ้านเท่านั้น อย่างไรก็ตาม ไม่สามารถใช้งานภายในอาคารได้\n^i[103061] <ITEM>[Gender Change Card]<INFO>103061</INFO></ITEM>\n\n^FF0000ไอเทมนี้ไม่สามารถแลกเปลี่ยนได้เลยในทุกกรณี^00000.\nมีบางกรณีที่ Gender Change Card ^FF0000ไม่สามารถใช้งานได้^000000 โปรดตรวจสอบให้แน่ใจ ^FF0000ก่อนทำการซื้อ^000000\n\nค สถานะที่ไม่สามารถใช้งานได้\n- สำหรับอาชีพ Bard, Dancer และคลาสที่สูงกว่า\n- สำหรับอาชีพ Kagerou, Oboro และคลาสที่สูงกว่า\n- ในขณะที่แต่งงานอยู่\n- ในขณะที่ขี่สัตว์พาหนะเฉพาะอาชีพ\n- ในขณะที่ขี่สัตว์พาหนะทั่วไป\n- ในขณะที่อยู่ในปาร์ตี้\n- ในขณะที่อยู่ในกิลด์\n- ในขณะที่แปลงร่างเป็นมอนสเตอร์\n- ในขณะที่มีบัฟไอเทมที่ทำงานอยู่\n\nราคาขาย: \n 50x ^i[6909] <ITEM>[Nyangvine]<INFO>6909</INFO></ITEM>\n\nคำแนะนำ NPC ผู้ขาย:\nป <NAVI>[ตู้ขายบัตรเปลี่ยนเพศอัตโนมัติ]<INFO>prt_in,259,166,0,101,0</INFO></NAVI>\n\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9000] = {
		Title = "คู่มือการเปลี่ยนอาชีพคลาส 2",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เมื่อนักผจญภัยที่สำเร็จการเปลี่ยนอาชีพคลาส 1 และได้รับค่าประสบการณ์ถึงกำหนด เขาหรือเธอจะสามารถเปลี่ยนเป็นอาชีพคลาส 2 ได้\nสำหรับข้อมูลของอาชีพ Extended 2nd และ Extended 3rd โปรดอ้างอิงจากแต่ละหมวดหมู่ใน \nป <TIPBOX>[คู่มือการเปลี่ยนอาชีพหน่วยพิเศษ]<INFO>9039</INFO></TIPBOX>\n\nป <TIPBOX>เควสเปลี่ยนอาชีพคลาส 2<INFO>9001</INFO></TIPBOX>\nป <TIPBOX>เควสสกิลเสริมอาชีพคลาส 2<INFO>9015</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
