	[9101] = {
		Title = "Q Noisy Neighbors (130)",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"องค์ราชาต้องการให้คุณจัดการกับสิ่งที่ส่งเสียงดังรอบๆ ตัวเขา เพื่อที่เขาจะได้ใช้ชีวิตอย่างเงียบสงบ มากำจัดเหล่าค้างคาวและรวบรวมวัตถุดิบเพื่อทำผ้าคลุมเพื่อความเงียบสงบของพื้นที่รอบๆ กันเถอะ\n\nป <NAVI>[King]<INFO>gef_d01_i,185,97,0,101,0</INFO></NAVI>\n\nป <TIPBOX>Illusion of Vampire<INFO>9087</INFO></TIPBOX> เสร็จสมบูรณ์แล้ว\nค ^663399เลเวล 130 หรือสูงกว่า^000000\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9087</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
