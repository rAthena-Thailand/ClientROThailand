	[4030] = {
		Title = "ภูมิภาค: Rock Ridge",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip04030",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เป็นหมู่บ้านที่ก่อตัวขึ้นจากการรวมกลุ่มของผู้คนที่มาทำเหมือง \'แร่สีม่วง (purple ore)\' ที่ถูกค้นพบในโลกใหม่ ผู้คนที่มารวมตัวกันด้วยความฝันที่จะทำเงินได้สร้างความสัมพันธ์แบบร่วมมือกับชาวพื้นเมือง Cactus แต่พวกเขามักถูกปล้นโดยกลุ่มที่เรียกว่าโจรกลุ่มเล็กๆ (small bandits) มีนักผจญภัยคนไหนที่พร้อมจะมาช่วยแก้ปัญหาของนายอำเภอด้วยกันไหม?\n\nคุณสามารถเดินทางไปที่นั่นได้จาก Alberta\nป <NAVI>[ไป Rock Ridge]<INFO>alberta,240,103,0,101,0</INFO></NAVI>\nป <NAVI>[ที่ทำการนายอำเภอ Sheriff's Office]<INFO>harboro1,241,218,0,000,0</INFO></NAVI>\nป <NAVI>[ร้านค้า Store]<INFO>harboro1,312,193,0,000,0</INFO></NAVI>\nป <NAVI>[Inn]<INFO>harboro1,156,215,0,000,0</INFO></NAVI>\n\nป <TIPBOX>ภูมิภาคท้องถิ่น<INFO>4003</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
