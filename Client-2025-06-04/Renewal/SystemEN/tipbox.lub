	[74] = {
		Title = "เรือเหาะ#Airplane,World Transfer,Oversea Flight,International Flight,Domestic Flight,Boarding,Schwartzvald,Arunafeltz,Rune-Midgards",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00074",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เที่ยวบินระหว่างประเทศ\nป <NAVI>[Airship Staff]<INFO>izlude,202,75,0,101,0</INFO></NAVI>\nเรือเหาะระหว่างประเทศที่ออกเดินทางจากเมืองดาวเทียม Izlude จะเดินทางผ่านเมืองหลักๆ ในต่างแดน\n - Izlude ในอาณาจักร Rune-Midgards\n - Juno ในสาธารณรัฐ Schwartzvald\n - Rachel ณ มหาวิหารแห่ง Arunafeltz\nจะมีการใช้ Zeny จำนวนหนึ่งเมื่อขึ้นเรือเหาะ\n\nเที่ยวบินภายใน Schwartzvald\nป <NAVI>[Airport Staff]<INFO>y_airport,138,45,0,101,0</INFO></NAVI>\nเรือเหาะภายในประเทศ Schwartzvald จะเดินทางวนรอบสาธารณรัฐ Schwartzvald\n - Yuno\n - Hugel\n - Einbroch\n - Lighthalzen\nจะมีการใช้ Zeny จำนวนหนึ่งเมื่อขึ้นเรือเหาะ\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[75] = {
		Title = "การรวมไอเทมกดใช้จาก Cash Shop#Jin Series, Small, Medium, Mysterious, Water of Life, Mana, Shining, Defense, Scroll, Almighty, Limited Edition, Power, Booster, Infinity, Drink, Red, ASPD, Enhanced Potion, Tyr's, Blessing, Mental, Combat Manual, Bubble Gum, Core, Practical, Infinite Fly Wings, Daily Box, Paradise Group",
