		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ใช้ AI ปรับแต่งสำหรับ Homunculus และทหารรับจ้าง (Mercenaries)\nหากคุณใส่ไฟล์ .lua ที่ปรับแต่งเองลงในโฟลเดอร์ AI ภายใต้โฟลเดอร์ที่ติดตั้ง Ragnarok คุณสามารถทำให้พวกมันทำงานตามเนื้อหาในไฟล์นั้นได้\n\nค คำสั่ง\n/hoai: ให้ Homunculus ทำงานด้วย AI ปรับแต่ง / AI พื้นฐาน\n/merai: ให้ทหารรับจ้างทำงานด้วย AI ปรับแต่ง / AI พื้นฐาน\n\nป <TIPBOX>การตั้งค่าอื่นๆ และคำสั่งในการเล่นเกม<INFO>166</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
