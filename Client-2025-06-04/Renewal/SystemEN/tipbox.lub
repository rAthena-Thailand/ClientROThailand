	[89] = {
		Title = "สถานะ (Status)#Stat, Stats, Str, Strength, Agi, Agility, Int, Intelligence, Vit, Vitality, Dex, Dexterity, Luk, Luck, Speed",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00006",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Status คือค่าความสามารถที่กำหนดทิศทางการเติบโตของตัวละคร\nคุณสามารถทำให้ตัวละครแข็งแกร่งขึ้นได้โดยการนำ Status Points ที่ได้รับทุกครั้งที่เลเวลอัปไปอัปในค่าพลังที่คุณต้องการ\nคุณสามารถตรวจสอบสถานะได้โดยกด ALT+A และเพิ่มแต้มได้โดยกดที่ลูกศรทางด้านขวาของแต่ละค่า (Str, Agi, Vit, Int, Dex, Luk)\n\nคุณสามารถอัปค่าพลังได้อย่างง่ายดายโดยการพิมพ์คำสั่งดังนี้ในช่องแชท\n/str+ <จำนวน>\n/agi+ <จำนวน>\n/vit+ <จำนวน>\n/int+ <จำนวน>\n/dex+ <จำนวน>\n/luk+ <จำนวน>\nตัวอย่าง: หากป้อน /str+ 9 และปัจจุบันมี Str เป็น 1, ค่า STR จะกลายเป็น 10\n^ff6677เนื่องจากมีการใช้ Status Points การเพิ่มค่าจะถูกใช้ได้เฉพาะเท่าที่แต้มที่มีอยู่จะอำนวยเท่านั้น^000000\n\nป <TIPBOX>ค่าสถานะ: STR (พละกำลัง)<INFO>6</INFO></TIPBOX>\nป <TIPBOX>ค่าสถานะ: AGI (ความว่องไว)<INFO>7</INFO></TIPBOX>\nป <TIPBOX>ค่าสถานะ: VIT (ความอึด)<INFO>8</INFO></TIPBOX>\nป <TIPBOX>ค่าสถานะ: INT (ความฉลาด)<INFO>9</INFO></TIPBOX>\nป <TIPBOX>ค่าสถานะ: DEX (ความแม่นยำ)<INFO>10</INFO></TIPBOX>\nป <TIPBOX>ค่าสถานะ: LUK (โชค)<INFO>11</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
