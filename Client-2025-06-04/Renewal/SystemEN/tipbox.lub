	[9137] = {
		Title = "JQ Dragon Knight",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"อาชีพคลาส 4, Dragon Knight ผู้ที่เปลี่ยนอาชีพมาจาก Rune Knight ใช้?าวุธสองมือได้อย่างอิสระและจัดการกับ Servant Weapon ที่รวบรวมเจตจำนงของตนไว้ในรูปแบบของอาวุธ\nระหว่างการโจมตีพื้นฐาน สามารถทำการโจมตีเพิ่มเติมด้วย Servant Weapon รวมถึงการโจมตีระยะไกลที่รุนแรงได้\nค ^663399Base Level 200 หรือสูงกว่า^000000\nค ^663399Job Level 70 หรือสูงกว่า^000000\nค ^663399อาชีพที่ต้องการ: Rune Knight^000000\nป <NAVI>[Oscar]<INFO>gef_fild08,54,101,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>เควสเปลี่ยนอาชีพคลาส 4<INFO>9136</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9138] = {
		Title = "JQ Imperial Guard",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"อาชีพคลาส 4, Imperial Guard ผู้ที่เปลี่ยนอาชีพมาจาก Royal Guard ใช้ดาบและโล่ ผู้ที่ได้ค้นพบความเชื่อในความแข็งแกร่งที่แท้จริง\nโดยพื้นฐานแล้ว คุณจะได้รับพรจากพลังศักดิ์สิทธิ์ (Holy Power) ดังนั้นคุณจึงสามารถทำการโจมตีธาตุศักดิ์สิทธิ์ที่ทรงพลังยิ่งขึ้นได้\nค ^663399Base Level 200 หรือสูงกว่า^000000\nค ^663399Job Level 70 หรือสูงกว่า^000000\nค ^663399อาชีพที่ต้องการ: Royal Guard^000000\nป <NAVI>[King's Knight]<INFO>prt_cas,181,10,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>เควสเปลี่ยนอาชีพคลาส 4<INFO>9136</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9139] = {
		Title = "JQ Arch Mage",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Arch Mage อาชีพคลาส 4 ที่เปลี่ยนมาจาก Warlock เพิ่มความงดงามให้กับเวทมนตร์อันทรงพลังของเขาหรือเธอ นำเสนอเวทมนตร์ที่น่าอัศจรรย์\nคุณยังสามารถสร้างสวนดอกไม้แห่งเปลวเพลิง หรือทำให้ฝนตกหนักรอบตัวด้วยเวทมนตร์น้ำแข็ง นอกจากนี้ เมื่อเข้าสู่ช่วง Climax เวทมนตร์ที่มีอยู่เดิมจะทรงพลังยิ่งขึ้น\nค ^663399Base Level 200 หรือสูงกว่า^000000\nค ^663399Job Level 70 หรือสูงกว่า^000000\nค ^663399อาชีพที่ต้องการ: Warlock^000000\nป <NAVI>[Varmundt Mansion Garden]<INFO>ba_maison,200,256,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>เควสเปลี่ยนอาชีพคลาส 4<INFO>9136</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9140] = {
		Title = "JQ Elemental Master",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"อาชีพคลาส 4 Elemental Master เป็นอาชีพที่เชี่ยวชาญในการจัดการกับธาตุต่างๆ ของธรรมชาติ ด้วยการเสริมความแข็งแกร่งให้กับจิตวิญญาณ (Spirits) ที่มีอยู่ คุณสามารถอัญเชิญจิตวิญญาณใหม่หรือใช้เวทมนตร์ธาตุของธรรมชาติได้\nนอกจากนี้ยังใช้เวทมนตร์สนับสนุนต่างๆ เช่น การเพิ่มพลังเวทให้กับพันธมิตร\nค ^663399Base Level 200 หรือสูงกว่า^000000\nค ^663399Job Level 70 หรือสูงกว่า^000000\nค ^663399อาชีพที่ต้องการ: Sorcerer^000000\nป <NAVI>[Geffen Tower]<INFO>gef_tower,119,29,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>เควสเปลี่ยนอาชีพคลาส 4<INFO>9136</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9141] = {
		Title = "JQ Meister",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ในฐานะปรมาจารย์ด้านวิศวกรรมเครื่องกล อาชีพคลาส 4 Meister ผู้ที่เปลี่ยนอาชีพมาจาก Mechanics ใช้หุ่นยนต์ต่อสู้อัตโนมัติได้ตามต้องการ\nนอกจากนี้ ยังสามารถประดิษฐ์อุปกรณ์ต่างๆ เพื่อปกป้องหรือเสริมความแข็งแกร่งให้กับพันธมิตร และพวกเขายังยอดเยี่ยมในฐานะผู้สนับสนุนการต่อสู้ด้วย\nค ^663399Base Level 200 หรือสูงกว่า^000000\nค ^663399Job Level 70 หรือสูงกว่า^000000\nค ^663399อาชีพที่ต้องการ: Mechanic^000000\nป <NAVI>[Lodi]<INFO>yuno,111,208,0,101,0,</INFO></NAVI>\nป <NAVI>[Mist]<INFO>yuno,114,208,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>เควสเปลี่ยนอาชีพคลาส 4<INFO>9136</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
