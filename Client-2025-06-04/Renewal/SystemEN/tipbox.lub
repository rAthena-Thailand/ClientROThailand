	[8090] = {
		Title = "รายงานการทดลอง",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\collection\\Tablet_IL",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"แผนการจัดหาอาสาสมัครทดสอบรายใหม่เพื่อการดัดแปลงแกนกลางการต่อสู้ การทดลองปลูกถ่ายที่มีอยู่ในปัจจุบันสำหรับประชาชนทั่วไปจะถูกระงับโดยสิ้นเชิง\n\nอาสาสมัครจะถูกนำตัวมาหลังจากทำให้หมดสติด้วยก๊าซยาสลบในห้องปฏิบัติการที่ปลอมแปลงเป็นห้องรอรับรองประธานาธิบดี ต้องใช้ความระมัดระวังเป็นพิเศษเพื่อไม่ให้ส่งผลกระทบต่อการทดลองโดยการปรับปริมาณก๊าซยาสลบและยาสลบชนิดอื่นๆ\n\nกำลังขับของ Proto Battle Core ได้รับการปรับให้สูงกว่าเดิมเพื่อให้สอดคล้องกับวัตถุทดสอบใหม่ ดังนั้นจึงจำเป็นต้องยืนยันผลเมื่อทำการปลูกถ่าย" 
		}
	},
	[8091] = {
		Title = "รายงานการทดลอง",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\collection\\Tablet_IL",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เป้าหมายของระยะแรกคือการสังเกตความคืบหน้าหลังการฝังแกนกลาง และเพื่อยืนยันการรอดชีวิตของอาสาสมัคร เนื่องจากกำลังขับของแกนกลางการต่อสู้เพิ่มขึ้น จึงจำเป็นต้องปรับเปลี่ยนรายละเอียดตามตัวอาสาสมัครเมื่อทำการปลูกถ่าย\n\nหลังจากบรรลุการรอดชีวิตตามเวลาที่กำหนดแล้ว ให้เข้าสู่ระยะที่สองทันที" 
		}
	},
	[8092] = {
		Title = "รายงานการทดลอง",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\collection\\Tablet_IL",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เป้าหมายของระยะที่สองของการทดลองคือการดึงศักยภาพการต่อสู้ของสิ่งมีชีวิตออกมาให้ถึงขีดจำกัด สังเกตความคืบหน้า และรวบรวมข้อมูลที่มีความหมาย\n\nสำหรับการทดลองระยะที่สอง ให้จัดเตรียมสภาพแวดล้อมที่กระตุ้นซึ่งอาสาสมัครสามารถดึงพลังของแกนกลางการต่อสู้ออกมาและแผ่รังสีออกมาได้ และวัดค่าขีดจำกัด\n\nเนื่องจากสภาพแวดล้อมที่จำเป็นจะแตกต่างกันไปตามกลุ่มอาชีพ ให้ตรวจสอบประวัติของตัวอย่างและดำเนินการแยกกันสำหรับแต่ละห้องปฏิบัติการ โปรดส่งรายงานโดยเร็วที่สุดหลังจากสิ้นสุดการทดลอง\n\nผู้อำนวยการสถาบันวิจัย Borsev" 
		}
	},
	[8093] = {
		Title = "รายงานการทดลอง",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\collection\\Tablet_IL",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"แม้ว่าการปลูกถ่ายจะประสบความสำเร็จ แต่อาสาสมัครทดสอบรายหนึ่งก็มีปัญหาในการใช้พลังของแกนกลางการต่อสู้\n\nได้รับการยืนยันแล้วว่าไม่สามารถฟื้นฟูอาสาสมัครทดสอบที่มีปฏิกิริยาเลือดสีดำได้ (หมายเหตุ: การไหลของเลือดสีดำ ในกรณีที่รุนแรง เลือดสีดำจะไหลออกจากตาและหู บาดแผลที่มีอยู่เดิมหรือที่เพิ่งเกิดขึ้นใหม่)\n\nหลังจากปฏิกิริยาเลือดสีดำเกิดขึ้น จะเข้าสู่ระยะความตายภายในอย่างน้อย 5 ชั่วโมงในทันที และเป็นปฏิกิริยาสูงสุด แต่พบปรากฏการณ์พิเศษที่เกิดขึ้นหลังความตาย เรียกว่า 'การเพ่งพินิจ' (contemplation)..." 
		}
	},
	[8094] = {
		Title = "รายงานการทดลอง",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\collection\\Tablet_IL",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"จำนวนผู้เสียชีวิตภายในไม่เกิน 2 วันหลังความตาย รูปแบบความคิดแรกมีสติสัมปชัญญะที่ค่อนข้างชัดเจน แต่มีลักษณะเด่นคือการมีเป้าหมายเพียงอย่างเดียวอย่างไม่ลืมหูลืมตา\n\nมีสมมติฐานว่าเป้าหมายนี้เกี่ยวข้องกับเนื้อหาของสถานการณ์ที่ถูกยั่วยุซึ่งประสบก่อนความตาย แต่จำเป็นต้องมีการทดลองเพิ่มเติม\n\nในกรณีของร่างความคิดแรก มันยากที่จะแยกแยะเพราะมันคล้ายกับรูปลักษณ์ในขณะที่ยังมีชีวิตอยู่ และมันจะเกิดขึ้นชัดเจนยิ่งขึ้นเมื่ออาสาสมัครมีความรู้สึกในจุดมุ่งหมายที่รุนแรง" 
		}
	},
	[8095] = {
		Title = "รายงานการทดลอง",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\collection\\Tablet_IL",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ในกรณีของ Egnigem Cenia อาสาสมัครทดสอบที่ถูกเรียกว่า 'ความล้มเหลว' โดย ดร. Borsev หัวหน้าสถาบันวิจัย ความรู้สึกในจุดมุ่งหมายที่มีอยู่เดิมได้เปลี่ยนเป็นเพียงความปรารถนาในการเข่นฆ่าเมื่อกระบวนการสร้างความคิดดำเนินไป\n\nอย่างไรก็ตาม มีการปลูกฝังบางอย่างเกิดขึ้นที่ช่วยให้ความกระหายในการเข่นฆ่าสามารถปรับเปลี่ยนไปยังเป้าหมายได้ ดำเนินการจัดการโดยตรงโดย ดร. Borsev เพื่อการวัดผลเฉพาะเจาะจงของปรากฏการณ์นี้" 
		}
	},
	[8096] = {
		Title = "รายงานการทดลอง",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\collection\\Tablet_IL",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ยกเว้นในกรณีที่ไม่ปกติ เมื่อความคิดถูกทำให้เป็นรูปธรรมและแบ่งตัวออกเป็นจำนวนมากขึ้น ดูเหมือนว่ามันจะสูญเสียเป้าหมายเริ่มแรกและกลายเป็นหมกมุ่นอยู่กับการฆ่าและการทำลายล้าง\n\nเนื่องจากมีวิธีที่หาได้ยากในการกลับมาควบคุมร่างความคิดที่ควบคุมไม่ได้ จึงจำเป็นต้องมีการสังเกตเป็นพิเศษและแยกออกไปในระหว่างความคืบหน้าของร่างความคิด" 
		}
	},
	[8097] = {
		Title = "รายงานการทดลอง",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\collection\\Tablet_IL",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"หัวใจที่ถูกดัดแปลงของ pseudo Ymir หรือแกนกลางการต่อสู้ สามารถนำมาปลูกถ่ายลงในมนุษย์เพื่อให้แข็งแกร่งกว่าที่เป็นอยู่ตอนนี้ได้หรือไม่? ไม่จำเป็นต้องถามคำตอบสำหรับคำถามนี้ เป็นไปได้\n\nแต่มีเพียงสิ่งเดียวที่ขาดหายไป ความมุ่งมั่นที่จะมีชีวิตอยู่ให้นานขึ้น แข็งแกร่งพอที่จะไม่เผาผลาญตัวเองด้วยความโกรธ! เราต้องการบุคคลที่แข็งแกร่งทางจิตใจมากกว่านี้ มากกว่านี้!" 
		}
	},
	[8098] = {
		Title = "รายงานการทดลอง",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\collection\\Tablet_IL",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คณะสำรวจอย่างไม่เป็นทางการที่เริ่มต้นขึ้นอย่างลับๆ จากราชอาณาจักร Rune Midgards เหล่านักผจญภัยระดับหัวกะทิที่ไม่มีรายชื่อหลงเหลืออยู่ในบันทึกแม้ว่าพวกเขาจะไม่ได้กลับมาอย่างมีชีวิต\n\nนี่ไม่ใช่ตัวอย่างที่สมบูรณ์แบบสำหรับฉันหรอกหรือ! แม้ว่าเขาจะเรียกร้องมากเกินไปหน่อย แต่ด้วยอำนาจของ Rekenber เขาสามารถดึงพวกเขาออกมาได้โดยที่แม้แต่ประธานาธิบดีก็ไม่รู้ โดยการรวมพลังของเขากับอดีตสมาชิกของ Rune Midgards\n\nตอนนี้ เวทีสำหรับเด็กๆ ที่น่ารักนั้นสมบูรณ์แบบแล้ว ด้วยการทดลองที่ดีที่สุด พวกเขาจะได้รับเพียงความเอื้อเฟื้อที่ดีที่สุดจนถึงจุดจบที่พวกเขาจะได้รับ" 
		}
	},
	[8099] = {
		Title = "รายงานการทดลอง",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\collection\\Tablet_IL",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"อา... ฉันกำลังจะตายเพราะความง่วง นี่มันอะไรกัน นี่มันกี่วันแล้ว? อยากกลับบ้าน ช่วงนี้เวลาได้กลับบ้านหลังจากผ่านไปนาน แมวของฉันจำหน้าฉันไม่ได้ มันเลยเห่าใส่ฉัน\n\nถ้าบอกว่าคุณฝึกฝนชีวิตด้วยการกินมื้อค่ำ ทำไมคุณถึงเก็บรวบรวมบันทึกชีวมาตรและเปลี่ยนของใช้ในบ้านเป็นของเหมือนขอทาน และถ้ามันเป็นบริษัทจริงๆ และทุกอย่างล้มละลาย... … อะไรนะ นี่ไม่ใช่ไดอารี่ของฉัน ทำไมถึงลบอันนี้ไม่ได้ &#%&@…\n\n^FF0000นักวิจัยคนนี้ถูกให้ออกแล้ว เก็บรักษาข้อความต้นฉบับไว้เพื่อบันทึกเหตุผลในการกำจัด^000000" 
		}
	},
	[8100] = {
		Title = "รายงานการทดลอง",
		Search = 0,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\collection\\Tablet_IL",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เป้าหมายของระยะแรกคือการเปลี่ยนหัวใจด้วยแกนกลางต้นแบบและสังเกตความคืบหน้า และหลังจากบรรลุการรอดชีวิตตามเวลาที่กำหนดแล้ว ให้เข้าสู่ระยะที่สองทันที\n\nเป้าหมายของระยะที่สองของการทดลองคือการเพิ่มศักยภาพการต่อสู้ของสิ่งมีชีวิตให้สูงสุด เพื่อสังเกตความคืบหน้า และเพื่อรวบรวมข้อมูลที่มีความหมาย\n\nสำหรับการทดลองระยะที่สอง ให้จัดเตรียมสภาพแวดล้อมที่กระตุ้นซึ่งอาสาสมัครสามารถดึงและแผ่รังสีพลังของแกนกลางการต่อสู้ออกมาได้ และวัดค่าขีดจำกัด...\n\nจำเป็นต้องใช้ความระมัดระวังเป็นพิเศษเพื่อไม่ให้เกิดความตายเนื่องจากการกระตุ้นที่มากเกินไป แต่อัตราการเสียชีวิตในปัจจุบันคือ 100% ซึ่งเป็นทางเลือกหนึ่ง" 
		}
	},
	[8105] = {
		Title = "การประกวดออกแบบชุด คราฟต์หมวก#HatMm",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip08105",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"พบกับการผสมผสานหมวกแบบใหม่และช่างฝีมือหมวกที่รออยู่ในสถานที่ต่างๆ พร้อมไอเดียสุดพิเศษจากบุคคลพิเศษ\n\nค หน้านี้มีไว้เพื่อวัตถุประสงค์ในการแนะนำเท่านั้น และแสดงเพียงบางวิธีที่คุณจะได้รับวัตถุดิบ\n\n^EE0000ค ข้อควรระวัง: เว้นแต่จะระบุไว้เป็นอย่างอื่น จะใช้อุปกรณ์ที่ไม่มีรู (slot) เท่านั้นเป็นวัตถุดิบในการผสม\nหากคุณมีไอเทมซ้ำในคลัง ไอเทมที่ไม่ต้องการอาจถูกนำไปใช้ในการคราฟต์ได้ ดังนั้นโปรดพกเฉพาะไอเทมที่ต้องการใช้ในการคราฟต์เท่านั้น^000000\n\nค ^006699การคราฟต์หมวกจากการประกวดออกแบบชุด^000000\nป <TIPBOX>M Costume Nine Tail Wig<INFO>8106</INFO></TIPBOX>\nป <TIPBOX>M Costume Gothic Skull Ribbon<INFO>8107</INFO></TIPBOX>\nป <TIPBOX>M Costume Golden Violet<INFO>8108</INFO></TIPBOX>\n\nป <TIPBOX><INFO></INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
