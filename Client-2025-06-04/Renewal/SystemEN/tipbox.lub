		}
	},
	[5] = {
		Title = "ตัวละคร: การเลเวลอัป",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00005",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถเลเวลอัปได้จากการล่ามอนสเตอร์หรือทำเควสเพื่อรับค่าประสบการณ์\nเมื่อคุณเพิ่ม Base Level จากการสะสม EXP คุณจะได้รับ ^3b488cแต้มสถานะ (Status Points)^000000 ซึ่งใช้กำหนดความสามารถพื้นฐานของตัวละคร\nเมื่อคุณเพิ่ม Job Level จากการสะสม Job EXP คุณจะได้รับ ^3b488cแต้มทักษะ (Skill Points)^000000 เพื่อใช้เพิ่มระดับทักษะหรือเรียนรู้ทักษะใหม่ๆ\nป <TIPBOX>การต่อสู้: EXP<INFO>16</INFO></TIPBOX>\nป <TIPBOX>ตัวละคร: สถานะ<INFO>6</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		},
		PageEX = {
			{ EffectNum = 3, Twinkle = 1, StartX = 10, StartY = 265, DistX = 0, DistY = 0, MoveTime = 0 }
		}
	},
	[6] = {
		Title = "ค่าสถานะ: STR(Strength)#Stats",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00006",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ส่งผลโดยตรงต่อ ^3b488cพลังโจมตีกายภาพระยะประชิด^000000 และเพิ่มความเสียหายจากการโจมตีพื้นฐาน\nนอกจากนี้ ยังช่วยเพิ่ม ^3b488cน้ำหนักบรรทุก (Weight)^000000 ทำให้คุณสามารถพกพาไอเทมได้มากขึ้น\nป <TIPBOX>ค่าสถานะ: AGI(Agility)<INFO>7</INFO></TIPBOX>\nป <TIPBOX>ค่าสถานะ: VIT(Vitality)<INFO>8</INFO></TIPBOX>\nป <TIPBOX>ค่าสถานะ: INT(Intelligence)<INFO>9</INFO></TIPBOX>\nป <TIPBOX>ค่าสถานะ: DEX(Dexterity)<INFO>10</INFO></TIPBOX>\nป <TIPBOX>ค่าสถานะ: LUK(Luck)<INFO>11</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		},
