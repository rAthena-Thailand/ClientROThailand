	[43] = {
		Title = "Hotkey: แถบสกิล",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"การลงทะเบียนสกิลหรือไอเทมที่ใช้บ่อยในแถบสกิล (F12) จะช่วยให้คุณใช้งานได้ง่ายโดยการดับเบิลคลิกที่ช่องด้วยเมาส์หรือกดปุ่ม Hotkey\nแถบสกิลแรกจะตรงกับปุ่ม F1~F9 โดยปกติ และในตัวเลือกเกม คุณสามารถเปลี่ยน Hotkey ที่เกี่ยวข้องได้ในการตั้งค่า Hotkey ส่วน Hotkey สำหรับแถบสกิล 2~4 จะใช้งานได้เฉพาะในโหมดต่อสู้ (Battle Mode) เท่านั้น\nคุณสามารถเลือกสกิลหรือไอเทมด้วยเมาส์แล้วลากมาวางในช่องได้\nป <TIPBOX>ตัวเลือกเกม: Hotkey<INFO>41</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[44] = {
		Title = "Hotkey: Battle Mode",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Battle Mode จะล็อกฟีเจอร์การแชทเพื่อให้คุณสามารถใช้ Hotkey ที่ลงทะเบียนในแถบสกิลบนคีย์บอร์ดได้โดยตรง สามารถเปิด/ปิดได้ด้วยคำสั่ง /bm\n^ff0000 ในโหมด Battle Mode การแชทจะถูกล็อกโดยเริ่มต้น แต่คุณสามารถกดปุ่ม Enter เพื่อเปิดใช้งานหน้าต่างแชทได้^000000\nป <TIPBOX>ตัวเลือกเกม: BM/ปุ่มลัด<INFO>41</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
