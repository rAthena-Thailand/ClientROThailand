		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Eden Group คือองค์กรที่สนับสนุนเหล่านักผจญภัยด้วยสิ่งที่จำเป็นสำหรับการเอาชีวิตรอดในโลก Ragnarok\nตั้งแต่การสนับสนุนอุปกรณ์สำหรับผู้เริ่มต้นไปจนถึงเควสรายวันเพื่อช่วยในการเก็บเลเวล!\n\nProntera ป <NAVI>[Eden Teleport Officer]<INFO>prontera,124,76,0,101,0</INFO></NAVI>\nIzlude ป <NAVI>[Eden Teleport Officer]<INFO>izlude,131,148,0,101,0</INFO></NAVI>\nMorroc ป <NAVI>[Eden Teleport Officer]<INFO>morroc,161,97,0,101,0</INFO></NAVI>\nMorroc(ทางเข้า Pyramid) ป <NAVI>[Eden Teleport Officer]<INFO>moc_ruins,68,164,0,101,0</INFO></NAVI>\nComodo ป <NAVI>[Eden Teleport Officer]<INFO>comodo,202,151,0,101,0</INFO></NAVI>\nUmbala ป <NAVI>[Eden Teleport Officer]<INFO>umbala,105,158,0,101,0</INFO></NAVI>\nPayon ป <NAVI>[Eden Teleport Officer]<INFO>payon,177,111,0,101,0</INFO></NAVI>\nGeffen ป <NAVI>[Eden Teleport Officer]<INFO>geffen,132,66,0,101,0</INFO></NAVI>\nAlberta ป <NAVI>[Eden Teleport Officer]<INFO>alberta,124,67,0,101,0</INFO></NAVI>\nAldebaran ป <NAVI>[Eden Teleport Officer]<INFO>aldebaran,133,119,0,101,0</INFO></NAVI>\nYuno ป <NAVI>[Eden Teleport Officer]<INFO>yuno,144,189,0,101,0</INFO></NAVI>\nLighthalzen ป <NAVI>[Eden Teleport Officer]<INFO>lighthalzen,164,86,0,101,0</INFO></NAVI>\nEinbroch ป <NAVI>[Eden Teleport Officer]<INFO>einbroch,250,211,0,101,0</INFO></NAVI>\nHugel ป <NAVI>[Eden Teleport Officer]<INFO>hugel,93,153,0,101,0</INFO></NAVI>\nRachel ป <NAVI>[Eden Teleport Officer]<INFO>rachel,125,144,0,101,0</INFO></NAVI>\nVeins ป <NAVI>[Eden Teleport Officer]<INFO>veins,220,109,0,101,0</INFO></NAVI>\nLouyang ป <NAVI>[Eden Teleport Officer]<INFO>louyang,224,107,0,101,0</INFO></NAVI>\nBrasilis ป <NAVI>[Eden Teleport Officer]<INFO>brasilis,191,224,0,101,0</INFO></NAVI>\nAmatsu ป <NAVI>[Eden Teleport Officer]<INFO>amatsu,100,145,0,101,0</INFO></NAVI>\nPort Malaya ป <NAVI>[Eden Teleport Officer]<INFO>malaya,225,218,0,101,0</INFO></NAVI>\nAyothaya ป <NAVI>[Eden Teleport Officer]<INFO>ayothaya,221,191,0,101,0</INFO></NAVI>\nDewata ป <NAVI>[Eden Teleport Officer]<INFO>d