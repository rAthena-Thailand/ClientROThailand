	[9066] = {
		Title = "JQ Genetic",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Genetic อาชีพคลาส 3 ที่เปลี่ยนมาจาก Creator มีความสามารถในการแปรเปลี่ยนสสารผ่าน Change Materials, การปรุงอาหารแบบผสม (Mix Cooking) เพื่อสร้างอาหารชนิดใหม่ และความสามารถในการปรุงยาใหม่ๆ\nHomunculus ตัวใหม่จะวิวัฒนาการมาจาก Homunculus ตัวเดิมและกลายเป็นคู่หูที่ยอดเยี่ยมซึ่งมีพลังเท่ากับหรือมากกว่า Creator และเป็นไปได้ที่จะวิวัฒนาการเป็นแมลง, แฟรี่, สัตว์ หรือแร่ธาตุที่แตกต่างจาก Homunculus ที่มีอยู่เดิม\nค ^663399Base Level 99 หรือสูงกว่า^000000\nค ^663399Job Level 50 หรือสูงกว่า^000000\nค ^663399อาชีพที่กำหนด: Creator^000000\nป <NAVI>[Alchemist Union Member]<INFO>alde_alche,35,186,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>กลับไปหน้าก่อนหน้า<INFO>9053</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
