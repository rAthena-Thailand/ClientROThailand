	[110] = {
		Title = "ระบบ Activity Point(ระบบ AP)#Activity",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00110",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Activity Point (AP) คือระบบพอยต์ที่เพิ่มเข้ามาเมื่อเปลี่ยนเป็นอาชีพขั้นสูงหลังจากเลเวล 200\n\nAP คือพอยต์ที่ใช้เมื่อใช้งานสกิลที่มีพลังรุนแรง และมีค่าสูงสุดจำกัดอยู่ที่ 200 ไม่ว่าจะเป็นอาชีพใดก็ตาม\nAP สามารถฟื้นฟูหรือใช้ได้จากการร่ายสกิลที่มีผลในการฟื้นฟูหรือใช้ AP โดยตรงเท่านั้น (จะไม่ฟื้นฟูหรือถูกใช้หากสกิลนั้นทำงานผ่าน Auto Spell) และสำหรับบางอาชีพเท่านั้นที่จะสามารถฟื้นฟู AP ให้ผู้อื่นผ่านสกิลได้ คุณสามารถรับ AP หรือใช้ AP นั้นได้\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[111] = {
		Title = "การอัพเกรดเกรด (Grade Enhancement)#GradeEnhancement, Weapon, Armor, Etel Stone, Etel Dust",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00111",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เป็นไปได้ที่จะอัพเกรดเกรดของอาวุธเลเวล 5 หรือชุดเกราะเลเวล 2 บางชนิด\nป เงื่อนไขการอัพเกรดเกรด\nปไม่มีเกรด (No Rating): ระดับการตีบวกตั้งแต่ 9 ขึ้นไป\nปเกรด D: ระดับการตีบวกตั้งแต่ 10 ขึ้นไป\nป เกรด C: ระดับการตีบวกตั้งแต่ 11 ขึ้นไป\nป เกรด B: ระดับการตีบวกตั้งแต่ 11 ขึ้นไป\nคุณสามารถอัพเกรดเกรดและแลกเปลี่ยนวัตถุดิบได้ที่จุดอัพเกรดเกรดด้านล่างนี้\nป <NAVI>[Sratos]<INFO>grademk,34,184,0,100,0,0</INFO></NAVI>: สถานีอัพเกรดเกรด Prontera\nป <NAVI>[Shribel]<INFO>paramk,34,184,0,100,0,0</INFO></NAVI>: สถานีอัพเกรดเกรด Paramarket\nคด้านในโรงตีบวกแต่ละแห่ง\n\nผลของการอัพเกรดเกรด:\nอาวุธที่ได้รับการอัพเกรดเกรดจะได้รับโบนัสการตีบวก ATK/MATK เพิ่มเติมตามแต่ละเกรด\nออปชั่นของอุปกรณ์บางชนิดอาจแตกต่างกันไปในแต่ละเกรด\n\nป <TIPBOX>วัตถุดิบอัพเกรดเกรด<INFO>112</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[112] = {
		Title = "วัตถุดิบอัพเกรดเกรด#Grade Enhancement, Weapon, Armor, Etel Stone, Etel Dust, Combination",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00112",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถสร้างวัตถุดิบอัพเกรดเกรดได้โดยการผสมอัญมณีที่ซื้อได้จากร้านอัญมณีเข้ากับ Etheric Stones\n\nRank 1: \nป <ITEM>[Aquamarine]<INFO>720</INFO></ITEM> + <ITEM>[Etel Stone]<INFO>1000323</INFO></ITEM>\nRank 2:\nป <ITEM>[Topaz]<INFO>728</INFO></ITEM> + <ITEM>[Etel Stone]<INFO>1000323</INFO></ITEM>\nRank 3:\nป <ITEM>[Amethyst]<INFO>719</INFO></ITEM> + <ITEM>[Etel Stone]<INFO>1000323</INFO></ITEM>\nRank 4:\nป <ITEM>[Amber]<INFO>1000321</INFO></ITEM> + <ITEM>[Etel Stone]<INFO>1000323</INFO></ITEM>\n\nป <TIPBOX>Etel Material<INFO>114</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[113] = {
		Title = "เลเวลอาวุธ/ชุดเกราะ#Weapon Level, Armor Level",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00113",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"อาวุธและชุดเกราะแต่ละชนิดจะมีเลเวลระบุอยู่\nอาวุธเลเวล 5 และชุดเกราะเลเวล 2 จะไม่ถูกทำลายหรือหายไปแม้ว่าจะล้มเหลวในการตีบวกระหว่างระดับ 1 ถึง 10\nอย่างไรก็ตาม หากล้มเหลว ระดับการตีบวกจะลดลง\n\nตั้งแต่การพยายามตีบวกระดับ 11 เป็นต้นไป ไม่ว่าจะใช้แร่ตีบวกชนิดใด หากตีบวกล้มเหลว อุปกรณ์จะถูกทำลายทันที\n\nป <TIPBOX>การตีบวก (Refining)<INFO>77</INFO></TIPBOX>\nป <TIPBOX>Etel Material<INFO>114</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}, 
		PageEX = {
			{ EffectNum = 3, Twinkle = 1, StartX = 145, StartY = 190, DistX = 0, DistY = 0, MoveTime = 0 }
		}
	},
	[114] = {
		Title = "วัตถุดิบ Etel#Etel Dust, Etel Stone, Grade, Refine",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00114",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"วัตถุดิบ Etel ไม่สามารถใช้งานได้โดยตรง แต่เป็นแร่ที่ใช้สำหรับผสมกับอัญมณีหรือแร่อื่นๆ\nป <ITEM>[Etel Dust]<INFO>1000322</INFO></ITEM>\nป <ITEM>Etel Stone]<INFO>1000323</INFO></ITEM>\n\n\nEtel Dust และ Etel Stone ซึ่งเป็นวัตถุดิบหลัก สามารถหาได้จาก Dead Man's Banquet Hall, Collapsed Opera House, ชั้น 4 ของ Rudus, Abandoned Lab Amicitia - Comprehensive Lab และ Intensive Culture Room เป็นต้น\n\nป <TIPBOX>หินตีบวกเกรดสูง (High Grade Refine Stones)<INFO>135</INFO></TIPBOX>\nป <TIPBOX>เลเวลอาวุธ/ชุดเกราะ<INFO>113</INFO></TIPBOX>\nป <TIPBOX>การอัพเกรดเกรด<INFO>111</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[115] = {
		Title = "การตั้งค่าเอฟเฟกต์: ซ่อนผู้เล่น#Character, Translucent, User, Obscure",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00115",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"แสดงตัวละครผู้เล่นคนอื่นๆ ทั้งหมด (ยกเว้นตัวเราเอง) เป็นแบบกึ่งโปร่งใส\nฟีเจอร์นี้มีไว้เพื่อช่วยให้ค้นหา NPC ได้ง่ายขึ้นเมื่อมีผู้เล่นหนาแน่นและเกิดความสับสน โดยไม่มีผลกับ NPC, ร้านค้า (Stall), ห้องแชท หรือสัตว์อัญเชิญต่างๆ\nฟีเจอร์นี้จะถูกปิดใช้งานทุกครั้งที่ตัวละครล็อกอินเข้าสู่ระบบ\n\nคคำสั่งลัด: Ctrl+End\n\nป <TIPBOX>การตั้งค่าเอฟเฟกต์: ซ่อนสัตว์อัญเชิญ<INFO>150</INFO></TIPBOX>\nป <TIPBOX>การตั้งค่าเอฟเฟกต์<INFO>143</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตั้งค่าเกม (Game Options Window)<INFO>32</INFO>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[116] = {
		Title = "กิลด์: วอร์ (Siege)#WOE,PvP,Guild,Emperium,Valkyrie Realm,Britonia,Greenwood Lake,Luina,SE,Nidhoggur,Valfreyja,TE,Gloria,Kafragarten,HE,Herosria,Jewel,Beginning,Garden,Sanctuary",
