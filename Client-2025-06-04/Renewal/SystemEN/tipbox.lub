	[9082] = {
		Title = "Ranking System#Taekwon, Alchemist, Blacksmith",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ระบบการจัดอันดับแบ่งออกเป็น อันดับ Blacksmith, อันดับ Alchemist และอันดับ Taekwon\nอันดับ Blacksmith: คุณสามารถตรวจสอบได้ด้วยคำสั่ง /blacksmith\nอันดับ Alchemist: คุณสามารถตรวจสอบได้ด้วยคำสั่ง /alchemist\nอันดับ Taekwon: คุณสามารถตรวจสอบได้ด้วยคำสั่ง /taekwon\n\nป <TIPBOX>อันดับ: Blacksmith<INFO>9083</INFO></TIPBOX>\nป <TIPBOX>อันดับ: Alchemist<INFO>63</INFO></TIPBOX>\nป <TIPBOX>อันดับ: Taekwon<INFO>193</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9083] = {
		Title = "Ranking: Blacksmith",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"สิทธิประโยชน์ของผู้ติดอันดับ Blacksmith:\nอันดับ 1~5: มอบ Random Options 5 อย่างให้กับอาวุธเลเวล 3~4 ที่ผลิตเอง\nอันดับ 6-10: มอบ Random Options 4 อย่างให้กับอาวุธเลเวล 3~4 ที่ผลิตเอง\n(สำหรับ Blacksmith ที่ไม่อยู่ในอันดับ จะได้รับ Random Options 3 อย่างสำหรับอาวุธเลเวล 3~4)\n\n^3b488cวิธีได้รับคะแนนอันดับ^000000\n1 คะแนน: ตีบวกอาวุธเลเวล 1 ที่สร้างเองถึง +10\n10 คะแนน: สร้างอาวุธเลเวล 3 สำเร็จโดยใช้วัตถุดิบเพิ่มเติม 3 ชิ้น\n25 คะแนน: ตีบวกอาวุธเลเวล 2 ที่สร้างเองถึง +10\n1000 คะแนน: ตีบวกอาวุธเลเวล 3 ที่สร้างเองถึง +10\n\nอันดับ Blacksmith: /blacksmith\n\nป <TIPBOX>ระบบการจัดอันดับ<INFO>9082</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9084] = {
		Title = "Ranking: Alchemist",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"สิทธิประโยชน์ของผู้ติดอันดับ Alchemist:\nปริมาณการฟื้นฟูของยาที่ผลิตโดยผู้ติดอันดับ (อันดับที่ 1 ถึง 10) จะเพิ่มขึ้น 50%\n\n^3b488cวิธีได้รับคะแนนอันดับ^000000\n1 คะแนน: ปรุง Slim Potions สำเร็จ 3 ครั้งติดต่อกัน\n3 คะแนน: ปรุง Slim Potions สำเร็จ 5 ครั้งติดต่อกัน\n10 คะแนน: ปรุง Slim Potions สำเร็จ 7 ครั้งติดต่อกัน\n50 คะแนน: ปรุง Slim Potions สำเร็จ 10 ครั้งติดต่อกัน\n\nอันดับ Alchemist: /alchemist\n\nป <TIPBOX>ระบบการจัดอันดับ<INFO>9082</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9085] = {
		Title = "Illusion",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ไม่ใช่ที่นี่ ไม่ใช่ตอนนี้ แต่ก็คือความจริงและปัจจุบัน พื้นที่เหล่านี้ที่คุณสามารถมองเห็นอีกด้านหนึ่งจากฝั่งนี้ได้ แต่ไม่สามารถมองเห็นฝั่งนี้จากอีกด้านหนึ่งได้ เรียกว่า Illusions\nIllusion คือดินแดนสองมิติที่มักจะไม่มีบทลงโทษเรื่องส่วนต่างเลเวลสำหรับการดรอปไอเทมและค่าประสบการณ์ และจะมี <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM> อยู่ร่วมกันในทุกที่\n\nป <TIPBOX>Illusion of Moonlight<INFO>9086</INFO></TIPBOX>\nป <TIPBOX>Illusion of Vampire<INFO>9087</INFO></TIPBOX>\nป <TIPBOX>Illusion of Frozen<INFO>9088</INFO></TIPBOX>\nป <TIPBOX>Illusion of Abyss<INFO>9089</INFO></TIPBOX>\nป <TIPBOX>Illusion of Teddy Bear<INFO>9090</INFO></TIPBOX>\nป <TIPBOX>Illusion of Luanda<INFO>9091</INFO></TIPBOX>\nป <TIPBOX>Illusion of Labyrinth<INFO>9092</INFO></TIPBOX>\nป <TIPBOX>Illusion of Underwater<INFO>9093</INFO></TIPBOX>\nป <TIPBOX>Illusion of Twins<INFO>9157</INFO></TIPBOX>\n\nเกี่ยวกับทีมสำรวจ Illusion (Illusion Investigation Team)\nทีมสำรวจ Illusion ที่เชี่ยวชาญด้านการวิจัย Illusion ยินดีต้อนรับทุกคนที่ต้องการสำรวจ Illusions\nหลังจากลงทะเบียนกับหัวหน้าทีมสำรวจ Illusion ใน Prontera <NAVI>[Joel]<INFO>prt_in,136,34,</INFO></NAVI> แล้ว คุณสามารถทำเควสกำจัดศัตรูรายวันภายในแต่ละดันเจี้ยน Illusion ได้\nป <TIPBOX>ทีมสำรวจ Illusion<INFO>9126</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปหน้าก่อนหน้า<INFO>4100</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9086] = {
		Title = "Illusion of Moonlight",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ดูเหมือนว่าจะมีบางอย่างผิดปกติระหว่างพิธีกรรมชำระล้างที่ทำเป็นประจำใน Payon\nเหล่าผู้อาวุโสต้องการส่งเหล่านักผจญภัยเข้าไปเพื่อแก้ไขปัญหา และคุณที่ถูกดึงเข้าไปพัวพันกับเรื่องนี้ จะต้องเข้าไปสืบสวนฝันร้ายของ Moonlight ในหมู่บ้านร้างหรือที่ไหนสักแห่งที่ไม่ใช่หมู่บ้านร้าง\n\nค ^663399เลเวล 100 หรือสูงกว่า^000000\nป <NAVI>[Payon Elder Saniul]<INFO>payon,164,229,0,101,0</INFO></NAVI>\n\nเควสกำจัดศัตรูของทีมสำรวจ Illusion\nป <TIPBOX>Q Illusion of Moonlight กำจัด 100 ตัว (100)<INFO>9127</INFO></TIPBOX>\n\nเควสรายวันที่สามารถทำได้หลังจากสำเร็จเควสเนื้อเรื่อง\nป <TIPBOX>Q หยุดยั้งจอมเวทย์! (100)<INFO>9094</INFO></TIPBOX>\nป <TIPBOX>Q ไม่มีความเมตตาต่อภาพลวงตา! (100)<INFO>9095</INFO></TIPBOX>\nป <TIPBOX>Q ระลึกถึงบรรพบุรุษ! (100)<INFO>9096</INFO></TIPBOX>\n\nไอเทมสวมใส่บางอย่างสามารถแลกเปลี่ยนเป็นรุ่นที่มีประสิทธิภาพดีกว่าได้ โดยใช้ไอเทมเช่น <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM> ที่ได้รับจาก Illusion of Moonlight เป็นวัตถุดิบ\nอุปกรณ์ที่จะนำมาแลกเปลี่ยนต้องถูกตีบวกถึง +9 หรือสูงกว่า และการ Enchant (ออฟชั่น) ของอุปกรณ์และ Card จะหายไป\nค ^663399สถานที่แลกเปลี่ยน^000000\nป <NAVI>[Gemcutter]<INFO>pay_d03_i,160,45,0,101,0</INFO></NAVI>\n\nป <ITEM>[Illusion Staff of Bordeaux<INFO>26109</INFO></ITEM>\nป +9 <ITEM>[Staff of Bordeaux]<INFO>1648</INFO></ITEM>, 30x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 100x <ITEM>[Hazy Dream Fragment]<INFO>25256</INFO></ITEM>\nป <ITEM>[Illusion Long Mace[2]]<INFO>16063</INFO></ITEM>\nป +9 <ITEM>[Long Mace]<INFO>1525</INFO></ITEM>, 10x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 20x <ITEM>[Hazy Dream Fragment]<INFO>25256</INFO></ITEM>\nป <ITEM>[Illusion Moonlight Sword[1]]<INFO>28725</INFO></ITEM>\nป +9 <ITEM>[Moonlight Sword]<INFO>1234</INFO></ITEM>, 60x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 100x <ITEM>[Hazy Dream Fragment]<INFO>25256</INFO></ITEM>\nป <ITEM>[Illusion Spectral Spear[1]]<INFO>26007</INFO></ITEM>\nป +9 <ITEM>[Spectral Spear]<INFO>1477</INFO></ITEM>, 20x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 100x <ITEM>[Hazy Dream Fragment]<INFO>25256</INFO></ITEM>\nป <ITEM>[Illusion Nurse Cap[1]]<INFO>19209</INFO></ITEM>\nป +9 <ITEM>[Nurse Cap]<INFO>2277</INFO></ITEM>, 10x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 100x <ITEM>[Bloody Love Letter]<INFO>25257</INFO></ITEM>\nป <ITEM>[Illusion Apple of Archer[1]]<INFO>19210</INFO></ITEM>\nป +9 <ITEM>[Apple of Archer]<INFO>2285</INFO></ITEM>, 10x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 100x <ITEM>[Broken Arrow]<INFO>25258</INFO></ITEM>\nป <ITEM>[Illusion Muffler[1]]<INFO>20838</INFO></ITEM>\nป +9 <ITEM>[Muffler[1]]<INFO>2504</INFO></ITEM>, 10x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 100x <ITEM>[Hazy Moon Pastry]<INFO>23228</INFO></ITEM>\nป <ITEM>[Illusion Shoes[1]]<INFO>22133</INFO></ITEM>\nป +9 <ITEM>[Shoes[1]]<INFO>2404</INFO></ITEM>, 10x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 100x <ITEM>[Hazy Moon Pastry]<INFO>23228</INFO></ITEM>\nป <ITEM>[Illusion Puente Robe[1]]<INFO>15195</INFO></ITEM>\nป +9 <ITEM>[Puente Robe[1]]<INFO>15012</INFO></ITEM>, 10x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 100x <ITEM>[Hazy Dream Fragment]<INFO>25256</INFO></ITEM>\n\nป <TIPBOX>กลับไปหน้าก่อนหน้า<INFO>9085</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9087] = {
		Title = "Illusion of Vampire",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ที่มุมหนึ่งของดันเจี้ยนใต้ดิน Geffen มีนักบวชและจอมเวทย์กำลังต่อสู้กันอยู่\nเหล่านักบวชและจอมเวทย์รวมตัวกันเพื่อให้ผู้ตายได้พักผ่อน แต่มีการค้นพบว่าบันทึกที่ได้รับระหว่างการทำงานมีความทรงจำของเจ้าของบันทึกอยู่ นั่นคือพลังที่จะพาผ่านเข้าไปยังพื้นที่แห่งนี้...?\n\nค ^663399เลเวล 130 หรือสูงกว่า^000000\nป <NAVI>[Grimm]<INFO>gef_dun01,132,223,0,101,0</INFO></NAVI>\n\nเควสกำจัดศัตรูของทีมสำรวจ Illusion\nป <TIPBOX>Q Illusion of Vampire กำจัด 100 ตัว (130)<INFO>9128</INFO></TIPBOX>\n\nเควสรายวันที่สามารถทำได้หลังจากสำเร็จเควสเนื้อเรื่อง\nป <TIPBOX>Q อยากรู้อยากเห็นโดยธรรมชาติ (130)<INFO>9097</INFO></TIPBOX>\nป <TIPBOX>Q ส่งคนตายกลับคืนสู่ดิน (130)<INFO>9098</INFO></TIPBOX>\nป <TIPBOX>Q ฝันหวาน (130)<INFO>9099</INFO></TIPBOX>\nป <TIPBOX>Q เลือดปลอมที่เชื่อถือไม่ได้ (130)<INFO>9100</INFO></TIPBOX>\nป <TIPBOX>Q เพื่อนบ้านที่หนวกหู (130)<INFO>9101</INFO></TIPBOX>\nป <TIPBOX>Q การหล่อแบบ (130)<INFO>9102</INFO></TIPBOX>\n\nไอเทมสวมใส่บางอย่างสามารถแลกเปลี่ยนเป็นรุ่นที่มีประสิทธิภาพดีกว่าได้ โดยใช้ไอเทมเช่น <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM> ที่ได้รับจาก Illusion of Vampire เป็นวัตถุดิบ\nอุปกรณ์ที่จะนำมาแลกเปลี่ยนต้องถูกตีบวกถึง +9 หรือสูงกว่า และการ Enchant (ออฟชั่น) ของอุปกรณ์และ Card จะหายไป\nค ^663399สถานที่แลกเปลี่ยน^000000\nป <NAVI>[Great Merchant]<INFO>gef_dun01,139,228,0,101,0</INFO></NAVI>\n\nป <ITEM>[Illusion Infiltrator[2]]<INFO>28022</INFO></ITEM>\nป +9 <ITEM>[Infiltrator[1]]<INFO>1266</INFO></ITEM>, 80x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 20x <ITEM>[Torn Paper]<INFO>25261</INFO></ITEM>\nป <ITEM>[Illusion Sharpened Leg Bone of Ghoul<INFO>28023</INFO></ITEM>\n+9ป <ITEM>[Sharpened Leg Bone of Ghoul<INFO>1260</INFO></ITEM>, 10x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 100x <ITEM>[Cluster of Nightmares]<INFO>25264</INFO></ITEM>\nป <ITEM>[Illusion Wizardry Staff[2]]<INFO>2039</INFO></ITEM>\nป +9 <ITEM>[Wizardry Staff]<INFO>1473</INFO></ITEM>, 40x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 100x <ITEM>[Suspicious Pentacle]<INFO>25267</INFO></ITEM>\nป <ITEM>[Illusion Ballista[2]]<INFO>18149</INFO></ITEM>\nป +9 <ITEM>[Ballista[1]]<INFO>1727</INFO></ITEM>, 50x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 100x <ITEM>[Shining Spore]<INFO>25265</INFO></ITEM>\nป <ITEM>[Illusion Apocalypse[2]]<INFO>28612</INFO></ITEM>\nป +9 <ITEM>[Apocalypse]<INFO>1557</INFO></ITEM>, 50x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 10x <ITEM>[Well-dried Clover]<INFO>25262</INFO></ITEM>\nป <ITEM>[Illusion Cape of Ancient Lord[1]]<INFO>20840</INFO></ITEM>\nป +9 <ITEM>[Cape of Ancient Lord[1]]<INFO>2525</INFO></ITEM>, 30x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 200x <ITEM>[Short Bat Hair]<INFO>25263</INFO></ITEM>\nป <ITEM>[Illusion Skull Ring[1]]<INFO>28508</INFO></ITEM>\nป <ITEM>[Skull Ring[1]]<INFO>2715</INFO></ITEM>, 50x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 400x <ITEM>[Dried Yggdrasil Leaf]<INFO>25266</INFO></ITEM>\nป <ITEM>[Illusion Ring[1]]<INFO>28509</INFO></ITEM>\nป <ITEM>[Ring[1]]<INFO>2621</INFO></ITEM>, 50x <ITEM>[Illusion Stone]<INFO>25271</INFO></ITEM>, 400x <ITEM>[Suspicious Pentacle]<INFO>25267</INFO></ITEM>\n\nป <TIPBOX>กลับไปหน้าก่อนหน้า<INFO>9085</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
