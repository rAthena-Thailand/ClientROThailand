	[7078] = {
		Title = "Q ห้องน้ำ, สิ่งมีชีวิตประหลาด และฉัน (130)#Episode 17.2 Daily Quest",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"หลังจากผ่านโรงบำบัดน้ำเสียมาได้ ฉันก็มาถึงห้องน้ำเพื่อชำระล้างร่างกายที่สกปรก อย่างไรก็ตาม พวกเขาบอกว่ามีมอนสเตอร์อยู่ข้างในและพวกมันกำลังขวางทางเข้าไว้\nท้ายที่สุดแล้ว มันจะต้องมีผีอย่างน้อยสักตัวในคฤหาสน์เก่าแห่งนี้\n\nป มีเควสรายวัน 2 ประเภทที่สามารถทำได้หลังจากทำเควสนี้สำเร็จแล้ว\nระหว่างน้ำร้อนและน้ำเย็น (130)\nห้องน้ำกำลังถูกทำความสะอาด (130)\n\nป ทำเควส <TIPBOX>แขกของคฤหาสน์ (Guest of the mansion)<INFO>7071</INFO></TIPBOX> สำเร็จแล้ว\nค ^663399เลเวล 130 ขึ้นไป^000000\nป <NAVI>[Sinsa]<INFO>ba_in01,384,38,0,101,0</INFO></NAVI>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>7068</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[7079] = {
		Title = "Q คอกสัตว์ที่ถูกลืม (130)#Episode 17. MD Memorial Dungeon Daily Quest",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"สถานที่เพาะพันธุ์ที่สวยงามและงดงามตั้งอยู่ด้านหนึ่งของคฤหาสน์ มันเป็นบ้านของ Meows และ Pitayas\nจะลองเที่ยวชมคอกสัตว์และสัมผัสประสบการณ์การเก็บเกี่ยวภายใต้การแนะนำของหุ่นยนต์อัตโนมัติดูไหม?\n\nป มีเควสรายวัน 2 ประเภทที่สามารถทำได้หลังจากทำเควสนี้สำเร็จแล้ว\nการเก็บเกี่ยวหาง Pitaya (130)\nการเล่นกับ Pitaya (150)\n\nป ทำเควส <TIPBOX>แขกของคฤหาสน์ (Guest of the mansion)<INFO>7071</INFO></TIPBOX> สำเร็จแล้ว\nค ^663399เลเวล 130 ขึ้นไป^000000\nป <NAVI>[Ruinan]<INFO>ba_maison,311,206,0,101,0</INFO></NAVI>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>7068</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[7080] = {
		Title = "Q Hidden Flower Garden (130)#Episode 17.2 MD Memorial Dungeon Daily Quest",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เหล่าหุ่นยนต์อัตโนมัติที่รอคอยการส่งการบ้านแต่ไม่มีใครคอยตรวจสอบ ต้องการนักผจญภัยที่มีพลังเวทมนตร์ใกล้เคียงกับ Varmundt เพื่อรับการประเมินในฐานะผู้จัดการชั่วคราว\nแต่ดูเหมือนว่าหุ่นยนต์ผู้จัดการแต่ละตัวจะมีแนวคิดที่แตกต่างกันออกไป...?\n\nป เควสต์รายวันมี 2 ประเภทที่สามารถทำได้หลังจากเสร็จสิ้นเควสต์หลักแล้ว\nSecurity Zone 1 (เลเวล 130)\nSecurity Zone 2 (เลเวล 180)\n\nป <TIPBOX>ผ่านเควสต์ Guest of the mansion<INFO>7071</INFO></TIPBOX>\nค ^663399เลเวล 130 หรือสูงกว่า^000000\nป <NAVI>[Security Area Entry Officer]<INFO>ba_maison,120,321,0,101,0</INFO></NAVI>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>7068</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[7081] = {
		Title = "Q Sewage Treatment Plant, 1st Power Plant (130)#Episode 17.2 Daily Quest",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"หุ่นยนต์ทำความสะอาดช่างน่ารัก... หุ่นยนต์ทำความสะอาดตัวน้อยแสนน่ารัก Omega กำลังเศร้าเพราะมันไม่สามารถทำความสะอาดได้เนื่องจากมีมอนสเตอร์ที่น่ากลัวอยู่เต็มไปหมด\nมาช่วยหุ่นยนต์ทำความสะอาดตัวน้อยจัดการกับเหล่ามอนสเตอร์ในโรงบำบัดน้ำเสีย (Sewage Treatment Plant) และโรงไฟฟ้าแห่งที่ 1 (1st Power Plant) กันเถอะ\n\nป <TIPBOX>ผ่านเควสต์ Guest of the mansion<INFO>7071</INFO></TIPBOX>\nค ^663399เลเวล 130 หรือสูงกว่า^000000\nป <NAVI>[Cleaner Omega]<INFO>ba_in01,30,329,0,101,0</INFO></NAVI>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>7068</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[7082] = {
		Title = "Q Illusion Sprinkled Potato Chips (180)#Episode 17.2 MD Memorial Dungeon Daily Quest",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เหล่า Illusion ได้โปรยชิปรบกวนสัญญาณไว้ทั่วโรงไฟฟ้าแห่งที่ 2 เพื่อปิดกั้นคลื่นวิทยุของตุ๊กตาอัตโนมัติ\nมันส่งผลร้ายแรงต่อเหล่าตุ๊กตา แต่มันคือขนมขบเคี้ยวที่มีคุณค่าทางโภชนาการแสนอร่อยสำหรับนักผจญภัยที่มีชีวิต ลองชิมดูสักหน่อยไหม\n\nป <TIPBOX>ผ่านเควสต์ Guest of the mansion<INFO>7071</INFO></TIPBOX>\nค ^663399เลเวล 180 หรือสูงกว่า^000000\nป <NAVI>[Eorpa]<INFO>ba_maison,79,278,0,101,0</INFO></NAVI>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>7068</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[7083] = {
		Title = "Memorial Dungeon (MD)#Memorial Dungeon MD Reward",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ความอยากรู้อยากเห็นเกี่ยวกับสิ่งที่ไม่รู้ นำไปสู่การสำรวจ นี่คือชะตากรรมของนักผจญภัย\nข้ามพ้นทวีป Midgard ไปสู่โลกใหม่ สู่โลกอื่น เรื่องราวใหม่กำลังรอนักผจญภัยให้ค้นพบในทุกที่ที่เท้าสัมผัส\n\nป <TIPBOX>รายการ MD ทวีป Midgard<INFO>7084</INFO></TIPBOX>\nป <TIPBOX>รายการ MD ตาม Episode<INFO>7107</INFO></TIPBOX>\nป <TIPBOX>รายการ MD Heroes Trails<INFO>7129</INFO></TIPBOX>\nป <TIPBOX>รายการ MD EDDA<INFO>7137</INFO></TIPBOX>\nป <TIPBOX>รายการ MD ตามภูมิภาค<INFO>7141</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>4100</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[7084] = {
