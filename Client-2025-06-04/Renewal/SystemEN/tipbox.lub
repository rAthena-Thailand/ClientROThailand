	[9036] = {
		Title = "Archer",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ในฐานะอาชีพที่มีพรสวรรค์หลากหลายในทักษะการใช้ธนู จึงมีความสามารถที่ยอดเยี่ยมในการช่วยเหลือเพื่อนร่วมทีมด้วยการยิงจากระยะไกลหรือการสกัดกั้นศัตรู\nค ^663399Job Level 10 ขึ้นไป^000000\nค ^663399อาชีพที่เปลี่ยนได้: Novice^000000\nป <NAVI>[Archer Guildsman]<INFO>payon_in02,64,67,0,101,0,</INFO></NAVI>\n\nลูกธนูซึ่งเป็นสิ่งจำเป็นสำหรับ Archer มีจำหน่ายโดย NPC พ่อค้าลูกธนู (Arrow Merchant) ในร้านขายอาวุธของแต่ละท้องถิ่น\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9032</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9037] = {
		Title = "Magician",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เป็นอาชีพที่เชี่ยวชาญด้านเวทมนตร์โดยใช้ธาตุทั้งหมดที่มีอยู่ในโลก จำเป็นต้องมีการตอบสนองต่อสถานการณ์และการตัดสินใจที่รวดเร็ว แต่ก็เป็นอาชีพที่มีความแข็งแกร่งและสง่างาม\nค ^663399Job Level 10 ขึ้นไป^000000\nค ^663399อาชีพที่เปลี่ยนได้: Novice^000000\nป <NAVI>[Mage Guildsman]<INFO>geffen_in,164,124,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9032</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9038] = {
		Title = "Merchant",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"พวกเขามีทักษะต่างๆ ที่จำเป็นสำหรับการทำธุรกิจ การใช้รถเข็นหรือการแสดงพลังแห่งเงินอย่างทักษะ Mammonite จะทำให้ศัตรูได้ลิ้มรสชาติที่แท้จริงของเงินและพลังของพ่อค้าด้วยการโจมตีที่น่าตื่นเต้นเพียงครั้งเดียว\nค ^663399Job Level 10 ขึ้นไป^000000\nค ^663399อาชีพที่เปลี่ยนได้: Novice^000000\nป <NAVI>[Merchant]<INFO>alberta_in,56,43,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9032</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9039] = {
		Title = "คู่มือเปลี่ยนอาชีพสาย Expanded",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Novice ที่มี Job Level 10 ขึ้นไปสามารถเปลี่ยนอาชีพเป็นอาชีพสาย Expanded ได้เช่นกัน โปรดตรวจสอบให้แน่ใจว่าได้อัปสกิล Basic จนครบแล้ว\nซึ่งแตกต่างจากการเปลี่ยนอาชีพคลาส 1 พื้นฐาน อาชีพสาย Expanded มีวิธีพิเศษในการเปลี่ยนไปสู่อาชีพที่สูงขึ้น\n\nป <TIPBOX>Taekwon<INFO>9040</INFO></TIPBOX>\nป <TIPBOX>Ninja<INFO>9041</INFO></TIPBOX>\nป <TIPBOX>Gunslinger<INFO>9042</INFO></TIPBOX>\n\nป <TIPBOX>Super Novice<INFO>9043</INFO></TIPBOX>\n\nป <TIPBOX>ไปยังหน้าอาชีพ<INFO>1004</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9040] = {
		Title = "JQ Taekwon",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Taekwon เป็นอาชีพที่ใช้การโจมตีด้วยเท้าเป็นอาวุธหลัก ไม่สามารถสวมใส่อาวุธได้ รวมถึงไอเทมอื่นๆ ที่อาชีพทั้งหมดสวมใส่ได้ (ยกเว้น Novice) ก็ไม่สามารถสวมใส่ได้เช่นกัน\nค ^663399Job Level 10 ขึ้นไป^000000\nค ^663399อาชีพที่เปลี่ยนได้: Novice^000000\nป <NAVI>[Phoenix]<INFO>payon_in01,62,10,0,101,0,</INFO></NAVI>\n\nTaekwon ที่มี Job Level 40 ขึ้นไป จะสามารถเปลี่ยนอาชีพเป็นอาชีพสาย Expanded คลาส 2 ได้\nป <TIPBOX>Star Gladiator<INFO>9045</INFO></TIPBOX>\nป <TIPBOX>Soul Linker<INFO>9046</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9039</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9041] = {
		Title = "JQ Ninja",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Ninja ที่มีทักษะพิเศษในการเคลื่อนที่อย่างรวดเร็ว ไม่เพียงแต่ใช้อาวุธทั่วไปเท่านั้น แต่ยังใช้อาวุธขว้างและนินจุทสุ (วิชานินจา) และเป็นอาชีพแบบไฮบริดที่สามารถทำการโจมตีได้ทั้งกายภาพและเวทมนตร์ รวมถึงทักษะการหลบหลีกที่หลากหลาย นินจาสามารถจัดการศัตรูได้โดยใช้มีดสั้นและชูริเคน การขว้างอาวุธที่ไม่ใช่ดาบ และเวทมนตร์อย่าง “นินจุทสุ”\nค ^663399Job Level 10 ขึ้นไป^000000\nค ^663399อาชีพที่เปลี่ยนได้: Novice^000000\nป <NAVI>[Smuggler Captain]<INFO>alberta,168,138,0,101,0,</INFO></NAVI>\n\nอุปกรณ์นินจุทสุและของสิ้นเปลืองที่จำเป็นสำหรับนินจามีจำหน่ายโดย NPC พ่อค้านินจุทสุในร้านขายอาวุธของแต่ละท้องถิ่น\n\nNinja ที่มี Base Level 99 และ Job Level 70 ขึ้นไป จะสามารถเปลี่ยนอาชีพเป็นอาชีพสาย Expanded ระดับสูงขึ้นไปได้\nป <TIPBOX>Kagerou/Oboro<INFO>9049</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9041</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9042] = {
		Title = "JQ Gunslinger",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Gunslinger เป็นนักยิงระยะไกลที่ใช้ปืนหลากหลายชนิดเพื่อปราบศัตรู มีปืนทั้งหมด 5 ประเภท ซึ่งทั้งหมดเป็นอาวุธประเภทสองมือ\nค ^663399Job Level 10 ขึ้นไป^000000\nค ^663399อาชีพที่เปลี่ยนได้: Novice^000000\nป <NAVI>[Master Miller]<INFO>que_ng,152,167,0,101,0,</INFO></NAVI>\n\nอาวุธและของสิ้นเปลืองที่จำเป็นสำหรับ Gunslinger มีจำหน่ายโดย NPC พ่อค้ากระสุน (Ammunition Vendors) ในร้านขายอาวุธของแต่ละท้องถิ่น\n\nGunslinger ที่มี Base Level 99 และ Job Level 70 ขึ้นไป จะสามารถเปลี่ยนอาชีพเป็นอาชีพสาย Expanded ระดับสูงขึ้นไปได้\nป <TIPBOX>Rebellion<INFO>9050</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9039</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9043] = {
		Title = "JQ Super Novice",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ต่างจาก Novice ที่ใช้ได้เพียง First Aid และ Play Dead อาชีพ Super Novice เป็นอาชีพที่สามารถใช้สกิลส่วนใหญ่ของอาชีพคลาส 1 ทั้ง 6 อาชีพได้ เสน่ห์ที่ยิ่งใหญ่ที่สุดของ Super Novice คือการที่คุณสามารถเรียนรู้สกิลเกือบทั้งหมดของอาชีพคลาส 1\nอย่างไรก็ตาม เมื่อคุณกลายเป็น Super Novice แล้ว คุณจะไม่สามารถเปลี่ยนเป็นอาชีพคลาส 1 อื่นๆ ได้อีก\nค ^663399Base Level 45 ขึ้นไป^000000\nค ^663399Job Level 10 ขึ้นไป^000000\nค ^663399อาชีพที่เปลี่ยนได้: Novice^000000\nป <NAVI>[Tzerero]<INFO>aldeba_in,223,167,0,101,0,</INFO></NAVI>\n\nSuper Novice ที่มี Base Level 200 และ Job Level 70 ขึ้นไป จะสามารถเปลี่ยนอาชีพเป็นอาชีพสาย Expanded คลาส 4 ของตนได้\nป <TIPBOX>Hyper Novice<INFO>4250</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9039</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9044] = {
		Title = "JQ Doram",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เผ่า Doram มีความสามารถในฐานะ Summoner ที่ยอดเยี่ยมและมักจะเลือกที่จะเป็น Summoner\nการผจญภัยของ Summoner เผ่า Doram ผู้ซึ่งเพิ่งเปิดตัวในฐานะนักผจญภัยใน Midgard ได้เริ่มต้นขึ้นแล้วในตอนนี้\n\nDoram ที่มี Base Level 200 และ Job Level 60 ขึ้นไป จะสามารถเปลี่ยนอาชีพเป็นอาชีพสาย Expanded คลาส 4 ของตนได้\nป <TIPBOX>Spirit Handler<INFO>4251</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9039</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9045] = {
		Title = "JQ Star Gladiator",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Star Gladiator เป็นคลาสที่มีความสามารถในการเปลี่ยนพลังงานจากหนังสือมาเป็นพลังโจมตีของเท้าคุณ คุณลักษณะที่ใหญ่ที่สุดของ Star Gladiator คือมันสามารถพัฒนาได้โดยการปรับแต่งตัวละครให้เชี่ยวชาญในสถานที่เก็บเลเวลหรือมอนสเตอร์ที่คุณชอบ\nค ^663399Job Level 40 ขึ้นไป^000000\nค ^663399อาชีพที่เปลี่ยนได้: Taekwon^000000\nป <NAVI>[Moohyun]<INFO>payon,215,102,0,101,0,</INFO></NAVI>\n\nผู้ที่มี Base Level 99 และ Job Level 50 ขึ้นไป จะสามารถเปลี่ยนอาชีพเป็นอาชีพสาย Expanded ระดับสูงขึ้นไปได้\nป <TIPBOX>Star Emperor<INFO>9047</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9040</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9046] = {
		Title = "JQ Soul Linker",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Soul Linker คืออาชีพที่ละทิ้งวิถีแห่งเทควันโดและได้รับพลังแห่งจิตวิญญาณ Soul Linker มีคุณลักษณะที่เพิกเฉยต่อสกิลยกเลิกสถานะ (Dispel, Hermod, Flying Kick)\nค ^663399Job Level 40 ขึ้นไป^000000\nค ^663399อาชีพที่เปลี่ยนได้: Taekwon^000000\nป <NAVI>[Kid]<INFO>morocc_in,174,30,0,101,0,</INFO></NAVI>\n\nSoul Linker ที่มี Base Level 99 และ Job Level 50 ขึ้นไป สามารถเปลี่ยนเป็นอาชีพสาย Expanded ระดับสูงขึ้นไปได้\nป <TIPBOX>Soul Reaper<INFO>9048</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9040</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9047] = {
		Title = "JQ Star Emperor",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ในหมู่ผู้ที่ใช้พลังของดวงอาทิตย์ ดวงจันทร์ และดวงดาว ผู้ที่โหยหาความรู้ที่กว้างขวางยิ่งขึ้นเพื่อเพิ่มพลังของตนจะได้รับความรู้แห่งจักรวาลซึ่งเป็นหลักการของทุกสรรพสิ่ง และเรียกตนเองว่า Star Emperor\nค ^663399Base Level 99 ขึ้นไป^000000\nค ^663399Job Level 50 ขึ้นไป^000000\nค ^663399อาชีพที่เปลี่ยนได้: Star Gladiator^000000\nป <NAVI>[Man in sacramental Attire]<INFO>payon,171,171,0,101,0,</INFO></NAVI>\n\nStar Emperor ที่มี Base Level 200 และ Job Level 70 ขึ้นไป จะสามารถเปลี่ยนอาชีพเป็นอาชีพสาย Expanded คลาส 4 ของตนได้\nป <TIPBOX>Sky Emperor<INFO>4252</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9045</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9048] = {
		Title = "JQ Soul Reaper",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Soul Linker ผู้ยิ่งใหญ่ที่ตระหนักถึงพลังงานของจิตวิญญาณได้กลายเป็น Soul Reaper แต่ไม่สามารถกลับมายังโลกมนุษย์ได้ แทนที่ด้วยการรอคอย Soul Linker ที่จะมายังโลกหลังความตายเพื่อศึกษาเรื่องวิญญาณเช่นเดียวกับเธอ\nค ^663399Base Level 99 ขึ้นไป^000000\nค ^663399Job Level 50 ขึ้นไป^000000\nค ^663399อาชีพที่เปลี่ยนได้: Soul Linker^000000\nป <NAVI>[Half Drug]<INFO>pay_fild08,51,82,0,101,0,</INFO></NAVI>\n\nSoul Reaper ที่มี Base Level 200 และ Job Level 70 ขึ้นไป จะสามารถเปลี่ยนอาชีพเป็นอาชีพสาย Expanded คลาส 4 ของตนได้\nป <TIPBOX>Soul Ascetic<INFO>4253</INFO></TIPBOX>\n\nป <TIPBOX>กลับไปยังหน้าก่อนหน้า<INFO>9046</INFO></TIPBOX>\nค <TIPBOX>ดูรายการทิปทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
