	[9145] = {
		Title = "JQ Shadow Cross",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"อาชีพคลาส 4 Shadow Cross ผู้ที่เปลี่ยนอาชีพมาจาก Guillotine Cross คือเจ้าของความสามารถในการโจมตีศัตรูในขณะที่ซ่อนตัวอยู่\nนอกจากนี้ หากคุณใช้มีดสั้นเป็นอาวุธหลัก คุณสามารถหมุนใบมีดรอบตัวเพื่อสร้างบาดแผลให้กับเป้าหมายที่เข้ามาใกล้ได้\nค ^663399Base Level 200 หรือสูงกว่า^000000\nค ^663399Job Level 70 หรือสูงกว่า^000000\nค ^663399อาชีพที่ต้องการ: Guillotine Cross^000000\nป <NAVI>[Rumin]<INFO>job3_guil01,74,92,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>เควสเปลี่ยนอาชีพคลาส 4<INFO>9136</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
		}
