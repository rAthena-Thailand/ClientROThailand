	[120] = {
		Title = "Siege(HE)#PVP,Guild,Emperium,Herosria,Jewel,Beginning,Garden,Sanctuary",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00120",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"สถานที่ฝึกฝนที่จัดเตรียมโดยกลุ่มดาว Rigel\nแตกต่างจากการวอร์แบบเดิม ตรงที่เป็นพื้นที่วอร์ที่อนุญาตให้ใช้เฉพาะไอเทมอุปกรณ์สำหรับ Herosria PVP เท่านั้น\n\nทุกวันอาทิตย์: 20:00 (2 ชั่วโมง)\n\nป Sanctuary Herosria\nพื้นที่วอร์ขนาดใหญ่ที่ประกอบด้วย 13 ภูมิภาค ภายใต้คอนเซปต์ของฤดูกาลทั้งสี่\nป <NAVI>[Valkyrie Realm]<INFO>prt_gld,207,162,0,101,0</INFO></NAVI>\nป <NAVI>[Britonia]<INFO>gef_fild13,176,222,0,101,0</INFO></NAVI>\nป <NAVI>[Greenwood Lake]<INFO>pay_gld,200,150,0,101,0</INFO></NAVI>\nป <NAVI>[Luina]<INFO>alde_gld,186,142,0,101,0</INFO></NAVI> ช่วยให้คุณสามารถเข้าสู่พื้นที่ Sanctuary Herosria ได้\n\nกิลด์มาสเตอร์ที่ยึดครองปราสาทได้ จะได้รับของขวัญ Herosria Gift 10 ชิ้น วันละหนึ่งครั้งผ่านผู้จัดการ Herosria Sanctuary\n\nไอเทมอุปกรณ์ที่ได้รับจาก Herosria's Gift จะเปลี่ยนไปตามฤดูกาล\nนอกจากนี้ ไอเทมอุปกรณ์เหล่านี้ยังสามารถหาได้จาก Herosria PVP dungeon\n\nป พื้นที่ที่สามารถเข้าได้ผ่าน Herosria Gardening Cat\nGuild Dungeon(Spring): PVP Dungeon\nHerosria Training Grounds\n\nป <TIPBOX>กิลด์: วอร์ (Siege)<INFO>116</INFO></TIPBOX>\nป <TIPBOX>Siege(WOE)<INFO>117</INFO></TIPBOX>\nป <TIPBOX>Siege(SE)<INFO>118</INFO></TIPBOX>\nป <TIPBOX>Siege(TE)<INFO>119</INFO></TIPBOX>\nป <TIPBOX>ระบบกิลด์<INFO>30</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[121] = {
		Title = "Second Costume#3rd Clothing Stylist",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00121",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"หากคุณมี Base Level ถึง 170 ในอาชีพคลาส 3 คุณสามารถรับ Costume Change Ticket ได้\n(คุณสามารถตรวจสอบได้ในหัวข้อ \"\"General - Character - New Attitude\"\" ในหน้าต่าง Achievement และความสำเร็จนี้ใช้ได้กับกลุ่มอาชีพ 3-1 และ 3-2 เท่านั้น)\nคุณสามารถเปลี่ยนเป็นคอสตูมชุดที่สองได้โดยการนำคูปองไปมอบให้กับพนักงาน Styling Shop\n\n[Stylist]\nป <NAVI>[Prontera]<INFO>prt_in,243,168,0,100,0,0</INFO></NAVI>\nป <NAVI>[Alberta]<INFO>alberta_in,58,142,0,100,0,0</INFO></NAVI>\nป <NAVI>[Lighthalzen]<INFO>lhz_in02,100,143,0,100,0,0</INFO></NAVI>\nป <NAVI>[Rachel]<INFO>ra_in01,186,148,0,100,0,0</INFO></NAVI>\nป <NAVI>[Lasagna]<INFO>lasagna,134,113,0,100,0,0</INFO></NAVI>\n\nป <TIPBOX>Achievement<INFO>122</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[122] = {
		Title = "Achievement (ความสำเร็จ)#Achievements",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00122",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ของรางวัลจะมอบให้ตามภารกิจเฉพาะเจาะจงที่สำเร็จในระหว่างการผจญภัยและการต่อสู้ต่างๆ\nตรวจสอบของรางวัลหลากหลายตามความคืบหน้าในการผจญภัยของคุณ เช่น การเลเวลอัพ, การสำรวจ และการทำเควส\n(ของรางวัลทั้งหมดจะถูกส่งผ่านทาง RODEX)\n\nป คลิกไอคอน \"\"Achievement\"\" ในเมนูของหน้าต่างตัวละคร\n\nป <TIPBOX>Second Costume<INFO>121</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[123] = {
		Title = "การแต่งงาน#การแต่งงาน, ขอแต่งงาน, Tuxedo, Wedding, Bouquet, Veil, Cathedral, Doram, Lasagna, คำปฏิญาณ",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00123",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ค ข้อจำกัดการแต่งงาน\nป ผู้ที่แต่งงานแล้ว\nป เบบี้ (Baby)\nป Base Level ต่ำกว่า 45\nป เบบี้ที่แยกตัวออกไปเป็นบางส่วน\n\nค การเตรียมงานแต่งงาน\nผู้ชาย:\nป 1x ^i[6026] <ITEM>Written Oath of Marriage<INFO>6026</INFO></ITEM>,\nป 1x ^i[7170] <ITEM>Tuxedo<INFO>7170</INFO></ITEM>, 1x ^i[2613] <ITEM>Diamond Ring<INFO>2613</INFO></ITEM>\nผู้หญิง:\nป 1x ^i[6026] <ITEM>Written Oath of Marriage<INFO>6026</INFO></ITEM>,\nป 1x ^i[2338] <ITEM>Wedding Dress<INFO>2338</INFO></ITEM>, 1x ^i[2613] <ITEM>Diamond Ring<INFO>2613</INFO></ITEM>\nป สถานที่เลือกซื้อ\nป <NAVI>[Cognitive and Semi-Engraving]<INFO>prt_in,282,167,0,101,0</INFO></NAVI>\nป <NAVI>[Marriage Goods Merchant]<INFO>prt_in,282,169,0,101,0</INFO></NAVI>\n\nค สถานที่ที่สามารถแต่งงานได้\nป <NAVI>[มหาวิหาร Prontera Cathedral]<INFO>prt_church,97,100,0,101,0</INFO></NAVI>\nป สามารถแต่งงานระหว่าง มนุษย์+มนุษย์\nป <NAVI>[Lasagna Wedding Hall]<INFO>lasagna,335,248,0,101,0</INFO></NAVI>\nป สามารถแต่งงานระหว่าง Doram+Doram/ Doram+มนุษย์/ มนุษย์+มนุษย์\n\nค อื่นๆ\nป ชุด Tuxedo และ Wedding Dress จะสวมใส่เป็นเวลา 1 ชั่วโมงหลังแต่งงาน (ไม่สามารถต่อสู้ได้)\nป ชื่อของคู่สมรสสามารถสลักลงบนแหวนแต่งงานได้\nป สถานที่สลักชื่อ: <NAVI>[Cognitive and Semi-Engraving]<INFO>prt_in,282,167,0,101,0</INFO></NAVI>\n\nค สกิลจากแหวนแต่งงาน\nป I'll save you: ฟื้นฟู HP ของคู่สมรส\nป I'll sacrifice myself for you: ฟื้นฟู SP ของคู่สมรส\nป I miss you: อัญเชิญคู่สมรสมาที่ข้างกาย\n\nป <TIPBOX>การรับบุตรบุญธรรม (Adoption)<INFO>125</INFO></TIPBOX>\nป <TIPBOX>การหย่าร้าง<INFO>124</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[124] = {
		Title = "การหย่าร้าง#การแต่งงาน, ขอแต่งงาน, สำนักงานเขต",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00124",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถยกเลิกคำสัญญาแห่งรักนิรันดร์ได้ที่สำนักงานเขต Prontera หรือเมือง Niflheim\nค เงื่อนไข\nป 2,500,000 Zeny\n\nค ผู้ที่สามารถหย่าได้\nป ผู้ที่แต่งงานแล้ว\n\nค สถานที่ที่สามารถทำการหย่าได้\nป <NAVI>[Niflheim]<INFO>nif_in,190,112,0,101,0</INFO></NAVI>: สามารถหย่าได้ทันที\nป <NAVI>[Prontera Town Office]<INFO>prt_in,282,165,0,101,0</INFO></NAVI>: สามารถหย่าได้หลังจากผ่านช่วงพิจารณา 4 วัน\n\nป <TIPBOX>การรับบุตรบุญธรรม (Adoption)<INFO>125</INFO></TIPBOX>\nป <TIPBOX>การแต่งงาน<INFO>123</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[125] = {
		Title = "การรับบุตรบุญธรรม#การแต่งงาน, การรับเลี้ยง, ครอบครัว, พ่อ, แม่, พ่อแม่, ลูก, คู่รัก, เด็ก, เบบี้, ความรัก",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00125",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คู่รักที่แต่งงานแล้วสามารถรับเลี้ยงตัวละครที่ยังไม่ได้ผ่านการเปลี่ยนอาชีพขั้นที่ 2 เป็นบุตรบุญธรรมได้\n\nค เงื่อนไข ขั้นตอน และวิธีการรับบุตรบุญธรรม\nป เงื่อนไข: \nตัวละครพ่อแม่ (ชายและหญิง): Base Level 70 ขึ้นไป\nตัวละครลูก (ที่จะถูกรับเลี้ยง): ทุกอาชีพยกเว้นอาชีพ Rebirth (Base Level 50 หรือต่ำกว่า)\n\nป ขั้นตอน: \n1. คู่รักต้องสวมแหวนแต่งงาน\n2. คู่สมรสและตัวละครที่จะเป็นลูกต้องอยู่ในปาร์ตี้เดียวกัน\n3. สมัครรับเลี้ยงบุตรโดยการเปิดเมนูคลิกขวาที่ตัวละครที่จะมาเป็นลูกของคุณ\n\nค สกิลเพิ่มเติมหลังการรับเลี้ยง\nป สกิลสำหรับลูก\nป Mom, Dad, I love you!: ค่าประสบการณ์จะไม่ลดลงแม้ว่าจะตาย เป็นเวลา 2 นาที\nป Mom, Dad, I miss you!: อัญเชิญพ่อแม่มาหา\nป Mom Dad cheer up: เพิ่มสเตตัสทั้งหมดของพ่อแม่\n\nป สกิลสำหรับพ่อแม่\nป Come to me, honey~: อัญเชิญลูกมาหา\nป Death can not separate us: ชุบชีวิตสมาชิกในครอบครัวที่ไม่สามารถต่อสู้ได้\n\nป สกิลครอบครัว\nป We are with You: เรียกสมาชิกครอบครัวที่อยู่ในแผนที่เดียวกันมาหา\n\nค ข้อควรระวังเมื่อรับบุตรบุญธรรม\nป ลูกบุญธรรมจะมีขนาดตัวเล็กลง\nป ลูกบุญธรรมจะไม่สามารถจุติ (Rebirth) หรือแต่งงานได้\nป สามารถอัพสเตตัสได้สูงสุดเพียง 80 แต้มต่อค่าสถานะ\nป MaxHP, MaxSP และอัตราสำเร็จของสกิลสายผลิตจะลดลงเหลือ 70%\nป ชุดของ Baby Crusader และ Baby Dancer อาจมีความแตกต่างกัน\nป มีการตัดสินประเภทเป็นเผ่ากึ่งมนุษย์ (Humanoid) ขนาดเล็ก\nป คู่รักหนึ่งคู่สามารถรับเลี้ยงลูกได้เพียงคนเดียวเท่านั้น\n\nป <TIPBOX>ความเป็นอิสระ (Independence)<INFO>130</INFO></TIPBOX>\nป <TIPBOX>การแต่งงาน<INFO>123</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[126] = {
		Title = "Mercenary#ใบเรียกทหารรับจ้าง, การจ้างทหารรับจ้าง",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00126",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถจ้างทหารรับจ้างเพื่อร่วมเดินทางไปกับคุณในการผจญภัยได้โดยจ่ายราคาตามที่กำหนด\nทหารรับจ้างสามารถจ้างได้เป็นเวลา 30 นาทีหลังจากใช้ใบเรียก และโพชั่นรวมถึงไอเทมสิ้นเปลืองต่างๆ จะต้องใช้สำหรับทหารรับจ้างโดยเฉพาะเท่านั้น\n\nค ประเภทของทหารรับจ้าง\nทหารรับจ้างประเภทหอก (Spear), ทหารรับจ้างประเภทดาบ (Sword) และ ทหารรับจ้างประเภทธนู (Bow)\n\nค จำนวนเงินและเงื่อนไขการจ้างสำหรับทหารรับจ้างแต่ละระดับ\nLevel 1: Base Level 15 ขึ้นไป, ค่าจ้าง 10000z\nLevel 2: Base Level 25 ขึ้นไป, ค่าจ้าง 20000z\nLevel 3: Level 35 ขึ้นไป, ค่าจ้าง 30000z\nLevel 4: Base Level 45 ขึ้นไป, ค่าจ้าง 40000z\nLevel 5: Base Level 55 ขึ้นไป, ค่าจ้าง 50000z\nLevel 6: Base Level 65 ขึ้นไป, ค่าจ้าง 60000z\nLevel 7: Base Level 75 ขึ้นไป, ค่าความซื่อสัตย์ (Loyalty) 50 ขึ้นไป, ค่าจ้าง 70000z\nLevel 8: Base Level 85 ขึ้นไป, ค่าความซื่อสัตย์ (Loyalty) 100 ขึ้นไป, ค่าจ้าง 80000z\nLevel 9: Base Level 90 ขึ้นไป, ค่าความซื่อสัตย์ (Loyalty) 300 ขึ้นไป, ค่าจ้าง 90000z\nLevel 10: Base Level 90 ขึ้นไป, ค่าความซื่อสัตย์ (Loyalty) 500 ขึ้นไป, ค่าความซื่อสัตย์จะลดลง 400 เมื่อทำการจ้าง\n\nค ทหารรับจ้างประเภทหอก (Spear Mercenary)\nProntera <NAVI>[Mercenary Guild Official]<INFO>prontera,41,337,0,101,0</INFO></NAVI>\n\nค ทหารรับจ้างประเภทดาบ (Sword Mercenary)\nIzlude <NAVI>[Mercenary Guild Official]<INFO>izlude,47,170,0,101,0</INFO></NAVI>\n\nค ทหารรับจ้างประเภทธนู (Bow)\nPayon Archer Village <NAVI>[Mercenary Guild Official]<INFO>pay_arche,99,167,0,101,0</INFO></NAVI>\n\nค ผู้จำหน่ายไอเทมเฉพาะสำหรับทหารรับจ้าง\nป Prontera<NAVI>[Mercenary Goods Vendor]<INFO>prontera,30,337,0,101,0</INFO></NAVI>\nป Izlude <NAVI>[Mercenary Goods Vendor]<INFO>izlude,55,170,0,101,0</INFO></NAVI>\nป Payon Archer Village <NAVI>[Mercenary Goods Vendor]<INFO>pay_arche,102,167,0,101,0</INFO></NAVI>\n\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[127] = {
		Title = "Clan#กิลด์",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00127",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"กิลด์ประเภทหนึ่งที่ดำเนินการโดยอาณาจักรเพื่อสนับสนุนเหล่านักผจญภัยมือใหม่ที่เพิ่งเริ่มต้นออกเดินทาง\nแม้ว่าคุณจะไม่สามารถเข้าร่วมในการเลือกตั้งสาธารณะในฐานะกิลด์ที่เป็นกลางได้ แต่คุณสามารถรับบัฟสถานะและเควสพิเศษตามลักษณะเฉพาะของแต่ละแคลนได้\nเฉพาะนักผจญภัยที่ไม่มีกิลด์เท่านั้นที่สามารถเข้าร่วมได้ ไม่รวมถึงผู้ที่เป็นสมาชิกของกิลด์ที่จัดตั้งขึ้นโดยบุคคลทั่วไป\nหากคุณไม่เข้าสู่ระบบนานกว่าหนึ่งสัปดาห์ คุณจะถูกขับออกจากแคลนโดยอัตโนมัติ\n\nในการเข้าร่วมแคลน คุณต้องไม่สังกัดกิลด์ใดๆ และยื่นคำขอเข้าเป็นสมาชิกต่อหัวหน้าแคลนของแต่ละแคลน\n\nป ^663399Sword Clan^000000\nหัวหน้าแคลน <NAVI>[Lafam Oranpier]<INFO>prt_in,33,114,0,101,0</INFO></NAVI>\nเราสนับสนุนนักผจญภัยที่เน้นการต่อสู้ในระยะประชิด\nป บัฟพิเศษของ Sword Clan\nSTR+1, VIT+1, MaxHP+30, MaxSP+10\nป สถานที่รวมตัวของ Sword Clan\nProntera <NAVI>[Sword Clan]<INFO>prontera,32,325,0,101,0</INFO></NAVI>\n\nป ^663399Archwand Clan^000000\nหัวหน้าแคลน <NAVI>[Devon Air]<INFO>prt_in,35,114,0,101,0</INFO></NAVI>\nเราสนับสนุนนักผจญภัยที่ใช้เวทมนตร์โจมตีเป็นทักษะหลัก\nป บัฟพิเศษของ Archwand Clan\nINT+1, DEX+1, MaxHP+30, MaxSP+10\nป สถานที่รวมตัวของ Archwand Clan\nProntera <NAVI>[Arcwand Clan]<INFO>prontera,47,112,0,101,0</INFO></NAVI>\n\nป ^663399Golden Mace Clan^000000\nหัวหน้าแคลน <NAVI>[Berman Air]<INFO>prt_in,37,114,0,101,0</INFO></NAVI>\nเราสนับสนุนนักผจญภัยที่เน้นความสามารถสายสนับสนุน\nป บัฟพิเศษของ Golden Mace Clan\nINT+1, LUK+1, MaxHP+30, MaxSP+10\nป สถานที่รวมตัวของ Golden Mace Clan\nProntera <NAVI>[Golden Mace Clan]<INFO>prontera,226,355,0,101,0</INFO></NAVI>\n\nป ^663399Crossbow Clan^000000\nหัวหน้าแคลน <NAVI>[Sham Rumi]<INFO>prt_in,39,114,0,101,0</INFO></NAVI>\nเราสนับสนุนนักผจญภัยที่เน้นการต่อสู้ระยะไกลเป็นหลัก\nป บัฟพิเศษของ Crossbow Clan\nDEX+1, AGI+1, MaxHP+30, MaxSP+10\nป สถานที่รวมตัวของ Crossbow Clan\nProntera <NAVI>[Crossbow Clan]<INFO>prontera,204,259,0,101,0</INFO></NAVI>\n\nป <TIPBOX>ระบบกิลด์<INFO>30</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[128] = {
		Title = "Item Link",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00128",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ค วิธีใช้งาน Item Link\nป กด Shift + คลิกเมาส์ซ้ายที่ไอเทมในขณะที่ช่องแชทกำลังใช้งานอยู่\nป ชื่อไอเทมซึ่งรวมถึงข้อมูลไอเทมจะแสดงขึ้นเมื่อคุณกด Enter เหมือนกับการสนทนาปกติ\nป ข้อมูลสามารถส่งผ่านประกาศ (Announce) ได้เช่นกัน\n\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[129] = {
		Title = "การมีส่วนร่วมในเมืองใหญ่#การสนับสนุนนักผจญภัย, สมาคมพ่อค้า, ผู้จัดการการลงทุน",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00129",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ค การมีส่วนร่วมในพื้นที่เมืองใหญ่คืออะไร?\nเป็นมาตรการสนับสนุนเล็กน้อยสำหรับนักผจญภัยที่ไม่มีเงินทุนหรือผู้เล่นที่กำลังฝึกฝนตัวละครรอง\nเควสความสำเร็จ (Achievement Quest) -> อุปกรณ์ที่เหมาะสมโดยอิงตามไอเทมสมทบในพื้นที่เมืองใหญ่ในหมวดไอเทมทั่วไป\nนี่คือระบบที่คุณสามารถได้รับโอกาสในการซื้อสินค้า\nป <URL>เรียนรู้เพิ่มเติมบนเว็บไซต์<INFO>https://ro.gnjoy.com/news/update/View.asp?seq=177</INFO></URL>\n\nค จุดเริ่มต้น\nป <NAVI>[City Merchant Union Manager]<INFO>moc_para01,53,38,0,101,0</INFO></NAVI>\nคุณสามารถใช้งานได้หลังจากเข้าร่วม City Merchants Association\n\nค วิธีเพิ่มระดับการมีส่วนร่วม\nคุณสามารถเพิ่มการมีส่วนร่วมได้โดยการลงทุน Alliance Token วันละครั้งที่ผู้จัดการการลงทุน (Investment Manager) ในแต่ละเมืองใหญ่ด้านล่างนี้\nป <NAVI>[Prontera Investment Manager]<INFO>prontera,142,67,0,101,0</INFO></NAVI>\nป <NAVI>[Geffen Investment Manager]<INFO>geffen,103,69,0,101,0</INFO></NAVI>\nป <NAVI>[Morroc Investment Manager]<INFO>morocc,184,93,0,101,0</INFO></NAVI>\nป <NAVI>[Payon Investment Manager]<INFO>payon,156,60,0,101,0</INFO></NAVI>\nป <NAVI>[Yuno Investment Manager]<INFO>yuno,151,126,0,101,0</INFO></NAVI>\nป <NAVI>[Lighthalzen Investment Manager]<INFO>lighthalzen,220,109,0,101,0</INFO></NAVI>\nป <NAVI>[Einbroch Investment Manager]<INFO>einbroch,242,177,0,101,0</INFO></NAVI>\nป <NAVI>[Rachel Investment Manager]<INFO>rachel,267,130,0,101,0</INFO></NAVI>\nป <NAVI>[Veins Investment Manager]<INFO>veins,194,115,0,101,0</INFO></NAVI>\n\nข้อมูลเกี่ยวกับวิธีรับ Alliance Token และสถานที่ซื้อไอเทมอยู่ในหน้าที่สอง\n\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>",
			"ค วิธีรับ Alliance Token\nในขณะที่ทำงานเป็นสมาชิกของพันธมิตร จะมีโอกาสต่ำที่จะได้รับ Alliance Token เมื่อล่ามอนสเตอร์\nอย่างไรก็ตาม หากคุณต้องการได้รับ Union Token อย่างแน่นอนและรวดเร็วกว่าเดิม ให้ทำคำร้องบนกระดานประกาศของ City Merchants Association ให้เสร็จสิ้น\nป คุณสามารถรับ Alliance Token เพิ่มเติมได้โดยการรายงานต่อ Secretary Gavunus\nป <NAVI>[Urban Merchants Association Bulletin Board]<INFO>moc_para01,53,35,0,101,0</INFO></NAVI>\nป <NAVI>[Secretary Gavunus]<INFO>moc_para01,53,32,0,101,0</INFO></NAVI>\n\n\nค สถานที่ซื้อไอเทม\nอุปกรณ์ที่เหมาะสมกับระดับการมีส่วนร่วมจะถูกเปิดเผยผ่าน NPC สมาคมพ่อค้า (Merchant Union) ในแต่ละเมืองใหญ่ด้านล่างนี้\nลองกลับมาดูอีกครั้งเมื่อเราคิดว่าได้ทำแต้มสมทบเพียงพอแล้ว\nป <NAVI>[Prontera Merchant Association]<INFO>prontera,146,67,0,101,0</INFO></NAVI>\nป <NAVI>[Geffen Merchant Association]<INFO>geffen,99,70,0,101,0</INFO></NAVI>\nป <NAVI>[Morroc Merchant Association]<INFO>morocc,181,97,0,101,0</INFO></NAVI>\nป <NAVI>[Payon Merchant Association]<INFO>payon,152,61,0,101,0</INFO></NAVI>\nป <NAVI>[Yuno Merchant Association]<INFO>yuno,153,130,0,101,0</INFO></NAVI>\nป <NAVI>[Lighthalzen Merchant Association]<INFO>lighthalzen,220,113,0,101,0</INFO></NAVI>\nป <NAVI>[Einbroch Merchant Association]<INFO>einbroch,244,180,0,101,0</INFO></NAVI>\nป <NAVI>[Rachel Merchant Association]<INFO>rachel,263,131,0,101,0</INFO></NAVI>\nป <NAVI>[Veins Merchant Association]<INFO>veins,190,120,0,101,0</INFO></NAVI>"
		}
	},
	[130] = {
		Title = "ความเป็นอิสระ#ใบรับรอง, ครอบครัว, ความสัมพันธ์, เบบี้, สำนักงานเขต",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00130",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"หากตัวละครเบบี้ (Baby) กลายเป็นอิสระจากพ่อและแม่แล้วแยกตัวออกไป เขาหรือเธอจะได้รับการยกเว้นจากบทลงโทษทั้งหมด\nค เงื่อนไขความเป็นอิสระ\nป หากตัวเบบี้ต้องการเป็นอิสระ:\nป Base Level 99 ขึ้นไป\nป สามารถเป็นอิสระได้ฟรีทันทีหลังจากผ่านไปมากกว่า 100 วันนับตั้งแต่การเป็นเบบี้\nป หากยังไม่ครบ 100 วัน จะต้องใช้ 1 Independence Certificate และเงิน 2 ล้าน Zeny\nป หากพ่อและแม่ต้องการให้เบบี้เป็นอิสระ\nป 1 Independence Certificate\nป 50 ล้าน Zeny\nป ผ่านไปมากกว่า 100 วันนับตั้งแต่เบบี้ถูกรับเลี้ยง (สำหรับตัวละครเบบี้ที่ถูกลบไปแล้ว ความเป็นอิสระสามารถทำได้แม้จะไม่ครบ 100 วัน)\nป สถานที่ซื้อ <ITEM>[Independent Certificate]<INFO>25240</INFO></ITEM>\nป <NAVI>[Cognitive and Semi-Engraving]<INFO>prt_in,282,167,0,101,0</INFO></NAVI>\n\nค ประเภทความเป็นอิสระ\nป ความเป็นอิสระสมบูรณ์: สามารถทำได้เมื่อตัวละครพ่อและแม่ทั้งคู่ถูกลบไปแล้ว (สามารถแต่งงานได้หลังจากเป็นอิสระ)\nป ความเป็นอิสระบางส่วน: สามารถทำได้หากยังคงเหลือตัวละครพ่อหรือแม่มากกว่าหนึ่งตัว (ไม่สามารถแต่งงานได้หลังจากเป็นอิสระ)\n\nค สถานที่สำหรับดำเนินการเป็นอิสระ\nป Lasagna: <NAVI>[Independent Helper]<INFO>lasagna,100,200,0,101,0</INFO></NAVI>\nป Prontera's Town Office: <NAVI>[Family Relations Guide]<INFO>prt_in,282,171,0,101,0</INFO></NAVI>\n\nป <TIPBOX>การแต่งงาน<INFO>123</INFO></TIPBOX>\nป <TIPBOX>การรับบุตรบุญธรรม<INFO>125</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[131] = {
		Title = "งานพาร์ทไทม์ตั้งแผงลอย#",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00131",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"เฉพาะอาชีพ Merchant เท่านั้นที่สามารถเปิดแผงลอยริมถนนได้ แต่ถ้าคุณจ้างพนักงานพาร์ทไทม์ตั้งแผงลอย ตัวละครผู้เล่นทุกอาชีพจะสามารถเปิดแผงลอยที่มีฟังก์ชันจำกัดได้\nแผงลอยของพนักงานพาร์ทไทม์จะเปิดตามชั่วโมงที่ระบุไว้ในใบรับรองการจ้างงาน\n\nสามารถรับได้ผ่านใบรับรองการจ้างงานพนักงานพาร์ทไทม์ตั้งแผงลอย\nคุณสามารถรับซองใบรับรองการจ้างงานได้ที่ Base Level 40 ขึ้นไปโดยการทำเควสหรือซื้อ\nAlberta Merchants Association\nป โปรดติดต่อ <NAVI>[Employment Division Masha]<INFO>alberta_in,20,19,0,101,0</INFO></NAVI>\nหากคุณใช้ซองจดหมาย คุณจะได้รับบัตรประจำตัวการจ้างงานที่สามารถใช้งานได้เป็นเวลา 1 วันนับจากเวลานั้น\nป ซองใบรับรองการจ้างงานขายสินค้า (Sales)\nป ^i[23342] <ITEM>[Part Time Sales(Novice) 1day Employment Envelope]<INFO>23342</INFO></ITEM> ^i[23343] <ITEM>[Part Time Sales(Normal) 1day Employment Envelope]<INFO>23343</INFO></ITEM> ^i[23344] <ITEM>[Part Time Sales(Expert) 1day Employment Envelope]<INFO>23344</INFO></ITEM>\nป ซองใบรับรองการจ้างงานรับซื้อสินค้า (Purchase)\nป ^i[23345] ^i[23346] <ITEM>[Part-time Student Buyer(Normal) 1day Employment Envelope]<INFO>23346</INFO></ITEM> ^i[23347] <ITEM>[Part-time Student Buyer(Expert) 1day Employment Envelope]<INFO>23347</INFO></ITEM>\n\nค ประเภทของใบรับรองการจ้างงาน\nบัตรการจ้างงานแบ่งออกเป็นบัตรการจ้างงานสำหรับการขายและบัตรการจ้างงานสำหรับการรับซื้อ แต่ละประเภทแบ่งออกเป็นสามระดับขึ้นอยู่กับจำนวนไอเทมที่สามารถลงทะเบียนที่แผงลอยได้ในเวลาเดียวกัน และโดยพื้นฐานแล้วจะคงอยู่เป็นเวลาหนึ่งวัน\nจำนวนเงินที่ต้องใช้และระดับความยากของเควสจะแตกต่างกันไปตามแต่ละระดับ ดังนั้นโปรดปรึกษากับ Masha แห่งแผนกการจ้างงานอย่างรอบคอบก่อนตัดสินใจ เควสสามารถทำได้หนึ่งครั้งทุกๆ 7 วัน\nป ใบรับรองการจ้างงานขายสินค้า (Sales)\nป ^i[23348] <ITEM>[Part-time Student Sales(Novice) Employment Certificate]<INFO>23348</INFO></ITEM> ^i[23349] <ITEM>[Part-time Student Sales(Normal) Employment Certificate]<INFO>23349</INFO></ITEM> ^i[23350] <ITEM>[Part-time Student Sales(Expert) Employment Certificate]<INFO>23350</INFO></ITEM>\nป ใบรับรองการจ้างงานรับซื้อสินค้า (Purchase)\nป ^i[23351] <ITEM>[Part-time Student Buyer(Novice) Employment Certificate]<INFO>23351</INFO></ITEM> ^i[23352] <ITEM>[Part-time Student Buyer(Normal) Employment Certificate]<INFO>23352</INFO></ITEM> ^i[23353] <ITEM>[Part-time Student Buyer(Expert) Employment Certificate]<INFO>23353</INFO></ITEM>\n\nค การรวมซองใบรับรองการจ้างงาน\nหากคุณรวบรวมซองใบรับรองการจ้างงานประเภทเดียวกันครบ 3 ซอง คุณสามารถแลกเป็นซองใบรับรองการจ้างงานที่สามารถใช้งานต่อเนื่องได้เป็นเวลา 3 วัน\nAlberta Merchants Association\nป ติดต่อ <NAVI>[Employment Division Reedwan]<INFO>alberta_in,20,21,0,101,0</INFO></NAVI>\n\nป <TIPBOX>แผงลอย<INFO>67</INFO></TIPBOX>\nป <TIPBOX>การค้นหาแผงลอย<INFO>72</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>\n"
		}
	},
	[132] = {
		Title = "การสลับอุปกรณ์#ชุดอุปกรณ์, สลับ, เปลี่ยน",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00132",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"วิธีใช้งานระบบสลับอุปกรณ์ (Equipment Change)\nป สามารถเรียกใช้งานได้โดยกดปุ่ม \'Equipment Set Settings\' ที่ด้านล่างของหน้าต่างไอเทมที่สวมใส่\nป ไอเทมอุปกรณ์ในกระเป๋าเก็บของสามารถตั้งค่าได้โดยการลากและวาง\nป ไอเทมอุปกรณ์ที่ตั้งค่าไว้ในชุดอุปกรณ์จะไม่สามารถทิ้งลงบนพื้นได้\n\nค วิธีการใช้งานระบบสลับอุปกรณ์\nป ไอเทมอุปกรณ์ที่ตั้งค่าไว้จะถูกสวมใส่ด้วยปุ่ม \'CHANGE\'\nป \'อุปกรณ์ปกติ\' ที่คุณสวมใส่อยู่ในปัจจุบันจะถูกถอดออกและสลับเป็นอุปกรณ์สำรองที่ตั้งค่าไว้\n\nป <TIPBOX>ถอดอุปกรณ์<INFO>52</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[133] = {
		Title = "Rune Tablet",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00133",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Rune Tablet หนึ่งในงานวิจัยจำนวนมากของปราชญ์ผู้ยิ่งใหญ่ Varmeal เป็นป้ายหินที่ดึงพลังรูนของทุกชีวิตและสสารในโลกนี้มาเปลี่ยนเป็นพลังเฉพาะที่นักผจญภัยสามารถนำไปใช้ได้\nพลังรูนมีประเภทของเอฟเฟกต์ที่แตกต่างกันไปตามแต่ละพื้นที่ผจญภัย ดังนั้นคุณจึงสามารถรวบรวมชุดรูนต่างๆ และเปลี่ยนเอฟเฟกต์ของชุดให้เหมาะสมกับความต้องการของคุณได้\n\nป Rune Set (ชุดรูน)\nชุดรูนคือหน่วยที่ประกอบด้วยชิ้นส่วนรูน (Rune pieces) ระหว่าง 2 ถึง 6 ชิ้น\nส่วนประกอบและเอฟเฟกต์ของชุดรูนจะแตกต่างกันไปตามภูมิภาคของการผจญภัย\nชุดรูนต้องได้รับการเปิดใช้งานก่อนจึงจะสามารถสวมใส่ได้\nเอฟเฟกต์ของชุดรูนจะแตกต่างกันไปตามการจัดองค์ประกอบของชิ้นส่วนรูน\nเอฟเฟกต์ของชุดรูนยังได้รับผลจากการเสริมพลัง (Reinforcement) อีกด้วย\n\nป Rune Fragment (เศษรูน)\nเศษรูนคือวัตถุดิบสะสมที่สร้างขึ้นโดยการสกัดพลังรูนของไอเทม\nคุณต้องทำให้เศษรูนสมบูรณ์เพื่อดึงเอฟเฟกต์ที่แท้จริงของชุดรูนออกมา\nไอเทมอุปกรณ์ต้องได้รับการปรับแต่ง (Reformed) และสลัก (Engraved) เพื่อที่จะนำมาสกัดได้\nสำหรับอุปกรณ์ที่ถูกสลักแล้ว ระดับการตีบวกทั้งหมด, ออฟชั่นสุ่ม, การเสริมพลัง (Enchant) และการ์ดที่ติดตั้งอยู่จะหายไปทั้งหมด\n\nป การเสริมพลัง Rune Set\nชุดรูนที่เปิดใช้งานแล้วสามารถเสริมความแข็งแกร่งได้ด้วยไอเทมเฉพาะ\nคุณสามารถเพิ่มประสิทธิภาพของชุดรูนได้มากขึ้นผ่านการเสริมพลัง\n\nป การแยกชิ้นส่วน (Disassembly)\nพลังรูนของการ์ดสามารถเปลี่ยนเป็นรูปแบบที่ต้องการสำหรับ Rune Tablet ได้โดยการแยกชิ้นส่วน\nการ์ดบอสจะเปลี่ยนเป็นรูปแบบที่พิเศษยิ่งขึ้น\n\n[ตำแหน่งของ Rune Tablet]\nป <NAVI>[Prontera]<INFO>prontera,161,192,0,101,0,0</INFO></NAVI>\nป <NAVI>[Yuno]<INFO>yuno,142,177,0,101,0,0</INFO></NAVI>\nป <NAVI>[Rachel]<INFO>rachel,131,144,0,101,0,0</INFO></NAVI>\nป <NAVI>[Ice Castle]<INFO>icecastle,71,230,0,101,0,0</INFO></NAVI>\nป <NAVI>[Varmundt Mansion]<INFO>ba_maison,137,111,0,101,0,0</INFO></NAVI>\n\nป <TIPBOX>การเล่นเกม<INFO>1002</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	}, 
	[134] = {
		Title = "แชท: กิลด์พันธมิตร",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00134",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"การสนทนากับสมาชิกของกิลด์พันธมิตรสามารถทำได้โดยใช้เครื่องหมาย # หรือ CapsLock+ENTER\nนอกจากนี้ หากคุณกด ^3b488cวงกลมสีน้ำเงิน^000000 ทางด้านขวาของหน้าต่างแชท คุณสามารถตั้งค่า ^3b488cกลุ่มผู้รับ^000000 ได้\nคุณสามารถสร้างพันธมิตรได้สูงสุด 3 กิลด์\nป <TIPBOX>แชท: กิลด์<INFO>23</INFO></TIPBOX>\nป <TIPBOX>ระบบกิลด์<INFO>30</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}	
