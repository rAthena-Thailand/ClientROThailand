	[68] = {
		Title = "กิลด์: รูปสัญลักษณ์ (Emblem)",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00068",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถตั้งค่ารูปสัญลักษณ์ที่เป็นเอกลักษณ์สำหรับแต่ละกิลด์ได้ในหน้าต่างข้อมูลกิลด์\nในการลงทะเบียนรูปสัญลักษณ์กิลด์ คุณต้องสร้าง ^ff0000โฟลเดอร์ชื่อ emblem^000000 ไว้ในโฟลเดอร์ที่ ^ff0000ติดตั้งเกม Ragnarok^000000 และใส่ ^ff0000ไฟล์รูปภาพนามสกุล .bmp หรือ .gif ขนาด กว้าง 24 x ยาว 24 พิกเซล^000000 หลังจากนั้นให้คลิกปุ่มแก้ไขทางด้านขวาของหน้าต่างข้อมูลกิลด์เพื่อเลือกรูปภาพที่จะลงทะเบียน\nหากต้องการให้ส่วนใดของรูปโปร่งใส ให้ระบายส่วนนั้นด้วยสีชมพู ^ff0000RGB 255, 0, 255^000000\nค่าสี 255, 0, 255 จะดูเป็นสีชมพูในโปรแกรมแก้ไข แต่จะถูกแสดงผลเป็นสีโปร่งใสภายในเกม\n\n^ff0000- ข้อควรระวัง: หากคุณใช้เลเยอร์โปร่งใส (Transparent layer) เพื่อทำความโปร่งใส รูปภาพอาจแสดงผลไม่ถูกต้อง โปรดตรวจสอบให้แน่ใจว่าได้ใช้ค่าสี 255, 0, 255 สำหรับความโปร่งใส^000000\n\nป <TIPBOX>ระบบกิลด์<INFO>30</INFO></TIPBOX>\n\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
