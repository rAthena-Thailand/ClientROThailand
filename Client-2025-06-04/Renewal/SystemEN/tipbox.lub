	},
	[9147] = {
		Title = "JQ Wind Hawk",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Wind Hawk อาชีพคลาส 4 ที่เปลี่ยนมาจาก Ranger เป็นพลแม่นปืนผู้ใช้พลังลมที่แข็งแกร่ง\nWind Hawk ติดอาวุธด้วยทักษะการยิงธนูด้วยพลังแห่งสายลม และยังมีความสามารถในการสื่อสารกับสัตว์ต่างๆ ดังนั้นคุณจึงสามารถใช้ Warg และ Falcon ร่วมกันได้\nนอกจากนี้ยังเป็นอาชีพที่ใช้งานได้ทุกสถานการณ์ซึ่งสามารถใช้กับกับดักที่สร้างสถานะผิดปกติได้หลากหลาย\nค ^663399Base Level 200 หรือสูงกว่า^000000\nค ^663399Job Level 70 หรือสูงกว่า^000000\nค ^663399อาชีพที่ต้องการ: Ranger^000000\nป <NAVI>[Payon]<INFO>payon,100,177,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>เควสเปลี่ยนอาชีพคลาส 4<INFO>9136</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9148] = {
		Title = "JQ Troubadour",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"Troubadour อาชีพคลาส 4 ที่เปลี่ยนมาจาก Minstrel ขับขานท่วงทำนองที่ไพเราะเพื่อสร้างขวัญและกำลังใจให้กับพันธมิตร\nมันต่อสู้ด้วยพลังแห่งเสียงเพลง และบางครั้งก็ช่วยเสริมพลังให้กับพันธมิตรหรือลดพลังของศัตรู\nเป็นสายอาชีพที่พลิกสถานการณ์การเป็นผู้นำในสนามรบผ่านบทเพลง\nค ^663399Base Level 200 หรือสูงกว่า^000000\nค ^663399Job Level 70 หรือสูงกว่า^000000\nค ^663399อาชีพที่ต้องการ: Minstrel^000000\nป <NAVI>[Part-time Flyer]<INFO>lighthalzen,186,124,0,101,0,</INFO></NAVI>\n\nป <TIPBOX>เควสเปลี่ยนอาชีพคลาส 4<INFO>9136</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ (Tip List)<INFO>1000</INFO></TIPBOX>"
		}
	},
	[9149] = {
