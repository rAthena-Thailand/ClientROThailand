	[164] = {
		Title = "การตั้งค่ากราฟิก: โหมดหน้าจอ#เต็มจอ, โหมดหน้าต่าง, ตั้งค่าเกม",
		Search = 1,
		Image = "ภฏภ๚ภฮลอุไภฬฝบ\\tipbox\\tip00164",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"คุณสามารถเลือกหน้าจอโหมดหน้าต่างหรือโหมดเต็มหน้าจอได้\nเมื่อบันทึกการตั้งค่า เกมจะจบการทำงานโดยอัตโนมัติและหน้าเข้าสู่ระบบจะเปิดขึ้นมาเพื่อเริ่มเกมใหม่\n\nเมื่อใช้โหมดหน้าต่าง คุณสามารถตั้งค่าขอบเขตการเคลื่อนที่ของเคอร์เซอร์เมาส์แยกต่างหากได้\nป <TIPBOX>การตั้งค่าการควบคุม: Mouse Lock<INFO>155</INFO></TIPBOX>\n\nป <TIPBOX>การตั้งค่ากราฟิก<INFO>158</INFO></TIPBOX>\nป <TIPBOX>หน้าต่างตัวเลือกเกม<INFO>32</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[165] = {
		Title = "การตั้งค่ากราฟิก: Trinarian Filtering#ตั้งค่าเกม, การสร้างแบบจำลอง, ระยะทาง",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00165",
