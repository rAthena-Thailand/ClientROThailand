	},
	[117] = {
		Title = "Siege(WOE)#PVP,Guild,Emperium,Valkyrie Realm,Britonia,Greenwood Lake,Luina",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00117",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ระบบสงครามระหว่างกิลด์เพื่อยึดครองปราสาท\nทำลายหิน Emperium ในพื้นที่วอร์ของอาณาจักร Rune-Midgards เพื่อเป็นเจ้าของปราสาท\n\nทุกวันพุธ: 21:00 (1 ชั่วโมง)\n\nป Siege of Prontera - Valkyrie Realm\nปราสาทใน Valkyrie Realm: Kriemhild, Swanhild, Fadhgridh, Skoegul, Gondul\nป Siege of Geffen - Britonia\nปราสาทใน Britonia: Repherion, Eeyolbriggar, Yesnelph, Bergel, Mersetzdeitz\nป Siege of Payon - Greenwood Lake\nปราสาทใน Greenwood Lake: Greenwood Lake, Scarlet Palace, Holy Shadow, Sacred Altar, Bamboo Grove Hill\nป Siege of Aldebaran - Luina\nปราสาทใน Luina: Neuschwanstein, Hohenschwangau, Nuenberg, Wuerzburg, Rothenburg\n\nกิลด์ที่ยึดครองปราสาทได้จะสามารถเคลื่อนย้ายไปยังดันเจี้ยนกิลด์หรือห้องคลังสมบัติผ่าน NPC บริการด้านในปราสาท\n\nป ดันเจี้ยนที่สามารถเข้าได้\nValkyrie Realm's Underground Dungeon ชั้น 1\nValkyrie Realm's Underground Dungeon ชั้น 2\nCorridor of the Abyss: Warrior's Way\n\nป <TIPBOX>กิลด์: วอร์ (Siege)<INFO>116</INFO></TIPBOX>\nป <TIPBOX>Siege(SE)<INFO>118</INFO></TIPBOX>\nป <TIPBOX>Siege(TE)<INFO>119</INFO></TIPBOX>\nป <TIPBOX>Siege(HE)<INFO>120</INFO></TIPBOX>\nป <TIPBOX>ระบบกิลด์<INFO>30</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[118] = {
		Title = "Siege(SE)#PVP,Guild,Emperium,Nidhoggur,Valfreyja",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00118",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ระบบสงครามระหว่างกิลด์เพื่อยึดครองปราสาท\nทำลายหิน Emperium ในพื้นที่วอร์ของอาณาจักร Schwartzvald และ Arunafeltz เพื่อเป็นเจ้าของปราสาท\n\nทุกวันเสาร์: 21:00 (1 ชั่วโมง)\n\nป Siege of Yuno - Nidhoggur\nปราสาทใน Nidhoggur: Himinn, Andlangr, Vidblainn, Hljod, Skidbladnir\nป Siege of Rachel - Valfreyja\nปราสาทใน Valfreyja: Mardol, Cyr, Horn, Gefn, Banadis\n\nกิลด์ที่ยึดครองปราสาทได้จะสามารถเคลื่อนย้ายไปยังดันเจี้ยนกิลด์หรือห้องคลังสมบัติผ่าน NPC บริการด้านในปราสาท\n\nป ดันเจี้ยนที่สามารถเข้าได้\nNidhoggur Underground Dungeon\nValfreyja Underground Dungeon\n\nป <TIPBOX>กิลด์: วอร์ (Siege)<INFO>116</INFO></TIPBOX>\nป <TIPBOX>Siege(WOE)<INFO>117</INFO></TIPBOX>\nป <TIPBOX>Siege(TE)<INFO>119</INFO></TIPBOX>\nป <TIPBOX>Siege(HE)<INFO>120</INFO></TIPBOX>\nป <TIPBOX>ระบบกิลด์<INFO>30</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
	},
	[119] = {
		Title = "Siege(TE)#PVP,Guild,Emperium,Gloria,Kafragarten",
		Search = 1,
		Image = "ภฏภ๚ภฮลอฦไภฬฝบ\\tipbox\\tip00119",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ระบบสงครามระหว่างกิลด์เพื่อยึดครองปราสาท\nซึ่งแตกต่างจาก Siege แบบ WOE และ SE ตรงที่เป็นพื้นที่สงครามที่มีการจำกัด Base Level อยู่ที่ 99 โดยอนุญาตให้เพียงคลาส 1 และ คลาส 2 รวมถึง Novice เท่านั้นที่เข้าได้\n\nทุกวันอาทิตย์: 10:00 (1 ชั่วโมง)\n\nป Siege of Prontera - Gloria\nปราสาทใน Gloria: Gaebolg, Richard, Wigner, Heine, Nerious\nป Siege of Aldebaran - Kafragarten\nปราสาทใน Kafragarten: Glaris, Defolty, Sorin, Bennit, W\n\nกิลด์ที่ยึดครองปราสาทได้จะสามารถเคลื่อนย้ายไปยังดันเจี้ยนกิลด์หรือห้องคลังสมบัติผ่าน NPC บริการด้านในปราสาท\n\nป ดันเจี้ยนที่สามารถเข้าได้\nGloria Underground Dungeon\nKafragarten Underground Dungeon\n\nป <TIPBOX>กิลด์: วอร์ (Siege)<INFO>116</INFO></TIPBOX>\nป <TIPBOX>Siege(WOE)<INFO>117</INFO></TIPBOX>\nป <TIPBOX>Siege(SE)<INFO>118</INFO></TIPBOX>\nป <TIPBOX>Siege(HE)<INFO>120</INFO></TIPBOX>\nป <TIPBOX>ระบบกิลด์<INFO>30</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำทั้งหมด<INFO>1000</INFO></TIPBOX>"
		}
