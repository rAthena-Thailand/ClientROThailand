	[7151] = {
		Title = "Lunar New Year Event#New Year's Festival",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ปีใหม่มาถึงแล้ว หากคุณกำลังวางแผนที่จะเริ่มต้นปีด้วยปณิธานและความมุ่งมั่นใหม่ๆ ทำไมไม่ลองมาเยี่ยมชม Payon และเริ่มต้นปีด้วยกิจกรรมต่างๆ ล่ะ?\nค ^663399ช่วงเวลากิจกรรม: มกราคม - กุมภาพันธ์^000000\nสำหรับรายละเอียดของกิจกรรมวันหยุด โปรดดูข้อมูลกิจกรรมที่หน้าเว็บไซต์อย่างเป็นทางการ\nค <URL>กิจกรรมที่กำลังดำเนินอยู่<INFO>https://ro.gnjoy.com/news/event/list.asp,1024,768</INFO></URL>\n\nป <TIPBOX>กิจกรรมวันหยุด<INFO>7150</INFO></TIPBOX>\nป <TIPBOX>เควส<INFO>4100</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[7152] = {
		Title = "Dimension Rift Event#Summer Holiday Festival",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ก้าวข้ามรอยแยกมิติไปพร้อมกับผู้เหนือชั้น Varmundt!\nเราขอเชิญคุณเข้าสู่ Midgard อีกแห่งหนึ่ง ไปที่ Prontera ตอนนี้เลย!\nค ^663399ช่วงเวลากิจกรรม: สิงหาคม^000000\nสำหรับรายละเอียดของกิจกรรมวันหยุด โปรดดูข้อมูลกิจกรรมที่หน้าเว็บไซต์อย่างเป็นทางการ\nค <URL>กิจกรรมที่กำลังดำเนินอยู่<INFO>https://ro.gnjoy.com/news/event/list.asp,1024,768</INFO></URL>\n\nป <TIPBOX>กิจกรรมวันหยุด<INFO>7150</INFO></TIPBOX>\nป <TIPBOX>เควส<INFO>4100</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[7153] = {
		Title = "Thanksgiving Event#Autumn Holiday Thanksgiving Festival",
		Search = 1,
		Image = "",
		Imgcoord = { Position = 5, Size = 100 },
		Page = {
			"ฤดูใบไม้ร่วงอันอุดมสมบูรณ์! มาร่วมสนุกกับความสุขของการแบ่งปันด้วยกันที่ Payon ที่ซึ่งมีการเตรียมกิจกรรมต่างๆ มากมายเพื่อเฉลิมฉลองวันขอบคุณพระเจ้า\nค ^663399ช่วงเวลากิจกรรม: กันยายน - ตุลาคม^000000\nสำหรับรายละเอียดของกิจกรรมวันหยุด โปรดดูข้อมูลกิจกรรมที่หน้าเว็บไซต์อย่างเป็นทางการ\nค <URL>กิจกรรมที่กำลังดำเนินอยู่<INFO>https://ro.gnjoy.com/news/event/list.asp,1024,768</INFO></URL>\n\nป <TIPBOX>กิจกรรมวันหยุด<INFO>7150</INFO></TIPBOX>\nป <TIPBOX>เควส<INFO>4100</INFO></TIPBOX>\nค <TIPBOX>ดูรายการคำแนะนำ<INFO>1000</INFO></TIPBOX>"
		}
	},
	[7154] = {
