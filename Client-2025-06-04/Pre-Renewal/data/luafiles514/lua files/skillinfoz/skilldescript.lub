	[SKID.SG_FEEL] = {
		"Feeling of the Sun, Moon and Stars",
		"เลเวลสูงสุด: 3",
		"รูปแบบทักษะ: ^3F0099Active^000000",
		"ประเภท: ^339900Designation^000000",
		"เป้าหมาย: ^6666CCCaster^000000",
