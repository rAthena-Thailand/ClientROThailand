	[SKID.NJ_ISSEN] = {
		"Killing Strike (ปลิดชีพในดาบเดียว)",
		"เลเวลสูงสุด: 10",
		"^CC3399เงื่อนไข: Throwing Mastery เลเวล 7,",
		"Shadow Slash เลเวล 5, Ninja Aura เลเวล 1^000000",
		"รูปแบบสกิล: ^3F0099Active^000000",
		"ประเภท: ^FF0000กายภาพระยะไกลพิเศษ^000000",
		"เป้าหมาย: ^6666CC1 เป้าหมาย^000000",
		"คำอธิบาย: ^777777สังเวย ^CC6600HP^777777 ที่เหลืออยู่ของผู้ร่ายเพื่อ",
		"สร้างความเสียหายมหาศาลแก่เป้าหมาย ปริมาณของ",
		"^CC6600HP^777777 ที่เหลืออยู่มีผลต่อความแรง และการใช้สกิล",
		"นี้แต่ละครั้งจะลด ^CC6600HP^777777 ของผู้ร่ายเหลือ 1 เสมอ",
		"คำอธิบายเก่าของสกิลนี้บางครั้งจะระบุว่าสร้างความเสียหาย",
		"ลดลงต่อ ^00A100ผู้เล่น^777777 และ ^00A100บอส^777777 แต่ข้อมูลนั้นไม่ถูกต้อง",
		"นั่นคือคุณสมบัติของสกิล ^0000FFThrow Zeny^777777 ไม่ใช่สกิลนี้^000000",
		"[Lv 1]: ^777777(STR*40) +(8% ของ HP ที่เหลืออยู่)^000000",
		"[Lv 2]: ^777777(STR*40) +(16% ของ HP ที่เหลืออยู่)^000000",
		"[Lv 3]: ^777777(STR*40) +(24% ของ HP ที่เหลืออยู่)^000000",
		"[Lv 4]: ^777777(STR*40) +(32% ของ HP ที่เหลืออยู่)^000000",
		"[Lv 5]: ^777777(STR*40) +(40% ของ HP ที่เหลืออยู่)^000000",
		"[Lv 6]: ^777777(STR*40) +(48% ของ HP ที่เหลืออยู่)^000000",
		"[Lv 7]: ^777777(STR*40) +(56% ของ HP ที่เหลืออยู่)^000000",
		"[Lv 8]: ^777777(STR*40) +(64% ของ HP ที่เหลือ อยู่)^000000",
		"[Lv 9]: ^777777(STR*40) +(72% ของ HP ที่เหลืออยู่)^000000",
		"[Lv 10]: ^777777(STR*40) +(80% ของ HP ที่เหลืออยู่)^000000",
		"เพิ่มเติม: ^777777ในเซิร์ฟเวอร์ฐาน Hercules สกิลนี้จะใช้",
		"10% ของ HP นินจาต่อเลเวล แทนที่จะเป็น 8%",
		"สกิลนี้คล้ายกับ Asura Strike แต่ใช้ HP แทน",
		"นี่คือจุดที่คล้ายคลึงกัน:",
		"- ความเสียหายถูกบังคับเป็นธาตุไร้ธาตุ (Neutral);",
		"- ได้รับผลจากไอเทมและเปอร์เซ็นต์การ์ด เช่น",
		"Hydra, Abysmal Knight และ The Sign;",
		"- ต้องการบัฟในการร่าย (Ninja Aura) และจะลบบัฟออกหลังใช้;",
		"",
		"อย่างไรก็ตาม มีความแตกต่างที่สำคัญบางประการ:",
		"- ดาเมจเป็นประเภทระยะไกล ถูกบล็อกโดย Pneuma ได้",
		"แต่ Safety Wall บล็อกไม่ได้;",
		"- ไม่สนค่า FLEE แต่ 'ไม่' มองข้ามพลังป้องกัน (DEF)",
		"ผลของการ์ด Thanatos และ Ice Pick จะทำงานร่วมกับสกิลนี้;",
		"- มองข้ามพลังโจมตี (ATK) ทั้งหมด และคำนวณความเสียหาย",
		"โดยดูจากค่า ^CC6600STR^777777 ของคุณเท่านั้น;",
		"- การลดความเสียหายระยะไกล เช่น Defender หรือ",
		"การ์ด Alligator จะช่วยลดดาเมจที่ได้รับลงได้;",
		"- ไม่มีระยะเวลาร่าย และไม่มีดีเลย์หลังใช้สกิล;",
		"- หากศัตรูเป็น Stalker และมีบัฟ Reject Sword และนินจา",
		"สวมใส่มีดใช้ Killing Strike ใส่พวกเขา นินจาจะตาย",
		"ทันทีจากความเสียหายสะท้อน;",
		"",
		"วิธีที่ดีที่สุดในการเพิ่มดาเมจสกิลนี้คือเพิ่ม MaxHP",
		"ซึ่งอาจจะยากหน่อยเพราะนินจามี Base HP ต่ำและมีข้อจำกัด",
		"เรื่องอุปกรณ์สวมใส่ค่อนข้างมาก^000000"
	},
